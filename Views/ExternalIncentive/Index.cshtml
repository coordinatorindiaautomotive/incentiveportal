@model List<IncentivePortal.Models.ExternalIncentiveRecord>
@{
    ViewData["Title"] = "External Incentive Register";
    var selMonth      = (int)ViewBag.SelMonth;
    var selYear       = (int)ViewBag.SelYear;
    var locations     = (List<string>)ViewBag.Locations;
    var uploads       = (List<IncentivePortal.Models.ExternalIncentiveUpload>)ViewBag.Uploads;
    var totalNet      = (decimal)ViewBag.TotalNetSale;
    var totalDisc     = (decimal)ViewBag.TotalDiscount;
    var totalInc      = (decimal)ViewBag.TotalIncentive;
    var myBranchCode  = ViewBag.MyBranchCode as string;   // non-null = branch-scoped user
    string MonthName(int m) => new DateTime(2000, m, 1).ToString("MMMM");
}

<style>
    .eir-header { background: linear-gradient(135deg,#1e293b 0%,#0f172a 100%); border-radius: 14px; padding: 24px 28px; margin-bottom: 22px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
    .eir-title  {  font-size:1.4rem; font-weight:800; color:#fff; margin:0; }
    .eir-sub    { color:#94a3b8; font-size:.78rem; margin-top:2px; }
    .stat-card  { background:#fff; border-radius:12px; padding:16px 20px; border:1px solid #e2e8f0; box-shadow:0 1px 8px rgba(0,0,0,.04); }
    .stat-label { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#64748b; }
    .stat-value { font-size:1.45rem; font-weight:800;  margin-top:4px; }
    .filter-bar { background:#fff; border-radius:12px; padding:16px 20px; border:1px solid #e2e8f0; margin-bottom:18px; }
    .eir-table  { border-radius:12px; overflow:hidden; border:1px solid #e2e8f0; }
    .eir-table thead th { background:#1e293b; color:#fff; font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.4px; padding:12px 14px; border:none; }
    .eir-table tbody tr:hover { background:#f1f5f9; }
    .eir-table tbody td { padding:10px 14px; font-size:.86rem; vertical-align:middle; border-bottom:1px solid #f1f5f9; }
    .badge-loc  { background:#eff6ff; color:#1d4ed8; border-radius:6px; padding:2px 8px; font-size:.75rem; font-weight:600; }
    .badge-slab { background:#f0fdf4; color:#15803d; border-radius:6px; padding:2px 8px; font-size:.75rem; font-weight:600; }
    .upload-hist { background:#f8fafc; border-radius:10px; border:1px solid #e2e8f0; padding:14px 18px; }
    .upload-row  { display:flex; align-items:center; justify-content:space-between; padding:8px 0; border-bottom:1px solid #e2e8f0; font-size:.83rem; }
    .upload-row:last-child { border-bottom:none; }
    .tot-row td  { font-weight:800; background:#f0fdf4; color:#15803d; font-size:.9rem; }
</style>

<div class="eir-header">
    <div>
        <div class="eir-title">
            <i class="fa-solid fa-file-invoice-dollar me-2"></i>External Incentive Register
            @if (myBranchCode != null)
            {
                <span style="font-size:.65rem;font-weight:700;background:rgba(245,158,11,.18);color:#f59e0b;border:1px solid rgba(245,158,11,.3);border-radius:999px;padding:2px 10px;margin-left:8px;vertical-align:middle;letter-spacing:.05em;text-transform:uppercase;">
                    <i class="fa-solid fa-building-columns me-1"></i>@myBranchCode Only
                </span>
            }
        </div>
        <div class="eir-sub">Uploaded Excel data — @MonthName(selMonth) @selYear</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
        {
            <a href="@Url.Action("Upload")" class="btn btn-sm" style="background:var(--primary);color:#fff;border-radius:8px;font-weight:600;">
                <i class="fa-solid fa-cloud-arrow-up me-1"></i> Upload Excel
            </a>
        }
        @if (Model.Any())
        {
            <a href="@Url.Action("ExportExcel", new { month=selMonth, year=selYear, location=ViewBag.Location })"
               class="btn btn-sm btn-outline-success" style="border-radius:8px;font-weight:600;">
                <i class="fa-solid fa-file-excel me-1"></i> Export
            </a>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 mb-3" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 mb-3" role="alert">
        <i class="fa-solid fa-circle-xmark me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats Row -->
<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i class="fa-solid fa-users me-1 text-primary"></i> Total Parties</div>
            <div class="stat-value text-primary">@Model.Select(r=>r.ConsPartyCode).Distinct().Count()</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i class="fa-solid fa-indian-rupee-sign me-1 text-info"></i> Net Sale</div>
            <div class="stat-value text-info">₹@totalNet.ToString("N0")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i class="fa-solid fa-tag me-1 text-warning"></i> Discount</div>
            <div class="stat-value text-warning">₹@totalDisc.ToString("N0")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i class="fa-solid fa-star me-1 text-success"></i> Total Incentive</div>
            <div class="stat-value text-success">₹@totalInc.ToString("N0")</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <!-- Filter Bar -->
    <div class="col-md-8">
        <div class="filter-bar">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-sm-3">
                    <label class="form-label fw-semibold" style="font-size:.78rem;">Month</label>
                    <select name="month" class="form-select form-select-sm" style="border-radius:8px;">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == selMonth)">@MonthName(m)</option>
                        }
                    </select>
                </div>
                <div class="col-sm-3">
                    <label class="form-label fw-semibold" style="font-size:.78rem;">Year</label>
                    <select name="year" class="form-select form-select-sm" style="border-radius:8px;">
                        @for (int y = DateTime.Now.Year - 2; y <= DateTime.Now.Year + 1; y++)
                        {
                            <option value="@y" selected="@(y == selYear)">@y</option>
                        }
                    </select>
                </div>
                <div class="col-sm-3">
                    <label class="form-label fw-semibold" style="font-size:.78rem;">Location</label>
                    @if (myBranchCode != null)
                    {
                        @* Branch-scoped: show locked field, still submit the value *@
                        <input type="hidden" name="location" value="@myBranchCode" />
                        <div class="form-control form-control-sm d-flex align-items-center gap-2"
                             style="border-radius:8px;background:#fefce8;border-color:#fde68a;color:#92400e;font-weight:700;font-size:.82rem;cursor:default;">
                            <i class="fa-solid fa-lock" style="font-size:.7rem;"></i> @myBranchCode
                        </div>
                    }
                    else
                    {
                        <select name="location" class="form-select form-select-sm" style="border-radius:8px;">
                            <option value="">-- All --</option>
                            @foreach (var loc in locations)
                            {
                                <option value="@loc" selected="@(loc == (string?)ViewBag.Location)">@loc</option>
                            }
                        </select>
                    }
                </div>
                <div class="col-sm-3">
                    <button type="submit" class="btn btn-sm w-100" style="background:#1e293b;color:#fff;border-radius:8px;font-weight:600;">
                        <i class="fa-solid fa-filter me-1"></i> Apply Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Upload History -->
    <div class="col-md-4">
        <div class="upload-hist">
            <div class="fw-bold mb-2" style="font-size:.82rem; color:#475569;">
                <i class="fa-solid fa-clock-rotate-left me-1"></i> Upload History — @MonthName(selMonth) @selYear
            </div>
            @if (!uploads.Any())
            {
                <div class="text-muted" style="font-size:.8rem;">No uploads yet for this period.</div>
            }
            @foreach (var u in uploads)
            {
                <div class="upload-row">
                    <div>
                        <div class="fw-semibold" style="font-size:.82rem;">@u.FileName</div>
                        <div class="text-muted" style="font-size:.72rem;">
                            @u.TotalRows rows &nbsp;â€¢&nbsp; @u.CreatedAt.ToLocalTime().ToString("dd MMM, HH:mm")
                        </div>
                    </div>
                    @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
                    {
                        <form asp-action="DeleteUpload" asp-route-id="@u.Id" method="post"
                              onsubmit="return confirm('All records for this upload will be deleted. Are you sure?')">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger" style="border-radius:6px;padding:2px 8px;font-size:.72rem;" title="Delete">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </form>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Data Table -->
@if (!Model.Any())
{
    <div class="text-center py-5" style="background:#fff;border-radius:14px;border:1px solid #e2e8f0;">
        <i class="fa-solid fa-inbox" style="font-size:3rem;color:#cbd5e1;"></i>
        <p class="mt-3 text-muted fw-semibold">No data uploaded for this month yet.</p>
        @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
        {
            <a href="@Url.Action("Upload")" class="btn btn-sm mt-1" style="background:var(--primary);color:#fff;border-radius:8px;">
                <i class="fa-solid fa-cloud-arrow-up me-1"></i> Upload Excel
            </a>
        }
    </div>
}
else
{
    <div class="table-responsive eir-table">
        <table class="table table-hover mb-0" id="eirTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Month</th>
                    <th>Cons Party Code</th>
                    <th>Cons Party Name</th>
                    <th>Location</th>
                    <th class="text-end">Net Retail Selling</th>
                    <th class="text-end">Discount Amount</th>
                    <th>Slab</th>
                    <th class="text-end">Incentive</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 1; }
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="text-muted" style="font-size:.78rem;">@idx</td>
                        <td><span class="badge bg-secondary">@r.MonthLabel</span></td>
                        <td><code style="font-size:.8rem;">@r.ConsPartyCode</code></td>
                        <td class="fw-semibold">@r.ConsPartyName</td>
                        <td><span class="badge-loc">@r.Location</span></td>
                        <td class="text-end fw-semibold">@r.NetRetailSelling.ToString("N0")</td>
                        <td class="text-end text-danger">@r.DiscountAmount.ToString("N0")</td>
                        <td><span class="badge-slab">@(string.IsNullOrEmpty(r.Slab) ? "—" : r.Slab)</span></td>
                        <td class="text-end fw-bold text-success">@r.Incentive.ToString("N0")</td>
                    </tr>
                    idx++;
                }
            </tbody>
            <tfoot>
                <tr class="tot-row">
                    <td colspan="5" class="text-end">Total</td>
                    <td class="text-end">@totalNet.ToString("N0")</td>
                    <td class="text-end">@totalDisc.ToString("N0")</td>
                    <td></td>
                    <td class="text-end">@totalInc.ToString("N0")</td>
                </tr>
            </tfoot>
        </table>
    </div>
}

@section Scripts {
<script>
$(document).ready(function(){
    if($('#eirTable').length && $('#eirTable tbody tr').length > 5){
        $('#eirTable').DataTable({
            pageLength: 25,
            order:[[4,'asc']],
            language:{ search:"Search:", lengthMenu:"Show _MENU_ rows", zeroRecords:"No records found" },
            columnDefs:[{targets:[5,6,8], className:'text-end'}]
        });
    }
});
</script>
}

@section DataTableScripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
}



