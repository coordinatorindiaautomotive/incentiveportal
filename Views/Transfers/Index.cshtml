                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '/Transfers/DeleteUnmatchedRecord',
                    type: 'POST',
                    headers: {
                        "RequestVerificationToken": token
                    },
