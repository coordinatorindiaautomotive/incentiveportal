    // =========================================================
    // REAL-TIME IN-PLACE INDIVIDUAL AJAX MANUAL RECONCILIATION
    // =========================================================
    $(document).on('submit', 'form[data-ajax="true"]', function(e) {
        e.preventDefault();
        var form = $(this);
        var actionUrl = form.attr('action');
        var formData = form.serialize();
        var row = form.closest('.transfer-row');
        var rowId = row.attr('data-id');
        var utrValue = form.find('input[name="utr"]').val().trim();

        if (!utrValue) {
            Swal.fire({
                icon: 'warning',
                title: 'UTR Required',
                text: 'Please enter a valid UTR Reference.',
                confirmButtonColor: '#2563eb'
            });
            return;
        }

        Swal.fire({
            title: 'Reconciling...',
            text: 'Saving transaction UTR reference and closing ledger record...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: actionUrl,
            type: 'POST',
            data: formData,
            success: function(r) {
                Swal.close();
                if (r.ok) {
                    // 1. Alert user of successful update
                    Swal.fire({
                        icon: 'success',
                        title: 'Reconciled',
                        text: r.message,
                        timer: 1500,
                        showConfirmButton: false
                    });

                    // 2. Perform in-place DOM updates (No Page Reload!)
                    row.attr('data-status', 'Completed');
                    row.attr('data-utr', utrValue);
                    
                    // Replace checkbox with disabled one
                    var chkCell = row.find('td').first();
                    chkCell.html('<input type="checkbox" class="form-check-input transfer-select-item" disabled style="opacity: 0.25; cursor: not-allowed;" />');
                    
                    // Update UTR cell
                    row.find('.utr-cell').html('<code>' + utrValue + '</code>');
                    
                    // Update Transferred Amount
                    var netAmtVal = row.find('.text-amount').text();
                    row.find('.text-transferred-amount').text(netAmtVal);
                    
                    // Update Date cell (today)
                    var todayStr = new Date().toLocaleDateString('en-GB', {
                        day: '2-digit',
                        month: 'short',
                        year: 'numeric'
                    }).replace(/ /g, '-');
                    row.find('.date-cell').text(todayStr);

                    // Update Status Badge
                    row.find('.status-cell').html('<span class="status-badge success">Completed</span>');

                    // Replace inline form with Locked label
                    row.find('.action-cell').html('<span class="text-muted small"><i class="fa-solid fa-lock me-1"></i> Locked</span>');

                    // Highlight row with beautiful transition pulse
                    row.addClass('reconcile-success-pulse');
                    setTimeout(function() {
                        row.removeClass('reconcile-success-pulse');
                    }, 2000);

                    // Apply filters to dynamically update KPI metrics and badges in real-time
                    applyFilters();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: r.message,
                        confirmButtonColor: '#2563eb'
                    });
                }
            },
            error: function(xhr) {
                Swal.close();
                var msg = xhr.responseJSON ? xhr.responseJSON.message : "Error reconciling transfer.";
                Swal.fire({
                    icon: 'error',
                    title: 'Failed',
                    text: msg,
                    confirmButtonColor: '#2563eb'
                });
            }
        });
    });

    // =========================================================
    // REAL-TIME IN-PLACE BULK AJAX MANUAL RECONCILIATION
    // =========================================================
    $('#bulk-reconcile-action-form').on('submit', function(e) {
        e.preventDefault();

        if (selectedIds.length === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'No transfers selected',
                text: 'Please select one or more pending transfers to reconcile.',
                confirmButtonColor: '#2563eb'
            });
            return;
        }

        var utr = $('#bulk-utr-input').val().trim();
        var token = $('input[name="__RequestVerificationToken"]', this).val();

        Swal.fire({
            title: 'Bulk Reconciling...',
            text: 'Reconciling ' + selectedIds.length + ' transfers with common UTR: ' + utr + '...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: $(this).attr('action'),
            type: 'POST',
            data: {
                ids: selectedIds,
                utr: utr,
                __RequestVerificationToken: token
            },
            success: function(r) {
                Swal.close();
                if (r.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Bulk Reconciliation Completed',
                        text: r.message,
                        timer: 2000,
                        showConfirmButton: false
                    });

                    // Perform in-place DOM updates for all selected rows (No Page Reload!)
                    var todayStr = new Date().toLocaleDateString('en-GB', {
                        day: '2-digit',
                        month: 'short',
                        year: 'numeric'
                    }).replace(/ /g, '-');

                    selectedIds.forEach(function(id) {
                        var row = $('.transfer-row[data-id="' + id + '"]');
                        if (row.length > 0) {
                            row.attr('data-status', 'Completed');
                            row.attr('data-utr', utr);
                            
                            // Replace checkbox with disabled one
                            row.find('td').first().html('<input type="checkbox" class="form-check-input transfer-select-item" disabled style="opacity: 0.25; cursor: not-allowed;" />');
                            
                            // Update UTR & Date
                            row.find('.utr-cell').html('<code>' + utr + '</code>');
                            row.find('.date-cell').text(todayStr);

                            // Update Transferred Amount
                            var netAmtVal = row.find('.text-amount').text();
                            row.find('.text-transferred-amount').text(netAmtVal);

                            // Update Status badge
                            row.find('.status-cell').html('<span class="status-badge success">Completed</span>');

                            // Replace inline form with Locked label
                            row.find('.action-cell').html('<span class="text-muted small"><i class="fa-solid fa-lock me-1"></i> Locked</span>');

                            // Highlight row
                            row.addClass('reconcile-success-pulse');
                            setTimeout(function() {
                                row.removeClass('reconcile-success-pulse');
                            }, 2000);
                        }
                    });

                    // Reset and slide up bulk reconciliation panel
                    selectedIds = [];
                    $('#bulk-utr-input').val('');
                    $('#bulk-reconcile-panel').slideUp(200);
                    $('#selectAllTransfers').prop('checked', false);

                    // Apply filters to dynamically update KPI metrics and badges in real-time
                    applyFilters();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Bulk Reconcile Failed',
                        text: r.message,
                        confirmButtonColor: '#2563eb'
                    });
                }
            },
            error: function(xhr) {
                Swal.close();
                var msg = xhr.responseJSON ? xhr.responseJSON.message : "Error reconciling transfers.";
                Swal.fire({
                    icon: 'error',
                    title: 'Execution Failed',
                    text: msg,
                    confirmButtonColor: '#2563eb'
                });
            }
        });
    });

    // =========================================================
    // UNRECONCILED BANK STATEMENT REGISTRY CRUD & MANUAL MAPPING
    // =========================================================
    function loadUnmatchedRecords() {
        var month = $('#reconcile-month').val();
        var year = $('#reconcile-year').val();
        
        $.ajax({
            url: '/Transfers/GetUnmatchedRecords',
            type: 'GET',
            data: { month: month, year: year },
            success: function (records) {
                window.unmatchedRecords = records;
                var tbody = $('#unmatched-statement-table tbody');
                tbody.empty();
                
                $('#unmatched-count-badge').text(records.length + ' Unreconciled Rows');
                
                if (!records || records.length === 0) {
                    $('#unmatched-table-container').hide();
                    $('#unmatched-empty-state').show();
                } else {
                    $('#unmatched-empty-state').hide();
                    $('#unmatched-table-container').show();
                    
                    records.forEach(function (r) {
                        var dateStr = '-';
                        if (r.paymentDate) {
                            var date = new Date(r.paymentDate);
                            dateStr = date.toLocaleDateString('en-GB', {
                                day: '2-digit',
                                month: 'short',
                                year: 'numeric'
                            }).replace(/ /g, '-');
                        }

                        // Parse raw Excel row JSON to extract details
                        var rawData = {};
                        try {
                            rawData = JSON.parse(r.rawRowJson || "{}");
                        } catch (e) {
                            rawData = {};
                        }

                        var excelPartyCode = rawData["Debit narration"] || rawData["Debit Narration"] || rawData["Party Code"] || rawData["Dealer Code"] || "";
                        var rejectionReason = rawData["Rejection Reason"] || rawData["Rejection_Reason"] || rawData["Remark"] || rawData["Remarks"] || "";
                        
                        var nameHtml = '<strong>' + (r.beneficiaryName || '-') + '</strong>';
                        if (excelPartyCode) {
                            nameHtml += '<div class="text-muted mt-1" style="font-size: 0.76rem;"><span class="badge bg-light text-dark border">Excel Code: <strong>' + excelPartyCode + '</strong></span></div>';
                        }
                        if (rejectionReason) {
                            nameHtml += '<div class="text-danger mt-1" style="font-size: 0.74rem; max-width: 250px; white-space: normal; word-break: break-all; line-height: 1.25;"><i class="fa-solid fa-circle-exclamation text-warning me-1"></i>' + rejectionReason + '</div>';
                        }
                        
                        var dealerText = r.partyCode ? '<strong>' + r.partyCode + '</strong>' : 
                                         (excelPartyCode ? '<span class="text-warning small fw-semibold"><i class="fa-solid fa-circle-question me-1"></i> Unassigned<br/><span class="text-muted" style="font-size: 0.72rem;">(Excel: ' + excelPartyCode + ')</span></span>' : '<span class="text-danger small fw-semibold"><i class="fa-solid fa-circle-question me-1"></i> Unassigned</span>');
                        
                        var trHtml = '<tr data-record-id="' + r.id + '">' +
                            '<td style="text-align: center;"><code>' + r.rowNumber + '</code></td>' +
                            '<td>' + nameHtml + '</td>' +
                            '<td><code>' + (r.accountNumber || '-') + '</code></td>' +
                            '<td><code>' + (r.ifsc || '-') + '</code></td>' +
                            '<td class="text-end fw-bold text-danger">₹' + (r.amount || 0).toLocaleString('en-IN') + '</td>' +
                            '<td><span class="status-badge danger">' + (r.status || 'Failed') + '</span></td>' +
                            '<td><code>' + (r.utr || '-') + '</code></td>' +
                            '<td>' + dateStr + '</td>' +
                            '<td class="dealer-cell">' + dealerText + '</td>' +
                            '<td style="text-align: center;">' +
                                '<div class="btn-group">' +
                                    '<button class="btn btn-sm btn-outline-info btn-view-excel-details" title="View Full Excel Row Details" data-id="' + r.id + '" style="border-radius: 4px 0 0 4px;"><i class="fa-solid fa-circle-info"></i></button>' +
                                    '<button class="btn btn-sm btn-outline-secondary btn-edit-unmatched" title="Edit row details" data-id="' + r.id + '"><i class="fa-solid fa-pen-to-square"></i></button>' +
                                    '<button class="btn btn-sm btn-outline-primary btn-reconcile-unmatched" title="Manually reconcile to dealer" data-id="' + r.id + '"><i class="fa-solid fa-link"></i></button>' +
                                    '<button class="btn btn-sm btn-outline-danger btn-delete-unmatched" title="Delete record" data-id="' + r.id + '" style="border-radius: 0 4px 4px 0;"><i class="fa-solid fa-trash"></i></button>' +
                                '</div>' +
                            '</td>' +
                            '</tr>';
                        tbody.append(trHtml);
                    });
                }
            },
            error: function () {
                console.error("Error loading unmatched records.");
            }
        });
    }

