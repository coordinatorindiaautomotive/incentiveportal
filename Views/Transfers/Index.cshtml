                            '<input id="swal-add-date" type="date" class="form-control">' +
                        '</div>' +
                    '</div>' +
                '</div>',
            focusConfirm: false,
            showCancelButton: true,
            confirmButtonText: '<i class="fa-solid fa-plus me-1"></i> Add Record',
            cancelButtonText: 'Cancel',
            confirmButtonColor: '#2563eb',
            cancelButtonColor: '#64748b',
            preConfirm: () => {
                var addName = $('#swal-add-name').val().trim();
                var addAccount = $('#swal-add-account').val().trim();
                var addIfsc = $('#swal-add-ifsc').val().trim();
                var addAmount = parseFloat($('#swal-add-amount').val()) || 0;
                var addStatus = $('#swal-add-status').val();
                var addUtr = $('#swal-add-utr').val().trim();
                var addDate = $('#swal-add-date').val();

                if (!addName) {
                    Swal.showValidationMessage('Beneficiary Name is required.');
                    return false;
                }
                if (!addAccount) {
                    Swal.showValidationMessage('Account Number is required.');
                    return false;
                }
                if (!addIfsc) {
                    Swal.showValidationMessage('IFSC Code is required.');
                    return false;
                }
                if (addAmount <= 0) {
                    Swal.showValidationMessage('Amount must be greater than zero.');
                    return false;
                }

                return {
                    Month: m,
                    Year: y,
                    BeneficiaryName: addName,
                    AccountNumber: addAccount,
                    IFSC: addIfsc,
                    Amount: addAmount,
                    Status: addStatus,
                    UTR: addUtr,
                    PaymentDate: addDate ? new Date(addDate).toISOString() : null
                };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                var token = $('input[name="__RequestVerificationToken"]').val();
                
                Swal.fire({
                    title: 'Saving...',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '/Transfers/CreateUnmatchedRecord',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: {
                        "RequestVerificationToken": token
                    },
                    data: JSON.stringify(result.value),
                    success: function (r) {
                        Swal.close();
                        if (r.ok) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Created',
                                text: r.message,
                                timer: 1500,
                                showConfirmButton: false
                            });
                            loadUnmatchedRecords();
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Failed',
                                text: r.message,
                                confirmButtonColor: '#2563eb'
                            });
                        }
                    },
                    error: function (xhr) {
                        Swal.close();
                        var msg = xhr.responseJSON ? xhr.responseJSON.message : "Error creating record.";
                        Swal.fire({
                            icon: 'error',
                            title: 'Failed',
                            text: msg,
                            confirmButtonColor: '#2563eb'
                        });
                    }
                });
            }
        });
    });

    $(document).on('click', '.btn-edit-unmatched', function () {
        var id = $(this).data('id');
        var tr = $(this).closest('tr');
        var name = tr.find('td:nth-child(2) strong').text();
        var account = tr.find('td:nth-child(3) code').text();
        var ifsc = tr.find('td:nth-child(4) code').text();
        
        var amtText = tr.find('td:nth-child(5)').text().replace(/[₹,]/g, '').trim();
        var amount = parseFloat(amtText) || 0;
        
        var status = tr.find('td:nth-child(6) span').text();
        var utr = tr.find('td:nth-child(7) code').text();
        if (utr === '-') utr = '';
        
        var dateText = tr.find('td:nth-child(8)').text();
        var dateVal = '';
        if (dateText && dateText !== '-') {
            var parts = dateText.split('-');
            if (parts.length === 3) {
                var day = parts[0];
                var monthLabel = parts[1];
                var year = parts[2];
                var months = {
                    'Jan':'01', 'Feb':'02', 'Mar':'03', 'Apr':'04', 'May':'05', 'Jun':'06',
                    'Jul':'07', 'Aug':'08', 'Sep':'09', 'Oct':'10', 'Nov':'11', 'Dec':'12'
                };
                var month = months[monthLabel] || '01';
                dateVal = year + '-' + month + '-' + day;
            }
        }

        Swal.fire({
            title: 'Edit Statement Record',
            html:
                '<div class="text-start" style="font-size: 0.9rem;">' +
                    '<div class="mb-3">' +
                        '<label class="form-label fw-semibold">Beneficiary Name</label>' +
                        '<input id="swal-edit-name" class="form-control" value="' + name + '">' +
                    '</div>' +
                    '<div class="row g-2 mb-3">' +
                        '<div class="col-6">' +
                            '<label class="form-label fw-semibold">Account Number</label>' +
                            '<input id="swal-edit-account" class="form-control font-monospace" value="' + account + '">' +
                        '</div>' +
                        '<div class="col-6">' +
                            '<label class="form-label fw-semibold">IFSC Code</label>' +
                            '<input id="swal-edit-ifsc" class="form-control font-monospace" value="' + ifsc + '">' +
                        '</div>' +
                    '</div>' +
                    '<div class="row g-2 mb-3">' +
                        '<div class="col-6">' +
                            '<label class="form-label fw-semibold">Amount (₹)</label>' +
                            '<input id="swal-edit-amount" type="number" step="0.01" class="form-control" value="' + amount + '">' +
                        '</div>' +
                        '<div class="col-6">' +
                            '<label class="form-label fw-semibold">Status</label>' +
                            '<select id="swal-edit-status" class="form-select">' +
                                '<option value="Success"' + (status === 'Success' || status === 'Paid' ? ' selected' : '') + '>Success</option>' +
                                '<option value="Failed"' + (status === 'Failed' ? ' selected' : '') + '>Failed</option>' +
                            '</select>' +
                        '</div>' +
                    '</div>' +
                    '<div class="row g-2">' +
                        '<div class="col-6">' +
                            '<label class="form-label fw-semibold">UTR Reference</label>' +
                            '<input id="swal-edit-utr" class="form-control font-monospace" value="' + utr + '">' +
                        '</div>' +
                        '<div class="col-6">' +
                            '<label class="form-label fw-semibold">Payment Date</label>' +
                            '<input id="swal-edit-date" type="date" class="form-control" value="' + dateVal + '">' +
                        '</div>' +
                    '</div>' +
                '</div>',
            focusConfirm: false,
            showCancelButton: true,
            confirmButtonText: '<i class="fa-solid fa-save me-1"></i> Save Changes',
            cancelButtonText: 'Cancel',
            confirmButtonColor: '#2563eb',
            cancelButtonColor: '#64748b',
            preConfirm: () => {
                var editName = $('#swal-edit-name').val().trim();
                var editAccount = $('#swal-edit-account').val().trim();
                var editIfsc = $('#swal-edit-ifsc').val().trim();
                var editAmount = parseFloat($('#swal-edit-amount').val()) || 0;
                var editStatus = $('#swal-edit-status').val();
                var editUtr = $('#swal-edit-utr').val().trim();
                var editDate = $('#swal-edit-date').val();

                if (!editName) {
                    Swal.showValidationMessage('Beneficiary Name is required.');
                    return false;
                }
                if (!editAccount) {
                    Swal.showValidationMessage('Account Number is required.');
                    return false;
                }
                if (!editIfsc) {
                    Swal.showValidationMessage('IFSC Code is required.');
                    return false;
                }
                if (editAmount <= 0) {
                    Swal.showValidationMessage('Amount must be greater than zero.');
                    return false;
                }

                return {
                    Id: id,
                    BeneficiaryName: editName,
                    AccountNumber: editAccount,
                    IFSC: editIfsc,
                    Amount: editAmount,
                    Status: editStatus,
                    UTR: editUtr,
                    PaymentDate: editDate ? new Date(editDate).toISOString() : null
                };
            }
        }).then((result) => {
            if (result.isConfirmed) {
                var token = $('input[name="__RequestVerificationToken"]').val();
                
                Swal.fire({
                    title: 'Saving...',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '/Transfers/SaveUnmatchedRecord',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: {
                        "RequestVerificationToken": token
                    },
                    data: JSON.stringify(result.value),
                    success: function (r) {
                        Swal.close();
                        if (r.ok) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Updated',
                                text: r.message,
                                timer: 1500,
                                showConfirmButton: false
                            });
                            loadUnmatchedRecords();
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Failed',
                                text: r.message,
                                confirmButtonColor: '#2563eb'
                            });
                        }
                    },
                    error: function (xhr) {
                        Swal.close();
                        var msg = xhr.responseJSON ? xhr.responseJSON.message : "Error saving record.";
                        Swal.fire({
                            icon: 'error',
                            title: 'Failed',
                            text: msg,
                            confirmButtonColor: '#2563eb'
                        });
                    }
                });
            }
        });
    });

    $(document).on('click', '.btn-delete-unmatched', function () {
        var id = $(this).data('id');
        
        Swal.fire({
            title: 'Delete Record?',
            text: "Are you sure you want to remove this bank statement record from reconciliation?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it',
            cancelButtonText: 'Cancel',
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#64748b'
        }).then((result) => {
            if (result.isConfirmed) {
                var token = $('input[name="__RequestVerificationToken"]').val();
                
                Swal.fire({
                    title: 'Deleting...',
