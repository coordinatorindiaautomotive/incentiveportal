    // Excel Reconciliation Submit handler
    $('#bulk-reconcile-form').on('submit', function(e) {
        e.preventDefault();
        
        var fileInput = $('#reconcile-file-input')[0];
        if (fileInput.files.length === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'No file chosen',
                text: 'Please select a statement Excel file first.',
                confirmButtonColor: '#2563eb'
            });
            return;
        }

        if ($('input[name="mappingMode"]:checked').val() === 'manual') {
            var acct = $('#map-account-no').val();
            var status = $('#map-status').val();
            var utr = $('#map-utr').val();
            if (!acct || !status || !utr) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Missing Mappings',
                    text: 'Please select columns for Beneficiary Account No, STATUS, and UTR NO.',
                    confirmButtonColor: '#2563eb'
                });
                return;
            }
        }

        var formData = new FormData(this);
        
        Swal.fire({
            title: 'Reconciling Statement...',
            text: 'Analyzing sheets, running priority-based matching, and verifying party bank master details...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: $(this).attr('action'),
            type: 'POST',
            data: formData,
            contentType: false,
            processData: false,
            success: function(r) {
                Swal.close();

                function showFinalSummary(message, logs) {
                    var logHtml = '<div style="text-align: left; max-height: 250px; overflow-y: auto; font-family: monospace; font-size: 0.85rem; background: #f8fafc; padding: 14px; border-radius: 8px; border: 1px solid #e2e8f0;"><ul style="list-style: none; padding-left: 0; margin-bottom: 0;">';
                    logs.forEach(function(log) {
                        var isFailed = log.indexOf("Unmatched") > -1;
                        var isProposed = log.indexOf("Proposed") > -1;
                        var color = isFailed ? "#dc2626" : (isProposed ? "#d97706" : "#16a34a");
                        var icon = isFailed ? '<i class="fa-solid fa-circle-xmark me-2"></i>' : (isProposed ? '<i class="fa-solid fa-circle-info me-2"></i>' : '<i class="fa-solid fa-circle-check me-2"></i>');
                        logHtml += '<li style="color: ' + color + '; margin-bottom: 5px; display: flex; align-items: center;">' + icon + '<span>' + log + '</span></li>';
                    });
                    logHtml += '</ul></div>';

                    Swal.fire({
                        title: 'Reconciliation Summary',
                        html: '<p style="font-size: 0.95rem; margin-bottom: 15px; color: #475569;">' + message + '</p>' + logHtml,
                        icon: 'success',
                        confirmButtonText: '<i class="fa-solid fa-circle-check"></i> Done & Refresh',
                        confirmButtonColor: '#2563eb',
                        width: '650px'
                    }).then(() => {
                        window.location.reload();
                    });
                }

                if (r.autoCreated && r.autoCreated.length > 0) {
                    var tableHtml = '<div class="text-start mb-2" style="font-size: 0.85rem; color: #475569;">' + r.autoCreated.length + ' bank credits matched dealers with no existing payout record. Review below:</div>';
                    tableHtml += '<div style="max-height: 250px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 8px; background: #fff; padding: 5px;">';
                    tableHtml += '<table class="table table-sm table-hover align-middle mb-0" style="font-size: 0.78rem; text-align: left;">';
                    tableHtml += '<thead class="table-light"><tr><th>Dealer</th><th>Account No</th><th style="text-align: right;">Amount</th><th>UTR</th></tr></thead>';
                    tableHtml += '<tbody>';
                    r.autoCreated.forEach(function(item) {
                        var code = item.partyCode || item.PartyCode || '';
                        var name = item.partyName || item.PartyName || '';
                        var acct = item.bankAccountNumber || item.BankAccountNumber || '';
                        var amt = item.netTransferAmount || item.NetTransferAmount || 0;
                        var utr = item.utrNumber || item.UTRNumber || '';
                        tableHtml += '<tr>';
                        tableHtml += '<td><strong>' + code + '</strong><br/><span class="text-muted" style="font-size: 0.72rem;">' + name + '</span></td>';
                        tableHtml += '<td><code>' + acct + '</code></td>';
                        tableHtml += '<td style="text-align: right; font-weight: bold; color: #16a34a;">₹' + amt.toLocaleString('en-IN') + '</td>';
                        tableHtml += '<td><code>' + (utr || '-') + '</code></td>';
                        tableHtml += '</tr>';
                    });
                    tableHtml += '</tbody></table></div>';
                    tableHtml += '<div class="text-start mt-3" style="font-size: 0.82rem; font-weight: 600; color: #1e293b;">Do you want to create and reconcile these payouts now?</div>';

                    Swal.fire({
                        title: 'Create Missing Payouts?',
                        html: tableHtml,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, create them',
                        cancelButtonText: 'No, skip them',
                        confirmButtonColor: '#2563eb',
                        cancelButtonColor: '#64748b',
                        width: '650px'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            Swal.fire({
                                title: 'Creating Payouts...',
                                allowOutsideClick: false,
                                didOpen: () => {
                                    Swal.showLoading();
                                }
                            });
                            
                            var token = $('input[name="__RequestVerificationToken"]').val();
                            $.ajax({
                                url: '/Transfers/ConfirmAutoCreatedPayouts',
                                type: 'POST',
                                contentType: 'application/json',
                                headers: {
                                    "RequestVerificationToken": token
                                },
                                data: JSON.stringify(r.autoCreated),
                                success: function(confirmRes) {
                                    Swal.close();
                                    showFinalSummary(r.message + " " + confirmRes.message, r.logs);
                                },
                                error: function(xhr) {
                                    Swal.close();
                                    var errorMsg = xhr.responseJSON ? xhr.responseJSON.message : "Error creating payouts.";
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Failed',
                                        text: errorMsg,
                                        confirmButtonColor: '#2563eb'
                                    }).then(() => {
                                        showFinalSummary(r.message, r.logs);
                                    });
                                }
                            });
                        } else {
                            showFinalSummary(r.message + " Skipped auto-creating new payouts.", r.logs);
                        }
                    });
                } else {
                    showFinalSummary(r.message, r.logs);
                }
            },
            error: function(xhr) {
                var msg = xhr.responseJSON ? xhr.responseJSON.message : "Error processing file upload.";
                Swal.fire({
                    icon: 'error',
                    title: 'Upload Failed',
                    text: msg,
                    confirmButtonColor: '#2563eb'
                });
            }
        });
    });

