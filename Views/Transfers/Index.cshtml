@model IReadOnlyList<IncentivePortal.Models.SsIncentive>
@inject IncentivePortal.Data.IncentiveDbContext Db
@{
    ViewData["Title"] = "Corporate Transfer Reconciliation Control";
    var branchMap = Db.Branches.Where(b => !b.IsDeleted).ToDictionary(b => b.Code, b => b.Name);
    var uniqueLocations = Model.Select(x => x.SourceLocation).Where(x => !string.IsNullOrEmpty(x)).Distinct().OrderBy(x => x).ToList();
}

<style>
    @@keyframes success-pulse {
        0% { background-color: rgba(22, 163, 74, 0.25); }
        100% { background-color: transparent; }
    }
    .reconcile-success-pulse {
        animation: success-pulse 2.0s ease-out;
    }
    .transfer-row {
        transition: all 0.25s ease;
    }
    .filter-tab.active {
        box-shadow: 0 4px 10px rgba(13, 82, 214, 0.15);
    }
    .dealer-select-btn {
        transition: all 0.2s ease;
    }
    .dealer-select-btn:hover {
        background-color: rgba(37, 99, 235, 0.08) !important;
        color: #2563eb !important;
        transform: translateX(4px);
    }
</style>

<!-- Control & Upload Center Row -->
<div class="row g-4 mb-4">
    <!-- Left Column: Period Selection & Reconciliation Progress -->
    <div class="col-12 col-xl-6 d-flex">
        <div class="card border-0 shadow-sm p-4 w-100" style="border-radius: 16px; background: #ffffff; border: 1px solid #e2e8f0;">
            <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-2">
                <h3 class="fs-5 fw-bold text-dark mb-0 d-flex align-items-center">
                    <i class="fa-solid fa-calendar-check text-primary me-2"></i> Reconciliation Period
                </h3>
                <span id="detected-period-badge" class="badge bg-light border text-dark p-2 animate-pulse" style="font-size: 0.82rem; font-weight: 600; border-radius: 6px;">
                    Loading Period...
                </span>
            </div>
            
            <div class="row g-3 mb-3">
                <div class="col-12 col-sm-6">
                    <label for="reconcile-month" class="small fw-bold text-secondary mb-1 d-block">Reconciliation Month</label>
                    <select id="reconcile-month" name="reconcileMonth" class="form-select corp-select py-2 px-3 fw-semibold w-100" style="height: 44px; border-radius: 8px;">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(ViewBag.DefaultMonth == m)">@System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(m)</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-sm-6">
                    <label for="reconcile-year" class="small fw-bold text-secondary mb-1 d-block">Reconciliation Year</label>
                    <select id="reconcile-year" name="reconcileYear" class="form-select corp-select py-2 px-3 fw-semibold w-100" style="height: 44px; border-radius: 8px;">
                        @for (int y = 2024; y <= 2028; y++)
                        {
                            <option value="@y" selected="@(ViewBag.DefaultYear == y)">@y</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Reconciliation Progress Visualizer -->
            <div class="mt-4 pt-2">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="small fw-bold text-secondary">Period Progress</span>
                    <span class="badge bg-primary-subtle text-primary fw-bold" id="progress-percentage-badge" style="font-size: 0.85rem; border-radius: 6px; background-color: rgba(37, 99, 235, 0.1);">0% Completed</span>
                </div>
                <div class="progress" style="height: 8px; border-radius: 4px; background-color: #f1f5f9;">
                    <div id="reconciliation-progress-bar" class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <div class="mt-2">
                    <span class="text-muted small" style="font-size: 0.82rem;" id="progress-text-summary">₹0 reconciled of ₹0 accrued</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Statement Payout Upload -->
    <div class="col-12 col-xl-6 d-flex">
        <div class="card border-0 shadow-sm p-4 w-100" style="border-radius: 16px; background: linear-gradient(135deg, rgba(13, 82, 214, 0.02) 0%, rgba(6, 182, 212, 0.02) 100%); border: 1px solid rgba(13, 82, 214, 0.12);">
            <div class="d-flex align-items-center mb-3 border-bottom pb-2">
                <h3 class="fs-5 fw-bold text-dark mb-0 d-flex align-items-center">
                    <i class="fa-solid fa-file-excel text-primary me-2"></i> Bank Statement Upload Center
                </h3>
            </div>
            
            <p class="text-muted small mb-3">Upload your bank settlement statement Excel sheets (`.xlsx`) to auto-match UTRs and reconcile transaction payouts.</p>

            @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
            {
                <form asp-action="UploadReconciliation" method="post" enctype="multipart/form-data" class="d-flex flex-column gap-3 m-0" id="bulk-reconcile-form">
                    @Html.AntiForgeryToken()
                    <!-- Pass selected Month/Year inside the form automatically -->
                    <input type="hidden" name="reconcileMonth" id="upload-form-month" value="@ViewBag.DefaultMonth" />
                    <input type="hidden" name="reconcileYear" id="upload-form-year" value="@ViewBag.DefaultYear" />
                    
                    <!-- Mapping Mode Selection -->
                    <div class="d-flex align-items-center gap-4 mb-1">
                        <label class="small fw-bold text-secondary mb-0">Mapping Option:</label>
                        <div class="form-check form-check-inline m-0">
                            <input class="form-check-input" type="radio" name="mappingMode" id="mapping-mode-auto" value="auto" checked style="cursor: pointer;" />
                            <label class="form-check-label small fw-semibold text-dark" for="mapping-mode-auto" style="cursor: pointer;">Auto Mapping</label>
                        </div>
                        <div class="form-check form-check-inline m-0">
                            <input class="form-check-input" type="radio" name="mappingMode" id="mapping-mode-manual" value="manual" style="cursor: pointer;" />
                            <label class="form-check-label small fw-semibold text-dark" for="mapping-mode-manual" style="cursor: pointer;">Manual Column Mapping</label>
                        </div>
                    </div>

                    <!-- Manual Column Mapping Section -->
                    <div id="manual-mapping-section" class="p-3 border rounded bg-white shadow-inner" style="display: none; border-radius: 8px; border-color: rgba(13, 82, 214, 0.15) !important;">
                        <h4 class="fs-6 fw-bold text-dark mb-3"><i class="fa-solid fa-gears text-primary me-2"></i> Map Excel Columns</h4>
                        <div class="row g-3">
                            <div class="col-6 col-sm-4">
                                <label class="small fw-semibold text-muted d-block mb-1">Beneficiary Account No *</label>
                                <select name="mapAccountNo" id="map-account-no" class="form-select form-select-sm mapping-dropdown" disabled></select>
                            </div>
                            <div class="col-6 col-sm-4">
                                <label class="small fw-semibold text-muted d-block mb-1">STATUS *</label>
                                <select name="mapStatus" id="map-status" class="form-select form-select-sm mapping-dropdown" disabled></select>
                            </div>
                            <div class="col-6 col-sm-4">
                                <label class="small fw-semibold text-muted d-block mb-1">UTR NO *</label>
                                <select name="mapUtr" id="map-utr" class="form-select form-select-sm mapping-dropdown" disabled></select>
                            </div>
                            <div class="col-6 col-sm-4">
                                <label class="small fw-semibold text-muted d-block mb-1">Debit Narration (Party Code)</label>
                                <select name="mapPartyCode" id="map-party-code" class="form-select form-select-sm mapping-dropdown" disabled></select>
                            </div>
                            <div class="col-6 col-sm-4">
                                <label class="small fw-semibold text-muted d-block mb-1">Beneficiary Name</label>
                                <select name="mapName" id="map-name" class="form-select form-select-sm mapping-dropdown" disabled></select>
                            </div>
                            <div class="col-6 col-sm-4">
                                <label class="small fw-semibold text-muted d-block mb-1">Bene IFSC Code</label>
                                <select name="mapIfsc" id="map-ifsc" class="form-select form-select-sm mapping-dropdown" disabled></select>
                            </div>
                            <div class="col-6 col-sm-4">
                                <label class="small fw-semibold text-muted d-block mb-1">Amount</label>
                                <select name="mapAmount" id="map-amount" class="form-select form-select-sm mapping-dropdown" disabled></select>
                            </div>
                            <div class="col-6 col-sm-4">
                                <label class="small fw-semibold text-muted d-block mb-1">Payment Date</label>
                                <select name="mapDate" id="map-date" class="form-select form-select-sm mapping-dropdown" disabled></select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="w-100 mb-3">
                        <div id="reconcileDropZone" class="mb-3 text-center p-4" style="border: 2px dashed #cbd5e1; border-radius: 10px; background: #f8fafc; cursor: pointer; transition: all 0.25s ease;" onclick="$('#reconcile-file-input').click();">
                            <i class="fa-regular fa-file-excel fa-3x text-success mb-3"></i>
                            <h6 class="fw-bold text-dark mb-1">Drag & Drop Excel File Here</h6>
                            <p class="text-muted small mb-3">or click to browse local folders</p>
                            <input type="file" name="file" id="reconcile-file-input" style="display: none;" required accept=".xlsx" onclick="event.stopPropagation();" />
                            <span id="selectedReconFileName" class="badge bg-secondary px-3 py-2 fw-semibold d-none" style="font-size: 0.78rem; max-width: 100%; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;"></span>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-end">
                        <button type="submit" id="btnReconcileSubmit" class="btn btn-primary d-flex align-items-center justify-content-center gap-2" style="height: 44px; border-radius: 8px; font-weight: 600; padding: 0 20px; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);" disabled>
                            <i class="fa-solid fa-circle-check"></i> Reconcile Excel
                        </button>
                    </div>
                </form>
                <div class="text-muted small mt-2 d-flex align-items-center gap-1" style="font-size: 0.78rem;" id="recon-info-text">
                    <i class="fa-solid fa-circle-info text-primary"></i>
                    <span>Excel must contain columns: `Beneficiary Account No`, `STATUS`, and `UTR NO` (or map them manually).</span>
                </div>
            }
            else
            {
                <div class="alert alert-secondary d-flex align-items-center gap-2 mb-0" role="alert" style="border-radius: 8px;">
                    <i class="fa-solid fa-lock text-muted"></i>
                    <span class="small text-muted">You do not have permission to upload bank statements. View-only access is active.</span>
                </div>
            }
        </div>
    </div>
</div>

@if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
{
<!-- Run Reconciliation Action Card -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4" style="border-radius: 16px; background: linear-gradient(135deg, rgba(6,182,212,0.04) 0%, rgba(13,82,214,0.04) 100%); border: 1px solid rgba(13,82,214,0.10);">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center justify-content-center rounded-3 text-white" style="width:46px;height:46px;background:linear-gradient(135deg,#0d52d6,#06b6d4);flex-shrink:0;">
                        <i class="fa-solid fa-rotate fa-lg"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-dark mb-0">Re-Run Reconciliation</h5>
                        <p class="text-muted small mb-0">Re-applies status &amp; date from existing bank records. Marks outstanding parties without a match as <strong>Credit Party</strong>.</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small fw-semibold" id="run-recon-period-label">Period: —</span>
                    <button type="button" id="btnRunReconciliation"
                            class="btn btn-primary d-flex align-items-center gap-2"
                            style="height:42px;border-radius:8px;font-weight:600;padding:0 20px;box-shadow:0 4px 12px rgba(13,82,214,0.2);">
                        <i class="fa-solid fa-play" id="btnRunReconIcon"></i>
                        <span id="btnRunReconText">Run Reconciliation</span>
                    </button>
                </div>
            </div>
            <!-- Result display -->
            <div id="run-recon-result" class="mt-3" style="display:none;">
                <div id="run-recon-alert" class="alert mb-2" role="alert" style="border-radius:8px;font-size:0.88rem;"></div>
                <div id="run-recon-logs-wrapper" style="display:none;">
                    <button class="btn btn-sm btn-outline-secondary mb-2" onclick="$('#run-recon-logs').toggle();">
                        <i class="fa-solid fa-terminal me-1"></i> Toggle Logs
                    </button>
                    <pre id="run-recon-logs" class="bg-dark text-light p-3 rounded" style="font-size:0.75rem;max-height:220px;overflow-y:auto;display:none;"></pre>
                </div>
            </div>
        </div>
    </div>
</div>
}

<!-- Metrics & Quick Insights Cards -->
<div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm p-3" style="border-radius: 12px; background: rgba(13, 82, 214, 0.04); border-left: 5px solid var(--color-1) !important;">
            <div class="text-muted small fw-bold">Total Accrued Payouts</div>
            <div class="fs-3 fw-bold text-dark mt-1" id="metric-accrued-amount">₹0</div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm p-3" style="border-radius: 12px; background: rgba(245, 158, 11, 0.04); border-left: 5px solid #f59e0b !important;">
            <div class="text-muted small fw-bold">Pending Payouts</div>
            <div class="fs-3 fw-bold text-dark mt-1" id="metric-pending-count">0</div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm p-3" style="border-radius: 12px; background: rgba(22, 163, 74, 0.04); border-left: 5px solid #16a34a !important;">
            <div class="text-muted small fw-bold">Reconciled / Completed</div>
            <div class="fs-3 fw-bold text-dark mt-1" id="metric-reconciled-count">0</div>
        </div>
    </div>
</div>

<!-- Active Transfers Ledger -->
<div class="panel">
    <div class="panel-header border-bottom pb-3 mb-3">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 w-100">
            <div>
                <h2>Transfer Ledger Registry</h2>
                <p>Accrued liabilities and real-time bank settlement status records</p>
            </div>
            <!-- Client-Side Instant Search -->
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="left: 12px; top: 12px; font-size: 0.9rem;"></i>
                <input type="text" id="transferSearchInput" class="form-control corp-input py-1 ps-5 pe-3" style="width: 280px; height: 38px; border-radius: 8px;" placeholder="Search Code, Name, UTR..." />
            </div>
        </div>
        
        <!-- Multi-Filter Toolbar Grid -->
        <div class="d-flex flex-wrap align-items-center gap-2 mt-3 pt-3 border-top w-100">
            <!-- Dynamic Status Filter Tabs -->
            <div class="btn-group" role="group" aria-label="Status Filter">
                <button type="button" class="btn btn-outline-secondary filter-tab" data-status="all" style="height: 38px; border-radius: 8px 0 0 8px; font-weight: 600; font-size: 0.88rem;">
                    All <span class="badge bg-secondary ms-1 text-white px-2 py-1" id="tab-count-all" style="font-size: 0.72rem;">0</span>
                </button>
                <button type="button" class="btn btn-outline-warning active filter-tab" data-status="Pending" style="height: 38px; font-weight: 600; font-size: 0.88rem;">
                    Pending <span class="badge bg-warning text-dark ms-1 px-2 py-1" id="tab-count-pending" style="font-size: 0.72rem;">0</span>
                </button>
                <button type="button" class="btn btn-outline-success filter-tab" data-status="Completed" style="height: 38px; font-weight: 600; font-size: 0.88rem;">
                    Reconciled <span class="badge bg-success ms-1 text-white px-2 py-1" id="tab-count-completed" style="font-size: 0.72rem;">0</span>
                </button>
                <button type="button" class="btn btn-outline-danger filter-tab" data-status="Failed" style="height: 38px; border-radius: 0 8px 8px 0; font-weight: 600; font-size: 0.88rem;">
                    Failed / Reversed <span class="badge bg-danger ms-1 text-white px-2 py-1" id="tab-count-failed" style="font-size: 0.72rem;">0</span>
                </button>
            </div>

            <!-- Transfer Mode Filter -->
            <div class="d-flex align-items-center">
                <select id="transferModeFilter" class="form-select corp-select py-1 px-2" style="width: 150px; height: 38px; font-weight: 600; border-radius: 8px; font-size: 0.88rem;">
                    <option value="all">Modes: All</option>
                    <option value="NEFT">NEFT</option>
                    <option value="RTGS">RTGS</option>
                    <option value="IMPS">IMPS</option>
                    <option value="UPI">UPI</option>
                </select>
            </div>

            <!-- Branch Multiselect Filter -->
            <div class="d-flex align-items-center">
                <div class="custom-multiselect dropdown" id="branchMultiselect">
                    <button class="form-select corp-select text-start dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="min-width: 180px; height: 38px; font-weight: 600; font-size: 0.88rem; border-radius: 8px; background-color: #fff; border: 1px solid #ced4da;">
                        <span class="selected-label">Branches: All</span>
                    </button>
                    <div class="dropdown-menu p-3 shadow-lg" style="min-width: 260px; max-height: 320px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 8px;">
                        <input type="text" class="form-control form-control-sm mb-2 search-input" placeholder="🔍 Search branch..." style="font-size: 0.85rem;" />
                        <div class="options-container">
                            <div class="form-check mb-1 select-all-wrapper">
                                <input class="form-check-input select-all-cb" type="checkbox" id="branch_all" checked style="cursor: pointer;" />
                                <label class="form-check-label fw-bold" for="branch_all" style="cursor: pointer;">Select All / Clear</label>
                            </div>
                            <hr class="my-2" />
                            @foreach (var code in uniqueLocations)
                            {
                                var branchName = branchMap.ContainsKey(code) ? branchMap[code] : code;
                                <div class="form-check mb-1 option-item">
                                    <input class="form-check-input option-cb branch-cb" type="checkbox" value="@code" id="cb_branch_@code" checked style="cursor: pointer;" />
                                    <label class="form-check-label small" for="cb_branch_@code" style="cursor: pointer;"><strong>@code</strong> - @branchName</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payout Amount Filters -->
            <div class="d-flex align-items-center gap-2 bg-light px-3 py-1 border" style="border-radius: 8px; height: 38px;">
                <span class="text-muted small fw-semibold" style="font-size: 0.82rem; white-space: nowrap;">Amount:</span>
                <input type="number" id="minAmountFilter" class="form-control border-0 bg-transparent p-0 font-monospace text-end" style="width: 75px; font-size: 0.85rem; outline: none; box-shadow: none;" placeholder="Min ₹" />
                <span class="text-muted small">—</span>
                <input type="number" id="maxAmountFilter" class="form-control border-0 bg-transparent p-0 font-monospace text-end" style="width: 75px; font-size: 0.85rem; outline: none; box-shadow: none;" placeholder="Max ₹" />
            </div>

            <!-- Reset Button -->
            <button type="button" id="btnResetFilters" class="btn btn-outline-secondary d-flex align-items-center justify-content-center" style="height: 38px; width: 38px; border-radius: 8px;" title="Reset All Filters">
                <i class="fa-solid fa-arrows-rotate"></i>
            </button>

            <!-- Export Excel Button -->
            <button type="button" onclick="exportTableToCSV('#transfersGrid', 'Bank_Transfers.csv')" class="btn btn-outline-success d-flex align-items-center justify-content-center gap-2 px-3" style="height: 38px; border-radius: 8px; font-weight: 600;" title="Export to Excel">
                <i class="fa-solid fa-download"></i> Export Excel
            </button>
        </div>
    </div>

    <!-- Floating Bulk Reconciliation Control Bar (Admin Only) -->
    @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
    {
    <div id="bulk-reconcile-panel" class="p-3 mb-3 border-0 shadow-sm" style="display: none; border-radius: 8px; background: linear-gradient(135deg, rgba(30, 64, 175, 0.08) 0%, rgba(14, 165, 233, 0.08) 100%); border-left: 5px solid var(--primary) !important; margin: 0 20px;">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-primary text-white" id="selected-count-badge" style="font-size: 0.95rem; font-weight: 700; border-radius: 6px;">0</span>
                <span class="fw-bold text-dark" style="font-size: 0.95rem;">transfer(s) selected for bulk manual reconciliation</span>
            </div>
            <form id="bulk-reconcile-action-form" method="post" action="@Url.Action("BulkReconcile", "Transfers")" class="d-flex flex-wrap align-items-center gap-3 m-0">
                @Html.AntiForgeryToken()
                <div class="d-flex align-items-center gap-2">
                    <label for="bulk-utr-input" class="small fw-bold text-secondary mb-0">Common UTR:</label>
                    <input type="text" id="bulk-utr-input" class="form-control corp-input py-1 px-3" style="max-width: 200px; height: 38px; font-weight: 600;" placeholder="Enter UTR Reference" required />
                </div>
                <button type="submit" class="btn btn-primary d-flex align-items-center gap-2" style="height: 38px; font-weight: 600; box-shadow: 0 4px 12px rgba(30, 64, 175, 0.2); background-color: var(--primary); border-color: var(--primary);">
                    <i class="fa-solid fa-circle-check"></i> Reconcile Selected
                </button>
            </form>
        </div>
    </div>
    }

    <div class="table-responsive corp-table-wrapper" id="ledger-table-container">
        <table class="table table-hover corp-table align-middle" id="transfersGrid">
            <thead>
                <tr>
                    <th style="width: 45px; text-align: center;">
                        @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
                        {
                            <input type="checkbox" id="selectAllTransfers" class="form-check-input" style="cursor: pointer;" />
                        }
                        else
                        {
                            <span class="text-muted" style="font-size: 0.78rem;">#</span>
                        }
                    </th>
                    <th>Party Code</th>
                    <th>Beneficiary Name</th>
                    <th>Transfer Mode</th>
                    <th class="text-end">Eligible for Incentive</th>
                    <th class="text-end">Transferred Amount</th>
                    <th>Status</th>
                    <th>UTR Reference</th>
                    <th>Settlement Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr id="empty-table-row">
                    <td colspan="9" class="text-center py-4 text-muted">No transfer records registered</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                var statusClass = (item.PaymentStatus == "Success" || item.PaymentStatus == "Paid" || item.PaymentStatus == "Reconciled") ? "success" : (item.PaymentStatus == "Pending" ? "warning" : (item.PaymentStatus == "Failed" ? "danger" : (item.PaymentStatus == "Credit Party" ? "credit-party" : "neutral")));
                var transferMode = item.NetTransferAmount >= 200000 ? "RTGS" : "NEFT";
                <tr class="transfer-row" data-id="@item.Id" data-status="@item.PaymentStatus" data-partycode="@item.PartyCode" data-partyname="@item.PartyName" data-utr="@(item.UTRNumber ?? "")" data-amount="@item.NetTransferAmount" data-transferred="@item.TransferredAmount" data-month="@item.Month" data-year="@item.Year" data-mode="@transferMode" data-location="@item.SourceLocation">
                    <td style="text-align: center;">
                        @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
                        {
                            @if ((item.PaymentStatus == "Pending" || item.PaymentStatus == "Failed" || item.PaymentStatus == "Reversed" || item.PaymentStatus == "Credit Party") 
                                 && !string.IsNullOrWhiteSpace(item.BankAccountNumber) && item.BankAccountNumber != "-" 
                                 && !string.IsNullOrWhiteSpace(item.IFSC) && item.IFSC != "-")
                            {
                                <input type="checkbox" class="form-check-input transfer-select-item" data-id="@item.Id" style="cursor: pointer;" />
                            }
                            else
                            {
                                <input type="checkbox" class="form-check-input transfer-select-item" disabled style="opacity: 0.25; cursor: not-allowed;" />
                            }
                        }
                        else
                        {
                            <span class="text-muted" style="font-size: 0.78rem;">—</span>
                        }
                    </td>
                    <td><span class="party-code-badge" style="background: rgba(13, 82, 214, 0.1); color: var(--color-1); padding: 4px 8px; border-radius: 4px; font-weight: 600; font-size: 0.85rem;">@item.PartyCode</span></td>
                    <td class="party-name-cell">
                        <strong>@item.PartyName</strong>
                        @if (string.IsNullOrWhiteSpace(item.BankAccountNumber) || item.BankAccountNumber == "-" || string.IsNullOrWhiteSpace(item.IFSC) || item.IFSC == "-")
                        {
                            <span class="d-block text-danger small fw-bold mt-1" style="font-size: 0.76rem;"><i class="fa-solid fa-circle-exclamation me-1"></i> Not Link Ac No</span>
                        }
                        else
                        {
                            <span class="d-block text-muted small mt-1" style="font-size: 0.74rem; opacity: 0.85;"><i class="fa-solid fa-credit-card me-1"></i> A/c: @item.BankAccountNumber | IFSC: @item.IFSC</span>
                        }
                    </td>
                    <td><span class="badge bg-light text-dark border">@transferMode</span></td>
                    <td class="text-end fw-bold text-amount">₹@item.NetTransferAmount.ToString("N0")</td>
                    <td class="text-end fw-bold text-success text-transferred-amount">@(item.TransferredAmount > 0 ? "₹" + item.TransferredAmount.ToString("N0") : "-")</td>
                    <td class="status-cell"><span class="status-badge @statusClass">@item.PaymentStatus</span></td>
                    <td class="utr-cell"><code>@(item.UTRNumber ?? "-")</code></td>
                    <td class="date-cell">@(item.PaymentDate?.ToString("dd-MMM-yyyy") ?? "-")</td>
                    <td class="action-cell">
                        @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
                        {
                            @if (item.PaymentStatus == "Pending" || item.PaymentStatus == "Failed" || item.PaymentStatus == "Reversed" || item.PaymentStatus == "Credit Party")
                            {
                                @if (!string.IsNullOrWhiteSpace(item.BankAccountNumber) && item.BankAccountNumber != "-" && !string.IsNullOrWhiteSpace(item.IFSC) && item.IFSC != "-")
                                {
                                    <form asp-action="Reconcile" method="post" data-ajax="true" class="d-flex gap-2 align-items-center m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input name="utr" class="form-control corp-input py-1 utr-input-field" style="max-width: 150px; font-size: 0.85rem; height: 32px;" placeholder="UTR" required value="@item.UTRNumber" />
                                        <button class="btn btn-sm btn-outline-primary submit-single-reconcile" style="height: 32px; padding: 2px 10px;" title="Reconcile manually"><i class="fa-solid fa-check"></i></button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-danger small fw-bold"><i class="fa-solid fa-circle-exclamation me-1"></i> Missing bank details</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small"><i class="fa-solid fa-lock me-1"></i> Locked</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small"><i class="fa-solid fa-eye me-1"></i> View Only</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <!-- Beautiful Empty State Block -->
    <div id="no-data-alert" class="text-center py-5" style="display: none; border-radius: 12px; margin: 20px; border: 1px dashed #e2e8f0; background: #fafafa;">
        <div class="mb-3">
            <i class="fa-solid fa-folder-open text-muted" style="font-size: 3.5rem; opacity: 0.35;"></i>
        </div>
        <h4 class="fw-bold text-secondary">No Matching Payouts Found</h4>
        <p class="text-muted small mx-auto mb-0" style="max-width: 450px;">
            We couldn't find any transfer records matching the current filters for <strong id="empty-state-period" class="text-primary">February 2026</strong>.
        </p>
        <p class="text-muted small mx-auto mt-1" style="max-width: 450px;">
            Try adjusting your search query, selecting another status tab, changing the amount range, or uploading a statement excel.
        </p>
    </div>
</div>

<!-- Unreconciled Bank Statement Registry Panel -->
<div class="panel mt-4" id="unmatched-statement-card">
    <div class="panel-header border-bottom pb-3 mb-3">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 w-100">
            <div>
                <h2 class="d-flex align-items-center fs-5 fw-bold text-dark mb-1">
                    <i class="fa-solid fa-file-invoice-dollar text-primary me-2"></i> Unreconciled Bank Statement Registry
                </h2>
                <p class="text-muted small mb-0">Transactions from uploaded bank statements that could not be matched automatically. Perform CRUD edits or manual mapping here.</p>
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance"))
                {
                    <button class="btn btn-sm btn-primary d-flex align-items-center gap-2" id="btnAddUnmatchedRecord" style="height: 38px; border-radius: 8px; font-weight: 600;">
                        <i class="fa-solid fa-plus"></i> Add Statement Row
                    </button>
                }
                <span class="badge bg-danger text-white px-3 py-2 fw-semibold" id="unmatched-count-badge" style="font-size: 0.82rem; border-radius: 6px;">0 Unreconciled Rows</span>
            </div>
        </div>
    </div>

    <div class="table-responsive corp-table-wrapper" id="unmatched-table-container" style="display: none; margin: 0 10px;">
        <table class="table table-hover corp-table align-middle" id="unmatched-statement-table">
            <thead>
                <tr>
                    <th style="width: 50px; text-align: center;">Row</th>
                    <th>Beneficiary Name</th>
                    <th>Account No</th>
                    <th>IFSC</th>
                    <th class="text-end">Amount</th>
                    <th>Status</th>
                    <th>UTR</th>
                    <th>Date</th>
                    <th>Mapped Dealer</th>
                    <th style="width: 140px; text-align: center;">Action</th>
                </tr>
            </thead>
            <tbody>
                <!-- Populated dynamically via AJAX -->
            </tbody>
        </table>
    </div>

    <!-- Empty State for Unmatched -->
    <div id="unmatched-empty-state" class="text-center py-5" style="border-radius: 12px; margin: 20px; border: 1px dashed #e2e8f0; background: #fafafa;">
        <div class="mb-2">
            <i class="fa-solid fa-circle-check text-success" style="font-size: 3rem; opacity: 0.8;"></i>
        </div>
        <h4 class="fw-bold text-success">All Statement Rows Reconciled!</h4>
        <p class="text-muted small mx-auto mb-0" style="max-width: 450px;">
            There are no unmatched bank statement transactions for the selected month and year. Everything is matched and locked!
        </p>
    </div>
</div>

@section Scripts {
<script>
$(document).ready(function() {
    var defaultMonth = @ViewBag.DefaultMonth;
    var defaultYear = @ViewBag.DefaultYear;

    // Current Active Filters
    var currentSearch = "";
    var currentStatusFilter = "Pending";
    var currentModeFilter = "all";
    var currentBranchesFilter = [];

    // Populate initial branches
    $('#branchMultiselect .branch-cb').each(function() {
        currentBranchesFilter.push($(this).val());
    });

    // Load month and year from sessionStorage if available
    var savedMonth = sessionStorage.getItem('reconcile_month');
    var savedYear = sessionStorage.getItem('reconcile_year');
    if (savedMonth) {
        $('#reconcile-month').val(savedMonth);
    }
    if (savedYear) {
        $('#reconcile-year').val(savedYear);
    }

    // Sync upload forms on load
    $('#upload-form-month').val($('#reconcile-month').val());
    $('#upload-form-year').val($('#reconcile-year').val());

    function updateBadge() {
        var monthText = $('#reconcile-month option:selected').text();
        var yearText = $('#reconcile-year option:selected').text();
        $('#detected-period-badge')
            .removeClass('bg-secondary text-white')
            .addClass('bg-light border text-dark')
            .html('📅 Reconciling: <strong class="text-primary">' + monthText + ' ' + yearText + '</strong>')
            .fadeIn(200);
    }

    updateBadge();

    $('#reconcile-month, #reconcile-year').on('change', function() {
        var m = $('#reconcile-month').val();
        var y = $('#reconcile-year').val();
        
        // Sync to upload form inputs
        $('#upload-form-month').val(m);
        $('#upload-form-year').val(y);
        
        // Save to sessionStorage
        sessionStorage.setItem('reconcile_month', m);
        sessionStorage.setItem('reconcile_year', y);
        
        updateBadge();
        applyFilters();
        loadUnmatchedRecords();
    });

    $('#reconcile-file-input').on('change', function() {
        var filename = $(this).val().split('\\').pop();
        if (!filename) return;
        
        var monthVals = {
            'jan': 1, 'feb': 2, 'mar': 3, 'apr': 4, 'may': 5, 'jun': 6,
            'jul': 7, 'aug': 8, 'sep': 9, 'oct': 10, 'nov': 11, 'dec': 12
        };
        var match = filename.match(/(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*[\s']*(20\d{2}|\d{2})/i);
        if (match) {
            var m = match[1].toLowerCase().substring(0, 3);
            var yText = match[2];
            var year = yText.length === 2 ? "20" + yText : yText;
            var mVal = monthVals[m];
            if (mVal) {
                var fileMonth = parseInt(mVal);
                var fileYear = parseInt(year);
                var currentMonth = parseInt($('#reconcile-month').val());
                var currentYear = parseInt($('#reconcile-year').val());

                if (fileMonth !== currentMonth || fileYear !== currentYear) {
                    var monthNames = ["", "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
                    var detectedPeriod = monthNames[fileMonth] + " " + fileYear;
                    var chosenPeriod = monthNames[currentMonth] + " " + currentYear;
                    
                    Swal.fire({
                        title: 'Period Conflict Detected',
                        text: "File appears to be for " + detectedPeriod + " but you've selected " + chosenPeriod + " — use file's period instead?",
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, use file period',
                        cancelButtonText: 'No, keep my selection',
                        confirmButtonColor: '#2563eb',
                        cancelButtonColor: '#64748b'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            $('#reconcile-month').val(fileMonth);
                            $('#reconcile-year').val(fileYear);
                            sessionStorage.setItem('reconcile_month', fileMonth);
                            sessionStorage.setItem('reconcile_year', fileYear);
                            
                            // Sync to upload form inputs
                            $('#upload-form-month').val(fileMonth);
                            $('#upload-form-year').val(fileYear);
                            
                            updateBadge();
                            applyFilters();
                        }
                    });
                }
            }
        }
    });

    // =========================================================
    // INSTANT SEARCH AND MULTI-FILTER ENGINE
    // =========================================================
    function applyFilters() {
        var query = currentSearch.toLowerCase().trim();
        var filterMonth = parseInt($('#reconcile-month').val());
        var filterYear = parseInt($('#reconcile-year').val());
        var minAmount = $('#minAmountFilter').val() !== "" ? parseFloat($('#minAmountFilter').val()) : null;
        var maxAmount = $('#maxAmountFilter').val() !== "" ? parseFloat($('#maxAmountFilter').val()) : null;
        
        var rows = $('.transfer-row');
        var visibleCount = 0;

        // 1. Calculate metrics and tab counts *only for the chosen period*
        var countAll = 0;
        var countPending = 0;
        var countCompleted = 0;
        var countFailed = 0;
        
        var totalAccrued = 0;
        var totalReconciled = 0;

        rows.each(function() {
            var row = $(this);
            var status = row.attr('data-status');
            var amount = parseFloat(row.attr('data-amount')) || 0;
            var rowMonth = parseInt(row.attr('data-month'));
            var rowYear = parseInt(row.attr('data-year'));
            var rowLocation = row.attr('data-location') || "";

            var matchesPeriod = (rowMonth === filterMonth && rowYear === filterYear);
            var matchesLocation = currentBranchesFilter.includes(rowLocation);

            if (matchesPeriod && matchesLocation) {
                countAll++;
                if (status === 'Pending' || status === 'Credit Party') {
                    countPending++;
                } else if (status === 'Completed' || status === 'Reconciled' || status === 'Success' || status === 'Paid') {
                    countCompleted++;
                } else if (status === 'Failed' || status === 'Reversed') {
                    countFailed++;
                }

                totalAccrued += amount;
                if (status === 'Completed' || status === 'Reconciled' || status === 'Success' || status === 'Paid' || status === 'Credit Party') {
                    totalReconciled += amount;
                }
            }
        });

        // Update tab badge numbers
        $('#tab-count-all').text(countAll);
        $('#tab-count-pending').text(countPending);
        $('#tab-count-completed').text(countCompleted);
        $('#tab-count-failed').text(countFailed);

        // Indian Currency Format Helper
        function formatINR(num) {
            return '₹' + num.toLocaleString('en-IN', { maximumFractionDigits: 0 });
        }

        // Animate metrics change or update instantly
        $('#metric-accrued-amount').text(formatINR(totalAccrued));
        $('#metric-pending-count').text(countPending);
        $('#metric-reconciled-count').text(countCompleted);

        // Reconciliation Progress Bar
        var progressPercent = totalAccrued > 0 ? Math.round((totalReconciled / totalAccrued) * 100) : 0;
        $('#progress-percentage-badge').text(progressPercent + '% Completed');
        $('#reconciliation-progress-bar').css('width', progressPercent + '%').attr('aria-valuenow', progressPercent);
        $('#progress-text-summary').html('<strong>' + formatINR(totalReconciled) + '</strong> reconciled of <strong>' + formatINR(totalAccrued) + '</strong> accrued');

        rows.each(function() {
            var row = $(this);
            var status = row.attr('data-status');
            var partyCode = row.attr('data-partycode').toLowerCase();
            var partyName = row.attr('data-partyname').toLowerCase();
            var utr = row.attr('data-utr').toLowerCase();
            var amount = parseFloat(row.attr('data-amount')) || 0;
            var rowMonth = parseInt(row.attr('data-month'));
            var rowYear = parseInt(row.attr('data-year'));
            var mode = row.attr('data-mode') || "";
            var rowLocation = row.attr('data-location') || "";

            // Period check
            var matchesPeriod = (rowMonth === filterMonth && rowYear === filterYear);

            // Location check
            var matchesLocation = currentBranchesFilter.includes(rowLocation);

            // Status check
            var matchesStatus = true;
            if (currentStatusFilter !== 'all') {
                if (currentStatusFilter === 'Completed') {
                    matchesStatus = (status === 'Completed' || status === 'Reconciled' || status === 'Success' || status === 'Paid');
                } else if (currentStatusFilter === 'Failed') {
                    matchesStatus = (status === 'Failed' || status === 'Reversed');
                } else if (currentStatusFilter === 'Pending') {
                    matchesStatus = (status === 'Pending' || status === 'Credit Party');
                } else {
                    matchesStatus = (status === currentStatusFilter);
                }
            }

            // Transfer Mode check
            var matchesMode = true;
            if (currentModeFilter !== 'all') {
                matchesMode = (mode.toUpperCase() === currentModeFilter.toUpperCase());
            }

            // Amount Range check
            var matchesAmount = true;
            if (minAmount !== null && amount < minAmount) {
                matchesAmount = false;
            }
            if (maxAmount !== null && amount > maxAmount) {
                matchesAmount = false;
            }

            // Search Text check
            var matchesSearch = true;
            if (query !== "") {
                matchesSearch = partyCode.indexOf(query) > -1 || 
                                partyName.indexOf(query) > -1 || 
                                utr.indexOf(query) > -1 || 
                                amount.toString().indexOf(query) > -1;
            }

            // Toggle visibility
            if (matchesPeriod && matchesLocation && matchesStatus && matchesMode && matchesAmount && matchesSearch) {
                row.show();
                visibleCount++;
            } else {
                row.hide();
                row.find('.transfer-select-item').prop('checked', false);
            }
        });

        // Toggle master checkbox state
        updateSelectAllCheckboxState();
        updateBulkPanelState();

        // 3. Handle Empty State UI
        if (visibleCount === 0) {
            $('#ledger-table-container').hide();
            var monthText = $('#reconcile-month option:selected').text();
            var yearText = $('#reconcile-year').val();
            $('#empty-state-period').text(monthText + ' ' + yearText);
            $('#no-data-alert').show();
        } else {
            $('#no-data-alert').hide();
            $('#ledger-table-container').show();
        }
    }

    // Search input keyup hook
    $('#transferSearchInput').on('keyup', function() {
        currentSearch = $(this).val();
        applyFilters();
    });

    // Transfer mode dropdown change hook
    $('#transferModeFilter').on('change', function() {
        currentModeFilter = $(this).val();
        applyFilters();
    });

    // Min and Max Payout amount input change/keyup hooks
    $('#minAmountFilter, #maxAmountFilter').on('keyup change', function() {
        applyFilters();
    });

    // Status filter tabs click hook
    $('.filter-tab').on('click', function() {
        $('.filter-tab').removeClass('active');
        $(this).addClass('active');
        currentStatusFilter = $(this).attr('data-status');
        applyFilters();
    });

    // Prevent dropdown menu from closing when clicking inside
    $('.custom-multiselect .dropdown-menu').on('click', function(e) {
        e.stopPropagation();
    });

    function updateMultiselectLabel(wrapperId, defaultText) {
        var wrapper = $('#' + wrapperId);
        var checked = wrapper.find('.option-cb:checked');
        var total = wrapper.find('.option-cb').length;
        var labelSpan = wrapper.find('.selected-label');
        
        if (checked.length === total) {
            labelSpan.text(defaultText);
        } else if (checked.length === 0) {
            labelSpan.text('Branches: None');
        } else if (checked.length === 1) {
            labelSpan.text('Branch: ' + checked.val());
        } else {
            labelSpan.text(checked.length + ' Branches Selected');
        }
    }

    // Handle Select All / Clear checkbox change
    $('#branchMultiselect .select-all-cb').on('change', function() {
        var isChecked = $(this).is(':checked');
        var wrapper = $(this).closest('.custom-multiselect');
        
        wrapper.find('.option-cb').prop('checked', isChecked);
        updateMultiselectLabel('branchMultiselect', 'Branches: All');
        
        // Update branches array and filter
        currentBranchesFilter = [];
        if (isChecked) {
            wrapper.find('.option-cb').each(function() {
                currentBranchesFilter.push($(this).val());
            });
        }
        applyFilters();
    });

    // Handle individual option checkbox changes
    $('#branchMultiselect .option-cb').on('change', function() {
        var wrapper = $(this).closest('.custom-multiselect');
        var id = wrapper.attr('id');
        
        // Check if all are checked to sync the Select All checkbox
        var total = wrapper.find('.option-cb').length;
        var checkedCount = wrapper.find('.option-cb:checked').length;
        wrapper.find('.select-all-cb').prop('checked', total === checkedCount);
        
        updateMultiselectLabel(id, 'Branches: All');
        
        // Update branches array and filter
        currentBranchesFilter = [];
        wrapper.find('.option-cb:checked').each(function() {
            currentBranchesFilter.push($(this).val());
        });
        applyFilters();
    });

    // Handle inline search filtering inside the dropdown
    $('#branchMultiselect .search-input').on('input', function() {
        var query = $(this).val().toLowerCase().trim();
        var wrapper = $(this).closest('.custom-multiselect');
        
        wrapper.find('.option-item').each(function() {
            var labelText = $(this).find('label').text().toLowerCase();
            if (labelText.indexOf(query) > -1) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    });

    // Reset Filters click hook
    $('#btnResetFilters').on('click', function() {
        $('#transferSearchInput').val('');
        currentSearch = "";
        
        $('#transferModeFilter').val('all');
        currentModeFilter = "all";
        
        $('#minAmountFilter').val('');
        $('#maxAmountFilter').val('');
        
        // Reset status tab to Pending
        $('.filter-tab').removeClass('active');
        $('.filter-tab[data-status="Pending"]').addClass('active');
        currentStatusFilter = "Pending";

        // Reset Branch multiselect to All
        $('#branchMultiselect .option-cb').prop('checked', true);
        $('#branchMultiselect .select-all-cb').prop('checked', true);
        updateMultiselectLabel('branchMultiselect', 'Branches: All');
        currentBranchesFilter = [];
        $('#branchMultiselect .branch-cb').each(function() {
            currentBranchesFilter.push($(this).val());
        });
        
        applyFilters();
    });

    // Run applyFilters on initial load
    applyFilters();
    loadUnmatchedRecords();

    function updateSelectAllCheckboxState() {
        var visiblePending = $('.transfer-row:visible .transfer-select-item').not(':disabled');
        if (visiblePending.length > 0 && visiblePending.length === visiblePending.filter(':checked').length) {
            $('#selectAllTransfers').prop('checked', true);
        } else {
            $('#selectAllTransfers').prop('checked', false);
        }
    }

    // Toggle manual mapping section
    $('input[name="mappingMode"]').on('change', function() {
        if ($(this).val() === 'manual') {
            $('#manual-mapping-section').slideDown(250);
            loadHeadersForMapping();
        } else {
            $('#manual-mapping-section').slideUp(200);
            $('.mapping-dropdown').prop('required', false).prop('disabled', true).html('');
        }
    });

    $('#reconcile-file-input').on('change', function() {
        if ($('input[name="mappingMode"]:checked').val() === 'manual') {
            loadHeadersForMapping();
        }
    });

    function loadHeadersForMapping() {
        var fileInput = $('#reconcile-file-input')[0];
        if (fileInput.files.length === 0) {
            $('.mapping-dropdown').html('<option value="">-- Choose File First --</option>').prop('disabled', true);
            return;
        }

        var formData = new FormData();
        formData.append("file", fileInput.files[0]);
        var token = $('input[name="__RequestVerificationToken"]').val();

        Swal.fire({
            title: 'Parsing Headers...',
            text: 'Extracting column headers from the uploaded file...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: '/Transfers/ParseHeaders',
            type: 'POST',
            data: formData,
            contentType: false,
            processData: false,
            headers: {
                "RequestVerificationToken": token
            },
            success: function(r) {
                Swal.close();
                if (r.ok && r.headers && r.headers.length > 0) {
                    var optionsHtml = '<option value="">-- Select Column --</option>';
                    r.headers.forEach(function(h) {
                        optionsHtml += '<option value="' + h.index + '">' + h.name + ' (Col ' + h.index + ')</option>';
                    });
                    
                    $('.mapping-dropdown').html(optionsHtml).prop('disabled', false);
                    
                    // Enable required property for mandatory fields
                    $('#map-account-no, #map-status, #map-utr').prop('required', true);

                    // Client-side auto matching logic
                    r.headers.forEach(function(h) {
                        var name = h.name.toLowerCase().trim();
                        
                        if (name === "beneficiary account no" || name === "account no" || name === "beneficiary account no." || name === "account number" || name.includes("bene account") || name.includes("beneficiary account")) {
