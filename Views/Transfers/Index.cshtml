                        else if (name.includes("debit narration") || name.includes("party code") || name.includes("dealer code") || name.includes("customer ref")) {
                            $('#map-party-code').val(h.index);
                        }
                        else if (name === "beneficiary name" || name === "name" || name.includes("bene name") || name.includes("beneficiary name")) {
                            $('#map-name').val(h.index);
                        }
                        else if (name.includes("ifsc") || name.includes("ifsc code") || name.includes("branch identifier")) {
                            $('#map-ifsc').val(h.index);
