                        if (r.ok) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Deleted',
                                text: r.message,
                                timer: 1500,
                                showConfirmButton: false
                            });
                            loadUnmatchedRecords();
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Failed',
                                text: r.message,
                                confirmButtonColor: '#2563eb'
                            });
                        }
                    },
                    error: function (xhr) {
                        Swal.close();
                        var msg = xhr.responseJSON ? xhr.responseJSON.message : "Error deleting record.";
                        Swal.fire({
                            icon: 'error',
                            title: 'Failed',
