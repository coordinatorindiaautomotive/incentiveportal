    var activeDealers = null;

    function getDealers(callback) {
        if (activeDealers !== null) {
            callback(activeDealers);
            return;
        }

        $.ajax({
            url: '/Transfers/GetPartiesList',
            type: 'GET',
            success: function (list) {
                activeDealers = list;
                callback(activeDealers);
            },
            error: function () {
                Swal.fire({
                    icon: 'error',
                    title: 'Failed',
                    text: 'Could not fetch dealers list.',
                    confirmButtonColor: '#2563eb'
                });
            }
        });
    }

    $(document).on('click', '.btn-reconcile-unmatched', function () {
        var id = $(this).data('id');
        var tr = $(this).closest('tr');
        var amtText = tr.find('td:nth-child(5)').text().trim();
        var name = tr.find('td:nth-child(2) strong').text();

        getDealers(function (dealers) {
            var listHtml = '<div class="text-start" style="font-size: 0.9rem;">' +
                '<p class="mb-3 text-muted">Select the dealer to reconcile with this statement row (Amount: <strong>' + amtText + '</strong>, Name: <strong>' + name + '</strong>).</p>' +
                '<div class="mb-3 position-relative">' +
                    '<i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="left: 12px; top: 12px; font-size: 0.9rem;"></i>' +
                    '<input type="text" id="dealer-search-input" class="form-control ps-5" placeholder="Search Dealer Code or Name..." style="height: 40px; border-radius: 8px;">' +
                '</div>' +
                '<div id="dealer-list-container" style="max-height: 250px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 8px; background: #fff; padding: 5px;">' +
                    '<div class="list-group list-group-flush" id="dealer-list">';
            
            dealers.forEach(function (d) {
                listHtml += '<button type="button" class="list-group-item list-group-item-action dealer-select-btn d-flex justify-content-between align-items-center py-2 px-3 border-0" data-code="' + d.code + '" style="border-radius: 6px; margin-bottom: 2px;">' +
                    '<span><strong>' + d.code + '</strong> - ' + d.name + '</span>' +
                    '<i class="fa-solid fa-chevron-right text-muted" style="font-size: 0.8rem;"></i>' +
                '</button>';
            });

            listHtml += '</div></div></div>';

            Swal.fire({
                title: 'Select Dealer for Reconciliation',
                html: listHtml,
                showConfirmButton: false,
                showCancelButton: true,
                cancelButtonText: 'Cancel',
                cancelButtonColor: '#64748b',
                width: '600px',
                didOpen: () => {
                    $('#dealer-search-input').on('keyup', function () {
                        var val = $(this).val().toLowerCase().trim();
                        $('#dealer-list .dealer-select-btn').each(function () {
                            var text = $(this).text().toLowerCase();
                            if (text.indexOf(val) > -1) {
                                $(this).show();
                            } else {
                                $(this).hide();
                            }
                        });
                    });

                    $('#dealer-list').on('click', '.dealer-select-btn', function () {
                        var code = $(this).data('code');
                        var dealerName = $(this).find('span').text();
                        
                        Swal.fire({
                            title: 'Confirm Assignment',
                            html: 'Are you sure you want to reconcile this statement record to:<br/><strong>' + dealerName + '</strong>?',
                            icon: 'question',
                            showCancelButton: true,
                            confirmButtonText: 'Yes, reconcile',
                            cancelButtonText: 'Back to List',
                            confirmButtonColor: '#2563eb',
                            cancelButtonColor: '#64748b'
                        }).then((confirmRes) => {
                            if (confirmRes.isConfirmed) {
                                var token = $('input[name="__RequestVerificationToken"]').val();
                                
                                Swal.fire({
                                    title: 'Reconciling...',
                                    allowOutsideClick: false,
                                    didOpen: () => {
                                        Swal.showLoading();
                                    }
                                });

                                $.ajax({
                                    url: '/Transfers/ReconcileUnmatchedRecord',
                                    type: 'POST',
                                    headers: {
                                        "RequestVerificationToken": token
                                    },
                                    data: { id: id, partyCode: code },
                                    success: function (r) {
                                        Swal.close();
                                        if (r.ok) {
                                            Swal.fire({
                                                icon: 'success',
                                                title: 'Reconciled Successfully',
                                                text: r.message,
                                                confirmButtonColor: '#2563eb'
                                            }).then(() => {
                                                window.location.reload();
                                            });
                                        } else {
                                            Swal.fire({
                                                icon: 'error',
                                                title: 'Failed',
                                                text: r.message,
                                                confirmButtonColor: '#2563eb'
                                            });
                                        }
                                    },
                                    error: function (xhr) {
                                        Swal.close();
                                        var msg = xhr.responseJSON ? xhr.responseJSON.message : "Error reconciling record.";
                                        Swal.fire({
                                            icon: 'error',
                                            title: 'Failed',
                                            text: msg,
                                            confirmButtonColor: '#2563eb'
                                        });
                                    }
                                });
                            } else {
                                $('.btn-reconcile-unmatched[data-id="' + id + '"]').click();
                            }
                        });
                    });
                }
            });
        });
    });
            // Drag and Drop for Reconcile Modal Dropzone
            var reconDropZone = document.getElementById('reconcileDropZone');
            var reconFileInput = document.getElementById('reconcile-file-input');

            if (reconDropZone && reconFileInput) {
                reconDropZone.addEventListener('dragover', function (e) {
                    e.preventDefault();
                    reconDropZone.style.background = '#f0fdf4';
                    reconDropZone.style.borderColor = '#22c55e';
                });

                reconDropZone.addEventListener('dragleave', function () {
                    reconDropZone.style.background = '#f8fafc';
                    reconDropZone.style.borderColor = '#cbd5e1';
                });

                reconDropZone.addEventListener('drop', function (e) {
                    e.preventDefault();
                    reconDropZone.style.background = '#f8fafc';
                    reconDropZone.style.borderColor = '#cbd5e1';
                    
                    if (e.dataTransfer.files.length > 0) {
                        reconFileInput.files = e.dataTransfer.files;
                        $(reconFileInput).trigger('change');
                    }
                });
            }

            // File input selection tracking
            $('#reconcile-file-input').on('change', function () {
                var file = this.files[0];
                if (file) {
                    $('#selectedReconFileName').text(file.name).removeClass('d-none');
                    $('#btnReconcileSubmit').prop('disabled', false);
                } else {
                    $('#selectedReconFileName').addClass('d-none');
                    $('#btnReconcileSubmit').prop('disabled', true);
                }
            });

            // ── Run Reconciliation button ─────────────────────────────────────────────
            function updateRunReconPeriodLabel() {
                var m = $('#reconcile-month').val();
                var y = $('#reconcile-year').val();
                var monthName = new Date(y, m - 1, 1).toLocaleString('default', { month: 'long' });
                $('#run-recon-period-label').text('Period: ' + monthName + ' ' + y);
            }

            // Update label on dropdown changes
            $('#reconcile-month, #reconcile-year').on('change', function () {
                updateRunReconPeriodLabel();
            });
            updateRunReconPeriodLabel(); // Init on load

            $('#btnRunReconciliation').on('click', function () {
                var month = $('#reconcile-month').val();
                var year  = $('#reconcile-year').val();
                if (!month || !year) {
                    alert('Please select a month and year first.');
                    return;
                }

                var btn = $(this);
                btn.prop('disabled', true);
                $('#btnRunReconIcon').removeClass('fa-play').addClass('fa-spinner fa-spin');
                $('#btnRunReconText').text('Running...');
                $('#run-recon-result').hide();
                $('#run-recon-logs-wrapper').hide();
                $('#run-recon-logs').text('');

                $.post('@Url.Action("RunReconciliation","Transfers")', {
                    month: month,
                    year: year,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val()
                })
                .done(function (data) {
                    var alertEl = $('#run-recon-alert');
                    alertEl.removeClass('alert-success alert-danger alert-warning');
                    if (data.ok) {
                        alertEl.addClass('alert-success');
                        alertEl.html('<i class="fa-solid fa-circle-check me-2"></i><strong>' + data.message + '</strong>');
                    } else {
                        alertEl.addClass('alert-warning');
                        alertEl.html('<i class="fa-solid fa-triangle-exclamation me-2"></i>' + (data.message || 'Completed with warnings.'));
                    }
                    if (data.logs && data.logs.length > 0) {
                        $('#run-recon-logs').text(data.logs.join('\n'));
                        $('#run-recon-logs-wrapper').show();
                    }
                    $('#run-recon-result').show();
                    // Reload table data
                    if (typeof loadTransfersTable === 'function') loadTransfersTable();
                })
                .fail(function (xhr) {
                    var msg = (xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : 'Server error. Please try again.';
                    var alertEl = $('#run-recon-alert');
                    alertEl.removeClass('alert-success alert-warning').addClass('alert-danger');
                    alertEl.html('<i class="fa-solid fa-circle-xmark me-2"></i>' + msg);
                    $('#run-recon-result').show();
                })
                .always(function () {
                    btn.prop('disabled', false);
                    $('#btnRunReconIcon').removeClass('fa-spinner fa-spin').addClass('fa-play');
                    $('#btnRunReconText').text('Run Reconciliation');
                });
            });
        });
</script>

}


