@model IEnumerable<IncentivePortal.Models.HelpdeskTicket>
@{
    ViewData["Title"] = "Helpdesk Support Hub";
    var parties = ViewBag.Parties as IEnumerable<dynamic>;
    var users = ViewBag.Users as IEnumerable<string>;
    var kbArticles = ViewBag.KBArticles as List<IncentivePortal.Models.KnowledgeBaseArticle>;
}

<div class="container-fluid py-4">
    <!-- Header Block -->
    <div class="card p-3 mb-4 border-0 shadow-sm" style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px);">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h4 class="mb-1 text-primary fw-bold" style="font-family:'Inter',sans-serif;"><i class="fa-solid fa-headset me-2"></i> Dealer Helpdesk Hub</h4>
                <p class="text-muted small mb-0">Manage billing disputes, scheme verification, system outages, and customer complaints.</p>
            </div>
            <div class="col-md-6 text-end">
                <button class="btn btn-primary btn-sm bg-primary border-0" data-bs-toggle="modal" data-bs-target="#createTicketModal"><i class="fa-solid fa-plus-circle me-1"></i> Create Support Ticket</button>
            </div>
        </div>
    </div>

    <!-- Summary Stats Bar -->
    <div class="row g-4 mb-4 text-center">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3">
                <div class="small text-muted mb-1">New Tickets</div>
                <h2 class="fw-bold mb-0 text-info">@ViewBag.NewCount</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3">
                <div class="small text-muted mb-1">In Progress / Assigned</div>
                <h2 class="fw-bold mb-0 text-warning">@ViewBag.InprogressCount</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3">
                <div class="small text-muted mb-1">Resolved / Closed</div>
                <h2 class="fw-bold mb-0 text-success">@ViewBag.ResolvedCount</h2>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Ticket list sidebar (Left) -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100 p-3">
                <form method="get" action="/Helpdesk/Index" class="mb-3">
                    <div class="input-group input-group-sm mb-2">
                        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" class="form-control" name="search" value="@ViewBag.SearchFilter" placeholder="Search ticket details..." />
                        <button type="submit" class="btn btn-primary bg-primary border-0">Find</button>
                    </div>
                    <div class="row g-2">
                        <div class="col-6">
                            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">All Statuses</option>
                                <option value="New" selected="@(ViewBag.StatusFilter == "New" ? "selected" : null)">New</option>
                                <option value="Assigned" selected="@(ViewBag.StatusFilter == "Assigned" ? "selected" : null)">Assigned</option>
                                <option value="InProgress" selected="@(ViewBag.StatusFilter == "InProgress" ? "selected" : null)">In Progress</option>
                                <option value="Resolved" selected="@(ViewBag.StatusFilter == "Resolved" ? "selected" : null)">Resolved</option>
                                <option value="Closed" selected="@(ViewBag.StatusFilter == "Closed" ? "selected" : null)">Closed</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <select name="priority" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">All Priorities</option>
                                <option value="Low" selected="@(ViewBag.PriorityFilter == "Low" ? "selected" : null)">Low</option>
                                <option value="Medium" selected="@(ViewBag.PriorityFilter == "Medium" ? "selected" : null)">Medium</option>
                                <option value="High" selected="@(ViewBag.PriorityFilter == "High" ? "selected" : null)">High</option>
                                <option value="Urgent" selected="@(ViewBag.PriorityFilter == "Urgent" ? "selected" : null)">Urgent</option>
                            </select>
                        </div>
                    </div>
                </form>

                <div class="ticket-list scrollbar" style="max-height: 480px; overflow-y: auto;">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var ticket in Model)
                        {
                            <div class="ticket-item p-3 mb-2 rounded border cursor-pointer" onclick="loadTicketDetails(@ticket.Id)" id="ticket-item-@ticket.Id" style="transition: all 0.2s; border-color: rgba(196,198,207,0.3) !important;">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small text-muted">Ticket #@ticket.Id | @ticket.Category</span>
                                    <span class="badge @(ticket.Priority == "Urgent" ? "bg-danger" : ticket.Priority == "High" ? "bg-warning text-dark" : "bg-secondary")" style="font-size: 0.65rem;">@ticket.Priority</span>
                                </div>
                                <h6 class="fw-bold text-dark mb-2 text-truncate">@ticket.Title</h6>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge @(ticket.Status == "New" ? "bg-info text-dark" : ticket.Status == "Resolved" ? "bg-success" : "bg-primary")" style="font-size: 0.7rem;">@ticket.Status</span>
                                    <span class="small text-muted"><i class="fa-regular fa-clock me-1"></i> @ticket.CreatedAt.ToString("dd MMM yy")</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="fa-regular fa-folder-open fa-3x mb-3 opacity-55"></i>
                            <p class="small mb-0">No active tickets found matching parameters.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Ticket Detail Workspace (Right) -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100 p-4" id="ticketDetailPanel" style="min-height: 400px; display: flex; flex-direction: column; justify-content: center; align-items: center; background: rgba(255,255,255,0.95);">
                <div class="text-center text-muted" id="detailEmptyState">
                    <i class="fa-solid fa-ticket fa-4x mb-3 text-secondary opacity-35"></i>
                    <h5 class="fw-bold mb-1">Select a support ticket</h5>
                    <p class="small mb-0">Click any ticket in the list to open, assign, add comments and review SLA timeline details.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Create Ticket -->
<div class="modal fade" id="createTicketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
            <div class="modal-header border-bottom bg-light">
                <h5 class="modal-title fw-bold text-primary"><i class="fa-solid fa-plus-circle me-1"></i> Create Support Ticket</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/Helpdesk/Save" method="post" data-ajax="true">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Ticket Title</label>
                        <input type="text" class="form-control" name="Title" required placeholder="Brief description of the issue" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted">Detail Description</label>
                        <textarea class="form-control" name="Description" rows="4" required placeholder="Describe the inquiry or outage in full detail..."></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold small text-muted">Category</label>
                            <select class="form-select" name="Category">
                                <option value="General">General Inquiry</option>
                                <option value="Schemes">Slab / Schemes</option>
                                <option value="Billing">Dispute Invoice</option>
                                <option value="Systems">Tally Mismatch</option>
                                <option value="Logistics">Parts Delivery</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small text-muted">Priority</label>
                            <select class="form-select" name="Priority">
                                <option value="Low">Low</option>
                                <option value="Medium" selected>Medium</option>
                                <option value="High">High</option>
                                <option value="Urgent">Urgent</option>
                            </select>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold small text-muted">Associated Customer</label>
                            <select class="form-select" name="AssociatedPartyCode">
                                <option value="">General (No Customer)</option>
                                @if (parties != null)
                                {
                                    foreach (var p in parties)
                                    {
                                        <option value="@p.PartyCode">@p.PartyName (@p.PartyCode)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small text-muted">Assign Agent</label>
                            <select class="form-select" name="AssignedTo">
                                <option value="">Unassigned (Queue)</option>
                                @if (users != null)
                                {
                                    foreach (var u in users)
                                    {
                                        <option value="@u">@u</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm bg-primary border-0">Submit Ticket</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadTicketDetails(id) {
            $('.ticket-item').removeClass('border-primary shadow-sm bg-light-glow');
            $('#ticket-item-' + id).addClass('border-primary shadow-sm bg-light-glow');

            $('#ticketDetailPanel').html('<div class="d-flex flex-column align-items-center py-5"><div class="spinner-border text-primary" role="status"></div><span class="mt-3 text-muted">Retrieving ticket details...</span></div>');

            $.get('/Helpdesk/Details/' + id, function(t) {
                let commentsHtml = '';
                t.comments.forEach(c => {
                    commentsHtml += `
                        <div class="p-3 mb-2 rounded ${c.isInternal ? 'bg-warning-light border-warning' : 'bg-light'} border" style="font-size:0.82rem;">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold text-dark">${c.createdBy} ${c.isInternal ? '<span class="badge bg-warning text-dark px-2 py-0 ms-1" style="font-size:0.6rem">INTERNAL NOTE</span>' : ''}</span>
                                <span class="text-muted text-end" style="font-size:0.72rem;">${c.createdAt}</span>
                            </div>
                            <div class="text-secondary">${c.commentText}</div>
                        </div>
                    `;
                });

                const html = `
                    <div class="d-flex flex-column h-100 w-100" style="text-align: left;">
                        <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-3">
                            <div>
                                <span class="badge bg-primary mb-2">${t.category}</span>
                                <h4 class="fw-bold text-dark mb-1">${t.title}</h4>
                                <div class="small text-muted">Ticket #${t.id} | Assigned Agent: <strong>${t.assignedTo || 'Unassigned'}</strong></div>
                            </div>
                            <div class="text-end">
                                <span class="badge ${t.priority === 'Urgent' ? 'bg-danger' : t.priority === 'High' ? 'bg-warning text-dark' : 'bg-secondary'} px-3 py-1 rounded-pill mb-2">${t.priority}</span>
                                <div class="small text-muted">SLA Expiry: <strong>${t.slaExpiry || 'N/A'}</strong></div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h6 class="fw-bold text-muted small text-uppercase mb-2">Description</h6>
                            <div class="p-3 bg-light rounded text-secondary" style="font-size:0.88rem; white-space: pre-wrap;">${t.description}</div>
                        </div>

                        <div class="flex-grow-1 mb-3 scrollbar" style="max-height: 220px; overflow-y: auto;">
                            <h6 class="fw-bold text-muted small text-uppercase mb-2">Discussion & Logs</h6>
                            ${commentsHtml || '<div class="text-center text-muted py-3 small">No messages or internal notes added.</div>'}
                        </div>

                        <form id="addCommentForm" class="border-top pt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="${t.id}" />
                            <div class="mb-2">
                                <textarea class="form-control form-control-sm" name="commentText" rows="2" placeholder="Write a response or note..." required></textarea>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="isInternalCheck" name="isInternal" value="true">
                                    <label class="form-check-input-label small text-muted ms-1" for="isInternalCheck"><i class="fa-solid fa-lock text-warning"></i> Internal Note Only</label>
                                </div>
                                <button type="button" class="btn btn-primary btn-sm bg-primary border-0" onclick="submitComment()"><i class="fa-solid fa-paper-plane me-1"></i> Send Reply</button>
                            </div>
                        </form>
                    </div>
                `;
                $('#ticketDetailPanel').html(html);
            });
        }

        function submitComment() {
            const form = $('#addCommentForm');
            $.ajax({
                url: '/Helpdesk/AddComment',
                method: 'POST',
                data: form.serialize(),
                success: function(res) {
                    if (res.ok) {
                        const ticketId = form.find('input[name="ticketId"]').val();
                        loadTicketDetails(ticketId);
                    }
                },
                error: function(err) {
                    portalToast(err.responseText || 'Comment submission failed.', 'error');
                }
            });
        }
    </script>
}

