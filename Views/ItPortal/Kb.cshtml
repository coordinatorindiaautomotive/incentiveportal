@{
    ViewData["Title"] = "Knowledge Base & FAQs";
    Layout = "_Layout";
}

<div class="main">
    <!-- Header Block -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-1 fw-bold">IT Knowledge Base</h4>
            <p class="text-muted small mb-0">Search FAQs, guides, and documented workflows for recurring IT solutions.</p>
        </div>
        <div>
            <button onclick="openFormModal(0)" class="btn btn-primary btn-sm d-flex align-items-center gap-2">
                <i data-lucide="plus" style="width:14px; height:14px;"></i> Create Article
            </button>
        </div>
    </div>

    <!-- Global Search -->
    <div class="cc p-3 mb-4">
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i data-lucide="search" style="width:16px; height:16px;"></i></span>
            <input type="text" id="kbSearch" oninput="loadArticles()" class="form-control border-start-0" placeholder="Search articles by title, tags, or content keywords..." />
        </div>
    </div>

    <div class="row g-4">
        <!-- Categories Sidebar -->
        <div class="col-md-3">
            <div class="cc p-3">
                <h6 class="fw-bold mb-3 small text-muted uppercase">Categories</h6>
                <div class="list-group list-group-flush" id="kbCategories">
                    <a href="javascript:void(0)" onclick="selectCategory(null)" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center active" id="cat-all">
                        All Categories
                    </a>
                </div>
            </div>
        </div>

        <!-- Articles Grid -->
        <div class="col-md-9">
            <div id="articlesContainer" class="d-flex flex-column gap-3">
                <!-- Loaded Articles go here -->
                <div class="cc p-4 text-center text-muted">
                    Loading articles...
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Form -->
<div class="modal fade" id="kbModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Create Article</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="kbForm">
                    <input type="hidden" id="itemId" value="0" />
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Article Title</label>
                        <input type="text" id="kbTitle" class="form-control" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Category</label>
                            <select id="kbCategorySelect" class="form-select" required></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Tags (Comma-separated)</label>
                            <input type="text" id="kbTags" class="form-control" placeholder="VPN, Connection, Remote Work" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Content</label>
                        <textarea id="kbContent" class="form-control" rows="8" placeholder="Write the guide content here..." required></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" onclick="saveArticle()" class="btn btn-primary btn-sm">Save Article</button>
            </div>
        </div>
    </div>
</div>

<!-- Read Modal -->
<div class="modal fade" id="readModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title fw-bold" id="readTitle">Article Title</h5>
                    <div class="text-muted small mt-1">Created on <span id="readDate"></span> &bull; <span id="readViews"></span> Views</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="readContent" style="white-space: pre-wrap; line-height: 1.6; font-size: 14px;"></div>
                <div class="mt-4 pt-3 border-top" id="readTagsContainer"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let formModal = null;
        let readModal = null;
        let loadedArticles = [];
        let selectedCategory = null;

        document.addEventListener("DOMContentLoaded", () => {
            formModal = new bootstrap.Modal(document.getElementById("kbModal"));
            readModal = new bootstrap.Modal(document.getElementById("readModal"));
            loadCategories();
            loadArticles();
        });

        async function loadCategories() {
            try {
                const res = await fetch("/ItPortal/GetMasterData?type=TicketCategory");
                const cats = await res.json();
                
                const select = document.getElementById("kbCategorySelect");
                select.innerHTML = cats.map(c => `<option value="${c.id}">${c.name}</option>`).join("");

                const list = document.getElementById("kbCategories");
                list.innerHTML = `<a href="javascript:void(0)" onclick="selectCat(null)" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center active" id="cat-all">All Categories</a>` +
                    cats.map(c => `<a href="javascript:void(0)" onclick="selectCat(${c.id})" class="list-group-item list-group-item-action" id="cat-${c.id}">${c.name}</a>`).join("");
            } catch (err) {
                console.error("Failed to load categories", err);
            }
        }

        async function selectCat(catId) {
            selectedCategory = catId;
            document.querySelectorAll("#kbCategories .list-group-item").forEach(el => el.classList.remove("active"));
            
            if (catId === null) {
                document.getElementById("cat-all").classList.add("active");
            } else {
                document.getElementById("cat-" + catId).classList.add("active");
            }
            loadArticles();
        }

        async function loadArticles() {
            const search = document.getElementById("kbSearch").value;
            const container = document.getElementById("articlesContainer");

            try {
                const res = await fetch(`/ItPortal/GetKbArticles?search=${encodeURIComponent(search)}`);
                loadedArticles = await res.json();

                let filtered = loadedArticles;
                if (selectedCategory !== null) {
                    filtered = loadedArticles.filter(x => x.categoryId === selectedCategory);
                }

                if (filtered.length === 0) {
                    container.innerHTML = `<div class="cc p-4 text-center text-muted">No knowledge base articles found matching your search.</div>`;
                    return;
                }

                container.innerHTML = filtered.map(x => `
                    <div class="cc p-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="fw-bold mb-1"><a href="javascript:void(0)" onclick="readArticle(${x.id})">${escapeHtml(x.title)}</a></h5>
                                <div class="text-muted small mb-2">Created at ${x.createdAt} &bull; ${x.viewsCount} Views</div>
                                <p class="mb-2 text-muted small">${escapeHtml(x.content.substring(0, 180))}...</p>
                                <div>
                                    ${(x.tags || '').split(',').filter(t => t.trim() !== '').map(t => `<span class="badge bg-light text-dark me-1">${escapeHtml(t.trim())}</span>`).join('')}
                                </div>
                            </div>
                            <div>
                                <button class="btn btn-outline-primary btn-sm py-1 px-2" onclick="openFormModal(${x.id})">Edit</button>
                                <button class="btn btn-outline-danger btn-sm py-1 px-2" onclick="deleteArticle(${x.id})">Delete</button>
                            </div>
                        </div>
                    </div>
                `).join("");
            } catch (err) {
                container.innerHTML = `<div class="cc p-4 text-center text-danger">Error loading articles from knowledge base.</div>`;
            }
        }

        async function readArticle(id) {
            const item = loadedArticles.find(x => x.id === id);
            if (!item) return;

            // Increment views
            fetch(`/ItPortal/IncrementKbViews?id=${id}`, { method: "POST" });

            document.getElementById("readTitle").textContent = item.title;
            document.getElementById("readDate").textContent = item.createdAt;
            document.getElementById("readViews").textContent = item.viewsCount + 1;
            document.getElementById("readContent").textContent = item.content;

            const tagsCont = document.getElementById("readTagsContainer");
            if (item.tags) {
                tagsCont.innerHTML = `<div class="small fw-bold mb-2">Tags:</div>` +
                    item.tags.split(',').map(t => `<span class="badge bg-light text-dark me-1">${escapeHtml(t.trim())}</span>`).join('');
            } else {
                tagsCont.innerHTML = "";
            }

            readModal.show();
        }

        function openFormModal(id) {
            document.getElementById("kbForm").reset();
            document.getElementById("itemId").value = id;

            if (id === 0) {
                document.getElementById("modalTitle").textContent = "Create Article";
            } else {
                const item = loadedArticles.find(x => x.id === id);
                if (!item) return;

                document.getElementById("modalTitle").textContent = "Edit Article";
                document.getElementById("kbTitle").value = item.title;
                document.getElementById("kbCategorySelect").value = item.categoryId;
                document.getElementById("kbTags").value = item.tags || "";
                document.getElementById("kbContent").value = item.content;
            }

            formModal.show();
        }

        async function saveArticle() {
            const id = parseInt(document.getElementById("itemId").value);
            const title = document.getElementById("kbTitle").value.trim();
            const categoryId = parseInt(document.getElementById("kbCategorySelect").value);
            const tags = document.getElementById("kbTags").value.trim();
            const content = document.getElementById("kbContent").value.trim();

            if (!title || !content || !categoryId) {
                Swal.fire("Validation Error", "Title, Category, and Content are required.", "warning");
                return;
            }

            const model = { id, title, categoryId, tags, content };

            try {
                const res = await fetch("/ItPortal/SaveKbArticle", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(model)
                });
                
                const data = await res.json();
                if (data.ok) {
                    formModal.hide();
                    Swal.fire("Success", data.message, "success");
                    loadArticles();
                } else {
                    Swal.fire("Error", data.message, "error");
                }
            } catch (err) {
                Swal.fire("Error", "Server submission failed.", "error");
            }
        }

        async function deleteArticle(id) {
            const result = await Swal.fire({
                title: "Are you sure?",
                text: "Delete this article from the FAQ directory?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                confirmButtonText: "Yes, Delete"
            });

            if (!result.isConfirmed) return;

            try {
                const res = await fetch(`/ItPortal/DeleteKbArticle?id=${id}`, { method: "POST" });
                const data = await res.json();
                if (data.ok) {
                    Swal.fire("Deleted", data.message, "success");
                    loadArticles();
                } else {
                    Swal.fire("Error", data.message, "error");
                }
            } catch (err) {
                Swal.fire("Error", "Server deletion failed.", "error");
            }
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
        }
    </script>
}
