@section Scripts {
    <script>
        $(document).ready(function() {
            // Setup Brand Color pickers real-time style preview
            $('#brandColor').on('input', function() {
                $('.live-preview-card').css('--brand', $(this).val());
            });
            $('#canvasColor').on('input', function() {
                $('.live-preview-card').css('--canvas', $(this).val());
            });
            $('#panelColor').on('input', function() {
                $('.live-preview-card').css('--panel', $(this).val());
            });
            $('#inkColor').on('input', function() {
                $('.live-preview-card').css('--ink', $(this).val());
            });
            $('#lineColor').on('input', function() {
                $('.live-preview-card').css('--line', $(this).val());
            });
            $('#companyNameInput').on('input', function() {
                var val = $(this).val() || "ThessBuddy";
                $('#companyNamePreview').text(val);
                $('#companyLogoPreview').text(val.substring(0, 1).toLowerCase());
            });

            // Ajax Form Submission Handler
            $('form').on('submit', function(e) {
                if (e.target.id === "resetForm") return; // Skip auth forms

                e.preventDefault();
                var form = $(this);
                var url = form.attr('action');
                var data = form.serialize();

                $.post(url, data)
                    .done(function(res) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Saved!',
                            text: res.message || 'Settings saved successfully.',
                            confirmButtonColor: 'var(--brand, var(--primary))'
                        }).then(() => {
                            // If saving branding, refresh page to show dynamic styling instantly
                            if (form.attr('id') === 'portalSettingsForm') {
                                window.location.reload();
                            } else {
                                window.location.reload();
                            }
                        });
                    })
                    .fail(function(err) {
                        var msg = err.responseJSON ? err.responseJSON.message : 'An error occurred during submission.';
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: msg,
                            confirmButtonColor: 'var(--brand, var(--primary))'
                        });
                    });
            });
        });

        // â”€â”€ TDS RULES SCRIPTS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        function showTdsModal() {
            $('#tdsId').val(0);
            $('#tdsEffectiveFrom').val('');
            $('#tdsEffectiveTo').val('');
            $('#tdsAnnualThreshold').val('');
            $('#tdsRateWithPan').val('');
            $('#tdsRateNoPan').val('');
            $('#tdsSection').val('194H');
            $('#tdsNotes').val('');
            $('#tdsModalTitle').text('Add TDS Rule');
            $('#tdsModal').modal('show');
        }

        function editTdsRule(rule) {
            $('#tdsId').val(rule.Id);
            $('#tdsEffectiveFrom').val(rule.EffectiveFrom.split('T')[0]);
            $('#tdsEffectiveTo').val(rule.EffectiveTo.split('T')[0]);
            $('#tdsAnnualThreshold').val(rule.AnnualThreshold);
            $('#tdsRateWithPan').val(rule.RateWithPan * 100);
