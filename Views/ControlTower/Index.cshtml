        // â”€â”€ AUDIT LOG DIFF VIEWER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        function viewAuditDiff(id) {
            $('#diffModalSubtitle').text(`Loading log entry ID: ${id}...`);
            $('#diffModalBody').html('<tr><td colspan="3" class="text-center py-4"><i class="fa-solid fa-spinner fa-spin me-1"></i> Analysing values difference...</td></tr>');
            $('#auditDiffModal').modal('show');

            $.get(`/ControlTower/GetAuditLogDiff?id=${id}`)
                .done(function(res) {
                    $('#diffModalSubtitle').text(`${res.entityName} (Record ID: ${res.entityId}) changed by ${res.changedBy} on ${res.changedAt}`);
                    
                    var html = '';
                    if (res.diff && res.diff.length > 0) {
                        res.diff.forEach(item => {
                            html += `<tr>
                                <td class="fw-bold">${item.PropertyName}</td>
                                <td class="text-danger bg-light text-decoration-line-through">${item.OldValue || '<em class="text-muted">null</em>'}</td>
                                <td class="text-success" style="background:#ecfdf5; font-weight: 500;">${item.NewValue || '<em class="text-muted">null</em>'}</td>
                            </tr>`;
                        });
                    } else {
                        html = '<tr><td colspan="3" class="text-center text-muted py-4">No field modifications detected (values are identical or masked).</td></tr>';
                    }
                    $('#diffModalBody').html(html);
                })
                .fail(function(err) {
                    $('#diffModalBody').html(`<tr><td colspan="3" class="text-center text-danger py-4"><i class="fa-solid fa-circle-xmark me-1"></i> Failed to retrieve differences log: ${err.responseText}</td></tr>`);
                });
        }

