                            <h4 class="fw-bold mb-0" style="color: var(--ink);">Excel Import Mappings</h4>
                            <button class="btn btn-sm btn-primary px-3 py-2 border-0" style="background: var(--brand); border-radius:8px;" onclick="showMappingModal()"><i class="fa-solid fa-plus me-1"></i> Add Mapping</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle" style="font-size:0.88rem;">
                                <thead>
                                    <tr class="text-secondary fw-semibold">
                                        <th>Upload Context</th>
                                        <th>Excel Header</th>
                                        <th>Portal Field Target</th>
                                        <th>Status</th>
                                        <th>Notes</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var m in columnMappings)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary">@m.UploadContext</td>
                                            <td class="fw-bold">@m.ExcelHeader</td>
                                            <td><span class="badge bg-light text-dark border p-2">@m.PortalField</span></td>
                                            <td>
                                                <span class="badge @(m.IsActive ? "bg-success" : "bg-secondary")">@(m.IsActive ? "Active" : "Inactive")</span>
                                            </td>
                                            <td>@m.Notes</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-light border-0 me-1" onclick="editMapping(@JsonSerializer.Serialize(m))" title="Edit"><i class="fa-solid fa-edit text-secondary"></i></button>
                                                <button class="btn btn-sm btn-light border-0" onclick="deleteMapping(@m.Id, '@m.ExcelHeader')" title="Delete"><i class="fa-solid fa-trash text-danger"></i></button>
                                            </td>
                                        </tr>
                                    }
                                    @if (!columnMappings.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-4">No column mappings configured. Falling back to default header aliases.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 4. OUTSTANDING RULES -->
                <div class="tab-pane fade" id="tab-outstanding" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="fw-bold mb-0" style="color: var(--ink);">Outstanding Deduction Rules</h4>
                            <button class="btn btn-sm btn-primary px-3 py-2 border-0" style="background: var(--brand); border-radius:8px;" onclick="showOutstandingModal()"><i class="fa-solid fa-plus me-1"></i> Add Rule</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle" style="font-size:0.88rem;">
                                <thead>
                                    <tr class="text-secondary fw-semibold">
                                        <th style="width: 80px;">Priority</th>
                                        <th>Name</th>
                                        <th>Min Outstanding Threshold</th>
                                        <th>Withhold / Deduction %</th>
                                        <th>Status</th>
                                        <th>Description</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in outstandingRules)
                                    {
                                        <tr>
                                            <td class="fw-bold text-center"><span class="badge bg-secondary p-2">@o.Priority</span></td>
                                            <td class="fw-bold">@o.Name</td>
                                            <td class="fw-bold">₹@o.ThresholdAmount.ToString("N0")</td>
                                            <td class="fw-bold text-danger">@(o.DeductionRate * 100)%</td>
                                            <td>
                                                <span class="badge @(o.IsActive ? "bg-success" : "bg-secondary")">@(o.IsActive ? "Active" : "Inactive")</span>
                                            </td>
                                            <td>@o.Description</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-light border-0 me-1" onclick="editOutstandingRule(@JsonSerializer.Serialize(o))" title="Edit"><i class="fa-solid fa-edit text-secondary"></i></button>
                                                <button class="btn btn-sm btn-light border-0" onclick="deleteOutstandingRule(@o.Id, '@o.Name')" title="Delete"><i class="fa-solid fa-trash text-danger"></i></button>
                                            </td>
                                        </tr>
                                    }
                                    @if (!outstandingRules.Any())
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">No outstanding deduction rules configured. Defaulting to 100% outstanding balance deduction.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 5. NOTIFICATION SETTINGS -->
                <div class="tab-pane fade" id="tab-notifications" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
                        <h4 class="fw-bold mb-3" style="color: var(--ink);">Email & SMS Notifications Configurations</h4>

                        <form id="notificationSettingsForm" method="post" asp-action="SaveNotificationSettings">
                            @Html.AntiForgeryToken()
                            
                            <h5 class="fw-bold text-secondary mb-3 mt-2" style="font-size:0.95rem; text-transform:uppercase;"><i class="fa-regular fa-envelope me-1"></i> SMTP Server Setup</h5>
                            <div class="row mb-3">
                                <div class="col-md-3 mb-3">
                                    <label class="form-label small fw-bold">Provider</label>
                                    <select class="form-select" name="Provider">
                                        <option value="SMTP" selected>SMTP (Standard Email)</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">SMTP Host</label>
                                    <input type="text" class="form-control" name="SmtpHost" value="@notificationSetting.SmtpHost" placeholder="smtp.mailtrap.io" required />
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label small fw-bold">SMTP Port</label>
                                    <input type="number" class="form-control" name="SmtpPort" value="@notificationSetting.SmtpPort" required />
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">SMTP User / Username</label>
                                    <input type="text" class="form-control" name="SmtpUser" value="@notificationSetting.SmtpUser" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">SMTP Password</label>
                                    <input type="password" class="form-control" name="smtpPassword" value="@ViewBag.DecryptedSmtpPassword" placeholder="â€¢â€¢â€¢â€¢â€¢â€¢â€¢â€¢" />
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">From Email Address</label>
                                    <input type="email" class="form-control" name="FromEmail" value="@notificationSetting.FromEmail" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">From Display Name</label>
                                    <input type="text" class="form-control" name="FromName" value="@notificationSetting.FromName" required />
                                </div>
                            </div>
                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SmtpUseSsl" value="true" id="smtpSslSwitch" @(notificationSetting.SmtpUseSsl ? "checked" : "") />
                                    <label class="form-check-label small fw-bold" for="smtpSslSwitch">Use SSL / TLS Encryption</label>
                                </div>
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" name="EmailEnabled" value="true" id="emailEnabledSwitch" @(notificationSetting.EmailEnabled ? "checked" : "") />
                                    <label class="form-check-label small fw-bold" for="emailEnabledSwitch" style="color: var(--brand);">Enable Automated System Emails (Password Resets, Alerts)</label>
                                </div>
                            </div>

                            <h5 class="fw-bold text-secondary mb-3 mt-4" style="font-size:0.95rem; text-transform:uppercase;"><i class="fa-solid fa-mobile-screen-button me-1"></i> MSG91 SMS Gateway Setup</h5>
                            <div class="row mb-3">
                                <div class="col-md-8 mb-3">
                                    <label class="form-label small fw-bold">MSG91 Auth Key</label>
                                    <input type="text" class="form-control" name="SmsApiKey" value="@notificationSetting.SmsApiKey" placeholder="MSG91 API Auth Key" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold">Sender ID</label>
                                    <input type="text" class="form-control" name="SmsSenderId" value="@notificationSetting.SmsSenderId" placeholder="e.g. THESSB" />
                                </div>
                            </div>
                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SmsEnabled" value="true" id="smsEnabledSwitch" @(notificationSetting.SmsEnabled ? "checked" : "") />
                                    <label class="form-check-label small fw-bold" for="smsEnabledSwitch" style="color: var(--brand);">Enable Automated System SMS Alerts</label>
                                </div>
                            </div>

                            <div class="d-flex gap-3 mt-4">
                                <button type="submit" class="btn btn-primary px-4 py-2 border-0" style="background: var(--brand); font-weight:600;"><i class="fa-solid fa-save me-1"></i> Save Notification Settings</button>
                                <button type="button" class="btn btn-outline-secondary px-3" onclick="triggerTestEmail()"><i class="fa-solid fa-envelope me-1"></i> Test SMTP Email</button>
                                <button type="button" class="btn btn-outline-secondary px-3" onclick="triggerTestSms()"><i class="fa-solid fa-mobile-retro me-1"></i> Test SMS Dispatch</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- 6. ROLE PERMISSIONS MATRIX -->
                <div class="tab-pane fade" id="tab-permissions" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
                        <h4 class="fw-bold mb-1" style="color: var(--ink);">Role Permissions Matrix</h4>
                        <p class="text-secondary small mb-3">Grant or deny access dynamically to features. Checked cells mean ALLOWED. Unchecked cells mean BLOCKED/DENIED. Super Admin retains global bypass access.</p>

                        <form id="rolePermissionsForm" method="post" asp-action="SaveRolePermissions">
                            @Html.AntiForgeryToken()
                            
                            <div class="table-responsive">
                                <table class="table table-bordered align-middle text-center" style="font-size:0.86rem;">
                                    <thead>
                                        <tr style="background:#f8fafc;">
                                            <th class="text-start">Module / Controller</th>
                                            <th>Action</th>
                                            @foreach (var r in roles)
                                            {
                                                <th>@r</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{ var keyIdx = 0; }
                                        @foreach (var mod in modules)
                                        {
                                            foreach (var act in actions)
                                            {
                                                <tr>
                                                    <td class="text-start fw-bold">@mod</td>
                                                    <td><span class="badge bg-light text-secondary border">@act</span></td>
                                                    @foreach (var r in roles)
                                                    {
                                                        var isAllowed = rolePermissions.Any(p => p.RoleName == r && p.Module == mod && p.Action == act && p.IsAllowed);
                                                        <td>
                                                            <input type="checkbox" class="form-check-input" style="width:20px; height:20px;" 
                                                                   name="permissions[@(keyIdx)].IsAllowed" value="true" @(isAllowed ? "checked" : "") />
                                                            <input type="hidden" name="permissions[@(keyIdx)].RoleName" value="@r" />
                                                            <input type="hidden" name="permissions[@(keyIdx)].Module" value="@mod" />
                                                            <input type="hidden" name="permissions[@(keyIdx)].Action" value="@act" />
                                                        </td>
                                                        keyIdx++;
                                                    }
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <button type="submit" class="btn btn-primary px-4 py-2 mt-3 border-0" style="background: var(--brand); font-weight:600;"><i class="fa-solid fa-save me-1"></i> Save Access Matrix</button>
                        </form>
                    </div>
                </div>

                <!-- 7. TALLY INTEGRATION -->
                <div class="tab-pane fade" id="tab-tally" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
                        <h4 class="fw-bold mb-3" style="color: var(--ink);">Tally Integration Settings</h4>

                        <form id="tallySettingsForm" method="post" asp-action="SaveTallySettings">
                            @Html.AntiForgeryToken()
                            <div class="row">
                                <div class="col-md-8 mb-3">
                                    <label class="form-label small fw-bold">Tally Server Base URL</label>
                                    <input type="url" class="form-control" name="BaseUrl" value="@tallySetting.BaseUrl" placeholder="http://localhost:9000" required />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold">Port</label>
                                    <input type="number" class="form-control" name="Port" value="@tallySetting.Port" required />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Company Name (Exact match in Tally ERP/Prime)</label>
                                <input type="text" class="form-control" name="CompanyName" value="@tallySetting.CompanyName" required />
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">Tally XML Username (Optional)</label>
                                    <input type="text" class="form-control" name="Username" value="@tallySetting.Username" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">Tally XML Password (Optional)</label>
                                    <input type="password" class="form-control" name="tallyPassword" value="@ViewBag.DecryptedTallyPassword" placeholder="â€¢â€¢â€¢â€¢â€¢â€¢â€¢â€¢" />
                                </div>
                            </div>
                            <div class="row mb-4">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label small fw-bold">Timeout (Seconds)</label>
                                    <input type="number" class="form-control" name="TimeoutSeconds" value="@tallySetting.TimeoutSeconds" required />
                                </div>
                                <div class="col-md-6 d-flex align-items-center mt-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="IsEnabled" value="true" id="tallyEnabledSwitch" @(tallySetting.IsEnabled ? "checked" : "") />
                                        <label class="form-check-label small fw-bold" for="tallyEnabledSwitch" style="color: var(--brand);">Enable Automatic Sync</label>
                                    </div>
                                </div>
                            </div>

                            <div class="alert alert-info border-0 p-3 small mb-4" style="border-radius:10px;">
                                <i class="fa-solid fa-circle-info me-1"></i> Tally Sync Status: <strong>@tallySetting.LastSyncStatus</strong> (Last run: @(tallySetting.LastSyncAt?.ToString("g") ?? "Never"))
                            </div>

                            <button type="submit" class="btn btn-primary px-4 py-2 border-0" style="background: var(--brand); font-weight:600;"><i class="fa-solid fa-save me-1"></i> Save Tally Settings</button>
                        </form>
                    </div>
                </div>

                <!-- 8. AUDIT LOGS -->
                <div class="tab-pane fade" id="tab-audit" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
                        <h4 class="fw-bold mb-3" style="color: var(--ink);">Governance Change Log Tracker</h4>

                        <div class="table-responsive">
                            <table class="table align-middle" style="font-size:0.86rem;" id="auditLogsTable">
                                <thead>
                                    <tr class="text-secondary fw-semibold">
                                        <th>Timestamp</th>
                                        <th>User</th>
                                        <th>IP Address</th>
                                        <th>Entity Name</th>
                                        <th>Record ID</th>
                                        <th>Action</th>
                                        <th class="text-end">Changes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var l in auditLogs)
                                    {
                                        var actionClass = l.Action switch
                                        {
                                            "Added" => "bg-success",
                                            "Deleted" => "bg-danger",
                                            _ => "bg-warning text-dark"
                                        };
                                        <tr>
                                            <td>@l.ChangedAt.ToString("dd MMM yyyy HH:mm:ss")</td>
                                            <td class="fw-bold">@l.ChangedBy</td>
                                            <td class="small text-secondary">@l.IpAddress</td>
                                            <td><span class="badge bg-light text-dark border">@l.EntityName</span></td>
                                            <td class="fw-bold">@l.EntityId</td>
                                            <td><span class="badge @actionClass">@l.Action</span></td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary py-1 px-2 border-0" onclick="viewAuditDiff(@l.Id)" style="font-size:0.8rem;"><i class="fa-solid fa-eye me-1"></i> Diff</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 9. HELP TOOLTIPS -->
                <div class="tab-pane fade" id="tab-help" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="fw-bold mb-0" style="color: var(--ink);">Contextual Help Texts</h4>
                            <button class="btn btn-sm btn-primary px-3 py-2 border-0" style="background: var(--brand); border-radius:8px;" onclick="showHelpModal()"><i class="fa-solid fa-plus me-1"></i> Add Tooltip</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle" style="font-size:0.88rem;">
                                <thead>
                                    <tr class="text-secondary fw-semibold">
                                        <th>Page</th>
                                        <th>Field / Element Key</th>
                                        <th>Help Text Description</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var h in helpTexts)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary">@h.Page</td>
                                            <td class="fw-bold">@h.FieldKey</td>
                                            <td>@h.Text</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-light border-0 me-1" onclick="editHelpText(@JsonSerializer.Serialize(h))" title="Edit"><i class="fa-solid fa-edit text-secondary"></i></button>
                                            </td>
                                        </tr>
                                    }
                                    @if (!helpTexts.Any())
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-4">No tooltips configured. Configure tooltip descriptions for keys like 'FixedIncentivePercent'.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 10. REPORT COLUMNS CONFIG -->
                <div class="tab-pane fade" id="tab-reports" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="fw-bold mb-0" style="color: var(--ink);">Report Columns Config</h4>
                            <button class="btn btn-sm btn-primary px-3 py-2 border-0" style="background: var(--brand); border-radius:8px;" onclick="showReportColModal()"><i class="fa-solid fa-plus me-1"></i> Add Column Config</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle" style="font-size:0.88rem;">
                                <thead>
                                    <tr class="text-secondary fw-semibold">
                                        <th>Report Name</th>
                                        <th>Column Key</th>
                                        <th>Display Name</th>
                                        <th>Visible</th>
                                        <th>Sort Order</th>
                                        <th>Format</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var c in reportColumns)
                                    {
                                        <tr>
                                            <td class="fw-bold text-primary">@c.ReportName</td>
                                            <td class="fw-bold">@c.ColumnKey</td>
                                            <td>@c.DisplayName</td>
                                            <td>
                                                @if (c.IsVisible)
                                                {
                                                    <span class="badge bg-success">Visible</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Hidden</span>
                                                }
                                            </td>
                                            <td>@c.SortOrder</td>
                                            <td>@(string.IsNullOrEmpty(c.Format) ? "-" : c.Format)</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-light border-0 me-1" onclick="editReportCol(@JsonSerializer.Serialize(c))" title="Edit"><i class="fa-solid fa-edit text-secondary"></i></button>
                                                <button class="btn btn-sm btn-light border-0" onclick="deleteReportCol(@c.Id, '@c.DisplayName')" title="Delete"><i class="fa-solid fa-trash text-danger"></i></button>
                                            </td>
                                        </tr>
                                    }
                                    @if (!reportColumns.Any())
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">No report column configurations found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
