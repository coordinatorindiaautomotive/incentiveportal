        // â”€â”€ DYNAMIC IFRAME LOADING SCRIPTS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        function loadIframeTab(iframeId, url) {
            var iframe = document.getElementById(iframeId);
            if (iframe && (iframe.src === 'about:blank' || iframe.src === '' || iframe.getAttribute('src') === 'about:blank')) {
                var parent = iframe.parentElement;
                if (parent) {
                    var loader = parent.querySelector('.iframe-loader');
                    if (!loader) {
                        loader = document.createElement('div');
                        loader.className = 'iframe-loader d-flex flex-column align-items-center justify-content-center py-5';
                        loader.innerHTML = `
                            <div class="spinner-border text-primary mb-3" role="status" style="width: 2.5rem; height: 2.5rem; border-width: 3px;"></div>
                            <div class="text-muted small fw-bold" style="">Loading registry console...</div>
                        `;
                        parent.insertBefore(loader, iframe);
                        iframe.style.display = 'none';
                        
                        iframe.addEventListener('load', function() {
                            if (loader) {
                                loader.remove();
                            }
                            iframe.style.display = 'block';
                        });
                    }
                }
                iframe.src = url;
            }
        }

        $(document).ready(function() {
            // Deactivate active tabs and hide other panes across columns when a tab is clicked
            $('#ct-tabs .nav-link').on('click', function() {
                // Remove active class from all other tab buttons
                $('#ct-tabs .nav-link').not(this).removeClass('active').attr('aria-selected', 'false');
                
                // Hide all other tab content panes
                var targetPaneId = $(this).attr('data-bs-target');
                $('#ct-tabsContent .tab-pane').not(targetPaneId).removeClass('show active');
            });

            var urlParams = new URLSearchParams(window.location.search);
            var activeTab = urlParams.get('tab');
            if (activeTab) {
                var btn = $('#tab-' + activeTab + '-btn');
                if (btn.length) {
                    btn.trigger('click');
                }
            }
        });
    </script>
