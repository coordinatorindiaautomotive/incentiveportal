                            <input type="number" step="0.01" class="form-control" name="RateWithPan" id="tdsRateWithPan" placeholder="5" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Rate No PAN (%)</label>
                            <input type="number" step="0.01" class="form-control" name="RateNoPan" id="tdsRateNoPan" placeholder="20" required />
