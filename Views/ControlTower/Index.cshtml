@using System.Text.Json
@{
    ViewData["Title"] = "Control Tower Console";
    var portalSettings = ViewBag.PortalSettings as Dictionary<string, string> ?? new();
    var tdsRules = ViewBag.TdsRules as List<IncentivePortal.Models.TdsRule> ?? new();
    var columnMappings = ViewBag.ColumnMappings as List<IncentivePortal.Models.ColumnMappingRule> ?? new();
    var outstandingRules = ViewBag.OutstandingRules as List<IncentivePortal.Models.OutstandingRule> ?? new();
    var notificationSetting = ViewBag.NotificationSetting as IncentivePortal.Models.NotificationSetting ?? new();
    var tallySetting = ViewBag.TallySetting as IncentivePortal.Models.TallyIntegrationSetting ?? new();
    var rolePermissions = ViewBag.RolePermissions as List<IncentivePortal.Models.RolePermission> ?? new();
    var auditLogs = ViewBag.AuditLogs as List<IncentivePortal.Models.AuditLog> ?? new();
    var helpTexts = ViewBag.HelpTexts as List<IncentivePortal.Models.HelpText> ?? new();
    var reportColumns = ViewBag.ReportColumns as List<IncentivePortal.Models.ReportColumnConfig> ?? new();

    var modules = ViewBag.ModulesList as string[] ?? Array.Empty<string>();
    var actions = ViewBag.ActionsList as string[] ?? Array.Empty<string>();
    var roles = ViewBag.RolesList as string[] ?? Array.Empty<string>();

    string GetSetting(string key, string fallback = "")
        => portalSettings.TryGetValue(key, out var val) ? val : fallback;
}

<style>
    /* Responsive Iframe heights inside tab panes to prevent small viewport scroll traps */
    .tab-content iframe {
        width: 100% !important;
        height: calc(100vh - 220px) !important;
        border: none !important;
        border-radius: 12px !important;
    }
    @@media (max-width: 768px) {
        .tab-content iframe {
            height: 600px !important;
        }
    }

    /* ── Settings Tab Navigation ── */
    #ct-tabs .nav-link {
        background: transparent !important;
        border: 1px solid transparent !important;
        color: #44474e !important;
        border-radius: 6px !important;
        font-family: 'Inter', sans-serif !important;
        font-weight: 700 !important;
        font-size: 11.5px !important;
        padding: 8px 12px !important;
        margin-bottom: 2px !important;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1) !important;
        text-align: left !important;
        display: flex !important;
        align-items: center !important;
        gap: 8px !important;
        border-left: 3px solid transparent !important;
    }

    #ct-tabs .nav-link:hover {
        background-color: rgba(0, 89, 187, 0.03) !important;
        color: #0059bb !important;
    }

    #ct-tabs .nav-link.active {
        background-color: rgba(0, 89, 187, 0.06) !important;
        color: #0059bb !important;
        border-left: 3px solid #0059bb !important;
        box-shadow: none !important;
    }

    /* Column Category Divider */
    #ct-tabs .border-bottom {
        border-bottom: 1px solid rgba(196, 198, 207, 0.3) !important;
        color: #74777f !important;
        font-family: 'Inter', sans-serif !important;
        font-weight: 700 !important;
        font-size: 10px !important;
        letter-spacing: 0.08em !important;
        padding-bottom: 6px !important;
        margin-top: 12px !important;
        margin-bottom: 8px !important;
    }

    /* ── Toggle Switch Custom Styling ── */
    .form-switch .form-check-input {
        width: 2.8em !important;
        height: 1.5em !important;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='%23a1a8c0'/%3e%3c/svg%3e") !important;
        background-color: #e2e8f0 !important;
        border-color: rgba(196, 198, 207, 0.6) !important;
        border-radius: 2em !important;
        transition: background-position 0.15s ease-in-out, background-color 0.15s ease-in-out, border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out !important;
        cursor: pointer !important;
    }

    .form-switch .form-check-input:focus {
        box-shadow: 0 0 0 3px rgba(0, 89, 187, 0.08) !important;
        border-color: rgba(0, 89, 187, 0.4) !important;
        outline: none !important;
    }

    .form-switch .form-check-input:checked {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='%23ffffff'/%3e%3c/svg%3e") !important;
        background-color: #0059bb !important;
        border-color: #0059bb !important;
    }

    /* ── Tab Card Overrides ── */
    .tab-content .card {
        border-radius: 12px !important;
        border: 1px solid rgba(196, 198, 207, 0.4) !important;
        background-color: #ffffff !important;
        box-shadow: 0 4px 10px rgba(11, 28, 48, 0.02) !important;
        padding: 24px !important;
    }

    /* Table override inside console */
    .tab-content table thead th {
        background: linear-gradient(135deg, #0b1c30 0%, #002244 100%) !important;
        color: #ffffff !important;
        font-family: 'Inter', sans-serif !important;
        font-size: 11px !important;
        font-weight: 700 !important;
        border-bottom: 2px solid #0059bb !important;
    }
</style>

<div class="container-fluid py-4" style="">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 16px; background: linear-gradient(135deg, var(--panel) 0%, rgba(255, 255, 255, 0.95) 100%);">
                <div class="d-flex align-items-center gap-3">
                    <div style="background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; width: 56px; height: 56px; box-shadow: 0 4px 15px rgba(30, 64, 175, 0.3);">
                        <i class="fa-solid fa-tower-control-tower text-white fa-xl"></i>
                    </div>
                    <div>
                        <h2 class="h4 fw-bold mb-1" style="color: var(--ink); letter-spacing: -0.5px;">Control Tower Console</h2>
                        <p class="text-secondary small mb-0">Configure site branding, TDS calculations, columns mappings, outstanding adjustments, notifications, and access matrix. Zero code updates needed.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs Menu organized in 4 Columns side-by-side at the top -->
    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
        <div class="row" id="ct-tabs" role="tablist">
            <!-- Column 1: Core Configurations -->
            <div class="col-md-3 mb-3">
                <div class="px-3 py-2 text-uppercase fw-bold text-muted small border-bottom mb-2" style="font-size:0.7rem; letter-spacing:0.5px;">Core Configurations</div>
                <div class="nav flex-column nav-pills" role="tablist" aria-orientation="vertical">
                    <button class="nav-link active text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-portal-btn" data-bs-toggle="pill" data-bs-target="#tab-portal" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-palette text-secondary" style="width:16px;"></i> Portal Settings
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-tds-btn" data-bs-toggle="pill" data-bs-target="#tab-tds" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-percent text-secondary" style="width:16px;"></i> TDS Rules
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-mapping-btn" data-bs-toggle="pill" data-bs-target="#tab-mapping" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-table-columns text-secondary" style="width:16px;"></i> Column Mapping
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-outstanding-btn" data-bs-toggle="pill" data-bs-target="#tab-outstanding" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-scale-balanced text-secondary" style="width:16px;"></i> Outstanding Rules
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-notifications-btn" data-bs-toggle="pill" data-bs-target="#tab-notifications" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-envelope-open-text text-secondary" style="width:16px;"></i> Notifications Settings
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-permissions-btn" data-bs-toggle="pill" data-bs-target="#tab-permissions" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-user-lock text-secondary" style="width:16px;"></i> Role Permissions
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-tally-btn" data-bs-toggle="pill" data-bs-target="#tab-tally" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-file-invoice text-secondary" style="width:16px;"></i> Tally Integration
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-reports-btn" data-bs-toggle="pill" data-bs-target="#tab-reports" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-file-excel text-secondary" style="width:16px;"></i> Report Columns
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-help-btn" data-bs-toggle="pill" data-bs-target="#tab-help" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-circle-question text-secondary" style="width:16px;"></i> Help Tooltips
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-audit-btn" data-bs-toggle="pill" data-bs-target="#tab-audit" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;">
                        <i class="fa-solid fa-history text-secondary" style="width:16px;"></i> Audit Logs
                    </button>
                </div>
            </div>

            <!-- Column 2: Master Registries -->
            <div class="col-md-3 mb-3">
                <div class="px-3 py-2 text-uppercase fw-bold text-muted small border-bottom mb-2" style="font-size:0.7rem; letter-spacing:0.5px;">Master Registries</div>
                <div class="nav flex-column nav-pills" role="tablist" aria-orientation="vertical">
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-branches-btn" data-bs-toggle="pill" data-bs-target="#tab-branches" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('branches-iframe', '/Branches?embed=true')">
                        <i class="fa-solid fa-sitemap text-secondary" style="width:16px;"></i> Branches Registry
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-parties-btn" data-bs-toggle="pill" data-bs-target="#tab-parties" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('parties-iframe', '/Parties?embed=true')">
                        <i class="fa-solid fa-users text-secondary" style="width:16px;"></i> Parties Master
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-bankmaster-btn" data-bs-toggle="pill" data-bs-target="#tab-bankmaster" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('bankmaster-iframe', '/Parties/BankDetails?embed=true')">
                        <i class="fa-solid fa-credit-card text-secondary" style="width:16px;"></i> Bank Details Master
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-altcodes-btn" data-bs-toggle="pill" data-bs-target="#tab-altcodes" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('altcodes-iframe', '/Parties/AlternateMappings?embed=true')">
                        <i class="fa-solid fa-code-compare text-secondary" style="width:16px;"></i> Alternate Codes
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-partymappings-btn" data-bs-toggle="pill" data-bs-target="#tab-partymappings" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('partymappings-iframe', '/ControlTower/PartyCodeMappings?embed=true')">
                        <i class="fa-solid fa-code-merge text-secondary" style="width:16px;"></i> Party Mappings (Gov)
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-schemes-btn" data-bs-toggle="pill" data-bs-target="#tab-schemes" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('schemes-iframe', '/Schemes?embed=true')">
                        <i class="fa-solid fa-layer-group text-secondary" style="width:16px;"></i> Slab Master (Schemes)
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-formula-btn" data-bs-toggle="pill" data-bs-target="#tab-formula" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('formula-iframe', '/ControlTower/FormulaBuilder?embed=true')">
                        <i class="fa-solid fa-calculator text-secondary" style="width:16px;"></i> Formula Builder
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-mapping-executive-btn" data-bs-toggle="pill" data-bs-target="#tab-mapping-executive" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('mapping-executive-iframe', '/PartyExecutive?embed=true')">
                        <i class="fa-solid fa-people-arrows text-secondary" style="width:16px;"></i> Executive Mapping
                    </button>
                </div>
            </div>

            <!-- Column 3: Data Processing -->
            <div class="col-md-3 mb-3">
                <div class="px-3 py-2 text-uppercase fw-bold text-muted small border-bottom mb-2" style="font-size:0.7rem; letter-spacing:0.5px;">Data & Uploads</div>
                <div class="nav flex-column nav-pills" role="tablist" aria-orientation="vertical">
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-upload-btn" data-bs-toggle="pill" data-bs-target="#tab-upload" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('upload-iframe', '/UploadManagement?embed=true&v=' + new Date().getTime())">
                        <i class="fa-solid fa-cloud-arrow-up text-secondary" style="width:16px;"></i> Upload Console
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-calcengine-btn" data-bs-toggle="pill" data-bs-target="#tab-calcengine" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('calcengine-iframe', '/Imports/MonthlySales?tab=engine&embed=true&v=' + new Date().getTime())">
                        <i class="fa-solid fa-gears text-secondary" style="width:16px;"></i> Calculation Engine
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-datamanager-btn" data-bs-toggle="pill" data-bs-target="#tab-datamanager" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('datamanager-iframe', '/DataManagement?embed=true')">
                        <i class="fa-solid fa-database text-secondary" style="width:16px;"></i> Data Manager
                    </button>
                </div>
            </div>

            <!-- Column 4: Administration -->
            <div class="col-md-3 mb-3">
                <div class="px-3 py-2 text-uppercase fw-bold text-muted small border-bottom mb-2" style="font-size:0.7rem; letter-spacing:0.5px;">Administration</div>
                <div class="nav flex-column nav-pills" role="tablist" aria-orientation="vertical">
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-users-btn" data-bs-toggle="pill" data-bs-target="#tab-users" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('users-iframe', '/Users?embed=true')">
                        <i class="fa-solid fa-shield-halved text-secondary" style="width:16px;"></i> User Management
                    </button>
                    <button class="nav-link text-start py-2 px-3 mb-1 d-flex align-items-center gap-2 border-0" id="tab-announcements-btn" data-bs-toggle="pill" data-bs-target="#tab-announcements" type="button" role="tab" style="border-radius: 8px; font-weight: 550; font-size: 0.84rem;" onclick="loadIframeTab('announcements-iframe', '/Announcements?embed=true')">
                        <i class="fa-solid fa-bullhorn text-secondary" style="width:16px;"></i> Announcements
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Contents Panels -->
    <div class="row">
        <div class="col-12">
            <div class="tab-content" id="ct-tabsContent">
                
                <!-- 1. PORTAL SETTINGS -->
                <div class="tab-pane fade show active" id="tab-portal" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
                        <h4 class="fw-bold mb-3" style="color: var(--ink);">Portal Branding Settings</h4>
                        
                        <form id="portalSettingsForm" method="post" asp-action="SavePortalSettings">
                            @Html.AntiForgeryToken()
                            <div class="row">
                                <div class="col-md-7 mb-4">
                                    <div class="row mb-3">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label small fw-bold">Brand Color</label>
                                            <input type="color" class="form-control form-control-color w-100 border-0 p-1" style="height:44px; border-radius:8px;" name="settings[--brand]" id="brandColor" value="@GetSetting("--brand", "var(--primary)")" />
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label small fw-bold">Brand Dark Mode Color</label>
                                            <input type="color" class="form-control form-control-color w-100 border-0 p-1" style="height:44px; border-radius:8px;" name="settings[--brand-dark]" id="brandDarkColor" value="@GetSetting("--brand-dark", "var(--primary)")" />
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label small fw-bold">Canvas Background</label>
                                            <input type="color" class="form-control form-control-color w-100 border-0 p-1" style="height:44px; border-radius:8px;" name="settings[--canvas]" id="canvasColor" value="@GetSetting("--canvas", "#f8fafc")" />
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label small fw-bold">Panel Background</label>
                                            <input type="color" class="form-control form-control-color w-100 border-0 p-1" style="height:44px; border-radius:8px;" name="settings[--panel]" id="panelColor" value="@GetSetting("--panel", "#ffffff")" />
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label small fw-bold">Ink Color (Text)</label>
                                            <input type="color" class="form-control form-control-color w-100 border-0 p-1" style="height:44px; border-radius:8px;" name="settings[--ink]" id="inkColor" value="@GetSetting("--ink", "#1e293b")" />
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label small fw-bold">Line color</label>
                                            <input type="color" class="form-control form-control-color w-100 border-0 p-1" style="height:44px; border-radius:8px;" name="settings[--line]" id="lineColor" value="@GetSetting("--line", "#e2e8f0")" />
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">Company Display Name</label>
                                        <input type="text" class="form-control" name="settings[company_name]" id="companyNameInput" value="@GetSetting("company_name", "ThessBuddy")" placeholder="ThessBuddy" style="padding-left:15px;" />
                                    </div>
                                    <button type="submit" class="btn btn-primary px-4 py-2 mt-3" style="background: var(--brand); border: 0; border-radius: 8px; font-weight:600;"><i class="fa-solid fa-save me-1"></i> Save Changes</button>
                                </div>
                                
                                <!-- Live CSS Variable Preview Card -->
                                <div class="col-md-5 mb-4">
                                    <label class="form-label small fw-bold d-block mb-3">Style Live Preview</label>
                                    <div class="live-preview-card p-4 border border-secondary shadow-sm w-100" style="border-radius:12px; background:var(--canvas); --brand: @GetSetting("--brand", "var(--primary)"); --canvas: @GetSetting("--canvas", "#f8fafc"); --panel: @GetSetting("--panel", "#ffffff"); --ink: @GetSetting("--ink", "#1e293b"); --line: @GetSetting("--line", "#e2e8f0"); transition: all 0.25s;">
                                        <div class="card p-3 border-0 shadow-sm mb-3" style="border-radius: 10px; background:var(--panel);">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                <div style="background:var(--brand); border-radius: 6px; width: 28px; height: 28px; display:flex; align-items:center; justify-content:center;">
                                                    <span class="text-white fw-bold small" id="companyLogoPreview">a</span>
                                                </div>
                                                <span style="font-weight:700; color:var(--ink); font-size:1.05rem;" id="companyNamePreview">@GetSetting("company_name", "ThessBuddy")</span>
                                            </div>
                                            <div style="height: 1px; background: var(--line);" class="my-2"></div>
                                            <span style="font-size: 0.72rem; text-transform:uppercase; color:var(--ink); font-weight:700;">Dashboard Widget</span>
                                            <div class="mt-2 d-flex justify-content-between">
                                                <span class="small" style="color:var(--ink); opacity:0.75;">Gross Incentive</span>
                                                <span class="fw-bold" style="color:var(--brand);">₹150,000</span>
                                            </div>
                                        </div>
                                        <span class="text-secondary small d-block text-center mt-2">Outputs CSS variables directly to the root shell</span>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- 2. TDS RULES -->
                <div class="tab-pane fade" id="tab-tds" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="fw-bold mb-0" style="color: var(--ink);">TDS Slab Configurations</h4>
                            <button class="btn btn-sm btn-primary px-3 py-2 border-0" style="background: var(--brand); border-radius:8px;" onclick="showTdsModal()"><i class="fa-solid fa-plus me-1"></i> Add Rule</button>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle" style="font-size:0.88rem;">
                                <thead>
                                    <tr class="text-secondary fw-semibold">
                                        <th>Section</th>
                                        <th>Date Range</th>
                                        <th>Annual Threshold</th>
                                        <th>With PAN %</th>
                                        <th>No PAN %</th>
                                        <th>Notes</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in tdsRules)
                                    {
                                        <tr>
                                            <td class="fw-bold">@r.Section</td>
                                            <td>@r.EffectiveFrom.ToString("dd MMM yyyy") - @r.EffectiveTo.ToString("dd MMM yyyy")</td>
                                            <td class="fw-bold text-success">₹@r.AnnualThreshold.ToString("N0")</td>
                                            <td class="fw-bold">@(r.RateWithPan * 100)%</td>
                                            <td class="fw-bold text-danger">@(r.RateNoPan * 100)%</td>
                                            <td>@r.Notes</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-light border-0 me-1" onclick="editTdsRule(@JsonSerializer.Serialize(r))" title="Edit"><i class="fa-solid fa-edit text-secondary"></i></button>
                                                <button class="btn btn-sm btn-light border-0" onclick="deleteTdsRule(@r.Id, '@r.Section')" title="Delete"><i class="fa-solid fa-trash text-danger"></i></button>
                                            </td>
                                        </tr>
                                    }
                                    @if (!tdsRules.Any())
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">No TDS rules configured. Falling back to default system rates (10% with PAN / 20% without PAN).</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 3. COLUMN MAPPINGS -->
                <div class="tab-pane fade" id="tab-mapping" role="tabpanel">
                    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; background: var(--panel);">
