        function triggerTestEmail() {
            Swal.fire({
                title: 'Test SMTP settings',
                text: 'Enter the destination email address to dispatch the test email:',
                input: 'email',
                inputPlaceholder: 'recipient@company.local',
                showCancelButton: true,
                confirmButtonText: 'Send Test Mail',
                confirmButtonColor: 'var(--brand, var(--primary))',
                showLoaderOnConfirm: true,
                preConfirm: (email) => {
                    var form = $('#notificationSettingsForm');
                    var data = {
                        host: form.find('input[name="SmtpHost"]').val(),
                        port: form.find('input[name="SmtpPort"]').val(),
                        useSsl: form.find('input[name="SmtpUseSsl"]').is(':checked'),
                        user: form.find('input[name="SmtpUser"]').val(),
                        password: form.find('input[name="smtpPassword"]').val(),
                        fromEmail: form.find('input[name="FromEmail"]').val(),
                        fromName: form.find('input[name="FromName"]').val(),
                        testEmail: email,
                        __RequestVerificationToken: form.find('input[name="__RequestVerificationToken"]').val()
                    };

                    return $.post('/ControlTower/TestSmtpSettings', data)
                        .fail(function(err) {
                            var msg = err.responseJSON ? err.responseJSON.message : 'Email dispatch failed.';
                            Swal.showValidationMessage(`SMTP Error: ${msg}`);
                        });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire('Dispatched!', 'Test email dispatched successfully.', 'success');
                }
            });
        }

