                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" style="background:var(--brand); border:0;">Save Rule</button>
                </div>
            </form>
        </div>
    </div>
</div>

