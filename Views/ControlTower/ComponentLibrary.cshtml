<!-- Google Material Symbols & Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

<style>
    /* ── Dev Showcase Layout ── */
    .showcase-header {
        background: linear-gradient(135deg, #0b1c30 0%, #002244 100%) !important;
        border-bottom: 2px solid #0059bb !important;
        border-radius: 12px !important;
        color: #ffffff !important;
        padding: 24px 30px !important;
        margin-bottom: 24px !important;
        box-shadow: 0 4px 15px rgba(0, 89, 187, 0.1) !important;
    }
    
    .showcase-section {
        background: #ffffff !important;
        border: 1px solid rgba(196, 198, 207, 0.4) !important;
        border-radius: 12px !important;
        box-shadow: 0 4px 10px rgba(11, 28, 48, 0.02) !important;
        padding: 24px !important;
        margin-bottom: 24px !important;
    }

    .section-title {
        font-family: 'Inter', sans-serif !important;
        font-weight: 700 !important;
        color: #0b1c30 !important;
        border-bottom: 1px solid rgba(196, 198, 207, 0.3) !important;
        padding-bottom: 8px !important;
        margin-bottom: 20px !important;
        font-size: 1.15rem !important;
        display: flex !important;
        align-items: center !important;
        gap: 8px !important;
    }

    /* ── Token Grid ── */
    .token-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 16px;
    }
    .token-card {
        border: 1px solid rgba(196, 198, 207, 0.3);
        border-radius: 8px;
        padding: 12px;
        background: #f8f9ff;
    }
    .token-color-swatch {
        height: 48px;
        border-radius: 6px;
        margin-bottom: 8px;
        border: 1px solid rgba(0,0,0,0.05);
    }

    /* ── Dev Spec Badge ── */
    .dev-spec {
        font-family: monospace;
        font-size: 10px;
        color: #0059bb;
        background: rgba(0, 89, 187, 0.05);
        padding: 4px 8px;
        border-radius: 4px;
        margin-top: 8px;
        display: inline-block;
    }

    /* ── Code box ── */
    .code-box {
        background: #0f172a;
        color: #e2e8f0;
        font-family: 'Fira Code', monospace;
        font-size: 11px;
        padding: 12px;
        border-radius: 6px;
        max-height: 180px;
        overflow-y: auto;
        margin-top: 12px;
    }

    /* ── Custom UI Sandbox Components ── */
    
    /* Tags / Chips */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 100px;
        background: rgba(0, 89, 187, 0.05);
        border: 1px solid rgba(0, 89, 187, 0.12);
        color: #0059bb;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
    }
    .chip i {
        font-size: 10px;
        opacity: 0.7;
    }
    .chip:hover {
        background: rgba(0, 89, 187, 0.08);
    }

    /* Accordion */
    .styleguide-accordion {
        border: 1px solid rgba(196, 198, 207, 0.4);
        border-radius: 8px;
        overflow: hidden;
    }
    .accordion-item-head {
        background: #f8f9ff;
        padding: 12px 16px;
        font-weight: 700;
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(196, 198, 207, 0.3);
    }
    .accordion-item-body {
        padding: 16px;
        font-size: 12px;
        color: #44474e;
        display: none;
    }

    /* Progress Circle */
    .progress-ring {
        position: relative;
        width: 48px;
        height: 48px;
    }
    .progress-ring-svg {
        transform: rotate(-90deg);
        width: 100%;
        height: 100%;
    }
    .progress-ring-svg circle {
        fill: transparent;
        stroke-width: 4;
    }
    .progress-ring-svg .bg {
        stroke: #e2e8f0;
    }
    .progress-ring-svg .bar {
        stroke: #0059bb;
        stroke-dasharray: 125.6; /* 2 * pi * 20 */
        stroke-dashoffset: 37.6; /* 30% progress left */
        stroke-linecap: round;
        transition: stroke-dashoffset 0.35s;
    }

    /* Custom Switch Wrapper */
    .custom-tooltip {
        position: relative;
        display: inline-block;
        cursor: pointer;
    }
    .custom-tooltip .tooltiptext {
        visibility: hidden;
        width: 120px;
        background-color: #0b1c30;
        color: #fff;
        text-align: center;
        border-radius: 6px;
        padding: 5px 8px;
        position: absolute;
        z-index: 1;
        bottom: 125%; /* Position above tooltip trigger */
        left: 50%;
        margin-left: -60px;
        opacity: 0;
        transition: opacity 0.2s;
        font-size: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }
    .custom-tooltip:hover .tooltiptext {
        visibility: visible;
        opacity: 1;
    }
</style>

<div class="container-fluid py-4">
