<form method="post" id="actionForm" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="actionId" name="id">
    <input type="hidden" id="actionStatus" name="newStatus">
    <input type="hidden" name="remarks" value="">
</form>

@section Scripts {
<script>
    // Fetch and display Period Lock Status
    document.addEventListener("DOMContentLoaded", function () {
        fetch('/CashManagement/PeriodStatus')
            .then(response => response.json())
            .then(data => {
                if (data.isLocked) {
                    const banner = document.getElementById('period-locked-banner');
                    if (banner) banner.style.display = 'block';
                }
            })
            .catch(err => console.error("Error fetching period status:", err));
    });

    // Tab persistence script
    const activeTabKey = 'cashbookActiveTab';
    const tabElList = document.querySelectorAll('button[data-bs-toggle="pill"]');
    tabElList.forEach(tabEl => {
        tabEl.addEventListener('shown.bs.tab', event => {
            localStorage.setItem(activeTabKey, event.target.id);
        });
    });
    
    const savedActiveTabId = localStorage.getItem(activeTabKey);
    if (savedActiveTabId) {
        const savedTab = document.getElementById(savedActiveTabId);
        if (savedTab) {
            new bootstrap.Tab(savedTab).show();
        }
    }

    // Toggle format views for Ledger Book
    function toggleLedgerView(view) {
        const tAccountDiv = document.getElementById('taccount-ledger-container');
        const chronoDiv = document.getElementById('chrono-ledger-container');
        const btnT = document.getElementById('btnShowTAccount');
        const btnC = document.getElementById('btnShowChrono');

        if (view === 'taccount') {
