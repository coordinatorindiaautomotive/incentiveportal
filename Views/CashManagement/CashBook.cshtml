            const rows = document.querySelectorAll('#cashInRowsContainer .cashin-row-item');
            let total = 0;
            rows.forEach(row => {
                const amtInput = row.querySelector('[name="Amount"]');
                if (amtInput) {
                    const val = parseFloat(amtInput.value);
                    if (!isNaN(val) && val > 0) {
                        total += val;
                    }
                }
            });
            const badge = document.getElementById('cashInRunningTotalBadge');
            if (badge) {
                badge.textContent = 'Total: ₹' + total.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }
        }

        function calculateRunningSumForRow(rowId) {
            const dateVal = dateInput.value;
            const hiddenDealer = document.getElementById(`hidden-dealer-${rowId}`);
            if (!hiddenDealer) return;
            const dealerCodeVal = hiddenDealer.value;
            
            const alertDiv = document.getElementById(`running-sum-alert-${rowId}`);
            const alertText = document.getElementById(`running-sum-text-${rowId}`);
            
            if (dateVal && dealerCodeVal) {
                let sum = 0;
                rawIns.forEach(tx => {
                    if (tx.status !== 'Rejected' && tx.status !== 'Draft') {
                        if (tx.date === dateVal && tx.dealerCode && tx.dealerCode.toLowerCase() === dealerCodeVal.toLowerCase()) {
                            sum += tx.amount;
                        }
                    }
                });
                
                if (alertText) {
                    alertText.innerHTML = `Total already received for <strong>${dealerCodeVal}</strong> on selected date: <strong>₹${sum.toLocaleString('en-IN')}</strong>`;
                }
                if (alertDiv) alertDiv.classList.remove('d-none');
