                                <div style="font-size:0.68rem; color:#64748b; margin-top:8px; border-top: 1px dashed #e2e8f0; padding-top:6px;" class="italic">
                                    Note: Entered breakdown amounts will automatically sum into the main transaction Amount field.
                                </div>
                            </div>
                        </div>

                        <!-- DMS Validation Box Container (Initially Hidden) -->
                        <div class="col-md-12 d-none" id="dmsSaleContainer">
                            <div style="background: rgba(99,102,241,.05); border: 1.5px dashed #6366f1; border-radius: 8px; padding: 14px 18px;">
                                <label class="form-label fw-bold text-indigo mb-1" style="font-size:.82rem;">
                                    <i class="fa-solid fa-server me-1"></i> Total Sale from Server (To Validate)
                                </label>
                                <input type="text" class="form-control" value="₹0 (Will be fetched from server)" disabled style="background:#fff; border: 1px solid #cbd5e1; border-radius: 6px; font-weight:700; color:#475569;">
                                <div style="font-size:.7rem; color:#64748b; margin-top:4px;" class="italic">
                                    Note: Validation criteria will be implemented in the next phase.
                                </div>
