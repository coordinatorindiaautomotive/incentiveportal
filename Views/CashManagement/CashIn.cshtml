<!-- Hidden forms for approve/reject -->
<form method="post" id="actionForm" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="actionId" name="id">
    <input type="hidden" id="actionStatus" name="newStatus">
    <input type="hidden" name="remarks" value="">
</form>

@section Scripts {
<script>
const WORKFLOW_STEPS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(CashTxStatus.Workflow));

function filterTable(val, tbodyId) {
    document.querySelectorAll('#' + tbodyId + ' tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(val.toLowerCase()) ? '' : 'none';
    });
}

function viewCashIn(id, txNo, branch, date, type, customer, dealer, amount, mode, bank, txRef, txStatus, tally, narration) {
    document.getElementById('viewModalTitle').innerHTML = `<i class="fa-solid fa-arrow-circle-down me-2" style="color:#22c55e;"></i>${txNo}`;
    const fields = [
        ['Transaction ID', `<code style="color:#6366f1;font-weight:700;">${txNo}</code>`],
        ['Branch', branch], ['Date', date], ['Receipt Type', type],
        ['Customer / Party', customer], ['Dealer Code', dealer || '—'],
        ['Amount', `<strong style="color:#22c55e;font-size:1.1rem;">${amount}</strong>`],
        ['Payment Mode', `<span style="background:rgba(59,130,246,.1);color:#3b82f6;padding:2px 10px;border-radius:20px;font-size:.8rem;font-weight:600;">${mode}</span>`],
        ['Bank', bank || '—'], ['Reference No.', txRef],
        ['Status', `<span class="cash-badge badge-${txStatus.toLowerCase()}">${txStatus}</span>`],
        ['Tally Voucher', tally !== '—' ? `<span class="tally-chip">${tally}</span>` : '<span style="color:#cbd5e1;">Not Posted</span>'],
        ['Narration', narration || '—']
    ];
    const activeIdx = WORKFLOW_STEPS.indexOf(txStatus);
    const workflowHtml = WORKFLOW_STEPS.map((step, i) => {
        const isActive = i === activeIdx;
        const isDone = activeIdx > i;
        const bg = isActive ? 'var(--primary)' : isDone ? 'rgba(34,197,94,.15)' : '#f1f5f9';
        const color = isActive ? '#fff' : isDone ? '#16a34a' : '#94a3b8';
        return `<span style="padding:4px 10px;border-radius:20px;font-size:.72rem;font-weight:700;background:${bg};color:${color};">${step}</span>${i < WORKFLOW_STEPS.length - 1 ? '<i class="fa-solid fa-chevron-right" style="font-size:8px;color:#cbd5e1;margin:0 2px;"></i>' : ''}`;
    }).join('');
    document.getElementById('viewModalBody').innerHTML = `
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            ${fields.map(([k, v]) => `
            <div style="background:#f8fafc;border-radius:8px;padding:12px;">
                <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;color:#94a3b8;letter-spacing:.5px;margin-bottom:4px;">${k}</div>
                <div style="font-size:.86rem;font-weight:600;color:#1e293b;">${v}</div>
            </div>`).join('')}
        </div>
        <div style="margin-top:16px;background:#fff3cd;border:1px solid #ffc10733;border-radius:8px;padding:12px 16px;">
            <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;color:#856404;margin-bottom:8px;"><i class="fa-solid fa-diagram-next me-1"></i>Workflow Progress</div>
            <div style="display:flex;align-items:center;gap:4px;flex-wrap:wrap;">${workflowHtml}</div>
        </div>`;
    new bootstrap.Modal(document.getElementById('viewModal')).show();
}

function quickAction(url, id, txStatus, message) {
    Swal.fire({
        title: message, icon: 'question', showCancelButton: true,
        confirmButtonText: 'Yes, proceed', cancelButtonText: 'Cancel',
        confirmButtonColor: 'var(--primary)', cancelButtonColor: '#6c757d'
    }).then(result => {
        if (result.isConfirmed) {
            const form = document.getElementById('actionForm');
            form.action = url;
            document.getElementById('actionId').value = id;
            document.getElementById('actionStatus').value = txStatus;
            form.submit();
        }
    });
}

// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// DYNAMIC MODAL LOGIC (DMS PAYMENT BREAKDOWN & SEARCHABLE DROPDOWNS)
// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
const rawIns = [
    @if (Model != null)
    {
        @foreach (var tx in Model)
        {
            <text>{ id: @tx.Id, refNo: '@tx.TransactionNo', date: '@tx.TransactionDate.ToString("yyyy-MM-dd")', type: '@tx.ReceiptType', amount: @tx.Amount, status: '@tx.Status', customer: '@tx.CustomerName.Replace("'", "\\'")', dealerCode: '@(tx.DealerCode?.Replace("'", "\\'") ?? "")', mode: '@tx.PaymentMode', bank: '@(tx.BankName?.Replace("'", "\\'") ?? "")', txRef: '@(tx.ReferenceNo?.Replace("'", "\\'") ?? "")', narration: '@(tx.Narration?.Replace("'", "\\'") ?? "")', tally: '@(tx.TallyVoucherNo ?? "—")' },</text>
        }
    }
];

document.addEventListener("DOMContentLoaded", function() {
    const cashInModal = document.getElementById('cashInModal');
    if (!cashInModal) return;

    const receiptTypeSelect = document.getElementById('cashInReceiptType');
    const dealerDropdownContainer = document.getElementById('dealerCodeDropdownContainer');
    const dealerInputContainer = document.getElementById('dealerCodeInputContainer');
    const dealerInput = document.getElementById('cashInDealerCodeInput');
    const dealerHidden = document.getElementById('cashInDealerCodeHidden');
    const customerNameInput = document.getElementById('cashInCustomerNameInput');
    const customerNameContainer = document.getElementById('customerNameContainer');
    const bankNameContainer = document.getElementById('bankNameContainer');
    const referenceNoContainer = document.getElementById('referenceNoContainer');
    const referenceNoInput = document.getElementById('cashInReferenceNoInput');
    const dmsSaleContainer = document.getElementById('dmsSaleContainer');
    const dmsPaymentBreakdownContainer = document.getElementById('dmsPaymentBreakdownContainer');
    const paymentModeContainer = document.getElementById('paymentModeContainer');
    const paymentModeSelect = document.getElementById('cashInPaymentMode');
    const amountInput = cashInModal.querySelector('[name="Amount"]');
    const dateInput = cashInModal.querySelector('[name="TransactionDate"]');
    const runningSumAlert = document.getElementById('runningSumAlertContainer');

    const dealerDropdownBtn = document.getElementById('cashInDealerDropdownBtn');
    const dealerSearch = document.getElementById('cashInDealerSearch');
    const dealerOptions = document.getElementById('cashInDealerOptions');
    const breakdownInputs = document.querySelectorAll('.dms-breakdown-input');

    const receiptNoContainer = document.getElementById('receiptNoContainer');
    const receiptNoInput = document.getElementById('cashInReceiptNoInput');
    const dmsPaymentBreakdownTitle = document.getElementById('dmsPaymentBreakdownTitle');

    function isAdvanceType(val) {
        return val && val.toLowerCase().includes('advance');
    }

    function isDmsCashType(val) {
        if (!val) return false;
        const cleaned = val.toLowerCase().replace(/[^a-z0-9]/g, '');
        return cleaned.includes('dms');
    }

    function isReceiptType(val) {
        if (!val) return false;
        return val.toLowerCase().trim() === 'receipt';
    }

    function handleReceiptTypeChange() {
        const val = receiptTypeSelect.value;
        
        // Reset input values initially
        dealerInput.value = '';
        dealerHidden.value = '';
        customerNameInput.value = '';
        customerNameInput.removeAttribute('readonly');
        if (dealerDropdownBtn) {
            const span = dealerDropdownBtn.querySelector('span');
            if (span) span.textContent = '-- Select Code --';
        }
        if (dealerSearch) dealerSearch.value = '';
        filterOptions('');
        resetBreakdown();
        
        dmsSaleContainer.classList.add('d-none');
        runningSumAlert.classList.add('d-none');
        dmsPaymentBreakdownContainer.classList.add('d-none');
        paymentModeContainer.classList.remove('d-none');
        if (paymentModeSelect) paymentModeSelect.setAttribute('required', 'required');

        // Default show fields and restore required attributes
        if (customerNameContainer) customerNameContainer.classList.remove('d-none');
        if (customerNameInput) customerNameInput.setAttribute('required', 'required');
        if (bankNameContainer) bankNameContainer.classList.remove('d-none');
        if (referenceNoContainer) referenceNoContainer.classList.remove('d-none');
        if (referenceNoInput) referenceNoInput.setAttribute('required', 'required');

        if (receiptNoContainer) receiptNoContainer.classList.add('d-none');
        if (receiptNoInput) {
            receiptNoInput.removeAttribute('required');
            receiptNoInput.removeAttribute('name');
            receiptNoInput.value = '';
        }
        if (referenceNoInput) referenceNoInput.setAttribute('name', 'ReferenceNo');
        if (dmsPaymentBreakdownTitle) dmsPaymentBreakdownTitle.textContent = 'DMS Sale Payment Mode Breakdown (₹)';

        if (isAdvanceType(val)) {
            // Advance: Show text input for Dealer Code, make select not required, hide warning sum
            dealerDropdownContainer.classList.add('d-none');
            dealerInputContainer.classList.remove('d-none');
        } else if (isDmsCashType(val)) {
            // DMS Cash: Hide Customer Code dropdown, Dealer Code manual input, Customer / Party Name, Bank Name, and Reference / UTR No.
            dealerDropdownContainer.classList.add('d-none');
            dealerInputContainer.classList.add('d-none');
            if (customerNameContainer) customerNameContainer.classList.add('d-none');
            if (bankNameContainer) bankNameContainer.classList.add('d-none');
            if (referenceNoContainer) referenceNoContainer.classList.add('d-none');
            
            dmsSaleContainer.classList.remove('d-none');

            // Remove required validations since these fields are NOT required for DMS Cash Sale
            if (customerNameInput) customerNameInput.removeAttribute('required');
            if (referenceNoInput) {
                referenceNoInput.removeAttribute('required');
                referenceNoInput.removeAttribute('name');
            }
            
            // Hide single Payment Mode dropdown, set to Multiple Modes, show multi-mode breakdown
            if (dmsPaymentBreakdownTitle) dmsPaymentBreakdownTitle.textContent = 'DMS Sale Payment Mode Breakdown (₹)';
            dmsPaymentBreakdownContainer.classList.remove('d-none');
            paymentModeContainer.classList.add('d-none');
            if (paymentModeSelect) {
                paymentModeSelect.removeAttribute('required');
                paymentModeSelect.value = 'Multiple Modes';
            }
        } else if (isReceiptType(val)) {
            // Receipts: Show dropdown for Customer Code selection, auto-load read-only Customer Name, show running sum
            dealerDropdownContainer.classList.remove('d-none');
            dealerInputContainer.classList.add('d-none');
            customerNameInput.setAttribute('readonly', 'readonly');

            // Hide Bank Name and Reference/UTR No.
            if (bankNameContainer) bankNameContainer.classList.add('d-none');
            if (referenceNoContainer) referenceNoContainer.classList.add('d-none');
            if (referenceNoInput) {
                referenceNoInput.removeAttribute('required');
                referenceNoInput.removeAttribute('name');
            }

            // Show Receipt No. and make required
            if (receiptNoContainer) receiptNoContainer.classList.remove('d-none');
            if (receiptNoInput) {
                receiptNoInput.setAttribute('name', 'ReferenceNo');
                receiptNoInput.setAttribute('required', 'required');
            }

            // Enable multi-mode breakdown for Receipts too!
            if (dmsPaymentBreakdownTitle) dmsPaymentBreakdownTitle.textContent = 'Receipt Payment Mode Breakdown (₹)';
            dmsPaymentBreakdownContainer.classList.remove('d-none');
            paymentModeContainer.classList.add('d-none');
            if (paymentModeSelect) {
                paymentModeSelect.removeAttribute('required');
                paymentModeSelect.value = 'Multiple Modes';
            }
        } else {
            // Receipts: Show dropdown for Customer Code selection, auto-load read-only Customer Name, show running sum
            dealerDropdownContainer.classList.remove('d-none');
            dealerInputContainer.classList.add('d-none');
            customerNameInput.setAttribute('readonly', 'readonly');
        }
    }

    function handleDealerOptionClick(e) {
        const btn = e.target.closest('.dropdown-item');
        if (!btn) return;

        const code = btn.getAttribute('data-value') || '';
        const name = btn.getAttribute('data-name') || '';

        // Update dropdown button text
        if (dealerDropdownBtn) {
            const span = dealerDropdownBtn.querySelector('span');
            if (span) span.textContent = code ? `${code} - ${name}` : '-- Select Code --';
        }

        dealerHidden.value = code;
        customerNameInput.value = name;
        
        calculateRunningSum();
    }

    function handleDealerInputChange() {
        dealerHidden.value = dealerInput.value;
    }

    function filterOptions(searchVal) {
        const items = dealerOptions.querySelectorAll('.dropdown-item');
        const search = searchVal.toLowerCase();
        items.forEach(item => {
            const text = item.textContent.toLowerCase();
            item.style.display = text.includes(search) ? 'flex' : 'none';
        });
    }

    function resetBreakdown() {
        breakdownInputs.forEach(input => input.value = '');
        if (amountInput) {
            amountInput.value = '';
            amountInput.removeAttribute('readonly');
        }
    }

    function updateSumFromBreakdown() {
        let total = 0;
        breakdownInputs.forEach(input => {
            total += parseFloat(input.value) || 0;
        });
        
        if (total > 0) {
            amountInput.value = total.toFixed(2);
            amountInput.setAttribute('readonly', 'readonly');
        } else {
            amountInput.value = '';
            amountInput.removeAttribute('readonly');
        }
    }

    function calculateRunningSum() {
        const dateVal = dateInput.value;
        const dealerCodeVal = dealerHidden.value;
        const rTypeVal = receiptTypeSelect.value;

        // Running sum is only displayed for Receipt types (not Advance or DMS Cash)
        if (dateVal && dealerCodeVal && !isAdvanceType(rTypeVal) && !isDmsCashType(rTypeVal)) {
            let sum = 0;
            rawIns.forEach(tx => {
                if (tx.status !== 'Rejected' && tx.status !== 'Draft') {
                    if (tx.date === dateVal && tx.dealerCode && tx.dealerCode.toLowerCase() === dealerCodeVal.toLowerCase()) {
                        sum += tx.amount;
                    }
                }
            });

            const alertText = document.getElementById('runningSumAlertText');
            if (alertText) {
                alertText.innerHTML = `Total already received for <strong>${dealerCodeVal}</strong> on selected date: <strong style="font-size:0.95rem; color:#15803d;">₹${sum.toLocaleString('en-IN')}</strong>`;
            }
            runningSumAlert.classList.remove('d-none');
        } else {
            runningSumAlert.classList.add('d-none');
        }
    }

    // Bind event listeners
    if (receiptTypeSelect) receiptTypeSelect.addEventListener('change', handleReceiptTypeChange);
    if (dealerOptions) dealerOptions.addEventListener('click', handleDealerOptionClick);
    if (dealerInput) dealerInput.addEventListener('input', handleDealerInputChange);
    if (dealerSearch) {
        dealerSearch.addEventListener('input', function(e) {
            filterOptions(e.target.value);
        });
    }
    if (dateInput) {
        dateInput.addEventListener('change', calculateRunningSum);
        dateInput.addEventListener('input', calculateRunningSum);
    }

    if (cashInModal) {
        cashInModal.addEventListener('show.bs.modal', function() {
            handleReceiptTypeChange();
        });
    }

    breakdownInputs.forEach(input => {
        input.addEventListener('input', updateSumFromBreakdown);
    });

    // Validate and Format Narration on submit
    const form = cashInModal.querySelector('form');
    if (form) {
        form.addEventListener('submit', function(e) {
            const val = receiptTypeSelect.value;
            if (!isAdvanceType(val) && !isDmsCashType(val) && !dealerHidden.value) {
                e.preventDefault();
                portalToast('Please select a Customer Code', 'error');
                return;
            }

            if (isDmsCashType(val) || isReceiptType(val)) {
                let total = 0;
                breakdownInputs.forEach(input => total += parseFloat(input.value) || 0);

                if (total <= 0) {
                    e.preventDefault();
                    const errorMsg = isReceiptType(val) 
                        ? 'Please enter breakdown amounts for Receipt' 
                        : 'Please enter breakdown amounts for DMS Cash Sale';
                    portalToast(errorMsg, 'error');
                    return;
                }

                // Format beautiful breakdown string inside narration
                const cash = parseFloat(document.getElementById('dmsAmtCash').value) || 0;
                const upi = parseFloat(document.getElementById('dmsAmtUpi').value) || 0;
                const card = parseFloat(document.getElementById('dmsAmtCard').value) || 0;
                const bank = parseFloat(document.getElementById('dmsAmtBank').value) || 0;
                const cheque = parseFloat(document.getElementById('dmsAmtCheque').value) || 0;

                let parts = [];
                if (cash > 0) parts.push(`Cash: ₹${cash.toLocaleString('en-IN')}`);
                if (upi > 0) parts.push(`UPI: ₹${upi.toLocaleString('en-IN')}`);
                if (card > 0) parts.push(`Card: ₹${card.toLocaleString('en-IN')}`);
                if (bank > 0) parts.push(`Bank Transfer: ₹${bank.toLocaleString('en-IN')}`);
                if (cheque > 0) parts.push(`Cheque: ₹${cheque.toLocaleString('en-IN')}`);

                const narrationTextarea = cashInModal.querySelector('[name="Narration"]');
                if (narrationTextarea) {
                    let base = narrationTextarea.value.split('\n---\n')[0];
                    const titleLabel = isReceiptType(val) ? 'Receipt Mode Breakdown' : 'DMS Sale Mode Breakdown';
                    narrationTextarea.value = base + '\n---\n' + `${titleLabel}: ` + parts.join(', ');
                }
            }
        });
    }

    // Initialize state
    if (receiptTypeSelect) handleReceiptTypeChange();
});

function checkTallyEntry(id, type, tallyStatus, currentVoucherNo = '') {
    if (tallyStatus === 'Correct') {
        Swal.fire({
            title: 'Verify with Tally',
            text: 'Please enter the Tally Voucher Number to mark this entry as correct:',
            input: 'text',
            inputValue: currentVoucherNo,
            inputPlaceholder: 'Tally Voucher No. (e.g. TLY-1234)',
            showCancelButton: true,
            confirmButtonText: 'Confirm & Verify',
            confirmButtonColor: '#22c55e',
            cancelButtonColor: '#6c757d'
        }).then(result => {
            if (result.isConfirmed) {
                const f = document.getElementById('tallyVerificationForm');
                document.getElementById('tallyVerifyId').value = id;
                document.getElementById('tallyVerifyType').value = type;
                document.getElementById('tallyVerifyStatus').value = tallyStatus;
                document.getElementById('tallyVerifyVoucherNo').value = result.value || '';
                document.getElementById('tallyVerifyRemarks').value = '';
                f.submit();
            }
        });
    } else {
        Swal.fire({
            title: 'Report Tally Discrepancy',
            text: 'Please describe the discrepancy or error details (required):',
            input: 'textarea',
            inputPlaceholder: 'e.g. Amount mismatch, reference incorrect in Tally...',
            inputValidator: (value) => {
                if (!value) {
                    return 'You must enter remarks for wrong entries!'
                }
            },
            showCancelButton: true,
            confirmButtonText: 'Report Discrepancy',
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6c757d'
        }).then(result => {
            if (result.isConfirmed) {
                const f = document.getElementById('tallyVerificationForm');
                document.getElementById('tallyVerifyId').value = id;
                document.getElementById('tallyVerifyType').value = type;
                document.getElementById('tallyVerifyStatus').value = tallyStatus;
                document.getElementById('tallyVerifyVoucherNo').value = '';
                document.getElementById('tallyVerifyRemarks').value = result.value;
                f.submit();
            }
        });
    }
}

function editCashIn(id, date, branchId, receiptType, customerName, dealerCode, amount, paymentMode, bankName, referenceNo, narration) {
    document.getElementById('cashInTxId').value = id;
    const titleEl = document.querySelector('#cashInModal .modal-title');
    if (titleEl) {
        titleEl.innerHTML = `<i class="fa-solid fa-pen-to-square me-2" style="color:#f59e0b;"></i>Edit Cash In Transaction`;
    }
    const modal = document.getElementById('cashInModal');
    modal.querySelector('[name="TransactionDate"]').value = date;
    modal.querySelector('[name="BranchId"]').value = branchId;
    modal.querySelector('[name="ReceiptType"]').value = receiptType;
    modal.querySelector('[name="PaymentMode"]').value = paymentMode;
    modal.querySelector('[name="CustomerName"]').value = customerName;
    modal.querySelector('[name="Amount"]').value = amount;
    modal.querySelector('[name="BankName"]').value = bankName;
    modal.querySelector('[name="ReferenceNo"]').value = referenceNo;
    modal.querySelector('[name="Narration"]').value = narration;

    const dealerHidden = document.getElementById('cashInDealerCodeHidden');
    if (dealerHidden) dealerHidden.value = dealerCode;
    const dealerBtn = document.getElementById('cashInDealerDropdownBtn');
    if (dealerBtn) {
        const span = dealerBtn.querySelector('span');
        if (span) span.textContent = dealerCode ? dealerCode : '-- Select Code --';
    }
    new bootstrap.Modal(modal).show();
}

function resetCashInForm() {
    const idEl = document.getElementById('cashInTxId');
    if (idEl) idEl.value = '0';
    const titleEl = document.querySelector('#cashInModal .modal-title');
    if (titleEl) {
        titleEl.innerHTML = `<i class="fa-solid fa-arrow-circle-down me-2" style="color:#22c55e;"></i>New Cash In Transaction`;
    }
    const form = document.querySelector('#cashInModal form');
    if (form) {
        form.reset();
        const dateInput = form.querySelector('[name="TransactionDate"]');
        if (dateInput) dateInput.value = new Date().toISOString().substring(0, 10);
        const dealerHidden = document.getElementById('cashInDealerCodeHidden');
        if (dealerHidden) dealerHidden.value = '';
        const dealerBtn = document.getElementById('cashInDealerDropdownBtn');
        if (dealerBtn) {
            const span = dealerBtn.querySelector('span');
            if (span) span.textContent = '-- Select Code --';
        }
    }
}
</script>

<form method="post" id="tallyVerificationForm" action="/CashManagement/VerifyTally" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="tallyVerifyId" name="id">
    <input type="hidden" id="tallyVerifyType" name="type">
    <input type="hidden" id="tallyVerifyStatus" name="tallyStatus">
    <input type="hidden" id="tallyVerifyVoucherNo" name="tallyVoucherNo">
    <input type="hidden" id="tallyVerifyRemarks" name="remarks">
</form>
}



