@model List<IncentivePortal.Models.CashInTransaction>
@using IncentivePortal.Models
@inject IncentivePortal.Helpers.ICurrentUser Cu
@{
    ViewData["Title"] = "Cash In";
    var branches = ViewData["Branches"] as List<Branch> ?? new();
    bool isHO = Cu.IsInRole(AppRoles.SuperAdmin) || Cu.IsInRole(AppRoles.HOFinance) || Cu.IsInRole(AppRoles.Auditor);
    bool canCreate = !Cu.IsInRole(AppRoles.Auditor);
    bool canApprove = Cu.IsInRole(AppRoles.SuperAdmin) || Cu.IsInRole(AppRoles.HOFinance);
    bool canVerifyTally = Cu.IsInRole(AppRoles.SuperAdmin) || Cu.IsInRole(AppRoles.HOFinance);
    bool canEdit = Cu.IsInRole(AppRoles.SuperAdmin) || Cu.IsInRole(AppRoles.HOFinance);
    decimal totalAmt = (decimal)(ViewBag.TotalAmount ?? 0m);
    int totalCount = (int)(ViewBag.TotalCount ?? 0);

    string FormatCr(decimal v) => v >= 10000000m ? $"₹{v/10000000m:N2} Cr" : v >= 100000m ? $"₹{v/100000m:N2} L" : $"₹{v:N0}";
}

<style>
.cash-badge { display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:0.72rem;font-weight:700;letter-spacing:.3px; }
.cash-badge::before { content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0; }
.badge-draft{background:rgba(100,116,139,.12);color:#64748b;}.badge-draft::before{background:#64748b;}
.badge-submitted{background:rgba(59,130,246,.12);color:#3b82f6;}.badge-submitted::before{background:#3b82f6;}
.badge-verified{background:rgba(20,184,166,.12);color:#14b8a6;}.badge-verified::before{background:#14b8a6;}
.badge-approved{background:rgba(34,197,94,.12);color:#22c55e;}.badge-approved::before{background:#22c55e;}
.badge-posted{background:rgba(99,102,241,.12);color:#6366f1;}.badge-posted::before{background:#6366f1;}
.badge-reconciled{background:rgba(34,197,94,.15);color:#16a34a;}.badge-reconciled::before{background:#16a34a;}
.badge-rejected{background:rgba(239,68,68,.12);color:#ef4444;}.badge-rejected::before{background:#ef4444;}
.badge-closed{background:rgba(100,116,139,.1);color:#94a3b8;}.badge-closed::before{background:#94a3b8;}
.tally-chip{font-size:0.7rem;font-weight:700;color:#6366f1;background:rgba(99,102,241,.1);padding:2px 8px;border-radius:20px;font-family:monospace;}
.act-icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:11px;border:1px solid #e2e8f0;color:#64748b;transition:all .15s;cursor:pointer;}
.act-icon:hover.vi{background:rgba(59,130,246,.1);color:#3b82f6;border-color:rgba(59,130,246,.3);}
.act-icon:hover.ap{background:rgba(34,197,94,.1);color:#22c55e;border-color:rgba(34,197,94,.3);}
.act-icon:hover.re{background:rgba(239,68,68,.1);color:#ef4444;border-color:rgba(239,68,68,.3);}
.act-icon:hover.dl{background:rgba(239,68,68,.1);color:#ef4444;border-color:rgba(239,68,68,.3);}
.workflow-step{display:inline-flex;align-items:center;gap:3px;font-size:10px;font-weight:600;padding:3px 9px;border-radius:20px;}
.workflow-step.done{background:rgba(34,197,94,.12);color:#16a34a;}
.workflow-step.current{background:var(--primary);color:#fff;}
.workflow-step.future{background:#f1f5f9;color:#94a3b8;}
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-3" style="border-radius:8px;font-size:.875rem;">
        <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-3" style="border-radius:8px;font-size:.875rem;">
        <i class="fa-solid fa-circle-xmark me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Page Header -->
<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <div style="font-size:.72rem;font-weight:600;text-transform:uppercase;color:#94a3b8;letter-spacing:.5px;">Cash Management</div>
        <h2 style="font-size:1.5rem;font-weight:700;color:var(--ink);margin:0;">
            <i class="fa-solid fa-arrow-circle-down me-2" style="color:#22c55e;"></i>Cash In Register
        </h2>
        <p class="text-muted mb-0" style="font-size:.82rem;">
            @totalCount record(s) &nbsp;|&nbsp; Total: <strong style="color:#22c55e;">@FormatCr(totalAmt)</strong>
        </p>
    </div>
    <div class="d-flex gap-2">
        @if (canCreate)
        {
            <button class="btn btn-primary d-flex align-items-center gap-2 px-4"
                    style="background:#22c55e;border:none;height:40px;font-weight:600;font-size:.88rem;border-radius:8px;box-shadow:0 4px 12px rgba(34,197,94,.2);"
                    data-bs-toggle="modal" data-bs-target="#cashInModal" onclick="resetCashInForm()">
                <i class="fa-solid fa-plus"></i> New Cash In
            </button>
        }
        <a href="@Url.Action("CashIn")" class="btn btn-outline-secondary d-flex align-items-center gap-2" style="height:40px;border-radius:8px;font-size:.88rem;font-weight:600;">
            <i class="fa-solid fa-arrows-rotate"></i> Refresh
        </a>
    </div>
</div>

<!-- Workflow Banner -->
<div class="d-flex align-items-center gap-1 mb-4 flex-wrap" style="background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:12px 16px;box-shadow:0 1px 4px rgba(0,0,0,.04);">
    <span style="font-size:.72rem;font-weight:700;text-transform:uppercase;color:#94a3b8;margin-right:8px;">Workflow:</span>
    @foreach (var (step, i) in CashTxStatus.Workflow.Select((s,i) => (s,i)))
    {
        <span class="workflow-step future">@step</span>
        @if (i < CashTxStatus.Workflow.Length - 1)
        {
            <i class="fa-solid fa-chevron-right" style="font-size:9px;color:#cbd5e1;"></i>
        }
    }
</div>

<!-- Filters -->
<div class="panel mb-3" style="background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:16px 20px;box-shadow:0 1px 4px rgba(0,0,0,.04);">
    <form method="get" class="d-flex flex-wrap align-items-end gap-3">
        <div>
            <label class="form-label mb-1" style="font-size:.72rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Status</label>
            <select name="status" class="form-select form-select-sm" style="width:140px;border-radius:8px;">
                <option value="">All Status</option>
                @foreach (var s in CashTxStatus.Workflow)
                {
                    <option value="@s" selected="@(ViewBag.FilterStatus==s?"selected":null)">@s</option>
                }
                <option value="Rejected" selected="@(ViewBag.FilterStatus=="Rejected"?"selected":null)">Rejected</option>
            </select>
        </div>
        @if (isHO)
        {
            <div>
                <label class="form-label mb-1" style="font-size:.72rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Branch</label>
                <select name="branchId" class="form-select form-select-sm" style="width:170px;border-radius:8px;">
                    <option value="">All Branches</option>
                    @foreach (var b in branches)
                    {
                        <option value="@b.Id" selected="@(ViewBag.FilterBranchId?.ToString()==b.Id.ToString()?"selected":null)">@b.Name</option>
                    }
                </select>
            </div>
        }
        <div>
            <label class="form-label mb-1" style="font-size:.72rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">From</label>
            <input type="date" name="from" value="@ViewBag.FilterFrom" class="form-control form-control-sm" style="width:145px;border-radius:8px;">
        </div>
        <div>
            <label class="form-label mb-1" style="font-size:.72rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">To</label>
            <input type="date" name="to" value="@ViewBag.FilterTo" class="form-control form-control-sm" style="width:145px;border-radius:8px;">
        </div>
        <button type="submit" class="btn btn-sm btn-outline-secondary" style="height:32px;border-radius:8px;font-weight:600;font-size:.8rem;">
            <i class="fa-solid fa-filter me-1"></i>Apply
        </button>
        <a href="@Url.Action("CashIn")" class="btn btn-sm btn-ghost text-muted" style="height:32px;font-size:.8rem;">Clear</a>
    </form>
</div>

<!-- Table -->
<div class="panel" style="background:#fff;border:1px solid #e2e8f0;border-radius:8px;box-shadow:0 1px 4px rgba(0,0,0,.04);overflow:hidden;">
    <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
        <div style="font-size:.88rem;font-weight:700;color:var(--ink);">
            <i class="fa-solid fa-table me-2 text-muted"></i>Transaction Register
        </div>
        <div class="d-flex gap-2">
            <input type="text" id="ciSearch" placeholder="Search..." class="form-control form-control-sm" style="width:220px;border-radius:20px;font-size:.82rem;" oninput="filterTable(this.value,'ciTbody')">
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" style="font-size:.83rem;">
            <thead style="background:#f8fafc;">
                <tr>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;padding:12px 16px;">Transaction ID</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Branch</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Date</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Type</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Party</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Amount</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Mode</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Reference</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Status</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Tally Voucher</th>
                    <th style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;">Actions</th>
                </tr>
            </thead>
            <tbody id="ciTbody">
                @if (!Model.Any())
                {
                    <tr><td colspan="11" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-inbox fa-2x mb-2 d-block" style="opacity:.2;"></i>No records found
                    </td></tr>
                }
                @foreach (var tx in Model)
                {
                    <tr>
                        <td><code style="font-size:.78rem;color:#6366f1;font-weight:700;">@tx.TransactionNo</code></td>
                        <td style="font-weight:500;">@tx.Branch?.Name</td>
                        <td>@tx.TransactionDate.ToString("dd MMM yyyy")</td>
                        <td><span style="font-size:.75rem;color:#64748b;">@tx.ReceiptType</span></td>
                        <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@tx.CustomerName">@tx.CustomerName</td>
                        <td style="font-weight:700;color:#22c55e;font-family:monospace;">@FormatCr(tx.Amount)</td>
                        <td><span style="font-size:.72rem;background:rgba(59,130,246,.1);color:#3b82f6;padding:2px 8px;border-radius:20px;font-weight:600;">@tx.PaymentMode</span></td>
                        <td style="font-size:.75rem;color:#94a3b8;max-width:100px;overflow:hidden;text-overflow:ellipsis;">@tx.ReferenceNo</td>
                        <td><span class="cash-badge badge-@tx.Status.ToLower()">@tx.Status</span></td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                @if (tx.TallySyncStatus == "Correct")
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle" style="font-size:0.7rem; padding:3px 8px; border-radius:12px; align-self: start;">
                                        <i class="fa-solid fa-circle-check me-1"></i>Tally OK
                                    </span>
                                    @if (!string.IsNullOrEmpty(tx.TallyVoucherNo))
                                    {
                                        <span class="tally-chip" style="font-size: 0.68rem; align-self: start;"><i class="fa-solid fa-receipt me-1"></i>@tx.TallyVoucherNo</span>
                                    }
                                }
                                else if (tx.TallySyncStatus == "Wrong")
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle" style="font-size:0.7rem; padding:3px 8px; border-radius:12px; align-self: start;" title="@tx.ApprovalRemarks">
                                        <i class="fa-solid fa-circle-xmark me-1"></i>Tally Error
                                    </span>
                                    <span style="font-size:0.68rem; color:#ef4444; max-width:100px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@tx.ApprovalRemarks">@tx.ApprovalRemarks</span>
                                }
                                else
                                {
                                    @if (!string.IsNullOrEmpty(tx.TallyVoucherNo))
                                    {
                                        <span class="tally-chip"><i class="fa-solid fa-link me-1"></i>@tx.TallyVoucherNo</span>
                                    }
                                    else
                                    {
                                        <span style="color:#cbd5e1;font-size:.75rem;">—</span>
                                    }
                                }
                            </div>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <button class="act-icon vi" title="View"
                                        onclick="viewCashIn(@tx.Id,'@tx.TransactionNo','@(tx.Branch?.Name?.Replace("'", "\\'"))','@tx.TransactionDate.ToString("dd MMM yyyy")','@tx.ReceiptType','@(tx.CustomerName.Replace("'", "\\'"))','@(tx.DealerCode?.Replace("'", "\\'") ?? "")','@FormatCr(tx.Amount)','@tx.PaymentMode','@(tx.BankName?.Replace("'", "\\'") ?? "")','@(tx.ReferenceNo?.Replace("'", "\\'") ?? "")','@tx.Status','@(tx.TallyVoucherNo ?? "—")','@(tx.Narration?.Replace("'", "\\'").Replace("\r", "").Replace("\n", " ") ?? "")')">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                                @if (canEdit)
                                {
                                    <button class="act-icon text-warning" style="border-color: rgba(245, 158, 11, .3);" title="Edit"
                                            onclick="editCashIn('@tx.Id', '@tx.TransactionDate.ToString("yyyy-MM-dd")', '@tx.BranchId', '@tx.ReceiptType', '@(tx.CustomerName.Replace("'", "\\'"))', '@(tx.DealerCode?.Replace("'", "\\'") ?? "")', '@tx.Amount', '@tx.PaymentMode', '@(tx.BankName?.Replace("'", "\\'") ?? "")', '@(tx.ReferenceNo?.Replace("'", "\\'") ?? "")', '@(tx.Narration?.Replace("'", "\\'").Replace("\r", "").Replace("\n", " ") ?? "")')">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                }
                                @if (canVerifyTally)
                                {
                                    <button class="act-icon text-success" style="border-color: rgba(34,197,94,.3);" title="Verify Tally Entry"
                                            onclick="checkTallyEntry('@tx.Id', 'CashIn', 'Correct', '@(tx.TallyVoucherNo ?? "")')">
                                        <i class="fa-solid fa-check"></i>
                                    </button>
                                    <button class="act-icon text-danger" style="border-color: rgba(239,68,68,.3);" title="Report Tally Discrepancy"
                                            onclick="checkTallyEntry('@tx.Id', 'CashIn', 'Wrong')">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                }
                                @if (canApprove && (tx.Status == CashTxStatus.Submitted || tx.Status == CashTxStatus.Verified))
                                {
                                    <button class="act-icon ap" title="Approve"
                                            onclick="quickAction('/CashManagement/ApproveCashIn','@tx.Id','@CashTxStatus.Approved','Approve this Cash In transaction?')">
                                        <i class="fa-solid fa-check"></i>
                                    </button>
                                    <button class="act-icon re" title="Reject"
                                            onclick="quickAction('/CashManagement/ApproveCashIn','@tx.Id','@CashTxStatus.Rejected','Reject this transaction?')">
                                        <i class="fa-solid fa-times"></i>
                                    </button>
                                }
                                @if (canEdit && tx.Status == CashTxStatus.Approved)
                                {
                                    <button class="act-icon" style="color:#6366f1;" title="Post to Tally"
                                            onclick="quickAction('/CashManagement/ApproveCashIn','@tx.Id','@CashTxStatus.Posted','Post this to Tally?')">
                                        <i class="fa-solid fa-upload"></i>
                                    </button>
                                }
                                @if (canCreate && tx.Status == CashTxStatus.Draft)
                                {
                                    <form method="post" action="/CashManagement/DeleteCashIn" class="d-inline" onsubmit="return confirm('Delete this draft?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@tx.Id">
                                        <button type="submit" class="act-icon dl" title="Delete"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top" style="font-size:.78rem;color:#94a3b8;">
        <span>Showing @Model.Count records</span>
        <span>Total: <strong style="color:#22c55e;">@FormatCr(totalAmt)</strong></span>
    </div>
</div>

<!-- New Cash In Modal -->
<div class="modal fade" id="cashInModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius:14px;">
            <div class="modal-header border-0 pb-0" style="padding:24px 28px 12px;">
                <div>
                    <h5 class="modal-title fw-bold" style="font-size:1.1rem;">
                        <i class="fa-solid fa-arrow-circle-down me-2" style="color:#22c55e;"></i>New Cash In Transaction
                    </h5>
                    <p class="text-muted mb-0" style="font-size:.78rem;">Fill in all required fields to record a cash receipt.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @{
                var parties = ViewBag.Parties as List<Party> ?? new();
                var receiptTypes = ViewBag.ReceiptTypes as List<string> ?? new();
            }
            <form method="post" action="/CashManagement/CreateCashIn" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="cashInTxId" value="0" />
                <div class="modal-body" style="padding:20px 28px;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Transaction Date <span class="text-danger">*</span></label>
                            <input type="date" name="TransactionDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required style="border-radius:8px;">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Branch <span class="text-danger">*</span></label>
                            <select name="BranchId" class="form-select" required style="border-radius:8px;" @(!isHO?"disabled":"")>
                                @foreach (var b in branches)
                                {
                                    <option value="@b.Id">@b.Name (@b.Code)</option>
                                }
                            </select>
                            @if (!isHO && branches.Count == 1)
                            {
                                <input type="hidden" name="BranchId" value="@branches[0].Id">
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Receipt Type <span class="text-danger">*</span></label>
                            <select name="ReceiptType" id="cashInReceiptType" class="form-select" required style="border-radius:8px;">
                                @if (receiptTypes.Any())
                                {
                                    @foreach (var type in receiptTypes)
                                    {
                                        <option value="@type">@type</option>
                                    }
                                }
                                else
                                {
                                    <option>Customer Payment</option><option>Dealer Collection</option>
                                    <option>Cash Collection</option><option>Commission</option>
                                    <option>Advance</option><option>Refund</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6" id="paymentModeContainer">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Payment Mode <span class="text-danger">*</span></label>
                            <select name="PaymentMode" id="cashInPaymentMode" class="form-select" required style="border-radius:8px;">
                                <option>NEFT</option><option>RTGS</option><option>IMPS</option>
                                <option>Cheque</option><option>Cash</option><option>UPI</option><option>DD</option>
                                <option value="Multiple Modes" class="d-none">Multiple Modes</option>
                            </select>
                        </div>

                        <!-- Binded Hidden Field for Dealer Code to submit correctly -->
                        <input type="hidden" id="cashInDealerCodeHidden" name="DealerCode" />

                        <!-- Customer Code Searchable Dropdown (Shown for Receipts) -->
                        <div id="dealerCodeDropdownContainer" class="col-md-4">
                            <label class="form-label fw-semibold" style="font-size:.8rem;">Customer Code <span class="text-danger">*</span></label>
                            <div class="dropdown w-100" id="cashInDealerDropdown">
                                <button class="form-select text-start d-flex justify-content-between align-items-center" type="button" id="cashInDealerDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius:8px; background-color: #fff; font-size: 0.8rem; font-weight: 500;">
                                    <span>-- Select Code --</span>
                                </button>
                                <div class="dropdown-menu p-3 w-100 shadow border-0" style="max-height: 320px; overflow-y: auto; border-radius: 12px; min-width: 320px; z-index: 1060; border: 1px solid #e2e8f0 !important;">
                                    <input type="text" id="cashInDealerSearch" class="form-control form-control-sm mb-2" placeholder="Search code or name..." style="border-radius: 6px; font-size: 0.78rem;">
                                    <div id="cashInDealerOptions" style="display:flex; flex-direction:column; gap:2px;">
                                        <button type="button" class="dropdown-item rounded py-1.5 text-start font-semibold" data-value="" data-name="" style="font-size:0.76rem; color:#94a3b8; border: none; background: transparent;">
                                            -- Clear Selection --
                                        </button>
                                        @foreach (var p in parties)
                                        {
                                            <button type="button" class="dropdown-item rounded py-1.5 text-start d-flex justify-content-between align-items-center" data-value="@p.PartyCode" data-name="@p.PartyName" style="font-size:0.78rem; border: none; background: transparent; transition: background 0.15s;">
                                                <span class="font-bold text-indigo" style="font-family: monospace;">@p.PartyCode</span>
                                                <span class="text-muted text-end ms-2" style="font-size:0.72rem; max-width: 170px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@p.PartyName">@p.PartyName</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

