                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label mb-1" style="font-size: 0.72rem; font-weight: 600; color:#64748b;">UPI / QR Code (₹)</label>
                                        <input type="number" id="dmsAmtUpi" class="form-control form-control-sm dms-breakdown-input" placeholder="0.00" min="0" step="0.01" style="border-radius: 6px;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label mb-1" style="font-size: 0.72rem; font-weight: 600; color:#64748b;">Card (POS) (₹)</label>
                                        <input type="number" id="dmsAmtCard" class="form-control form-control-sm dms-breakdown-input" placeholder="0.00" min="0" step="0.01" style="border-radius: 6px;">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label mb-1" style="font-size: 0.72rem; font-weight: 600; color:#64748b;">NEFT/RTGS/IMPS (₹)</label>
                                        <input type="number" id="dmsAmtBank" class="form-control form-control-sm dms-breakdown-input" placeholder="0.00" min="0" step="0.01" style="border-radius: 6px;">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label mb-1" style="font-size: 0.72rem; font-weight: 600; color:#64748b;">Cheque / DD (₹)</label>
                                        <input type="number" id="dmsAmtCheque" class="form-control form-control-sm dms-breakdown-input" placeholder="0.00" min="0" step="0.01" style="border-radius: 6px;">
