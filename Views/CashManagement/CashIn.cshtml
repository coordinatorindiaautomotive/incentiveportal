                        <!-- Running Sum Alert Container (Initially Hidden) -->
                        <div class="col-md-12 d-none" id="runningSumAlertContainer">
                            <div style="background: rgba(34,197,94,.06); border: 1px solid rgba(34,197,94,.2); border-radius: 8px; padding: 10px 14px; display:flex; align-items:center; gap:10px;">
                                <div style="background: rgba(34,197,94,.12); color:#22c55e; width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                                    <i class="fa-solid fa-wallet" style="font-size:.8rem;"></i>
                                </div>
                                <div>
                                    <div style="font-size:.7rem; color:#15803d; font-weight:600; text-transform:uppercase; letter-spacing:.3px;">Running Sum (Selected Date)</div>
                                    <div style="font-size:.84rem; font-weight:700; color:#166534;" id="runningSumAlertText">
                                        Total received on this date: ₹0
                                    </div>
                                </div>
                            </div>
