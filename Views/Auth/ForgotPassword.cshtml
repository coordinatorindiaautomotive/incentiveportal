@{
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Forgot Password - ThessBuddy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/design-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reset.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/typography.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/topbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modals.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/alerts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/utilities.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dark-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    
    <!-- Google Fonts: Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    
    <style>
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: linear-gradient(135deg, var(--nav) 0%, var(--nav-2) 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            position: relative;
        }
        
        /* Grid Vector Background overlay */
        body::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
            pointer-events: none;
            z-index: 1;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 12px;
            box-shadow: 0 10px 35px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 40px;
            width: 100%;
            max-width: 440px;
            position: relative;
            z-index: 10;
            transition: transform 0.3s ease;
        }
        
        .login-card:hover {
            transform: translateY(-2px);
        }

        .form-control {
            border-radius: 8px !important;
            height: 46px;
            font-size: 0.9rem;
            padding-left: 42px;
            border: 1px solid #cbd5e1;
            transition: all 0.25s ease;
        }

        .form-control:focus {
            box-shadow: 0 0 0 3px var(--primary-glow);
            border-color: var(--primary);
        }

        .input-group-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.95rem;
            z-index: 10;
        }

        .btn-reset {
            background: var(--primary);
            color: white;
            border: none;
            height: 46px;
            border-radius: 8px !important;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.25s ease;
            box-shadow: 0 4px 12px var(--primary-glow);
        }

        .btn-reset:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 6px 15px var(--primary-glow);
            color: white;
        }

        .btn-reset:active {
            transform: translateY(0);
        }

        /* Submit Loader Screen */
        .lottie-submit-loader {
            position: absolute;
            inset: 0;
            background: rgba(255, 255, 255, 0.96);
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 100;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease, visibility 0.3s;
        }

        .rounder {
            width: 60px;
            height: 60px;
            border: 4px solid rgba(30, 64, 175, 0.1);
            border-left-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            position: relative;
        }

        .rounder::after {
            content: '';
            position: absolute;
            top: 5px;
            left: 5px;
            right: 5px;
            bottom: 5px;
            border: 4px solid rgba(79, 70, 229, 0.1);
            border-right-color: var(--secondary);
            border-radius: 50%;
            animation: spin-reverse 1.5s linear infinite;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @@keyframes spin-reverse {
            0% { transform: rotate(360deg); }
            100% { transform: rotate(0deg); }
        }
    </style>
</head>
<body>
    <main class="container d-flex align-items-center justify-content-center py-5">
        <div class="login-card">
            <!-- Submission Overlay with CSS Rounder -->
            <div id="resetLoader" class="lottie-submit-loader">
                <div class="loading-rounder-container" style="display: flex; align-items: center; justify-content: center; width: 160px; height: 160px; margin-bottom: 5px;">
                    <div class="rounder"></div>
                </div>
                <div style="font-weight: 700; color: #1E293B; font-size: 1.1rem; margin-top: 5px; letter-spacing: -0.3px;">Processing Reset...</div>
                <div style="color: #94a3b8; font-size: 0.8rem; margin-top: 4px;">Sending credentials...</div>
            </div>

            <!-- Top Header Branding for ThessBuddy -->
            <div class="text-center mb-4">
                <div class="brand-logo-login mb-3" style="display: inline-flex; align-items: center; justify-content: center;">
                    <img src="/thessbuddy-logo.png" alt="ThessBuddy" style="height:96px;width:auto;object-fit:contain;" asp-append-version="true" />
                </div>
                <h1 class="h4 fw-bold text-dark mb-1" style="letter-spacing: -0.5px;">Reset Password</h1>
                <p class="text-secondary small mb-0">Enter details to recover your account</p>
            </div>

            <form method="post" id="resetForm" asp-action="ForgotPassword">
                @Html.AntiForgeryToken()

                <!-- Feedback Message -->
                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success p-3 small mb-3 border-0" style="border-radius: 8px; font-size: 0.85rem;">
                        <i class="fa-solid fa-circle-check me-1"></i> @ViewBag.Message
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger p-3 small mb-3 border-0" style="border-radius: 8px; font-size: 0.85rem;">
                        <i class="fa-solid fa-circle-xmark me-1"></i> @ViewBag.Error
                    </div>
                }

                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <!-- Username or Email Field -->
                <div class="mb-4 position-relative">
                    <label for="usernameOrEmail" class="form-label small fw-bold text-secondary">Username or Email</label>
                    <div class="position-relative">
                        <i class="fa-regular fa-envelope input-group-icon"></i>
                        <input id="usernameOrEmail" name="usernameOrEmail" class="form-control" placeholder="Enter username or email" required />
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-reset w-100 d-flex align-items-center justify-content-center gap-2 mb-3">
                    <i class="fa-solid fa-paper-plane"></i> Send Temporary Password
                </button>

                <!-- Back to Login -->
                <div class="text-center">
                    <a asp-action="Login" class="small text-decoration-none fw-semibold" style="color: var(--primary); font-size: 0.85rem;">
                        <i class="fa-solid fa-arrow-left me-1"></i> Back to Login
                    </a>
                </div>
            </form>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#resetForm').on('submit', function() {
                if (this.checkValidity()) {
                    $('#resetLoader').css({
                        'opacity': '1',
                        'visibility': 'visible'
                    });
                }
            });
        });
    </script>
</body>
</html>

