@model IReadOnlyList<IncentivePortal.Models.IncentiveScheme>
@{
    ViewData["Title"] = "Slab Master Management";
}

<!-- Split Layout Dashboard -->
<div class="row">
    <!-- Left Panel: Schemes List -->
    <div class="col-lg-5 mb-4 mb-lg-0">
        <div class="panel h-100">
            <div class="panel-header d-flex justify-content-between align-items-center">
                <div>
                    <h2>Active Schemes</h2>
                    <p>Monthly incentive rules and version configurations</p>
                </div>
                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createSchemeModal">&#x26A1; Create Scheme</button>
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover corp-table align-middle" id="schemesTable">
                    <thead>
                        <tr>
                            <th>Scheme Name</th>
                            <th>Period</th>
                            <th>Ver</th>
                            <th class="text-center">Slabs</th>
                            <th>Status</th>
                            @if (User.IsInRole(IncentivePortal.Data.AppRoles.SuperAdmin))
                            {
                                <th class="text-end">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var visibleCount = 0;
                        }
                        @for (var i = 0; i < Model.Count; i++)
                        {
                            var item = Model[i];
                            if (item.Name == "Imported Workbook Scheme") continue;
                            
                            var activeClass = visibleCount == 0 ? "table-active" : "";
                            visibleCount++;
                            
                            <tr class="scheme-row @activeClass" style="cursor: pointer;" data-scheme-id="@item.Id" data-details='@Html.Raw(Json.Serialize(item.Details.Select(d => new { d.RuleName, d.MinAchievementPercent, d.MaxAchievementPercent, Percentage = d.Percentage ?? 0m, FixedAmount = d.FixedAmount ?? 0m })))'>
                                <td><strong>@item.Name</strong></td>
                                <td>
                                    <div class="fw-bold text-dark" style="font-size: 0.85rem;"><i class="fa-regular fa-calendar-check text-primary me-1"></i> @item.EffectiveFrom.ToString("dd MMM yyyy")</div>
                                    <div class="text-muted small font-semibold" style="font-size: 0.72rem; margin-top: 2px; padding-left: 17px;">to @(item.EffectiveTo.Year >= 2099 ? "Ongoing" : item.EffectiveTo.ToString("dd MMM yyyy"))</div>
                                </td>
                                <td><span class="badge bg-light text-dark border">v@(item.Version)</span></td>
                                <td class="text-center"><span class="badge bg-teal">@item.Details.Count slabs</span></td>
                                <td>
                                    <span class="status-badge @(item.IsLocked ? "danger" : "success")">
                                        @(item.IsLocked ? "Locked" : "Open")
                                    </span>
                                </td>
                                @if (User.IsInRole(IncentivePortal.Data.AppRoles.SuperAdmin))
                                {
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-danger delete-scheme-btn" data-id="@item.Id" style="border-color: var(--primary); color: var(--primary); background: rgba(30, 64, 175, 0.05); font-weight: 600; padding: 4px 10px; border-radius: 6px; transition: all 0.2s;"><i class="fa-solid fa-trash-can me-1"></i> Delete</button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right Panel: Slabs Breakdown -->
    <div class="col-lg-7">
        <div class="panel h-100" id="slabDetailsPanel">
            <div class="panel-header">
                <div>
                    <h2 id="selectedSchemeName">Scheme Slabs Breakdown</h2>
                    <p>Incentive slabs triggered by dealer achievement ratios</p>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table corp-table align-middle" id="slabsTable">
                    <thead>
                        <tr>
                            <th>Rule / Slab Title</th>
                            <th class="text-end">Min Sales Value (₹)</th>
                            <th class="text-end">Max Sales Value (₹)</th>
                            <th class="text-end">Percentage Payout</th>
                            <th class="text-end">Fixed Payout</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Dynamically filled by JavaScript -->
                    </tbody>
                </table>
            </div>
            
            <div id="slabEmptyState" class="text-center py-5" style="display: none;">
                <div class="fs-1">🔍</div>
                <h3>Select a Scheme</h3>
                <p class="text-muted">Choose an active monthly scheme from the left panel to load its slab ranges.</p>
            </div>
        </div>
    </div>
</div>

<!-- Premium Interactive Creation Modal -->
<div class="modal fade" id="createSchemeModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form id="createSchemeForm">
                @Html.AntiForgeryToken()
                <div class="modal-header" style="background: #f8fbff; border-bottom: 1px solid var(--line);">
                    <h5 class="modal-title fw-bold text-dark">&#x26A1; Create Scheme & Slabs</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding: 28px;">
                    <!-- Scheme Header Config -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Scheme Name</label>
                            <input name="Name" class="form-control corp-input" placeholder="e.g., Volume Target Scheme" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Effective From</label>
                            <input type="date" name="EffectiveFrom" class="form-control corp-input" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Effective To <span class="text-muted small fw-normal">(Optional - leaves scheme Ongoing)</span></label>
                            <input type="date" name="EffectiveTo" class="form-control corp-input" />
                        </div>
                    </div>

                    <!-- Dynamic Slab Rows Config -->
                    <div class="border-top pt-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold mb-0 text-teal">📊 Slabs & Threshold Calculations</h6>
                            <button type="button" class="btn btn-xs btn-outline-teal" id="addSlabRowBtn">+ Add Slab Row</button>
                        </div>
                        
                        <div class="table-responsive">
                            <table class="table table-sm align-middle" id="slabBuilderTable">
                                <thead>
                                    <tr>
                                        <th>Rule Name</th>
                                        <th style="width: 130px;">Min Sales Value (₹)</th>
                                        <th style="width: 130px;">Max Sales Value (₹)</th>
                                        <th style="width: 110px;">Fixed AMT (₹)</th>
                                        <th style="width: 100px;">Percentage (%)</th>
                                        <th style="width: 50px;" class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="slab-builder-row">
                                        <td><input type="text" class="form-control form-control-sm" name="RuleName" placeholder="e.g. Slab 1" required /></td>
                                        <td><input type="number" step="1" class="form-control form-control-sm text-end" name="MinAchievementPercent" placeholder="0" required /></td>
                                        <td><input type="number" step="1" class="form-control form-control-sm text-end" name="MaxAchievementPercent" placeholder="29999" required /></td>
                                        <td><input type="number" step="0.01" class="form-control form-control-sm text-end" name="FixedAmount" placeholder="0" value="0" /></td>
                                        <td><input type="number" step="0.001" class="form-control form-control-sm text-end" name="Percentage" placeholder="0" value="0" /></td>
                                        <td class="text-center"><button type="button" class="btn btn-xs btn-danger remove-slab-row"><i class="fa-solid fa-trash"></i></button></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="background: #f8fbff; border-top: 1px solid var(--line); padding: 16px;">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-success"><i class="fa-solid fa-check me-1"></i> Save Scheme & Slabs</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(document).ready(function() {
    // Fill Slab Details for currently active scheme
    function loadSchemeSlabs(row) {
        $('.scheme-row').removeClass('table-active');
        row.addClass('table-active');

        const schemeName = row.find('td:first strong').text();
        $('#selectedSchemeName').text(schemeName + ' - Slabs');

        const slabs = row.data('details');
        const tbody = $('#slabsTable tbody').empty();
        
        if (slabs && slabs.length > 0) {
            slabs.forEach(s => {
                tbody.append(`
                    <tr>
                        <td><strong>${s.ruleName}</strong></td>
                        <td class="text-end fw-semibold">₹${Math.round(s.minAchievementPercent).toLocaleString()}</td>
                        <td class="text-end fw-semibold">${s.maxAchievementPercent >= 999999999 ? '& above' : '₹' + Math.round(s.maxAchievementPercent).toLocaleString()}</td>
                        <td class="text-end text-primary fw-bold">${s.percentage.toFixed(2)}%</td>
                        <td class="text-end text-success fw-bold">₹${Math.round(s.fixedAmount).toLocaleString()}</td>
                    </tr>
                `);
            });
            $('#slabsTable').show();
            $('#slabEmptyState').hide();
        } else {
            $('#slabsTable').hide();
            $('#slabEmptyState').show();
        }
    }

    // Bind row click triggers
    $('.scheme-row').on('click', function() {
        loadSchemeSlabs($(this));
    });

    // Load first row automatically at start
    const firstRow = $('.scheme-row').first();
    if (firstRow.length) {
        loadSchemeSlabs(firstRow);
    } else {
        $('#slabsTable').hide();
        $('#slabEmptyState').show();
    }

    // Dynamic Slabs Adder
    $('#addSlabRowBtn').on('click', function() {
        const rowMarkup = `
            <tr class="slab-builder-row">
                <td><input type="text" class="form-control form-control-sm" name="RuleName" placeholder="Rule Name" required /></td>
                <td><input type="number" step="1" class="form-control form-control-sm text-end" name="MinAchievementPercent" placeholder="0" required /></td>
                <td><input type="number" step="1" class="form-control form-control-sm text-end" name="MaxAchievementPercent" placeholder="29999" required /></td>
                <td><input type="number" step="0.01" class="form-control form-control-sm text-end" name="FixedAmount" placeholder="0" value="0" /></td>
                <td><input type="number" step="0.001" class="form-control form-control-sm text-end" name="Percentage" placeholder="0" value="0" /></td>
                <td class="text-center"><button type="button" class="btn btn-xs btn-danger remove-slab-row"><i class="fa-solid fa-trash"></i></button></td>
            </tr>
        `;
        $('#slabBuilderTable tbody').append(rowMarkup);
    });

    // Remove row trigger
    $('#slabBuilderTable').on('click', '.remove-slab-row', function() {
        if ($('#slabBuilderTable tbody tr').length > 1) {
            $(this).closest('tr').remove();
        } else {
            portalToast('A scheme must contain at least one target slab.');
        }
    });

    // Ajax Save Scheme & Slabs
    $('#createSchemeForm').on('submit', function(e) {
        e.preventDefault();
        
        const name = $(this).find('[name="Name"]').val();
        const effectiveFrom = $(this).find('[name="EffectiveFrom"]').val();
        let effectiveTo = $(this).find('[name="EffectiveTo"]').val();
        if (!effectiveTo) {
            effectiveTo = "2099-12-31"; // Indefinite fallback
        }

        if (!effectiveFrom) {
            portalToast('Please select a valid Effective From date.', 'warning');
            return;
        }

        // Robust timezone-safe extraction of Year and Month from date input value
        let schemeYear = null;
        let schemeMonth = null;
        const dateParts = effectiveFrom.split(/[-/]/);
        if (dateParts.length === 3) {
            if (dateParts[0].length === 4) {
                schemeYear = Number(dateParts[0]);
                schemeMonth = Number(dateParts[1]);
            } else if (dateParts[2].length === 4) {
                schemeYear = Number(dateParts[2]);
                schemeMonth = Number(dateParts[1]);
            }
        }
        
        if (!schemeYear || !schemeMonth || isNaN(schemeYear) || isNaN(schemeMonth)) {
            const dateObj = new Date(effectiveFrom);
            if (!isNaN(dateObj.getTime())) {
                if (effectiveFrom.indexOf('-') !== -1) {
                    schemeYear = dateObj.getUTCFullYear();
                    schemeMonth = dateObj.getUTCMonth() + 1;
                } else {
                    schemeYear = dateObj.getFullYear();
                    schemeMonth = dateObj.getMonth() + 1;
                }
            }
        }

        if (!schemeYear || !schemeMonth || isNaN(schemeYear) || isNaN(schemeMonth)) {
            portalToast('Could not extract a valid month and year from the selected Effective From date.', 'warning');
            return;
        }

        // Gather Slabs Details
        const details = [];
        let hasRangeError = false;

        $('.slab-builder-row').each(function() {
            const ruleName = $(this).find('[name="RuleName"]').val();
            const minAch = Number($(this).find('[name="MinAchievementPercent"]').val());
            const maxAch = Number($(this).find('[name="MaxAchievementPercent"]').val());
            const fixedAmt = $(this).find('[name="FixedAmount"]').val();
            const pct = $(this).find('[name="Percentage"]').val();

            if (isNaN(minAch) || isNaN(maxAch)) {
                portalToast(`Please enter valid numbers for achievement slab values in "${ruleName || 'Slab'}".`, 'warning');
                hasRangeError = true;
                return false;
            }

            if (minAch > maxAch) {
                portalToast(`Slab range error inside "${ruleName}": Minimum (${minAch}) cannot exceed Maximum (${maxAch}).`, 'warning');
                hasRangeError = true;
                return false;
            }

            details.push({
                minAchievementPercent: minAch,
                maxAchievementPercent: maxAch,
                fixedAmount: fixedAmt ? Number(fixedAmt) : 0,
                percentage: pct ? Number(pct) : 0,
                ruleName: ruleName || 'Slab'
            });
        });

        if (hasRangeError) return;

        if (details.length === 0) {
            portalToast('A scheme must contain at least one target slab.', 'warning');
            return;
        }

        // Check for overlaps across different slabs in JavaScript
        const sortedSlabs = [...details].sort((a, b) => a.minAchievementPercent - b.minAchievementPercent);
        for (let i = 0; i < sortedSlabs.length; i++) {
            const slab = sortedSlabs[i];
            if (i > 0 && slab.minAchievementPercent <= sortedSlabs[i - 1].maxAchievementPercent) {
                portalToast(`Overlapping slab boundaries detected between "${sortedSlabs[i - 1].ruleName}" and "${slab.ruleName}". Please ensure they do not overlap (e.g. Slab 1: 0 - 29999, Slab 2: 30000 - 49999).`, 'warning');
                return;
            }
        }

        const payload = {
            name: name,
            schemeMonth: schemeMonth,
            schemeYear: schemeYear,
            effectiveFrom: effectiveFrom,
            effectiveTo: effectiveTo,
            details: details
        };

        const button = $(this).find('[type="submit"]')[0];
        portalSetBusy(button, 'Saving...');

        // Query with anti-forgery headers
        let token = $(this).find('[name="__RequestVerificationToken"]').val();
        if (!token) {
            token = $('input[name="__RequestVerificationToken"]').val();
        }

        $.ajax({
            url: '@Url.Action("Create", "Schemes")',
            method: 'POST',
            data: JSON.stringify(payload),
            contentType: 'application/json',
            headers: {
                'RequestVerificationToken': token
            }
        })
        .done(r => {
            portalToast(r.message || 'Scheme created successfully.', 'success');
            $('#createSchemeModal').modal('hide');
            // Reload page to display changes
            setTimeout(() => location.reload(), 800);
        })
        .fail(xhr => {
            portalToast(xhr.responseJSON?.message || xhr.responseText || 'Failed to save scheme.', 'error');
        })
        .always(() => portalClearBusy(button));
    });

    // Delete Scheme Event Handler
    $(document).on('click', '.delete-scheme-btn', function(e) {
        e.stopPropagation();
        const id = $(this).data('id');
        Swal.fire({
            title: 'Are you sure?',
            text: "This will soft-delete the incentive scheme and all its slab rules!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: 'var(--primary)',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '/Schemes/Delete',
                    method: 'POST',
                    data: { 
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }
                })
                .done(r => {
                    portalToast(r.message || 'Scheme deleted successfully.');
                    setTimeout(() => location.reload(), 800);
                })
                .fail(xhr => {
                    portalToast(xhr.responseJSON?.message || xhr.responseText || 'Failed to delete scheme.');
                });
            }
        });
    });
});
</script>
}


