// Helper function to poll background job status
function pollJobStatus(jobId, onProgress, onSuccess, onFailure) {
    const interval = setInterval(() => {
        $.ajax({
            url: '/Imports/GetJobStatus',
            method: 'GET',
            data: { jobId: jobId }
        })
        .done(status => {
            if (status.status === 'Succeeded') {
                clearInterval(interval);
                onSuccess(status);
            } else if (status.status === 'Failed') {
                clearInterval(interval);
                onFailure(status.error || status.message || 'Job failed.');
            } else {
                if (onProgress) {
                    onProgress(status.message || 'Processing...');
                }
            }
        })
        .fail(xhr => {
            clearInterval(interval);
            onFailure(xhr.responseJSON?.message || xhr.responseText || 'Error fetching job status.');
        });
    }, 1500);
}
// Approve overrides button click handler
$(document).on('click', '#approveOverridesBtn', function() {
    const month = currentCalcMonth;
    const year = currentCalcYear;
    if (!month || !year) {
        portalToast('No active period identified for approval.', 'error');
        return;
    }

    const btn = this;
    portalSetBusy(btn, 'Posting...');

    $.ajax({
        url: '@Url.Action("ApproveCalculation", "Imports")',
        method: 'POST',
        data: {
            month: month,
            year: year,
            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val()
        }
    })
    .done(res => {
        portalClearBusy(btn);
        if (res.ok) {
            portalToast(res.message || 'Calculations approved and posted successfully!', 'success');
            // Re-run the preview to update status badges
            runCalculationPreview(currentCalcMonth, currentCalcYear, currentCalcForce, pendingCalcBranchRulesSnapshot, pendingCalcPartyMappingsSnapshot);
        } else {
            portalToast(res.message || 'Approval failed.', 'error');
        }
    })
    .fail(xhr => {
        portalClearBusy(btn);
        const errMsg = xhr.responseJSON?.message || xhr.responseText || 'Failed to approve calculations.';
        portalToast(errMsg, 'error');
    });
});
