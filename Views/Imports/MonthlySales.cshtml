            <script>
            (function() {
                function toggleWorkflow(mode) {
                    var dynamicCtrls = document.querySelectorAll('.dynamic-ctrl');
                    var precalcCtrls = document.querySelectorAll('.precalc-ctrl');
                    if (mode === 'Dynamic') {
                        for (var i = 0; i < dynamicCtrls.length; i++) {
                            dynamicCtrls[i].style.setProperty('display', '', 'important');
                        }
                        for (var i = 0; i < precalcCtrls.length; i++) {
                            precalcCtrls[i].style.setProperty('display', 'none', 'important');
                        }
                    } else {
                        for (var i = 0; i < dynamicCtrls.length; i++) {
                            dynamicCtrls[i].style.setProperty('display', 'none', 'important');
                        }
                        for (var i = 0; i < precalcCtrls.length; i++) {
                            precalcCtrls[i].style.setProperty('display', '', 'important');
                        }
                    }
                }

                // Attach native listener immediately to ensure it catches all user clicks
                document.addEventListener('change', function(e) {
                    if (e.target && e.target.name === 'calcWorkflow') {
                        toggleWorkflow(e.target.value);
                    }
                });

                // Attach to DOMContentLoaded to handle initial state of the selected radio button
                document.addEventListener('DOMContentLoaded', function() {
                    var checkedRadio = document.querySelector('input[name="calcWorkflow"]:checked');
                    if (checkedRadio) {
                        toggleWorkflow(checkedRadio.value);
                    }
                });
                
                // Also poll/fallback check to handle cases where script runs after DOM is ready
                setTimeout(function() {
                    var checkedRadio = document.querySelector('input[name="calcWorkflow"]:checked');
                    if (checkedRadio) {
                        toggleWorkflow(checkedRadio.value);
                    }
                }, 100);
            })();
            </script>

