                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0 text-secondary" style="font-size:1rem;">Code Redirection Register</h5>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="toggleBulkMappingArea()"><i class="fa-solid fa-paste"></i> Bulk Copy-Paste</button>
                                <button type="button" class="btn btn-sm btn-outline-success" id="addMappingRowBtn">+ Add Custom Merge</button>
                            </div>
                        </div>

                        <!-- Bulk paste container (initially hidden) -->
                        <div id="bulkMappingContainer" class="card border mb-3 d-none shadow-sm" style="background:#f8fafc; border-radius:8px;">
                            <div class="card-body p-3">
                                <label class="form-label small fw-bold text-muted">Paste your data here (Comma, Tab, or Space separated values - e.g. copied from Excel columns):</label>
                                <textarea id="bulkMappingInput" class="form-control form-control-sm mb-2 font-monospace" rows="5" placeholder="AlternativeCode,OriginalCode&#10;AlternativeCode2 OriginalCode2&#10;AlternativeCode3	OriginalCode3" style="font-size:0.82rem;"></textarea>
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-secondary btn-sm" onclick="toggleBulkMappingArea()">Close</button>
                                    <button type="button" class="btn btn-primary btn-sm" onclick="processBulkMappings(false)">Append Mappings</button>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="processBulkMappings(true)">Replace Existing</button>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive" style="max-height:350px;border-radius:8px;border:1px solid var(--line);">
                            <table class="table table-hover align-middle mb-0" id="modalMappingsTable">
                                <thead class="table-light" style="position:sticky;top:0;z-index:1;">
                                    <tr>
                                        <th style="padding:12px 16px; width: 42%;">Alternate Party Code</th>
                                        <th style="padding:12px 16px; width: 10%; text-align: center;"></th>
                                        <th style="padding:12px 16px; width: 38%;">Original Party Code (Merge Target)</th>
                                        <th style="width:10%;padding:12px 16px;" class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @{
                                    var mappings = ViewBag.AlternateMappings as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                                    var mappingList = mappings.ToList();
                                    if (mappingList.Count == 0)
                                    {
                                        <tr class="mapping-row">
                                            <td data-label="Alternate Party Code" style="padding:8px 16px; width: 42%;">
                                                <div class="input-group input-group-sm">
                                                    <span class="input-group-text bg-light text-muted"><i class="fa-solid fa-link-slash"></i></span>
                                                    <input class="form-control mapping-alt-input" placeholder="Alternate Code (e.g. 1944A)" value="" style="height:34px;" />
                                                </div>
                                            </td>
                                            <td style="padding:8px 16px; width: 10%; text-align: center; vertical-align: middle;">
                                                <span style="font-size: 1.25rem; color: var(--brand, #2563eb); font-weight: bold;"><i class="fa-solid fa-circle-arrow-right"></i></span>
                                            </td>
                                            <td data-label="Merge Target" style="padding:8px 16px; width: 38%;">
                                                <div class="input-group input-group-sm">
                                                    <span class="input-group-text bg-light text-muted"><i class="fa-solid fa-link"></i></span>
                                                    <input class="form-control mapping-orig-input" placeholder="Merge Target (e.g. 1944)" value="" style="height:34px;" />
                                                </div>
                                            </td>
                                            <td data-label="Action" style="padding:8px 16px; width: 10%;" class="text-center">
                                                <button type="button" class="btn btn-sm btn-outline-danger remove-mapping-row-btn" style="padding:4px 12px; font-size:0.8rem; border-radius: 6px;"><i class="fa-solid fa-trash"></i></button>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var m in mappingList)
                                        {
                                            <tr class="mapping-row">
                                                <td data-label="Alternate Party Code" style="padding:8px 16px; width: 42%;">
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text bg-light text-muted"><i class="fa-solid fa-link-slash"></i></span>
                                                        <input class="form-control mapping-alt-input" placeholder="Alternate Code (e.g. 1944A)" value="@m.alternateCode" style="height:34px;" />
                                                    </div>
                                                </td>
                                                <td style="padding:8px 16px; width: 10%; text-align: center; vertical-align: middle;">
                                                    <span style="font-size: 1.25rem; color: var(--brand, #2563eb); font-weight: bold;"><i class="fa-solid fa-circle-arrow-right"></i></span>
                                                </td>
                                                <td data-label="Merge Target" style="padding:8px 16px; width: 38%;">
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text bg-light text-muted"><i class="fa-solid fa-link"></i></span>
                                                        <input class="form-control mapping-orig-input" placeholder="Merge Target (e.g. 1944)" value="@m.originalCode" style="height:34px;" />
                                                    </div>
                                                </td>
                                                <td data-label="Action" style="padding:8px 16px; width: 10%;" class="text-center">
                                                    <button type="button" class="btn btn-sm btn-outline-danger remove-mapping-row-btn" style="padding:4px 12px; font-size:0.8rem; border-radius: 6px;"><i class="fa-solid fa-trash"></i></button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 bg-light" style="gap: 10px;">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <!-- Preview button (shown only in preview mode) -->
                <button type="button" class="btn btn-primary px-4 shadow" id="applyRulesAndPreviewBtn" style="background:var(--brand);border-color:var(--brand);">Apply Rules &amp; Run Preview</button>
                <!-- Calculate button (shown only in calc mode) -->
                <button type="button" class="btn px-4 shadow fw-bold d-none" id="applyRulesAndCalcBtn" style="background:linear-gradient(135deg,var(--primary),var(--primary-hover));color:white;border:none;">
