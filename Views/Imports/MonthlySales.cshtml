// Pre-Calculated Excel Upload Preview Handler
window.handlePrecalcUpload = function(btn) {
    try {
        const fileInput = document.getElementById('precalcFile');
        if (!fileInput) {
            Swal.fire('Error', 'File input element #precalcFile not found.', 'error');
            return;
        }
        const file = fileInput.files[0];
        if (!file) {
            Swal.fire('Warning', 'Please select a valid Excel file to upload.', 'warning');
            return;
        }
        uploadedPrecalcFile = file;

        portalSetBusy(btn, 'Uploading & Previewing...');
        $('#calcStatusRow').hide();

        const formData = new FormData();
        formData.append("file", file);
        formData.append("uploadMode", "PreCalculated");
        
        const token = $('input[name="__RequestVerificationToken"]').val();
        if (token) {
            formData.append("__RequestVerificationToken", token);
        }

        $.ajax({
            url: '@Url.Action("Preview", "Imports")',
            method: 'POST',
            data: formData,
            processData: false,
            contentType: false
        })
        .done(res => {
            portalClearBusy(btn);
            // Server now returns { previewToken, rows } вЂ” store the token for fast commit
            const rows = res.rows || res;
            precalcPreviewToken = res.previewToken || null;
            precalcFileRows = rows;

            // Destroy DataTable if it exists
            if ($.fn.DataTable.isDataTable('#calcPreviewTable')) {
                $('#calcPreviewTable').DataTable().destroy();
            }

            const body = $('#calcPreviewTable tbody').empty();
            
            let totalSales = 0;
            let grossIncentives = 0;
            let netTransfer = 0;
            let hasErrors = false;
            
            $.each(rows, (i, r) => {
                totalSales += Number(r.saleValue || 0);
                grossIncentives += Number(r.fileIncentive || 0);
                netTransfer += Number((r.transferAmount !== null && r.transferAmount !== undefined) ? r.transferAmount : (r.fileIncentive || 0));

                let badge = '';
                if (r.error) {
                    hasErrors = true;
                    badge = `<span class="status-badge danger text-danger bg-danger-subtle border border-danger-subtle px-2 py-1" style="border-radius: 6px; font-weight: 600; font-size: 0.72rem;" title="${r.error}"><i class="fa-solid fa-triangle-exclamation me-1"></i>Error</span>`;
                } else {
                    badge = `<span class="status-badge success text-success bg-success-subtle border border-success-subtle px-2 py-1" style="border-radius: 6px; font-weight: 600; font-size: 0.72rem;"><i class="fa-solid fa-circle-check me-1"></i>Pre-Calculated</span>`;
                }

                body.append(`
                    <tr>
                        <td><strong>${r.partyCode || r.resolvedPartyCode}</strong></td>
                        <td class="party-name-col">${r.partyName || '-'}</td>
                        <td><span class="badge bg-secondary-subtle text-secondary">${r.location || '-'}</span></td>
                        <td class="text-end">${Number(r.saleValue).toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                        <td class="text-end">${Number(r.discount).toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                        <td><span class="text-primary small fw-bold">${(r.slabPercent * 100).toFixed(2)}%</span></td>
                        <td class="text-end fw-bold">${Number(r.fileIncentive).toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                        <td class="text-end">0%</td>
                        <td class="text-end text-danger fw-semibold">0</td>
                        <td class="text-end text-warning">вЂ”</td>
                        <td class="text-end text-success fw-bold">${Number((r.transferAmount !== null && r.transferAmount !== undefined) ? r.transferAmount : r.fileIncentive).toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                        <td>${badge}</td>
                        <td class="text-center">
                            <span class="text-muted small">вЂ”</span>
                        </td>
                    </tr>
                `);
            });

            if (rows.length === 0) {
                body.append('<tr><td colspan="13" class="text-center text-muted py-4">No records found in Excel sheet.</td></tr>');
            } else {
                $('#calcPreviewTable').DataTable({
                    pageLength: 25,
                    lengthMenu: [10, 25, 50, 100],
                    language: {
                        search: "",
                        searchPlaceholder: "Search calculation previews..."
                    },
                    dom: "<'row mb-2 align-items-center'<'col-sm-6'l><'col-sm-6 text-end'f>>t<'row mt-2'<'col-sm-6'i><'col-sm-6 text-end'p>>"
                });
            }

            // Run live counting animations
            animateValue("calcTotalParties", 0, rows.length, 800);
            animateValue("calcTotalSales", 0, Math.round(totalSales), 800, "в‚№");
            animateValue("calcGrossIncentive", 0, Math.round(grossIncentives), 800, "в‚№");
            animateValue("calcNetTransfer", 0, Math.round(netTransfer), 800, "в‚№");

            if (hasErrors) {
                Swal.fire('Warning', 'Some rows in the Excel sheet contain validation errors.', 'warning');
                $('#commitCalcBtn').hide();
            } else if (rows.length > 0) {
                $('#commitCalcBtn').show();
            }
            $('#downloadCalcPreviewBtn').hide();

            // Scroll down to preview panel
            $('html, body').animate({
                scrollTop: $("#calcPreviewTable").offset().top - 100
            }, 500);
        })
        .fail(xhr => {
            portalClearBusy(btn);
            const errMsg = xhr.responseJSON?.message || xhr.responseText || 'Pre-calculated preview failed.';
            Swal.fire('Error', errMsg, 'error');
        });
    } catch (err) {
        if (btn) portalClearBusy(btn);
        Swal.fire('Client Error', err.message, 'error');
    }
};

// Commit (Push) calculation preview click handler
window.handlePrecalcCommit = function(btn) {
    try {
        const workflowMode = $('input[name="calcWorkflow"]:checked').val();
        
        if (workflowMode === 'PreCalculated') {
            if (!uploadedPrecalcFile) {
                Swal.fire('Warning', 'Please upload and preview a file first.', 'warning');
                return;
            }
            
            portalSetBusy(btn, 'Committing Payouts...');
            $('#calcStatusRow').hide();
            
            const formData = new FormData();
            formData.append("file", uploadedPrecalcFile);
            formData.append("uploadMode", "PreCalculated");
            formData.append("rewriteSales", "true");
            formData.append("changeReason", "Imported pre-calculated monthly incentives");
            if (precalcPreviewToken) {
                formData.append("previewToken", precalcPreviewToken);
            }
            
            const token = $('input[name="__RequestVerificationToken"]').val();
            if (token) {
                formData.append("__RequestVerificationToken", token);
            }

            $.ajax({
                url: '@Url.Action("Commit", "Imports")',
                method: 'POST',
                data: formData,
                processData: false,
                contentType: false
            })
            .done(res => {
                if (res.ok && res.jobId) {
                    portalSetBusy(btn, 'Importing...');
                    
                    pollJobStatus(res.jobId,
                        (progressMsg) => {
                            portalSetBusy(btn, progressMsg);
                        },
                        (statusRes) => {
                            portalClearBusy(btn);
                            Swal.fire('Success', statusRes.message || 'Pre-calculated incentives committed successfully!', 'success');
                            
                            $('#calcStatusAlert')
                                .removeClass('alert-danger').addClass('alert-success')
                                .html(`<i class="fa-solid fa-circle-check text-success me-1"></i> <strong>${statusRes.message || 'Import completed successfully.'}</strong>`);
                            $('#calcStatusRow').show();

                            $('#commitCalcBtn').hide();
                        },
                        (errorMsg) => {
                            portalClearBusy(btn);
                            Swal.fire('Error', errorMsg, 'error');
                            
                            $('#calcStatusAlert')
                                .removeClass('alert-success').addClass('alert-danger')
                                .html(`<i class="fa-solid fa-circle-exclamation text-danger me-1"></i> <strong>Error:</strong> ${errorMsg}`);
                            $('#calcStatusRow').show();
                        }
                    );
                } else {
                    portalClearBusy(btn);
                    Swal.fire('Error', res.message || 'Intake commit failed.', 'error');
                }
            })
            .fail(xhr => {
                portalClearBusy(btn);
                const errMsg = xhr.responseJSON?.message || xhr.responseText || 'Failed to commit pre-calculated incentives.';
                Swal.fire('Error', errMsg, 'error');
                
                $('#calcStatusAlert')
                    .removeClass('alert-success').addClass('alert-danger')
                    .html(`<i class="fa-solid fa-circle-exclamation text-danger me-1"></i> <strong>Error:</strong> ${errMsg}`);
                $('#calcStatusRow').show();
            });
            return;
        }

        const month = parseInt($('#calcMonth').val());
        const year = parseInt($('#calcYear').val());
        const force = $('#calcForce').val();

        portalSetBusy(btn, 'Queueing Calculations...');

        $.ajax({
            url: '@Url.Action("Calculate", "Imports")',
            method: 'POST',
            data: {
                month: month,
                year: year,
                forceRecalculate: force,
                branchRulesJson: pendingCalcBranchRules && pendingCalcBranchRules.length > 0 ? JSON.stringify(pendingCalcBranchRules) : '',
                partyMappingsJson: pendingCalcPartyMappings && pendingCalcPartyMappings.length > 0 ? JSON.stringify(pendingCalcPartyMappings) : '',
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            }
        })
        .done(res => {
            if (res.ok && res.jobId) {
                portalSetBusy(btn, 'Calculating...');
                
                pollJobStatus(res.jobId,
                    (progressMsg) => {
                        portalSetBusy(btn, progressMsg);
                    },
                    (statusRes) => {
                        portalClearBusy(btn);
                        Swal.fire('Success', statusRes.message || 'Calculations committed successfully!', 'success');
                        
                        $('#calcStatusAlert')
                            .removeClass('alert-danger').addClass('alert-success')
                            .html(`<i class="fa-solid fa-circle-check text-success me-1"></i> <strong>${statusRes.message || 'Calculation completed.'}</strong>`);
                        $('#calcStatusRow').show();

                        $('#commitCalcBtn').hide();
                        $('#downloadCalcPreviewBtn').hide();
                    },
                    (errorMsg) => {
                        portalClearBusy(btn);
                        Swal.fire('Error', errorMsg, 'error');
                        
                        $('#calcStatusAlert')
                            .removeClass('alert-success').addClass('alert-danger')
                            .html(`<i class="fa-solid fa-circle-exclamation text-danger me-1"></i> <strong>Error:</strong> ${errorMsg}`);
                        $('#calcStatusRow').show();
                    }
                );
            } else {
                portalClearBusy(btn);
                Swal.fire('Error', res.message || 'Calculation failed.', 'error');
            }
        })
        .fail(xhr => {
            portalClearBusy(btn);
            const errMsg = xhr.responseJSON?.message || xhr.responseText || 'Failed to commit calculations.';
            Swal.fire('Error', errMsg, 'error');
            
            $('#calcStatusAlert')
                .removeClass('alert-success').addClass('alert-danger')
                .html(`<i class="fa-solid fa-circle-exclamation text-danger me-1"></i> <strong>Error:</strong> ${errMsg}`);
            $('#calcStatusRow').show();
        });
    } catch (err) {
        if (btn) portalClearBusy(btn);
        Swal.fire('Client Error', err.message, 'error');
    }
};

