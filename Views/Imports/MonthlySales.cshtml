<div class="modal fade" id="rulesModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius:12px;overflow:hidden;background:#fdfdfd;">
            <div class="modal-header border-0 p-4" style="background:linear-gradient(135deg,#093375 0%,#051b3f 100%);color:white;">
                <div>
                    <h4 class="modal-title fw-bold" style="font-size:1.35rem;margin:0;">Calculation Governance Console</h4>
                    <p id="rulesModalSubtitle" style="margin:4px 0 0 0;font-size:0.85rem;opacity:0.9;">Configure branch/category scope and alternate code merges before previewing</p>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <ul class="nav nav-tabs portal-pills mb-4" id="modalTab" role="tablist" style="border-bottom:2px solid var(--line);">
                    <li class="nav-item" role="presentation" style="margin-right:8px;">
                        <button class="nav-link active fw-bold" id="branch-rules-tab" data-bs-toggle="tab" data-bs-target="#branch-rules" type="button" role="tab" aria-selected="true" style="border-radius:6px;padding:8px 16px;">
                            рџ’ј Branch Inclusion Scope
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold" id="code-mappings-tab" data-bs-toggle="tab" data-bs-target="#code-mappings" type="button" role="tab" aria-selected="false" style="border-radius:6px;padding:8px 16px;">
                            рџ”— Alternate Code Merges
                        </button>
                    </li>
                </ul>
                <div class="tab-content mt-3" id="modalTabContent">
                    <!-- Branch Rules Tab -->
                    <div class="tab-pane fade show active" id="branch-rules" role="tabpanel">
                        <div class="alert alert-info py-2 px-3 small border-0 mb-3" style="background:rgba(13,202,240,0.08);color:#087990;border-radius:6px;">
                            рџ’Ў Configure the allowed categories and party types for each branch. Uncheck any options to exclude them from the incentive calculation.
                        </div>

                        <!-- Real-time search and select-all actions -->
                        <div class="d-flex justify-content-between align-items-center mb-3 gap-3">
                            <div class="input-group input-group-sm" style="max-width: 320px;">
                                <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-magnifying-glass"></i></span>
                                <input type="text" id="branchSearchInput" class="form-control border-start-0 ps-0" placeholder="Search branches by code..." style="font-size:0.85rem;" />
                            </div>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-primary" id="selectAllCatsBtn" style="font-size: 0.78rem;">Select All Categories</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="deselectAllCatsBtn" style="font-size: 0.78rem;">Deselect All</button>
                            </div>
                        </div>

                        <div class="table-responsive" style="max-height:400px;border-radius:8px;border:1px solid var(--line);">
                            <table class="table table-hover align-middle mb-0" style="font-size:0.9rem;" id="modalBranchesTable">
                                <thead class="table-light" style="position:sticky;top:0;z-index:1;">
                                    <tr>
                                        <th style="width:15%;padding:12px 16px;">Location</th>
                                        <th style="width:42%;padding:12px 16px;">Allowed Categories</th>
                                        <th style="width:43%;padding:12px 16px;">Allowed Party Types</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @{
                                    var allCats = new[] { "AA", "M", "AG" };
                                    var allTypes = new[] { "INDEPENDENT WORKSHOP", "MASS" };
                                    var branches = ViewBag.Branches as IEnumerable<IncentivePortal.Models.Branch> ?? Enumerable.Empty<IncentivePortal.Models.Branch>();
                                    int rowIdx = 0;
                                    foreach (var branch in branches)
                                    {
                                        var defCats = (branch.AllowedCategories ?? "AA,M")
                                            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                        var defTypes = (branch.AllowedPartyTypes ?? "INDEPENDENT WORKSHOP")
                                            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                        <tr data-loc="@branch.Code">
                                            <td data-label="Location" style="padding:12px 16px;"><strong style="color:var(--brand);">@branch.Code</strong></td>
                                            <td data-label="Allowed Categories" style="padding:12px 16px;">
                                                @foreach (var cat in allCats)
                                                {
                                                    var cbId = $"cat_{rowIdx}_{cat}";
                                                    var isChk = defCats.Contains(cat);
                                                    <div class="form-check form-check-inline me-3 mb-1">
                                                        <input class="form-check-input branch-cat-check" type="checkbox" data-loc="@branch.Code" value="@cat" id="@cbId" @(isChk ? "checked" : "") />
                                                        <label class="form-check-label small fw-bold" for="@cbId" style="cursor:pointer;">@cat</label>
