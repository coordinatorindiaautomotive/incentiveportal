                                    }
                                    if (!branches.Any())
                                    {
                                        <tr><td colspan="3" class="text-center text-muted py-3">No branches configured. Please add branches in Master Data.</td></tr>
                                    }
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Code Mappings Tab -->
                    <div class="tab-pane fade" id="code-mappings" role="tabpanel">
                        <div class="alert alert-info py-2 px-3 small border-0 mb-3" style="background:rgba(13,202,240,0.08);color:#087990;border-radius:6px;">
