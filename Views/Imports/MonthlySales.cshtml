                                            </td>
                                            <td data-label="Allowed Party Types" style="padding:12px 16px;">
                                                @foreach (var pt in allTypes)
                                                {
                                                    var cbId2 = $"type_{rowIdx}_{pt.Replace(" ", "_")}";
                                                    var isChk2 = defTypes.Contains(pt);
                                                    <div class="form-check form-check-inline me-3 mb-1">
                                                        <input class="form-check-input branch-type-check" type="checkbox" data-loc="@branch.Code" value="@pt" id="@cbId2" @(isChk2 ? "checked" : "") />
