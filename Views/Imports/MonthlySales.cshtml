@section Scripts {
<script>
let currentBranchRules = [];
let currentMappings = [];
let isCalcMode = false;
let pendingCalcBranchRules = [];

function forceDismissModal(modalId) {
    const modalEl = document.getElementById(modalId);
    if (modalEl) {
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        if (modal) {
            modal.hide();
        }
    }
    $('.modal-backdrop').remove();
    $('body').removeClass('modal-open').css({ overflow: '', 'padding-right': '' });
}

function updateImportStats(rows) {
    const total = (rows.length > 0 && rows[0].totalRawRows) ? rows[0].totalRawRows : rows.length;
    const errors = rows.some(r => r.error) ? rows.filter(r => r.error).length : 0;
    $('#totalRows').text(total.toLocaleString());
    $('#validRows').text((total - errors).toLocaleString());
    $('#errorRows').text(errors.toLocaleString());
}

// Interactive Stepper progression helper
function setStepper(stepNum) {
    const percent = ((stepNum - 1) / 3) * 100;
    $('#stepperProgress').css('width', percent + '%');
    
    for (let i = 1; i <= 4; i++) {
        const item = $('#step' + i);
        if (i < stepNum) {
            item.removeClass('active').addClass('completed');
        } else if (i === stepNum) {
            item.removeClass('completed').addClass('active');
        } else {
            item.removeClass('active completed');
        }
    }
}

// High-performance value counting animation
function animateValue(id, start, end, duration, prefix = "") {
    if (isNaN(end)) end = 0;
    const obj = document.getElementById(id);
    if (!obj) return;
    let startTimestamp = null;
    const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const currentVal = Math.floor(progress * (end - start) + start);
        if (prefix === "в‚№") {
            obj.innerHTML = prefix + currentVal.toLocaleString('en-IN');
        } else {
            obj.innerHTML = currentVal.toLocaleString();
        }
        if (progress < 1) {
            window.requestAnimationFrame(step);
        } else {
            if (prefix === "в‚№") {
                obj.innerHTML = prefix + end.toLocaleString('en-IN');
            } else {
                obj.innerHTML = end.toLocaleString();
            }
        }
    };
    window.requestAnimationFrame(step);
}

$(document).ready(function() {
    // Elements are loaded, but we still use delegated handlers for maximum safety.
});

// Modal branch searching logic
$(document).on('keyup', '#branchSearchInput', function() {
    const val = $(this).val().trim().toUpperCase();
    $('#modalBranchesTable tbody tr').each(function() {
        const loc = $(this).data('loc') ? $(this).data('loc').toString().toUpperCase() : '';
        if (loc.indexOf(val) > -1) {
            $(this).show();
        } else {
            $(this).hide();
        }
    });
});

// Modal select all/deselect all categories
$(document).on('click', '#selectAllCatsBtn', function() {
    $('#modalBranchesTable tbody tr:visible .branch-cat-check').prop('checked', true);
});
$(document).on('click', '#deselectAllCatsBtn', function() {
    $('#modalBranchesTable tbody tr:visible .branch-cat-check').prop('checked', false);
});

function addMappingRow(alt, orig) {
    const tbody = $('#modalMappingsTable tbody');
    tbody.append(`
        <tr class="mapping-row">
            <td data-label="Alternate Party Code" style="padding: 8px 16px; width: 42%;">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light text-muted"><i class="fa-solid fa-link-slash"></i></span>
                    <input class="form-control mapping-alt-input" placeholder="Alternate Code (e.g. 1944A)" value="${alt || ''}" style="height: 34px;" />
                </div>
            </td>
            <td style="padding: 8px 16px; width: 10%; text-align: center; vertical-align: middle;">
                <span style="font-size: 1.25rem; color: var(--brand, #2563eb); font-weight: bold;"><i class="fa-solid fa-circle-arrow-right"></i></span>
            </td>
            <td data-label="Merge Target" style="padding: 8px 16px; width: 38%;">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light text-muted"><i class="fa-solid fa-link"></i></span>
                    <input class="form-control mapping-orig-input" placeholder="Merge Target (e.g. 1944)" value="${orig || ''}" style="height: 34px;" />
                </div>
            </td>
            <td data-label="Action" style="padding: 8px 16px; width: 10%;" class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger remove-mapping-row-btn" style="padding: 4px 12px; font-size: 0.8rem; border-radius: 6px;"><i class="fa-solid fa-trash"></i></button>
            </td>
        </tr>
    `);
}

function toggleBulkMappingArea() {
    $('#bulkMappingContainer').toggleClass('d-none');
    $('#bulkMappingInput').val('');
}

function processBulkMappings(replaceExisting) {
    var txt = $('#bulkMappingInput').val();
    if (!txt || !txt.trim()) {
        toggleBulkMappingArea();
        return;
    }

    if (replaceExisting) {
        $('#modalMappingsTable tbody').empty();
    }

    var lines = txt.split(/\r?\n/);
    var addedCount = 0;

    $.each(lines, function(i, line) {
        if (!line || !line.trim()) return;
        // Split by tab, comma, or space
        var parts = line.split(/[\t,\s]+/);
        if (parts.length >= 2) {
            var alt = $.trim(parts[0]);
            var orig = $.trim(parts[1]);
            if (alt && orig) {
                addMappingRow(alt, orig);
                addedCount++;
            }
        }
    });

    // If replaceExisting was true and we added no rows, or table is empty, add blank row
    if ($('#modalMappingsTable tbody tr').length === 0) {
        addMappingRow('', '');
    }

    toggleBulkMappingArea();
    if (addedCount > 0) {
        portalToast('Successfully processed and added ' + addedCount + ' mappings!', 'success');
    } else {
        portalToast('No valid mappings found in the pasted text.', 'warning');
    }
}

$(document).on('click', '#addMappingRowBtn', function() {
    addMappingRow('', '');
});

// ================================================================
// CALCULATE MONTHLY INCENTIVES вЂ” Opens Governance Modal from DB
// ================================================================
$(document).on('click', '#runCalcBtn', function () {
    const month = parseInt($('#calcMonth').val());
    const year = parseInt($('#calcYear').val());

    if (!month || !year) {
        portalToast('Please select a valid month and year.', 'warning');
        return;
    }

    const btn = this;
    portalSetBusy(btn, 'Loading...');
    isCalcMode = true;

    const monthNames = ["January", "February", "March", "April", "May", "June",
                        "July", "August", "September", "October", "November", "December"];
    const monthName = (month >= 1 && month <= 12) ? monthNames[month - 1] : month;
    $('#rulesModalSubtitle').text(`Configure Scope вЂ” ${monthName} ${year}`);

    // Show correct footer buttons: hide both old preview and calculate buttons, show calculation preview button
    $('#applyRulesAndPreviewBtn').addClass('d-none');
    $('#applyRulesAndCalcBtn').addClass('d-none');
    $('#applyRulesAndCalcPreviewBtn').removeClass('d-none');

    // Fetch metadata from DB for this period
    $.ajax({
        url: '@Url.Action("GetCalcMetadata", "Imports")',
        method: 'GET',
        data: { month: month, year: year }
    })
    .done(function(meta) {
        portalClearBusy(btn);

        var categories = (meta.categories && meta.categories.length > 0) ? meta.categories : ['AA', 'M', 'AG'];
        var partyTypes = (meta.partyTypes && meta.partyTypes.length > 0) ? meta.partyTypes : ['INDEPENDENT WORKSHOP', 'MASS'];

        // Populate Branch Inclusion Scope table
        var tbody = $('#modalBranchesTable tbody').empty();
        if (meta.locations && meta.locations.length > 0) {
            $.each(meta.locations, function(i, loc) {
                var locUpper = loc.toUpperCase();
                var seededBranch = null;
                if (meta.seededBranches) {
                    var locKey = Object.keys(meta.seededBranches).find(function(k) { return k.toUpperCase() === locUpper; });
                    if (locKey) seededBranch = meta.seededBranches[locKey];
                }

                var allowedCats = (seededBranch && seededBranch.allowedCategories) ? seededBranch.allowedCategories : 'AA,M';
                var allowedTypes = (seededBranch && seededBranch.allowedPartyTypes) ? seededBranch.allowedPartyTypes : 'INDEPENDENT WORKSHOP';

                if (!allowedCats) allowedCats = 'AA,M';
                if (!allowedTypes) allowedTypes = 'INDEPENDENT WORKSHOP';

                var catArray = $.map(allowedCats.split(','), function(c) { return $.trim(c).toUpperCase(); });
                var typeArray = $.map(allowedTypes.split(','), function(t) { return $.trim(t).toUpperCase(); });

                var catTd = $('<td>').attr('data-label', 'Allowed Categories').css('padding', '12px 16px');
                var catContainer = $('<div>').addClass('allowed-grid-cats');
                $.each(categories, function(j, cat) {
                    var isChecked = $.inArray($.trim(cat).toUpperCase(), catArray) >= 0;
                    var id = 'chk_calc_cat_' + i + '_' + cat;
                    var wrapper = $('<div>').addClass('form-check mb-0');
                    var cb = $('<input>').addClass('form-check-input branch-cat-check')
                         .attr({ type: 'checkbox', 'data-loc': loc, value: cat, id: id })
                         .prop('checked', isChecked);
                    var lbl = $('<label>').addClass('form-check-label small fw-bold').attr('for', id)
                        .css('cursor', 'pointer').text(cat);
                    wrapper.append(cb).append(lbl);
                    catContainer.append(wrapper);
                });
                catTd.append(catContainer);

                var typeTd = $('<td>').attr('data-label', 'Allowed Party Types').css('padding', '12px 16px');
                var typeContainer = $('<div>').addClass('allowed-grid');
                $.each(partyTypes, function(j, pt) {
                    var isChecked = $.inArray($.trim(pt).toUpperCase(), typeArray) >= 0;
                    var id = 'chk_calc_type_' + i + '_' + pt.replace(/ /g, '_');
                    var wrapper = $('<div>').addClass('form-check mb-0');
                    var cb = $('<input>').addClass('form-check-input branch-type-check')
                         .attr({ type: 'checkbox', 'data-loc': loc, value: pt, id: id })
                         .prop('checked', isChecked);
                    var lbl = $('<label>').addClass('form-check-label small fw-bold').attr('for', id)
                        .css('cursor', 'pointer').text(pt);
                    wrapper.append(cb).append(lbl);
                    typeContainer.append(wrapper);
                });
                typeTd.append(typeContainer);

                var locTd = $('<td>').attr('data-label', 'Location').css('padding', '12px 16px')
                    .append($('<strong>').css('color', 'var(--primary)').text(loc));
                var tr = $('<tr>').attr('data-loc', loc).append(locTd).append(catTd).append(typeTd);
                tbody.append(tr);
            });
        } else {
            tbody.append('<tr><td colspan="3" class="text-center text-muted py-3">No sales data found for this period. Please import data first.</td></tr>');
        }

        // Populate alternate code mappings
        var mappingsBody = $('#modalMappingsTable tbody').empty();
        if (meta.seededPartyMappings && meta.seededPartyMappings.length > 0) {
            $.each(meta.seededPartyMappings, function(i, m) { addMappingRow(m.alternateCode, m.originalCode); });
        } else {
            addMappingRow('', '');
        }

        // Show modal
        var modalEl = document.getElementById('rulesModal');
        var bsModal = bootstrap.Modal.getOrCreateInstance(modalEl);
        bsModal.show();
    })
    .fail(function(xhr) {
        portalClearBusy(btn);
        isCalcMode = false;
        $('#applyRulesAndPreviewBtn').removeClass('d-none');
        $('#applyRulesAndCalcPreviewBtn').addClass('d-none');
        var msg = xhr.responseJSON?.message || xhr.responseText || 'Failed to load calculation metadata.';
        portalToast(msg, 'error');
    });
});

// Apply Rules & Run Preview (for calculation mode) button handler
$(document).on('click', '#applyRulesAndCalcPreviewBtn', function () {
    const month = parseInt($('#calcMonth').val());
    const year = parseInt($('#calcYear').val());
    const force = $('#calcForce').val();

    // Collect branch rules from modal
    const branchRules = [];
    $('#modalBranchesTable tbody tr').each(function() {
        const loc = $(this).data('loc');
        const checkedCats = [];
        $(this).find('.branch-cat-check:checked').each(function() { checkedCats.push($(this).val()); });
        const checkedTypes = [];
        $(this).find('.branch-type-check:checked').each(function() { checkedTypes.push($(this).val()); });
        branchRules.push({
            location: loc,
            allowedCategories: checkedCats.join(','),
            allowedPartyTypes: checkedTypes.join(',')
        });
    });

    // Collect custom mappings from modal
    const codeMappings = [];
    $('#modalMappingsTable tbody tr.mapping-row').each(function() {
        const alt = $(this).find('.mapping-alt-input').val().trim();
        const orig = $(this).find('.mapping-orig-input').val().trim();
        if (alt && orig) {
            codeMappings.push({ AlternateCode: alt, OriginalCode: orig });
        }
    });

    pendingCalcBranchRules = branchRules;
    pendingCalcPartyMappings = codeMappings;
    forceDismissModal('rulesModal');

    // Reset footer state for next open
    $('#applyRulesAndPreviewBtn').removeClass('d-none');
    $('#applyRulesAndCalcPreviewBtn').addClass('d-none');
    isCalcMode = false;

    // Execute preview instead of direct calculation
    runCalculationPreview(month, year, force, branchRules, codeMappings);
});

// Module-level state for the currently previewed period
var currentCalcMonth = null;
var currentCalcYear  = null;
var currentCalcForce = true;
var pendingCalcBranchRulesSnapshot = [];
var pendingCalcPartyMappingsSnapshot = [];

function runCalculationPreview(month, year, force, branchRules, partyMappings) {
    currentCalcMonth = month;
    currentCalcYear  = year;
    currentCalcForce = force;
    pendingCalcBranchRulesSnapshot = branchRules || [];
    pendingCalcPartyMappingsSnapshot = partyMappings || [];

    $('#commitCalcBtn').hide();
    $('#downloadCalcPreviewBtn').hide();

    // Destroy DataTable if it exists
    if ($.fn.DataTable.isDataTable('#calcPreviewTable')) {
        $('#calcPreviewTable').DataTable().destroy();
    }

    const btn = document.getElementById('runCalcBtn');
    portalSetBusy(btn, 'Running Calculation Preview...');
    $('#calcStatusRow').hide();

    $.ajax({
        url: '@Url.Action("PreviewCalculation", "Imports")',
        method: 'POST',
        data: {
            month: month,
            year: year,
            forceRecalculate: force,
            branchRulesJson: branchRules && branchRules.length > 0 ? JSON.stringify(branchRules) : '',
            partyMappingsJson: partyMappings && partyMappings.length > 0 ? JSON.stringify(partyMappings) : '',
            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
        }
    })
    .done(rows => {
        portalClearBusy(btn);
        
        const body = $('#calcPreviewTable tbody').empty();
        
        // Sum high-level financial stats for animation
        let totalSales = 0;
        let grossIncentives = 0;
        let netTransfer = 0;
        let hasPendingApprovals = false;
        
        $.each(rows, (i, r) => {
            totalSales += Number(r.saleValue || 0);
            grossIncentives += Number(r.grossIncentive || 0);
            netTransfer += Number(r.netTransfer || 0);

            if (r.status === "Pending Approval") {
                hasPendingApprovals = true;
            }

            const badge = r.status === "Pending Approval"
                ? `<span class="status-badge warning text-warning bg-warning-subtle border border-warning-subtle px-2 py-1" style="border-radius: 6px; font-weight: 600; font-size: 0.72rem;"><i class="fa-solid fa-clock me-1"></i>Pending Approval</span>`
                : (r.isEdited 
                    ? `<span class="status-badge success text-success bg-success-subtle border border-success-subtle px-2 py-1" style="border-radius: 6px; font-weight: 600; font-size: 0.72rem;"><i class="fa-solid fa-circle-check me-1"></i>Posted (Edited)</span>`
                    : `<span class="status-badge success text-success bg-success-subtle border border-success-subtle px-2 py-1" style="border-radius: 6px; font-weight: 600; font-size: 0.72rem;"><i class="fa-solid fa-circle-check me-1"></i>Posted</span>`);

            const rowStyle = r.isEdited
                ? `style="background-color: rgba(245, 158, 11, 0.04);"`
                : ``;

            const actions = `
                <div class="d-flex gap-1 justify-content-center">
                    <button class="btn btn-xs calc-edit-btn" title="Edit Sale Values"
                        data-party="${r.partyCode}" data-month="${currentCalcMonth}" data-year="${currentCalcYear}"
                        style="padding:2px 5px;font-size:.7rem;border-radius:5px;background:rgba(30, 64, 175,.1);color:var(--primary);border:1px solid rgba(30, 64, 175,.25);">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                    <button class="btn btn-xs calc-delete-btn" title="Delete Sale Record"
                        data-party="${r.partyCode}" data-month="${currentCalcMonth}" data-year="${currentCalcYear}"
                        style="padding:2px 5px;font-size:.7rem;border-radius:5px;background:rgba(239,68,68,.08);color:#ef4444;border:1px solid rgba(239,68,68,.2);">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </div>`;
            body.append(`
                <tr ${rowStyle}>
                    <td><strong>${r.partyCode}</strong></td>
                    <td class="party-name-col">${r.partyName}</td>
                    <td><span class="badge bg-secondary-subtle text-secondary">${r.location}</span></td>
                    <td class="text-end">${Number(r.saleValue).toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                    <td class="text-end">${Number(r.discount).toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                    <td><span class="text-primary small fw-bold">${r.slabApplied}</span></td>
                    <td class="text-end fw-bold">${Number(r.grossIncentive).toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                    <td class="text-end">${Number(r.tdsPercent)}%</td>
                    <td class="text-end text-danger fw-semibold">${Number(r.tdsAmount).toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                    <td class="text-end text-warning">${r.adjustedAmount > 0 ? '-' + Number(r.adjustedAmount).toLocaleString('en-IN', {maximumFractionDigits:0}) : 'вЂ”'}</td>
                    <td class="text-end text-success fw-bold">${Number(r.netTransfer).toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                    <td>${badge}</td>
                    <td class="text-center">${actions}</td>
                </tr>
            `);
        });

        if (hasPendingApprovals) {
            $('#approvalAlertContainer').show();
        } else {
            $('#approvalAlertContainer').hide();
        }

        if (rows.length === 0) {
            body.append('<tr><td colspan="13" class="text-center text-muted py-4">No calculations generated. Click "Configure &amp; Calculate" above to run the preview engine.</td></tr>');
        } else {
            // Initialize DataTable for calculation preview
            $('#calcPreviewTable').DataTable({
                pageLength: 25,
                lengthMenu: [10, 25, 50, 100],
                language: {
                    search: "",
                    searchPlaceholder: "Search calculation previews..."
                },
                dom: "<'row mb-2 align-items-center'<'col-sm-6'l><'col-sm-6 text-end'f>>t<'row mt-2'<'col-sm-6'i><'col-sm-6 text-end'p>>"
            });
        }

        // Run live counting animations on Payout KPI Tiles
        animateValue("calcTotalParties", 0, rows.length, 800);
        animateValue("calcTotalSales", 0, Math.round(totalSales), 800, "в‚№");
        animateValue("calcGrossIncentive", 0, Math.round(grossIncentives), 800, "в‚№");
        animateValue("calcNetTransfer", 0, Math.round(netTransfer), 800, "в‚№");

        // Show monthly calculation preview download & commit buttons
        $('#downloadCalcPreviewBtn').show();
        $('#commitCalcBtn').show();

        portalToast('Calculation preview generated successfully.');
        
        // Scroll down to preview panel
        $('html, body').animate({
            scrollTop: $("#calcPreviewTable").offset().top - 100
        }, 500);
    })
    .fail(xhr => {
        portalClearBusy(btn);
        const errMsg = xhr.responseJSON?.message || xhr.responseText || 'Calculation preview failed.';
        portalToast(errMsg, 'error');
    });
}

// ГўвЂќв‚¬ГўвЂќв‚¬ PAYOUT ENGINE: EDIT SALE ROW ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// Open edit modal вЂ” delegated handler (table rows are re-created on each preview)
$(document).on('click', '.calc-edit-btn', function () {
    const partyCode = $(this).data('party');
    const month     = $(this).data('month');
    const year      = $(this).data('year');

    // Fetch current sale values
    $.ajax({
        url: '@Url.Action("GetSaleRow", "Imports")',
        method: 'GET',
        data: { partyCode, month, year }
    })
    .done(function (s) {
        if (s.isLocked) {
            portalToast('This period is locked. Unlock it first from Control Tower.', 'error');
            return;
        }
        $('#editSaleId').val(s.id);
        $('#editSaleMonth').val(s.month);
        $('#editSaleYear').val(s.year);
        $('#editSalePartyCode').val(s.partyCode);
        $('#editSaleValue').val(s.saleValue);
        $('#editSaleDiscount').val(s.discount);
        $('#editSaleRemarks').val('');
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        $('#editSaleModalSubtitle').text(`${s.partyCode} В· ${s.partyName} В· ${months[s.month-1]}-${s.year}`);
        const modal = new bootstrap.Modal(document.getElementById('editSaleModal'));
        modal.show();
    })
    .fail(function (xhr) {
        portalToast(xhr.responseJSON?.message || 'Could not load sale record.', 'error');
    });
});

// Save edit modal
$(document).on('click', '#saveEditSaleBtn', function () {
    const id        = $('#editSaleId').val();
    const saleValue = $('#editSaleValue').val();
    const discount  = $('#editSaleDiscount').val();
    const remarks   = $('#editSaleRemarks').val();

    if (!id || saleValue === '') {
        portalToast('Please enter a sale value.', 'error');
        return;
    }

    const btn = this;
    portalSetBusy(btn, 'Saving...');

    $.ajax({
        url: '@Url.Action("EditSaleRow", "Imports")',
        method: 'POST',
        data: {
            id, saleValue, discount, remarks,
            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val()
        }
    })
    .done(function (res) {
        portalClearBusy(btn);
        bootstrap.Modal.getInstance(document.getElementById('editSaleModal')).hide();
        portalToast(res.message || 'Saved! Re-running preview...');
        // Auto re-run the preview to show updated incentive
        runCalculationPreview(currentCalcMonth, currentCalcYear, currentCalcForce, pendingCalcBranchRulesSnapshot, pendingCalcPartyMappingsSnapshot);
    })
    .fail(function (xhr) {
        portalClearBusy(btn);
        portalToast(xhr.responseJSON?.message || 'Save failed.', 'error');
    });
});

// ГўвЂќв‚¬ГўвЂќв‚¬ PAYOUT ENGINE: DELETE SALE ROW ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
$(document).on('click', '.calc-delete-btn', function () {
    const partyCode = $(this).data('party');
    const month     = $(this).data('month');
    const year      = $(this).data('year');

    // First fetch the sale ID
    $.ajax({
        url: '@Url.Action("GetSaleRow", "Imports")',
        method: 'GET',
        data: { partyCode, month, year }
    })
    .done(function (s) {
        if (s.isLocked) {
            portalToast('This period is locked. Unlock it first from Control Tower.', 'error');
            return;
        }
        const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        Swal.fire({
            title: 'Delete Sale Record?',
            html: `<div style='font-size:.9rem;'>
                    <b>${s.partyCode}</b> вЂ” ${s.partyName}<br/>
                    <span class='text-muted'>${months[s.month-1]}-${s.year}</span><br/><br/>
                    Sale Value: <b>\u20b9${Number(s.saleValue).toLocaleString('en-IN')}</b>
                   </div>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: '<i class="fa-solid fa-trash-can me-1"></i> Delete',
            cancelButtonText: 'Cancel'
        }).then(result => {
            if (!result.isConfirmed) return;

            $.ajax({
                url: '@Url.Action("DeleteSaleRow", "Imports")',
                method: 'POST',
                data: {
                    id: s.id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val()
                }
            })
            .done(function (res) {
                portalToast(res.message || 'Deleted! Re-running preview...');
                runCalculationPreview(currentCalcMonth, currentCalcYear, currentCalcForce, pendingCalcBranchRulesSnapshot, pendingCalcPartyMappingsSnapshot);
            })
            .fail(function (xhr) {
                portalToast(xhr.responseJSON?.message || 'Delete failed.', 'error');
            });
        });
    })
    .fail(function (xhr) {
        portalToast(xhr.responseJSON?.message || 'Could not load sale record.', 'error');
    });
});

// Download calculation preview Excel click handler
$(document).on('click', '#downloadCalcPreviewBtn', function() {
    const month = parseInt($('#calcMonth').val());
    const year = parseInt($('#calcYear').val());
    const force = $('#calcForce').val();
    const rulesJson = pendingCalcBranchRules.length > 0 ? JSON.stringify(pendingCalcBranchRules) : '';
    const mappingsJson = pendingCalcPartyMappings.length > 0 ? JSON.stringify(pendingCalcPartyMappings) : '';

    // Create a dynamic form to submit as a POST request so that it triggers a file download without URL length limits
    const form = $('<form>', {
        action: '@Url.Action("ExportCalculationPreview", "Imports")',
        method: 'POST',
        target: '_blank'
    });

    form.append($('<input>', { type: 'hidden', name: 'month', value: month }));
    form.append($('<input>', { type: 'hidden', name: 'year', value: year }));
    form.append($('<input>', { type: 'hidden', name: 'forceRecalculate', value: force }));
    form.append($('<input>', { type: 'hidden', name: 'branchRulesJson', value: rulesJson }));
    form.append($('<input>', { type: 'hidden', name: 'partyMappingsJson', value: mappingsJson }));
    form.append($('<input>', { type: 'hidden', name: '__RequestVerificationToken', value: $('input[name="__RequestVerificationToken"]').val() }));

    $('body').append(form);
    form.submit();
    form.remove();
});

// Pre-Calculated Excel Import memory stores
let precalcFileRows = null;
let uploadedPrecalcFile = null;
