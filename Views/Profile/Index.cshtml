@model IncentivePortal.Models.User
@{
    ViewData["Title"] = "Account Profile";
    var recentLogs = ViewBag.RecentLogs as List<IncentivePortal.Models.AuditLog> ?? new List<IncentivePortal.Models.AuditLog>();
    var roles = Model.UserRoles.Select(ur => ur.Role.Name).ToList();
    var rolesDisplay = roles.Any() ? string.Join(", ", roles) : "No Assigned Role";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">User Settings</div>
        <h1 class="page-h1">Account Profile</h1>
    </div>
    <div class="page-header-actions">
        <span class="badge bg-primary px-3 py-2 fs-6 shadow-sm"><i class="fa-solid fa-shield-halved me-1"></i> Active Session</span>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: User Card & Forms -->
    <div class="col-xl-5 col-lg-6">
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3 pb-3 mb-3 border-bottom">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white font-bold" style="width: 60px; height: 60px; font-size: 24px; background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);">
                        @Model.UserName.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <h4 class="mb-1 font-bold text-ink">@Model.UserName</h4>
                        <p class="text-muted mb-0 small">@rolesDisplay</p>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <div class="small text-muted">Account Status</div>
                        <div class="fw-semibold text-success"><i class="fa-solid fa-circle-check me-1"></i> Active</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">Corporate Branch</div>
                        <div class="fw-semibold text-ink">@(Model.Branch?.Name ?? "General Office / HO")</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">Branch Code</div>
                        <div class="fw-semibold text-ink">@(Model.Branch?.Code ?? "N/A")</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-muted">Last Login</div>
                        <div class="fw-semibold text-ink small">@(Model.LastLoginAt?.ToLocalTime().ToString("g") ?? "Just Now")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Update Details Card -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h5 class="card-title font-bold text-ink mb-1"><i class="fa-solid fa-envelope me-2 text-primary"></i> Contact Information</h5>
                <p class="text-muted small mb-0">Update your registered corporate email address.</p>
            </div>
            <div class="card-body p-4">
                <form id="emailForm" asp-action="UpdateEmail" asp-controller="Profile" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="Email" class="form-label font-bold small text-muted">Corporate Email</label>
                        <input type="email" class="form-control" id="Email" name="email" value="@Model.Email" required style="border-radius: 8px;" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold" style="border-radius: 8px; padding: 10px;">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Save Contact Details
                    </button>
                </form>
            </div>
        </div>

        <!-- Change Password Card -->
        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h5 class="card-title font-bold text-ink mb-1"><i class="fa-solid fa-key me-2 text-primary"></i> Change Password</h5>
                <p class="text-muted small mb-0">Update your security credentials regularly to maintain safety.</p>
            </div>
            <div class="card-body p-4">
                <form id="passwordForm" asp-action="ChangePassword" asp-controller="Profile" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="CurrentPassword" class="form-label font-bold small text-muted">Current Password</label>
                        <input type="password" class="form-control" id="CurrentPassword" name="currentPassword" required style="border-radius: 8px;" />
                    </div>
                    <div class="mb-3">
                        <label for="NewPassword" class="form-label font-bold small text-muted">New Password</label>
                        <input type="password" class="form-control" id="NewPassword" name="newPassword" required style="border-radius: 8px;" />
                        <div class="form-text small">Password must be at least 6 characters.</div>
                    </div>
                    <div class="mb-3">
                        <label for="ConfirmPassword" class="form-label font-bold small text-muted">Confirm New Password</label>
                        <input type="password" class="form-control" id="ConfirmPassword" name="confirmPassword" required style="border-radius: 8px;" />
                    </div>
                    <button type="submit" class="btn btn-outline-primary w-100 fw-bold" style="border-radius: 8px; padding: 10px;">
                        <i class="fa-solid fa-lock me-1"></i> Update Security Credentials
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right Column: Audit Logs -->
    <div class="col-xl-7 col-lg-6">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; display: flex; flex-direction: column;">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h5 class="card-title font-bold text-ink mb-1"><i class="fa-solid fa-user-shield me-2 text-primary"></i> Security &amp; Activity Log</h5>
                <p class="text-muted small mb-0">Audit history of changes and operations performed under your user account.</p>
            </div>
            <div class="card-body p-4 d-flex flex-column flex-grow-1">
                @if (recentLogs.Any())
                {
                    <div class="table-responsive flex-grow-1" style="max-height: 580px; overflow-y: auto;">
                        <table class="table align-middle table-hover text-ink" style="font-size: 0.85rem;">
                            <thead>
                                <tr class="text-muted small">
                                    <th>Operation</th>
                                    <th>Context / Target</th>
                                    <th>Terminal IP</th>
                                    <th class="text-end">Timestamp</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in recentLogs)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @(log.Action.Contains("Failed") || log.Action.Contains("Blocked") ? "bg-danger-subtle text-danger" : "bg-primary-subtle text-primary") px-2 py-1">
                                                @log.Action
                                            </span>
                                        </td>
                                        <td>
                                            <span class="fw-semibold">@log.EntityName</span>
                                            @if (!string.IsNullOrEmpty(log.EntityId) && log.EntityId != "{}")
                                            {
                                                <span class="text-muted small ms-1">(@log.EntityId)</span>
                                            }
                                        </td>
                                        <td class="text-muted small">@(string.IsNullOrEmpty(log.IpAddress) || log.IpAddress == "::1" ? "Localhost" : log.IpAddress)</td>
                                        <td class="text-end text-muted small">@log.ChangedAt.ToLocalTime().ToString("g")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column align-items-center justify-content-center text-center py-5 my-5 flex-grow-1">
                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-clock-rotate-left fs-3 text-muted"></i>
                        </div>
                        <h6 class="font-bold text-ink">No logs recorded yet</h6>
                        <p class="text-muted small max-w-sm">When you perform operations on the portal, your audit log registry history will appear here.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            // Email details update form submittal
            $('#emailForm').on('submit', function (e) {
                e.preventDefault();
                var $form = $(this);
                var $btn = $form.find('button[type="submit"]');
                var originalText = $btn.html();

                $btn.prop('disabled', true).html('<i class="fa-solid fa-circle-notch fa-spin me-1"></i> Saving...');

                $.ajax({
                    url: $form.attr('action'),
                    type: 'POST',
                    data: $form.serialize(),
                    success: function (res) {
                        portalToast(res.message || 'Email details updated successfully.', 'success');
                    },
                    error: function (xhr) {
                        portalToast(xhr.responseJSON?.message || 'Failed to update email details.', 'error');
                    },
                    complete: function () {
                        $btn.prop('disabled', false).html(originalText);
                    }
                });
            });

            // Password update form submittal
            $('#passwordForm').on('submit', function (e) {
                e.preventDefault();
                var $form = $(this);
                
                var newPwd = $('#NewPassword').val();
                var confirmPwd = $('#ConfirmPassword').val();
                if (newPwd !== confirmPwd) {
                    portalToast('New password and confirmation do not match.', 'warning');
                    return;
                }

                var $btn = $form.find('button[type="submit"]');
                var originalText = $btn.html();

                $btn.prop('disabled', true).html('<i class="fa-solid fa-circle-notch fa-spin me-1"></i> Updating...');

                $.ajax({
                    url: $form.attr('action'),
                    type: 'POST',
                    data: $form.serialize(),
                    success: function (res) {
                        portalToast(res.message || 'Password updated successfully.', 'success');
                        $form[0].reset();
                    },
                    error: function (xhr) {
                        portalToast(xhr.responseJSON?.message || 'Failed to update password.', 'error');
                    },
                    complete: function () {
                        $btn.prop('disabled', false).html(originalText);
                    }
                });
            });
        });
    </script>
}

