                        <span class="material-symbols-outlined">lock_open</span>
                    </div>
                    <h3 class="font-headline-md text-lg font-bold">Data Integrity Locks</h3>
                </div>
            </div>
            <div class="p-md space-y-6">
                <div class="grid grid-cols-1 xl:grid-cols-12 gap-gutter items-start">
                    
                    <!-- Active Period Locks List -->
                    <div class="xl:col-span-8 space-y-4">
                        <p class="text-body-sm text-on-surface-variant/70">Controlled periods prevent accidental modification or recalculation of historical distributor settlements.</p>
                        
