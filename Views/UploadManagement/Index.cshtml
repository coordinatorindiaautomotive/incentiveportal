    </div>
</div>

<!-- Deletion Confirmation Modal -->
<div class="modal fade" id="deleteRawModal" tabindex="-1" aria-labelledby="deleteRawModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-2xl overflow-hidden">
            <div class="modal-header border-b-0 pb-0 pt-6 px-6 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-error text-white rounded-full flex items-center justify-center">
                        <span class="material-symbols-outlined">warning</span>
                    </div>
                    <h5 class="modal-title font-headline-md text-base font-bold text-on-background" id="deleteRawModalLabel">Confirm Deletion</h5>
                </div>
                <button type="button" class="btn-close text-outline hover:text-black" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-6 py-4 space-y-3">
                <p class="text-xs text-on-surface-variant">You are about to permanently delete:</p>
                <div class="p-3.5 bg-red-50 text-red-800 rounded-xl border border-red-100 font-bold text-xs" id="del-modal-summary">
                    – records for –
                </div>
                <p class="text-xs text-on-surface-variant">This action <strong>cannot be undone</strong> and will clear associated logs. Type <code class="bg-surface px-1.5 py-0.5 rounded text-error font-extrabold">DELETE</code> to confirm:</p>
                <input type="text" id="del-confirm-input" class="w-full bg-surface border border-outline-variant rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-error/20" placeholder="Type DELETE to confirm" />
            </div>
            <div class="modal-body px-6 pb-6 pt-0 flex justify-end gap-3 border-t-0">
                <button type="button" class="px-4 py-2 border border-outline-variant rounded-xl text-xs font-semibold hover:bg-surface" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="px-5 py-2 bg-error text-white font-bold text-xs rounded-xl hover:bg-error/90" id="btn-modal-confirm-delete" onclick="confirmDeleteRaw()" disabled>
                    <span class="material-symbols-outlined text-sm mr-1">delete</span> Yes, Delete Permanently
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Module states
    let currentFile = null;
    let previewToken = null;
    let previewRows = [];
    let filteredPreviewRows = [];
    let currentPage = 1;
    const pageSize = 10;
    
    let pollInterval = null;
    let importStartTime = null;

    // Month name utility
    const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    function getMonthLabel(monthNum, yearNum) {
        if (monthNum >= 1 && monthNum <= 12) {
            return `${monthNames[monthNum - 1]} ${yearNum}`;
        }
        return `${monthNum} ${yearNum}`;
    }

    // Initialize Event Listeners
    document.addEventListener("DOMContentLoaded", () => {
        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('file-input');

        if (dropZone) {
            // Drag and Drop
            ['dragenter', 'dragover'].forEach(eventName => {
                dropZone.addEventListener(eventName, (e) => {
                    e.preventDefault();
                    dropZone.classList.add('border-secondary', 'bg-secondary/15', 'scale-[1.01]');
                }, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, (e) => {
                    e.preventDefault();
                    dropZone.classList.remove('border-secondary', 'bg-secondary/15', 'scale-[1.01]');
                }, false);
            });

            dropZone.addEventListener('drop', (e) => {
                const dt = e.dataTransfer;
                const files = dt.files;
                if (files.length > 0) {
                    fileInput.files = files;
                    handleFileSelection(files[0]);
                }
            }, false);
        }

        if (fileInput) {
            fileInput.addEventListener('change', function() {
                if (this.files.length > 0) {
                    handleFileSelection(this.files[0]);
                }
            });
        }

        // Filter text box
        const previewFilter = document.getElementById('preview-filter');
        if (previewFilter) {
            previewFilter.addEventListener('input', function() {
                filterPreviewData(this.value);
            });
        }

        // Load month locks list
        loadLocks();
    });

    // Reset view
    function resetUpload() {
        clearInterval(pollInterval);
        currentFile = null;
        previewRows = [];
        filteredPreviewRows = [];
        currentPage = 1;
        
        document.getElementById('file-input').value = "";
        document.getElementById('commit-reason').value = "";
        document.getElementById('preview-filter').value = "";
        
        document.getElementById('upload-card-wrapper').classList.remove('d-none');
        document.getElementById('progress-card').classList.add('d-none');
        document.getElementById('error-card').classList.add('d-none');
        document.getElementById('preview-panel').classList.add('d-none');
        document.getElementById('success-panel').classList.add('d-none');
    }

    // Set UI Progress state
    function updateProgress(percentage, title, subtitle) {
        document.getElementById('progress-card').classList.remove('d-none');
        document.getElementById('progress-bar').style.width = percentage + '%';
        document.getElementById('progress-pct').innerText = Math.round(percentage);
        
        if (title) document.getElementById('progress-title').innerText = title;
        if (subtitle) document.getElementById('progress-subtitle').innerText = subtitle;
    }

    // Show Error
    function showError(message) {
        document.getElementById('progress-card').classList.add('d-none');
        document.getElementById('preview-panel').classList.add('d-none');
        document.getElementById('success-panel').classList.add('d-none');
        
        document.getElementById('error-card').classList.remove('d-none');
        document.getElementById('error-message').innerText = message;
    }

    // File selection entry point
    function handleFileSelection(file) {
        if (!file) return;
        currentFile = file;
        
        document.getElementById('error-card').classList.add('d-none');
        document.getElementById('upload-card-wrapper').classList.add('d-none');
        
        updateProgress(20, "Reading Excel File...", "Extracting sheets and columns structures");
        
        // Post file to preview endpoint
        const formData = new FormData();
        formData.append("file", file);
        formData.append("uploadMode", "Sales");

        fetch('/Imports/Preview', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || ''
            }
        })
        .then(async response => {
            const text = await response.text();
            let json = null;
            try {
                json = text ? JSON.parse(text) : null;
            } catch (e) { }

            if (!response.ok) {
                const errorMsg = (json && json.message) || text || "The selected spreadsheet structure is invalid. Verify column names.";
                throw new Error(errorMsg);
            }
            return json;
        })
        .then(data => {
            updateProgress(100, "Spreadsheet read successfully", "Parsing row records");
            previewToken = data.previewToken || null;
            const rowsToDisplay = data.rows || data;
            setTimeout(() => {
                document.getElementById('progress-card').classList.add('d-none');
                displayPreview(file, rowsToDisplay);
            }, 400);
        })
        .catch(err => {
            showError(err.message);
        });
    }

    // Process and display preview data
    function displayPreview(file, rows) {
        previewRows = rows;
        filteredPreviewRows = [...rows];
        currentPage = 1;
        
        // Populate Summary dashboard
        document.getElementById('summary-filename').innerText = file.name;
        document.getElementById('summary-filename').title = file.name;
        document.getElementById('summary-filesize').innerText = formatBytes(file.size);
        document.getElementById('summary-totalrows').innerText = rows.length.toLocaleString();
        
        // Month year analysis
        const currentYear = new Date().getFullYear();
        const currentMonth = new Date().getMonth() + 1;
        const periodsMap = new Map();
        
        let fatalErrorCount = 0;
        
        rows.forEach(r => {
            const key = `${r.month}-${r.year}`;
            if (!periodsMap.has(key)) {
                periodsMap.set(key, { month: r.month, year: r.year, label: getMonthLabel(r.month, r.year) });
            }
            if (r.error && r.validationStatus === "Invalid") {
                fatalErrorCount++;
            }
        });
        
        // Generate period impact badges
        let periodsHtml = "";
        periodsMap.forEach(p => {
            const isCurrent = p.year > currentYear || (p.year === currentYear && p.month >= currentMonth);
            const badgeClass = isCurrent ? 'text-[10px] font-bold text-error bg-error-container/20 border border-error/25 px-2.5 py-0.5 rounded-full uppercase tracking-wider' : 'text-[10px] font-bold text-secondary bg-secondary-container/10 border border-secondary/15 px-2.5 py-0.5 rounded-full uppercase tracking-wider';
            const actionLabel = isCurrent ? 'Overwrite Month' : 'Append Raw';
            const tooltip = isCurrent ? 'Current period: all existing data for this month will be cleared first.' : 'Historical month: records will be appended without clearing previous data.';
            
            periodsHtml += `
                <div class="d-inline-flex align-items-center gap-2 p-2 border border-outline-variant/30 bg-surface rounded-xl shadow-sm" title="${tooltip}">
                    <strong class="text-xs text-on-surface font-headline-md">${p.label}</strong>
                    <span class="${badgeClass}">${actionLabel}</span>
                </div>
            `;
        });
        document.getElementById('periods-list-container').innerHTML = periodsHtml || '<span class="text-muted small">No target months found</span>';
        
        // Show status badge based on errors
        const statusBadge = document.getElementById('summary-status');
        const commitBtn = document.getElementById('btn-confirm-commit');
        
        if (fatalErrorCount > 0) {
            statusBadge.className = "mt-1 inline-flex items-center gap-1 text-xs font-bold text-error";
            statusBadge.innerHTML = `<span class="material-symbols-outlined text-sm">cancel</span> ${fatalErrorCount} Blockers Found`;
            commitBtn.disabled = true;
            commitBtn.title = "Please resolve fatal errors before importing data.";
        } else {
            statusBadge.className = "mt-1 inline-flex items-center gap-1 text-xs font-bold text-success";
            statusBadge.innerHTML = `<span class="material-symbols-outlined text-sm">check_circle</span> Ready to Commit`;
            commitBtn.disabled = false;
            commitBtn.title = "";
        }
        
        // Render preview table
        renderTablePage();
        document.getElementById('preview-panel').classList.remove('d-none');
    }

    // Render preview page of data
    function renderTablePage() {
        const tbody = document.getElementById('preview-table-body');
        tbody.innerHTML = "";
        
        const start = (currentPage - 1) * pageSize;
        const end = Math.min(start + pageSize, filteredPreviewRows.length);
        
        const pageData = filteredPreviewRows.slice(start, end);
        
        if (pageData.length === 0) {
            tbody.innerHTML = `<tr><td colspan="8" class="text-center text-muted py-6">No matching records found.</td></tr>`;
            document.getElementById('preview-pagination-text').innerText = "0 records";
            return;
        }

        pageData.forEach(r => {
            const tr = document.createElement('tr');
            tr.className = "hover:bg-surface-container-low transition-colors";
            
            let statusBadge = `<span class="inline-flex items-center text-[10px] font-bold text-success bg-success/15 border border-success/20 px-2 py-0.5 rounded-full uppercase tracking-wider">Valid</span>`;
            if (r.error) {
                if (r.validationStatus === "Invalid") {
                    statusBadge = `<span class="inline-flex items-center text-[10px] font-bold text-error bg-error-container/20 border border-error/25 px-2 py-0.5 rounded-full uppercase tracking-wider" title="${r.error}">Blocker</span>`;
                } else {
                    statusBadge = `<span class="inline-flex items-center text-[10px] font-bold text-amber-600 bg-amber-50 border border-amber-200 px-2 py-0.5 rounded-full uppercase tracking-wider" title="${r.error}">Warning</span>`;
                }
            }
            
            const monthLabel = getMonthLabel(r.month, r.year);
            const salesVal = typeof r.saleValue === 'number' ? r.saleValue.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : r.saleValue;
            const discVal = typeof r.discount === 'number' ? r.discount.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : r.discount;
            
            tr.innerHTML = `
                <td class="px-4 py-3 text-muted font-bold">#${r.rowNumber}</td>
                <td class="px-4 py-3 font-semibold">${monthLabel}</td>
                <td class="px-4 py-3"><span class="px-2 py-0.5 text-[11px] bg-surface-container text-on-surface border border-outline-variant/30 rounded-lg">${r.location}</span></td>
                <td class="px-4 py-3 font-medium text-truncate" style="max-width:140px;" title="${r.partyCode}">${r.partyCode}</td>
                <td class="px-4 py-3 text-on-surface-variant text-truncate" style="max-width:240px;" title="${r.partyName}">${r.partyName}</td>
                <td class="px-4 py-3 text-end font-bold text-on-background">₹ ${salesVal}</td>
                <td class="px-4 py-3 text-end text-outline">₹ ${discVal}</td>
                <td class="px-4 py-3">${statusBadge}</td>
            `;
            tbody.appendChild(tr);
        });
        
        // Update pagination text
        document.getElementById('preview-pagination-text').innerText = `Showing ${start + 1} to ${end} of ${filteredPreviewRows.length.toLocaleString()} rows`;
        document.getElementById('preview-rowcount').innerText = `${filteredPreviewRows.length.toLocaleString()} rows`;
        
        // Enable/Disable pagination buttons
        document.getElementById('btn-prev-page').disabled = currentPage === 1;
        document.getElementById('btn-next-page').disabled = end >= filteredPreviewRows.length;
    }

    // Filter preview rows
    function filterPreviewData(query) {
        if (!query) {
            filteredPreviewRows = [...previewRows];
        } else {
            const q = query.toLowerCase().trim();
            filteredPreviewRows = previewRows.filter(r => 
                r.partyCode.toLowerCase().includes(q) ||
                r.partyName.toLowerCase().includes(q) ||
                r.location.toLowerCase().includes(q) ||
                getMonthLabel(r.month, r.year).toLowerCase().includes(q)
            );
        }
        currentPage = 1;
        renderTablePage();
    }

    // Pagination controls
    function prevPage() {
        if (currentPage > 1) {
            currentPage--;
            renderTablePage();
        }
    }

    function nextPage() {
        if ((currentPage * pageSize) < filteredPreviewRows.length) {
            currentPage++;
            renderTablePage();
        }
    }

    // Format bytes to string
    function formatBytes(bytes, decimals = 2) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const dm = decimals < 0 ? 0 : decimals;
        const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
    }

    // Commit file upload
    function commitUpload() {
        if (!currentFile) return;
        
        document.getElementById('preview-panel').classList.add('d-none');
        document.getElementById('error-card').classList.add('d-none');
        
        updateProgress(5, "Queueing upload task...", "Initializing database writer transaction");
        
        const changeReason = document.getElementById('commit-reason').value;
        
        const formData = new FormData();
        formData.append("file", currentFile);
        formData.append("uploadMode", "Sales");
        formData.append("rewriteSales", "true");
        formData.append("changeReason", changeReason || "Periodic upload of sales data");
        if (previewToken) {
            formData.append("previewToken", previewToken);
        }
        
        importStartTime = performance.now();

        fetch('/Imports/Commit', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || ''
            }
        })
        .then(async response => {
            const text = await response.text();
            let json = null;
            try {
                json = text ? JSON.parse(text) : null;
            } catch (e) { }

            if (!response.ok) {
                const errorMsg = (json && json.message) || text || "Failed to initiate import commit.";
                throw new Error(errorMsg);
            }
            return json;
        })
        .then(data => {
            if (data.ok && data.jobId) {
                pollJobStatus(data.jobId);
            } else {
                throw new Error(data.message || "Invalid response structure from commit server.");
            }
        })
        .catch(err => {
            showError(err.message);
        });
    }

    // Poll background import job status
    function pollJobStatus(jobId) {
        let fakePct = 10;
        
        pollInterval = setInterval(() => {
            fetch(`/Imports/GetJobStatus?jobId=${jobId}`)
            .then(async res => {
                const text = await res.text();
                let json = null;
                try {
                    json = text ? JSON.parse(text) : null;
                } catch(e) {}
                if (!res.ok) {
                    throw new Error((json && json.message) || text || "Could not reach background worker registry.");
                }
                return json;
            })
            .then(state => {
                if (state.status === "Processing" || state.status === "Pending") {
                    fakePct = Math.min(fakePct + 8, 95);
                    updateProgress(fakePct, "Importing Sales Data...", state.message || "Writing rows to Raw Sales table");
                }
                else if (state.status === "Succeeded") {
                    clearInterval(pollInterval);
                    updateProgress(100, "Intake finished successfully", "Parsing commit aggregates");
                    
                    const durationSeconds = ((performance.now() - importStartTime) / 1000).toFixed(2);
                    
                    setTimeout(() => {
                        document.getElementById('progress-card').classList.add('d-none');
                        
                        // Show success view
                        document.getElementById('success-imported-rows').innerText = (state.successRows || 0).toLocaleString();
                        document.getElementById('success-deleted-rows').innerText = (state.deletedRows || 0).toLocaleString();
                        document.getElementById('success-duration').innerText = `${durationSeconds} seconds`;
                        document.getElementById('success-filename').innerText = currentFile.name;
                        document.getElementById('success-filename').title = currentFile.name;
                        
                        document.getElementById('success-panel').classList.remove('d-none');
                        
                        // If embedded, notify parent tower of changes
                        if (window.parent && typeof window.parent.notifyDataChanged === 'function') {
                            window.parent.notifyDataChanged();
                        }
                    }, 400);
                }
                else if (state.status === "Failed") {
                    clearInterval(pollInterval);
                    showError(state.error || "Background execution aborted. Check server logs.");
                }
            })
            .catch(err => {
                clearInterval(pollInterval);
                showError("Status polling failure: " + err.message);
            });
        }, 1000);
    }

    // Fetch and render active month locks
    function loadLocks() {
        const tbody = document.getElementById('locks-table-body');
        if (!tbody) return;

        fetch('/UploadManagement/GetLocks')
        .then(res => res.json())
        .then(data => {
            if (data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted p-4">No active month/period locks found.</td></tr>`;
                return;
            }

            let html = "";
            data.forEach(x => {
                html += `
                    <tr class="hover:bg-surface-container-low transition-colors">
                        <td class="px-4 py-3 font-bold text-on-surface">${x.lockYear}</td>
                        <td class="px-4 py-3"><span class="px-2 py-0.5 text-xs bg-surface-container text-on-surface border border-outline-variant/30 rounded-lg">${x.monthLabel}</span></td>
                        <td class="px-4 py-3 text-on-surface-variant font-medium">${x.lockedBy || 'system'}</td>
                        <td class="px-4 py-3 text-outline text-[11px]">${x.lockedAt}</td>
                        <td class="px-4 py-3 text-on-surface-variant text-truncate" style="max-width:200px;" title="${x.unlockReason || ''}">${x.unlockReason || '-'}</td>
                        <td class="px-4 py-3 text-center">
                            <button class="px-2.5 py-1 border border-red-200 text-error bg-red-50 hover:bg-red-100 rounded-lg text-xs font-semibold flex items-center gap-1 mx-auto" onclick="unlockPeriod(${x.id})">
                                <span class="material-symbols-outlined text-[14px]">lock_open</span> Unlock
                            </button>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        })
        .catch(err => {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center text-danger p-4">Failed to load locks: ${err.message}</td></tr>`;
        });
    }

    // Submit lock request
    function lockPeriod() {
        const year = document.getElementById('lock-year').value;
        const month = document.getElementById('lock-month').value;
        const reason = document.getElementById('lock-reason').value;

        const formData = new FormData();
        formData.append("year", year);
        formData.append("month", month);
        formData.append("reason", reason || "Manually locked via Lock Manager");

        fetch('/UploadManagement/LockPeriod', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || ''
            }
        })
        .then(async res => {
            const text = await res.text();
            let json = null;
            try { json = text ? JSON.parse(text) : null; } catch(e) {}

            if (!res.ok) {
                throw new Error((json && json.message) || text || "Failed to lock period.");
            }
            return json;
        })
        .then(data => {
            document.getElementById('lock-reason').value = "";
            loadLocks();
            alert("Period locked successfully.");
        })
        .catch(err => {
            alert(err.message);
        });
    }

    // Submit unlock request
    function unlockPeriod(id) {
        if (!confirm("Are you sure you want to unlock this period? This will allow uploads and modifications.")) {
            return;
        }

        const formData = new FormData();
        formData.append("id", id);

        fetch('/UploadManagement/UnlockPeriod', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || ''
            }
        })
        .then(async res => {
            const text = await res.text();
            let json = null;
            try { json = text ? JSON.parse(text) : null; } catch(e) {}

            if (!res.ok) {
                throw new Error((json && json.message) || text || "Failed to unlock period.");
            }
            return json;
        })
        .then(data => {
            loadLocks();
        })
        .catch(err => {
            alert(err.message);
        });
    }

    // ── Delete Raw Data ──
    let _delCount = 0;

    function rawCountReset() {
        _delCount = 0;
        document.getElementById('del-count-area').classList.add('d-none');
        document.getElementById('btn-delete-raw').disabled = true;
    }

    function checkRawCount() {
        const year  = document.getElementById('del-year').value;
        const month = document.getElementById('del-month').value;
        const btn   = document.getElementById('btn-check-raw');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1 w-3 h-3 border-2 border-t-transparent rounded-full animate-spin inline-block"></span> Checking...';

        fetch(`/UploadManagement/GetRawDataCount?year=${year}&month=${month}`)
        .then(async res => {
            const text = await res.text();
            let json = null;
            try { json = JSON.parse(text); } catch(e) {}
            if (!res.ok) throw new Error((json && json.message) || text || 'Failed to fetch count.');
            return json;
        })
        .then(data => {
            _delCount = data.count;
            const countArea = document.getElementById('del-count-area');
            const countText = document.getElementById('del-count-text');
            countArea.classList.remove('d-none');
            const monthNames = ['','January','February','March','April','May','June','July','August','September','October','November','December'];
            if (data.count === 0) {
                countText.innerHTML = `<span class="text-on-surface-variant font-medium">No raw records found for <strong>${monthNames[month]} ${year}</strong>. Nothing to delete.</span>`;
                document.getElementById('btn-delete-raw').disabled = true;
            } else {
                countText.innerHTML = `<span class="text-error font-extrabold">${data.count.toLocaleString()} record(s)</span> found for <strong>${monthNames[month]} ${year}</strong> — ready to purge.`;
                document.getElementById('btn-delete-raw').disabled = false;
            }
        })
        .catch(err => alert('Error: ' + err.message))
        .finally(() => {
            btn.disabled = false;
            btn.innerHTML = '<span class="material-symbols-outlined text-sm">search_check</span> Check Count';
        });
    }

    function openDeleteModal() {
        const year   = document.getElementById('del-year').value;
        const month  = document.getElementById('del-month').value;
        const monthNames = ['','January','February','March','April','May','June','July','August','September','October','November','December'];
        document.getElementById('del-modal-summary').textContent =
            `${_delCount.toLocaleString()} raw record(s) for ${monthNames[month]} ${year}`;
        document.getElementById('del-confirm-input').value = '';
        document.getElementById('btn-modal-confirm-delete').disabled = true;
        const modal = new bootstrap.Modal(document.getElementById('deleteRawModal'));
        modal.show();
    }

    document.addEventListener('DOMContentLoaded', () => {
        const confirmInput = document.getElementById('del-confirm-input');
        if (confirmInput) {
            confirmInput.addEventListener('input', function () {
                document.getElementById('btn-modal-confirm-delete').disabled = this.value.trim() !== 'DELETE';
            });
        }
    });

    function confirmDeleteRaw() {
        const year  = document.getElementById('del-year').value;
        const month = document.getElementById('del-month').value;
        const confirmBtn = document.getElementById('btn-modal-confirm-delete');
        confirmBtn.disabled = true;
        confirmBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1 w-3 h-3 border-2 border-t-transparent rounded-full animate-spin inline-block"></span> Deleting...';

        const formData = new FormData();
        formData.append('year', year);
        formData.append('month', month);
        formData.append('reason', 'Manually deleted via Delete Raw Data panel');

        fetch('/UploadManagement/DeleteRawData', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || ''
            }
        })
        .then(async res => {
            const text = await res.text();
            let json = null;
            try { json = JSON.parse(text); } catch(e) {}
            if (!res.ok) throw new Error((json && json.message) || text || 'Deletion failed.');
            return json;
        })
        .then(data => {
            bootstrap.Modal.getInstance(document.getElementById('deleteRawModal')).hide();
            const countArea = document.getElementById('del-count-area');
            const countText = document.getElementById('del-count-text');
            countArea.classList.remove('d-none');
            countText.innerHTML = `<span class="text-success font-extrabold"><span class="material-symbols-outlined text-sm mr-1">check_circle</span> ${data.message}</span>`;
            document.getElementById('btn-delete-raw').disabled = true;
            _delCount = 0;
        })
        .catch(err => {
            alert('Deletion failed: ' + err.message);
            confirmBtn.disabled = false;
            confirmBtn.innerHTML = '<span class="material-symbols-outlined text-sm mr-1">delete</span> Yes, Delete Permanently';
        });
    }
</script>


