                                    <label for="lock-month" class="block text-[10px] font-bold text-on-surface-variant mb-1.5 uppercase tracking-wider">Target Month</label>
                                    <select id="lock-month" class="w-full bg-surface-container-low border border-outline-variant/50 rounded-xl px-4 py-3 text-body-sm focus:ring-2 focus:ring-secondary/20 focus:bg-white transition-all outline-none appearance-none cursor-pointer">
                                        <option value="0">0 - Full Year</option>
                                        <option value="1">1 - January</option>
                                        <option value="2">2 - February</option>
                                        <option value="3">3 - March</option>
                                        <option value="4">4 - April</option>
                                        <option value="5">5 - May</option>
                                        <option value="6">6 - June</option>
                                        <option value="7">7 - July</option>
                                        <option value="8">8 - August</option>
                                        <option value="9">9 - September</option>
