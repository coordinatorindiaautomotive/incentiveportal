@model IReadOnlyList<IncentivePortal.Models.User>
@{
    ViewData["Title"] = "User Security & Mappings";
    var branches = (IReadOnlyList<IncentivePortal.Models.Branch>)ViewBag.Branches;
    var roles = (IReadOnlyList<IncentivePortal.Models.Role>)ViewBag.Roles;
}

<!-- Platform Security Registry -->
<div class="panel">
    <div class="panel-header d-flex justify-content-between align-items-center border-0 mb-3">
        <div>
            <h2>Platform Security Registry</h2>
            <p>Manage existing user profiles, role mappings, and scopes</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" onclick="exportTableToCSV('#usersTable', 'User_Security_Registry.csv')" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-download me-1"></i> Export Excel</button>
            <button type="button" class="btn btn-sm btn-primary" onclick="openUserModal()"><i class="fa-solid fa-plus me-1"></i> + Create New User</button>
        </div>
    </div>

    <div class="table-responsive corp-table-wrapper" style="margin-top: 16px;">
        <table class="table table-hover corp-table align-middle" id="usersTable">
            <thead>
                <tr>
                    <th>User Profile</th>
                    <th>Role Scope</th>
                    <th>Regional Branch Mapped</th>
                    <th>Status</th>
                    <th class="text-center" style="width: 150px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    var role = u.UserRoles.FirstOrDefault()?.Role.Name ?? "No Role";
                    var branchName = u.Branch?.Name ?? "Global / Head Office";
                    var branchCode = u.Branch?.Code ?? "HO";
                    <tr class="user-row" 
                        data-id="@u.Id" 
                        data-username="@u.UserName" 
                        data-email="@u.Email" 
                        data-branch-id="@u.BranchId" 
                        data-role-id="@(u.UserRoles.FirstOrDefault()?.RoleId)">
                        <td>
                            <div class="d-flex align-items-center">
                                <span class="avatar me-2" style="background: var(--brand); color: white; border-radius: 50%; display: grid; place-items: center; width: 30px; height: 30px; font-weight: 700;">@u.UserName[0].ToString().ToUpper()</span>
                                <div>
                                    <strong>@u.UserName</strong>
                                    <span class="d-block small text-muted">@u.Email</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">@role</span>
                        </td>
                        <td>
                            <span class="text-dark fw-semibold">@branchName</span>
                            <span class="d-block small text-muted">Code: @branchCode</span>
                        </td>
                        <td>
                            <span class="status-badge @(u.IsActive ? "success" : "danger")">
                                @(u.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <button type="button" class="btn btn-xs btn-outline-primary edit-user-btn"><i class="fa-solid fa-pencil"></i> Edit</button>
                                @if (!u.UserName.Equals("admin", StringComparison.OrdinalIgnoreCase))
                                {
                                    <button type="button" class="btn btn-xs btn-outline-secondary toggle-status-btn" data-id="@u.Id">
                                        @(u.IsActive ? "✕ Suspend" : "✓ Activate")
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Premium Interactive User Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="userForm" asp-action="Save" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="userId" value="0" />
                <div class="modal-header" style="background: #f8fbff; border-bottom: 1px solid var(--line);">
                    <h5 class="modal-title fw-bold text-dark" id="userModalTitle">⚡ Register New User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding: 24px;">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Username</label>
                        <input name="UserName" id="userName" class="form-control corp-input" placeholder="e.g., john.doe" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email Address</label>
                        <input type="email" name="Email" id="userEmail" class="form-control corp-input" placeholder="e.g., john.doe@company.local" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" id="passwordLabel">Password</label>
                        <input type="password" name="Password" id="userPassword" class="form-control corp-input" placeholder="Enter secure password" required />
                        <div class="form-text text-muted" id="passwordHelp">Password must be at least 6 characters long.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Security Access Role</label>
                        <select name="RoleId" id="userRole" class="form-select corp-select" required>
                            <option value="">-- Choose Role --</option>
                            @foreach (var r in roles)
                            {
                                <option value="@r.Id">@r.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Branch Boundaries Mapping</label>
                        <select name="BranchId" id="userBranch" class="form-select corp-select">
                            <option value="">-- Global / Head Office Scope --</option>
                            @foreach (var b in branches)
                            {
                                <option value="@b.Id">@b.Name (@b.Code)</option>
                            }
                        </select>
                        <div class="form-text text-muted">Leave empty to grant global administrative access across all branches.</div>
                    </div>
                </div>
                <div class="modal-footer" style="background: #f8fbff; border-top: 1px solid var(--line); padding: 14px;">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-success" id="saveUserBtn">✓ Save User</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(document).ready(function() {
    // Reset User Form Modal
    function resetUserForm() {
        $('#userId').val(0);
        $('#userName').val('');
        $('#userEmail').val('');
        $('#userBranch').val('');
        $('#userRole').val('');

        $('#userPassword').prop('required', true).attr('placeholder', 'Enter secure password');
        $('#passwordLabel').text('Password');
        $('#passwordHelp').text('Password must be at least 6 characters long.');

        $('#userModalTitle').text('⚡ Register New User');
        $('#saveUserBtn').text('✓ Save User');
    }

    // Modal Hide Hook
    $('#userModal').on('hidden.bs.modal', function() {
        resetUserForm();
    });

    // Open Modal for Add
    window.openUserModal = function() {
        resetUserForm();
        $('#userModal').modal('show');
    };

    // Open Modal and Populate for Edit
    $('.edit-user-btn').on('click', function() {
        const row = $(this).closest('tr');
        const id = row.data('id');
        const username = row.data('username');
        const email = row.data('email');
        const branchId = row.data('branch-id');
        const roleId = row.data('role-id');

        $('#userId').val(id);
        $('#userName').val(username);
        $('#userEmail').val(email);
        $('#userBranch').val(branchId || "");
        $('#userRole').val(roleId || "");

        // Password field is optional when editing
        $('#userPassword').prop('required', false).attr('placeholder', 'Leave blank to keep current password');
        $('#passwordLabel').text('Password (Optional)');
        $('#passwordHelp').text('Fill only if you want to reset this user\'s password.');

        // Update form titles
        $('#userModalTitle').text('⚡ Edit User Mappings: ' + username);
        $('#saveUserBtn').text('✓ Update User');
        $('#userModal').modal('show');
    });

    // AJAX Save Form submit
    $('#userForm').on('submit', function(e) {
        e.preventDefault();
        const data = $(this).serialize();
        const button = $('#saveUserBtn')[0];
        portalSetBusy(button, 'Saving...');

        $.ajax({
            url: $(this).attr('action'),
            method: 'POST',
            data: data
        })
        .done(r => {
            portalToast(r.message || 'User saved successfully.');
            $('#userModal').modal('hide');
            setTimeout(() => location.reload(), 800);
        })
        .fail(xhr => {
            portalToast(xhr.responseJSON?.message || xhr.responseText || 'Failed to save user.');
        })
        .always(() => portalClearBusy(button));
    });

    // AJAX Toggle status trigger
    $('.toggle-status-btn').on('click', function() {
        const id = $(this).data('id');
        const button = this;
        portalSetBusy(button, '...');

        $.ajax({
            url: '@Url.Action("ToggleStatus", "Users")',
            method: 'POST',
            data: { id: id }
        })
        .done(r => {
            portalToast(r.message || 'User status changed successfully.');
            setTimeout(() => location.reload(), 600);
        })
        .fail(xhr => {
            portalToast(xhr.responseJSON?.message || xhr.responseText || 'Action failed.');
        })
        .always(() => portalClearBusy(button));
    });
});
</script>
}
