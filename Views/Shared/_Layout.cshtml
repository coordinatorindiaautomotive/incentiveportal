                            <div class="search-results-dropdown" id="searchDropdown" style="display: none; position: absolute; top: calc(100% + 8px); left: 0; right: 0; background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius-md); box-shadow: var(--shadow-xl); max-height: 280px; overflow-y: auto; z-index: var(--z-dropdown); padding: 6px;">
                            </div>
                        </div>

