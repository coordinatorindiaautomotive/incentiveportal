                    <div class="user-avatar bg-primary text-white" style="width:34px; height:34px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:800; background:#0059bb !important; color:#ffffff !important;">
                        @((User.Identity?.Name ?? "U")[0])
