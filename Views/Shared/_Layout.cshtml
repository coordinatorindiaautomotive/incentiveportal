@inject IncentivePortal.Data.IncentiveDbContext DbContext
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache Cache
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isEmbed = Context.Request.Query["embed"].ToString() == "true";
    string IsActive(string targetController, string? targetAction = null)
        => controller.Equals(targetController, StringComparison.OrdinalIgnoreCase)
           && (targetAction is null || action.Equals(targetAction, StringComparison.OrdinalIgnoreCase))
            ? "active"
            : "";

    bool IsModuleAllowed(string moduleName, string actionName = "Access")
    {
        if (User.Identity?.IsAuthenticated != true) return false;
        if (User.IsInRole("Super Admin")) return true;

        var roles = User.Claims
            .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
            .Select(c => c.Value)
            .ToList();

        if (!roles.Any()) return false;

        var cacheKey = $"role_perm_{string.Join("_", roles)}_{moduleName}_{actionName}";
        return Cache.GetOrCreate(cacheKey, entry =>
        {
            // 10 min — reduced DB load; busted in ControlTowerController.SaveRolePermissions on any change
            entry.AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(10);
            // Link to eviction token: cancelled by SaveRolePermissions to instantly bust all entries
            entry.AddExpirationToken(new Microsoft.Extensions.Primitives.CancellationChangeToken(
                IncentivePortal.Controllers.ControlTowerController.RolePermEvictionSource.Token));
            
            var hasDeny = DbContext.RolePermissions.Any(p => 
                !p.IsDeleted && 
                roles.Contains(p.RoleName) && 
                p.Module == moduleName && 
                p.Action == actionName && 
                !p.IsAllowed);
            if (hasDeny) return false;

            var hasAllow = DbContext.RolePermissions.Any(p => 
                !p.IsDeleted && 
                roles.Contains(p.RoleName) && 
                p.Module == moduleName && 
                p.Action == actionName && 
                p.IsAllowed);
            if (hasAllow) return true;

            // Fallback for default role configuration
            return moduleName switch
            {
                "ControlTower" => false,
                "UploadManagement" or "Imports" or "DataManagement" or "PartyExecutive" or "Schemes" => 
                    roles.Contains("HO Finance"),
                "Transfers" => 
                    roles.Contains("HO Finance") || roles.Contains("Auditor"),
                "Reports" or "Ledger" => 
                    roles.Contains("HO Finance") || roles.Contains("Auditor") || roles.Contains("Branch Manager") || roles.Contains("Sales Executive"),
                "CashManagement" => 
                    !roles.Contains("Sales Executive"),
                _ => true
            };
        });
    }

    // Cache announcements for 5 minutes — busted immediately in AnnouncementsController on Create/Toggle/Delete
    var activeAnnouncements = User.Identity?.IsAuthenticated == true
        ? Cache.GetOrCreate("layout_announcements", entry =>
          {
              entry.AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(5);
              return DbContext.Announcements
                  .Where(a => a.IsActive && !a.IsDeleted && (a.StartDate == null || a.StartDate <= DateTime.UtcNow) && (a.EndDate == null || a.EndDate >= DateTime.UtcNow))
                  .OrderByDescending(a => a.CreatedAt)
                  .ToList();
          })!
        : new List<IncentivePortal.Models.Announcement>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThessBuddy</title>
    @* Fix Issue 5: Expose CSRF token as a meta tag so site.js can inject it
       automatically into every jQuery AJAX POST without per-call boilerplate. *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    }
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/core.min.css" />
    <link rel="stylesheet" href="~/css/app.min.css" />
    <link rel="stylesheet" href="~/css/design-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/topbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" integrity="sha512-z3gLpd7yknf1YoNbCzqRKc4qyor8gaKU1qmn+CShxbuBusANI9QpRohGBreCFkKxLhei6S9CQXFEbbKuqLg0DA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.0/dist/sweetalert2.all.min.js" integrity="sha384-3X/ekz+OfKpD8GxRB34ZNUuGC4p3wdoeX2WJhtJfoSyktaKzu7vmlRYCD4bV6lHa" crossorigin="anonymous" defer></script>
    <script>
        (function () {
            var theme = localStorage.getItem('theme') || 'light';
            if (theme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
