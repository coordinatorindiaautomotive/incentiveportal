                            <button class="topbar-icon-btn position-relative" id="notifDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                                <i class="fa-regular fa-bell"></i>
                                <span class="position-absolute translate-middle badge rounded-pill bg-danger d-none" id="notifCountBadge" style="top:6px; right:6px; font-size:0.55rem; padding: 2px 4px;">0</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end p-2 shadow-lg border-0" id="notifDropdownMenu" style="width:280px; font-size:0.8rem; border-radius:8px; background:var(--panel);">
                                <li class="dropdown-header fw-bold text-dark border-bottom pb-2">Recent Notifications</li>
                                <div id="notifDropdownList" class="scrollbar" style="max-height: 240px; overflow-y: auto;">
                                    <li class="text-center py-3 text-muted">No new alerts</li>
                                </div>
                                <li class="text-center pt-2 border-top"><a href="/NotificationCenter/Index" class="small text-decoration-none text-primary fw-bold">View All Notifications</a></li>
                            </ul>
                        </div>

                        <!-- Theme Toggle Button -->
                        <button class="theme-toggle-btn" id="themeToggleBtn" title="Toggle Dark/Light Mode">
                            <i class="fa-regular fa-moon" id="themeToggleIcon"></i>
                        </button>

                        <div class="topbar-divider"></div>

                        <!-- User Profile Dropdown Menu -->
                        <div class="user-profile-menu dropdown">
                            <div class="user-profile-trigger" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="avatar-circle">
                                    @((User.Identity?.Name ?? "U")[0])
                                </div>
                                <div class="user-details text-start">
                                    <div class="user-name-text">@User.Identity?.Name</div>
                                    <div class="user-role-text">
                                        @(User.IsInRole("Super Admin") ? "Super Admin" : User.IsInRole("HO Finance") ? "HO Finance" : User.IsInRole("Branch Manager") ? "Branch Manager" : User.IsInRole("Sales Executive") ? "Sales Executive" : "Representative")
                                    </div>
                                </div>
                                <i class="fa-solid fa-angle-down user-caret"></i>
                            </div>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow p-2 mt-2" aria-labelledby="userMenuDropdown" style="border-radius: 8px; background: var(--panel);">
                                <li><h6 class="dropdown-header text-muted fw-semibold" style="color: var(--nav-muted);">Hello, @User.Identity?.Name!</h6></li>
                                <li><a class="dropdown-item py-2" style="border-radius: 4px;" href="/Profile"><i class="fa-solid fa-user me-2"></i> Account Profile</a></li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button class="dropdown-item text-danger py-2" style="border-radius: 4px; width: 100%; border: none; background: none; text-align: left;"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </header>
                
                <div class="main-content fade-in">
                    @if (activeAnnouncements.Any())
                    {
                        <div class="announcement-ticker mb-4">
                            <span class="announcement-badge">
                                <i class="fa-solid fa-bullhorn"></i> Notice
                            </span>
                            <div class="announcement-track">
                                <div class="announcement-list">
                                    @foreach (var a in activeAnnouncements)
                                    {
                                        var severityClass = a.Severity switch
                                        {
                                            "warning" => "fa-triangle-exclamation text-warning",
                                            "danger" => "fa-circle-xmark text-danger",
                                            "success" => "fa-circle-check text-success",
                                            _ => "fa-circle-info text-info"
                                        };
                                        <span class="announcement-item">
                                            <i class="fa-solid @severityClass" style="font-size: 0.85rem; margin-right: 4px;"></i>
                                            <strong>@a.Message</strong>
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    
                    @RenderBody()

                    <footer class="main-footer">
                        <div>© 2026 ThessBuddy. All rights reserved.</div>
                        <div class="footer-right">
                            <a asp-controller="ControlTower" asp-action="ComponentLibrary">Component Library</a>
                            <span class="footer-dot"></span>
                            <a href="#" onclick="showHelpModal(); return false;">Support & Help</a>
                            <span class="footer-dot"></span>
                            <a href="mailto:support@thessbuddy.com">Contact Support</a>
                        </div>
                    </footer>
                </div>
            </main>
        }
        else
        {
            <main class="content-wrapper embedded">
                <div class="main-content fade-in">
                    @RenderBody()
                </div>
            </main>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/saas-upgrades.js" asp-append-version="true" defer></script>
    <script>
        $(document).ready(function() {
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
    @await RenderSectionAsync("DataTableScripts", required: false)

    <!-- Floating AI Copilot Widget -->
    <div id="aiCopilotWidget" style="position: fixed; bottom: 20px; right: 20px; z-index: 1000; font-family:'Inter', sans-serif;">
        <button class="btn btn-primary rounded-circle shadow-lg d-flex align-items-center justify-content-center" id="aiCopilotBubble" style="width: 52px; height: 52px; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%) !important; border: none; box-shadow: 0 8px 24px rgba(0,89,187,0.25) !important;" onclick="toggleFloatingChat()">
            <i class="fa-solid fa-robot text-white fs-4"></i>
        </button>
        
        <div class="card shadow-xl border-0 d-none" id="aiCopilotPanel" style="position: absolute; bottom: 64px; right: 0; width: 340px; height: 420px; border-radius: 12px; display: flex; flex-direction: column; overflow: hidden; border:1px solid var(--line-2) !important; background: var(--panel);">
            <div class="card-header text-white d-flex justify-content-between align-items-center py-3" style="background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); border:none;">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-robot"></i>
                    <div>
                        <h6 class="mb-0 fw-bold small text-white" style="line-height:1.2;">ThessBuddy AI Copilot</h6>
                        <span style="font-size:0.6rem; opacity:0.8; color: #fff;">Your Intelligent Business Companion</span>
                    </div>
                </div>
                <button class="btn-close btn-close-white" onclick="toggleFloatingChat()"></button>
            </div>
            <div class="card-body p-3 bg-light d-flex flex-column" style="overflow: hidden;">
                <div class="chat-messages flex-grow-1 scrollbar mb-2 p-2 bg-white rounded border" id="floatingChatBody" style="overflow-y: auto; font-size: 0.8rem; line-height: 1.4;">
                    <div class="p-2 mb-2 bg-light text-secondary rounded">
                        Hello! Ask me about branch performance, dealer outstanding, or dead stock items in ThessBuddy.
                    </div>
                </div>
                <form id="floatingChatForm" class="input-group input-group-sm">
                    <input type="text" class="form-control border-primary" id="floatingChatInput" placeholder="Type a message..." required autocomplete="off" />
                    <button type="submit" class="btn btn-primary bg-primary border-0"><i class="fa-solid fa-paper-plane"></i></button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>





