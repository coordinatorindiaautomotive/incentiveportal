</script>

<div id="dashboardWrapper" class="p-4 bg-dash-bg min-h-screen text-dash-text" style="transition: all 0.3s ease;">
    
    <!-- Top Greeting Section with Date Selector and Download Button -->
    <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
        <div>
            <h2 class="text-2xl font-extrabold tracking-tight flex items-center gap-2">
                Welcome back, @welcomeName! 👋
            </h2>
            <p class="text-xs text-dash-muted mt-1 flex flex-wrap items-center gap-2">
                Here's what's happening with your incentive program today.
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold bg-dash-primary/10 text-dash-primary border border-dash-primary/20">
                    <i class="fa-solid fa-cloud-arrow-up"></i> Data Uploaded Till: @latestUploadDateText
                </span>
            </p>
        </div>
        <div class="flex items-center gap-3">
            <!-- Datepicker Dropdown Trigger -->
            <div class="dropdown">
                <button class="btn btn-outline-secondary flex items-center gap-2 px-3 py-2 bg-dash-card border-dash-border text-dash-text" style="border-radius: 8px; font-size: 0.85rem; font-weight: 600; height: 40px;" type="button" id="dateRangePicker" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fa-regular fa-calendar-days text-dash-muted"></i> 
                    <span>01 May 2024 - 31 May 2024</span>
                    <i class="fa-solid fa-angle-down text-dash-muted" style="font-size: 0.72rem;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 bg-dash-card text-dash-text" aria-labelledby="dateRangePicker" style="border-radius: 12px; font-size: 0.85rem;">
                    <li><a class="dropdown-item py-2 active" style="border-radius:6px;" href="#">May 2024</a></li>
                    <li><a class="dropdown-item py-2 text-dash-text" style="border-radius:6px;" href="#">April 2024</a></li>
                    <li><a class="dropdown-item py-2 text-dash-text" style="border-radius:6px;" href="#">Q1 FY 2024-25</a></li>
                </ul>
            </div>

            <!-- Download Report Button -->
            <button class="btn btn-primary flex items-center gap-2 px-4 bg-dash-primary border-none" style="height: 40px; font-weight: 600; font-size: 0.88rem; border-radius: 8px; box-shadow: 0 4px 12px var(--dash-accent-glow);">
                <i class="fa-solid fa-cloud-arrow-down"></i> Download Report
