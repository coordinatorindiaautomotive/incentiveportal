@model IncentivePortal.DTOs.DashboardSummary
@inject IncentivePortal.Data.IncentiveDbContext Db
@inject IncentivePortal.Helpers.ICurrentUser CurrentUser
@using Microsoft.EntityFrameworkCore
@{
    ViewData["Title"] = "Dashboard";

    // Enforce branch-isolated filters for selectors
    var branches = Db.Branches.Where(x => !x.IsDeleted).ToList();
    if (CurrentUser.BranchId.HasValue && !CurrentUser.IsInRole("Super Admin") && !CurrentUser.IsInRole("HO Finance") && !CurrentUser.IsInRole("Auditor"))
    {
        branches = branches.Where(x => x.Id == CurrentUser.BranchId.Value).ToList();
    }

    var parties = Db.Parties.Include(x => x.Branch).Where(x => !x.IsDeleted).ToList();
    if (CurrentUser.BranchId.HasValue && !CurrentUser.IsInRole("Super Admin") && !CurrentUser.IsInRole("HO Finance") && !CurrentUser.IsInRole("Auditor"))
    {
        parties = parties.Where(x => x.BranchId == CurrentUser.BranchId.Value).ToList();
    }

    // Dynamic greeting calculation
    var welcomeName = "User";
    if (User.Identity?.IsAuthenticated == true)
    {
        if (User.IsInRole("Super Admin"))
        {
            welcomeName = "Admin User";
        }
        else if (User.IsInRole("HO Finance"))
        {
            welcomeName = "HO Finance User";
        }
        else if (User.IsInRole("Branch Manager") && CurrentUser.BranchId.HasValue)
        {
            var userBranch = Db.Branches.FirstOrDefault(x => x.Id == CurrentUser.BranchId.Value);
            welcomeName = userBranch != null ? $"{userBranch.Name} Manager" : "Branch Manager";
        }
        else
        {
            welcomeName = User.Identity.Name ?? "User";
        }
    }

    // Month-End Checklist readiness status queries
    var notificationSetting = Db.NotificationSettings.FirstOrDefault(n => !n.IsDeleted);
    bool isSmtpConfigured = notificationSetting != null && notificationSetting.EmailEnabled && !string.IsNullOrEmpty(notificationSetting.SmtpHost) && !string.IsNullOrEmpty(notificationSetting.SmtpUser);

    var todayDate = DateTime.UtcNow.Date;
    bool isTdsActive = Db.TdsRules.Any(r => !r.IsDeleted && r.EffectiveFrom <= todayDate && r.EffectiveTo >= todayDate);

    var tallySetting = Db.TallyIntegrationSettings.FirstOrDefault(t => !t.IsDeleted);
    bool isTallyActive = tallySetting != null && tallySetting.IsEnabled && !string.IsNullOrEmpty(tallySetting.BaseUrl);

    // Determine the latest period in SsIncentives (to identify active year/month)
    var latestPeriod = Db.SsIncentives.AsNoTracking()
        .Include(x => x.ImportLog)
        .Where(x => x.ImportLogId > 0 && !x.ImportLog!.IsHistorical)
        .Select(x => new { x.Year, x.Month })
        .OrderByDescending(x => x.Year)
        .ThenByDescending(x => x.Month)
        .FirstOrDefault();

    var curYear = latestPeriod?.Year ?? DateTime.UtcNow.Year;
    var curMonth = latestPeriod?.Month ?? DateTime.UtcNow.Month;

    var fyStart = curMonth >= 4 ? curYear : curYear - 1;
    var compYearStart = fyStart - 1;

    // Latest available date (maxDay) in selected month from Raws
    var maxDay = Db.Raws.AsNoTracking()
        .Where(x => x.YearNumber == curYear && x.MonthNumber == curMonth && !x.IsDeleted && x.Day.HasValue)
        .Select(x => x.Day!.Value)
        .OrderByDescending(x => x)
        .FirstOrDefault();
    var latestUploadDateText = "";
    if (maxDay > 0)
    {
        var monthNamesList = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
        var monthName = monthNamesList[curMonth - 1];
        latestUploadDateText = $"{maxDay} {monthName} {curYear}";
    }
    else
    {
        latestUploadDateText = "N/A";
    }
    if (maxDay == 0) maxDay = 31;

    var rawSalesQuery = Db.Raws.AsNoTracking().Where(x => !x.IsDeleted && x.ImportLogId > 0);
    if (CurrentUser.BranchId.HasValue && !CurrentUser.IsInRole("Super Admin") && !CurrentUser.IsInRole("HO Finance") && !CurrentUser.IsInRole("Auditor"))
    {
        var branchPartyCodes = Db.Parties
            .AsNoTracking()
            .Where(x => x.BranchId == CurrentUser.BranchId.Value)
            .Select(x => x.PartyCode)
            .ToList();
        rawSalesQuery = rawSalesQuery.Where(x => branchPartyCodes.Contains(x.OriginalCode) || branchPartyCodes.Contains(x.ConsPartyCode));
    }

    // Helper functions for fiscal ordering
    int FiscalOrder(int m) => m >= 4 ? m - 3 : m + 9;
    int GetCalendarYear(int startYear, int m) => m >= 4 ? startYear : startYear + 1;

    // Projection for locations
    var locRawData = rawSalesQuery
        .Where(x => 
            (x.YearNumber == fyStart && x.MonthNumber >= 4) || (x.YearNumber == fyStart + 1 && x.MonthNumber <= 3) ||
            (x.YearNumber == compYearStart && x.MonthNumber >= 4) || (x.YearNumber == compYearStart + 1 && x.MonthNumber <= 3)
        )
        .Select(x => new { YearNumber = x.YearNumber ?? 0, MonthNumber = x.MonthNumber ?? 0, Day = x.Day ?? 1, Sales = (decimal)x.NetRetailSelling, Loc = x.Loc ?? "" })
        .ToList();

    // MTD: Data from 1st of selected month up to maxDay
    var mtdSales = locRawData
        .Where(x => x.MonthNumber == curMonth && x.YearNumber == GetCalendarYear(fyStart, curMonth) && x.Day <= maxDay)
        .Sum(x => x.Sales);

    // LMTD: Same date range in the corresponding period of the previous year
    var lmtdSales = locRawData
        .Where(x => x.MonthNumber == curMonth && x.YearNumber == GetCalendarYear(compYearStart, curMonth) && x.Day <= maxDay)
        .Sum(x => x.Sales);

    // YTD: From start of the financial year (April 1st) up to maxDay of the selected month
    var ytdSales = locRawData
        .Where(x => 
            (FiscalOrder(x.MonthNumber) < FiscalOrder(curMonth) &&
             (((x.YearNumber == fyStart && x.MonthNumber >= 4) || (x.YearNumber == fyStart + 1 && x.MonthNumber <= 3))))
            ||
            (x.MonthNumber == curMonth && x.YearNumber == GetCalendarYear(fyStart, curMonth) && x.Day <= maxDay)
        )
        .Sum(x => x.Sales);

    // LYTD: Same financial year period in the previous year (matching YTD date range)
    var lytdSales = locRawData
        .Where(x => 
            (FiscalOrder(x.MonthNumber) < FiscalOrder(curMonth) &&
             (((x.YearNumber == compYearStart && x.MonthNumber >= 4) || (x.YearNumber == compYearStart + 1 && x.MonthNumber <= 3))))
            ||
            (x.MonthNumber == curMonth && x.YearNumber == GetCalendarYear(compYearStart, curMonth) && x.Day <= maxDay)
        )
        .Sum(x => x.Sales);

    var ytdGrowth = CalcGrowth(ytdSales, lytdSales);
    var mtdGrowth = CalcGrowth(mtdSales, lmtdSales);

    // Average Sales: average monthly sales of the current financial year up to curMonth
    var activeMonthsCount = FiscalOrder(curMonth);
    var avgSales = activeMonthsCount > 0 ? ytdSales / activeMonthsCount : 0m;

    var branchesList = Db.Branches.Where(x => !x.IsDeleted).ToList();
    var branchNamesMap = branchesList.ToDictionary(x => x.Code, x => x.Name, StringComparer.OrdinalIgnoreCase);

    // Location MTD
    var mtdBranchSales = locRawData
        .Where(x => x.MonthNumber == curMonth && x.YearNumber == GetCalendarYear(fyStart, curMonth) && x.Day <= maxDay && !string.IsNullOrEmpty(x.Loc))
        .GroupBy(x => x.Loc)
        .ToDictionary(g => g.Key, g => g.Sum(x => x.Sales), StringComparer.OrdinalIgnoreCase);

    // Location LMTD
    var lmtdBranchSales = locRawData
        .Where(x => x.MonthNumber == curMonth && x.YearNumber == GetCalendarYear(compYearStart, curMonth) && x.Day <= maxDay && !string.IsNullOrEmpty(x.Loc))
        .GroupBy(x => x.Loc)
        .ToDictionary(g => g.Key, g => g.Sum(x => x.Sales), StringComparer.OrdinalIgnoreCase);

    // Location YTD
    var ytdBranchSales = locRawData
        .Where(x => (
            (FiscalOrder(x.MonthNumber) < FiscalOrder(curMonth) &&
             (((x.YearNumber == fyStart && x.MonthNumber >= 4) || (x.YearNumber == fyStart + 1 && x.MonthNumber <= 3))))
            ||
            (x.MonthNumber == curMonth && x.YearNumber == GetCalendarYear(fyStart, curMonth) && x.Day <= maxDay)
        ) && !string.IsNullOrEmpty(x.Loc))
        .GroupBy(x => x.Loc)
        .ToDictionary(g => g.Key, g => g.Sum(x => x.Sales), StringComparer.OrdinalIgnoreCase);

    // Location LYTD
    var lytdBranchSales = locRawData
        .Where(x => (
            (FiscalOrder(x.MonthNumber) < FiscalOrder(curMonth) &&
             (((x.YearNumber == compYearStart && x.MonthNumber >= 4) || (x.YearNumber == compYearStart + 1 && x.MonthNumber <= 3))))
            ||
            (x.MonthNumber == curMonth && x.YearNumber == GetCalendarYear(compYearStart, curMonth) && x.Day <= maxDay)
        ) && !string.IsNullOrEmpty(x.Loc))
        .GroupBy(x => x.Loc)
        .ToDictionary(g => g.Key, g => g.Sum(x => x.Sales), StringComparer.OrdinalIgnoreCase);

    // Union of all locations that have any sales activity in these periods
    var allLocationCodes = mtdBranchSales.Keys
        .Union(lmtdBranchSales.Keys)
        .Union(ytdBranchSales.Keys)
        .Union(lytdBranchSales.Keys)
        .OrderBy(x => x)
        .ToList();
}

@functions {
    public string FormatCr(decimal value) {
        if (value >= 10000000m) {
            return (value / 10000000m).ToString("N2") + " Cr";
        } else if (value >= 100000m) {
            return (value / 100000m).ToString("N2") + " L";
        }
        return value.ToString("N0");
    }

    public decimal CalcGrowth(decimal current, decimal previous) {
        if (previous <= 0) return current > 0 ? 100m : 0m;
        return Math.Round((current - previous) / previous * 100m, 1);
    }
}

<!-- Premium Styles supporting light/dark theme variables -->
<style>
    :root {
        --dash-bg: #fcf8ff;
        --dash-card: #ffffff;
        --dash-border: #e4e1ed;
        --dash-text: #1b1b23;
        --dash-text-muted: #767586;
        --dash-primary: #4648d4;
        --dash-secondary: #006c49;
        --dash-accent: #0284c7;
        --dash-panel-shadow: 0 4px 12px -2px rgba(0, 0, 0, 0.05);
        --dash-accent-glow: rgba(70, 72, 212, 0.15);
    }

    .dark-theme {
        --dash-bg: #0e1511;
        --dash-card: #1a211d;
        --dash-border: #3c4a42;
        --dash-text: #dde4dd;
        --dash-text-muted: #bbcabf;
        --dash-primary: #4edea3;
        --dash-secondary: #7bd0ff;
        --dash-accent: #00a6e0;
        --dash-panel-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        --dash-accent-glow: rgba(78, 222, 163, 0.15);
    }

    /* CSS variable styles for components */
    .widget-card {
        background-color: var(--dash-card) !important;
        border: 1px solid var(--dash-border) !important;
        color: var(--dash-text) !important;
        border-radius: 0.75rem;
        box-shadow: var(--dash-panel-shadow);
        position: relative;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    
    .widget-card:hover {
        box-shadow: 0 12px 24px -6px var(--dash-accent-glow);
        transform: translateY(-2px);
    }

    .widget-card.card-purple { background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%) !important; color: #ffffff !important; }
    .widget-card.card-green { background: linear-gradient(135deg, #059669 0%, #10b981 100%) !important; color: #ffffff !important; }
    .widget-card.card-orange { background: linear-gradient(135deg, #ea580c 0%, #f97316 100%) !important; color: #ffffff !important; }
    .widget-card.card-blue { background: linear-gradient(135deg, #0284c7 0%, #06b6d4 100%) !important; color: #ffffff !important; }

    .widget-card.card-purple .text-dash-muted, .widget-card.card-purple .text-dash-text,
    .widget-card.card-green .text-dash-muted, .widget-card.card-green .text-dash-text,
    .widget-card.card-orange .text-dash-muted, .widget-card.card-orange .text-dash-text,
    .widget-card.card-blue .text-dash-muted, .widget-card.card-blue .text-dash-text {
        color: rgba(255, 255, 255, 0.9) !important;
    }

    .trend-pill-up {
        background-color: rgba(209, 250, 229, 0.2) !important;
        color: #10b981 !important; 
        border: 1px solid rgba(16, 185, 129, 0.3);
    }
    .trend-pill-down {
        background-color: rgba(254, 226, 226, 0.2) !important;
        color: #ef4444 !important; 
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    /* Bolder side vertical borders for lists */
    .border-vibrant-purple { border-color: #4f46e5 !important; }
    .border-vibrant-green { border-color: #059669 !important; }
    .border-vibrant-orange { border-color: #ea580c !important; }
    .border-vibrant-blue { border-color: #0284c7 !important; }
    .border-vibrant-pink { border-color: #db2777 !important; }

    .text-vibrant-purple { color: #4f46e5 !important; }
    .text-vibrant-green { color: #059669 !important; }
    .text-vibrant-orange { color: #ea580c !important; }
    .text-vibrant-blue { color: #0284c7 !important; }
    .text-vibrant-pink { color: #db2777 !important; }

    .dark-theme .text-vibrant-purple { color: #818cf8 !important; }
    .dark-theme .text-vibrant-green { color: #4edea3 !important; }
    .dark-theme .text-vibrant-orange { color: #f97316 !important; }
    .dark-theme .text-vibrant-blue { color: #7bd0ff !important; }
    .dark-theme .text-vibrant-pink { color: #f472b6 !important; }

    .dark-theme .border-vibrant-purple { border-color: #818cf8 !important; }
    .dark-theme .border-vibrant-green { border-color: #4edea3 !important; }
    .dark-theme .border-vibrant-orange { border-color: #f97316 !important; }
    .dark-theme .border-vibrant-blue { border-color: #7bd0ff !important; }
    .dark-theme .border-vibrant-pink { border-color: #f472b6 !important; }

    /* Custom scrollbars */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--dash-bg); }
    ::-webkit-scrollbar-thumb { background: var(--dash-border); border-radius: 3px; }

    /* Telemetry animations */
    @@keyframes neon-pulse-vibrant {
        0%, 100% { filter: drop-shadow(0 0 2px rgba(79, 70, 229, 0.3)); }
        50% { filter: drop-shadow(0 0 8px rgba(79, 70, 229, 0.6)); }
    }
    @@keyframes glow-green {
        0%, 100% { filter: drop-shadow(0 0 2px rgba(5, 150, 105, 0.3)); }
        50% { filter: drop-shadow(0 0 8px rgba(5, 150, 105, 0.6)); }
    }
    @@keyframes glow-orange {
        0%, 100% { filter: drop-shadow(0 0 2px rgba(234, 88, 12, 0.3)); }
        50% { filter: drop-shadow(0 0 8px rgba(234, 88, 12, 0.6)); }
    }

    .animate-pulse-vibrant { animation: neon-pulse-vibrant 3s ease-in-out infinite; }
    .glow-green-animate { animation: glow-green 3s ease-in-out infinite; }
    .glow-orange-animate { animation: glow-orange 3s ease-in-out infinite; }

    /* Tab links styling */
    .portal-dashboard-tabs .nav-link {
        color: var(--dash-text-muted) !important;
        background: transparent !important;
        transition: all 0.2s ease;
    }
    .portal-dashboard-tabs .nav-link.active {
        color: #ffffff !important;
        background: var(--dash-primary) !important;
    }

    /* Form control integration styling */
    .corp-select {
        background-color: var(--dash-card) !important;
        color: var(--dash-text) !important;
        border: 1px solid var(--dash-border) !important;
    }

    /* Metric displays */
    .metric {
        background: var(--dash-card) !important;
        border: 1px solid var(--dash-border) !important;
        color: var(--dash-text) !important;
        padding: 16px;
        border-radius: 8px;
        box-shadow: var(--dash-panel-shadow);
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .metric strong {
        color: var(--dash-text) !important;
    }
    .metric small {
        color: var(--dash-text-muted) !important;
    }

    /* Simulator overrides */
    .simulator-display-card {
        background: rgba(13, 82, 214, 0.03) !important;
        border: 1px solid rgba(13, 82, 214, 0.1) !important;
    }
    .dark-theme .simulator-display-card {
        background: rgba(255, 255, 255, 0.02) !important;
        border: 1px solid var(--dash-border) !important;
    }

    .progress {
        background-color: var(--dash-border) !important;
    }

    /* Table styles */
    .table {
        color: var(--dash-text) !important;
        border-color: var(--dash-border) !important;
    }
    .table-light {
        background-color: var(--dash-bg) !important;
        color: var(--dash-text) !important;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.04) !important;
    }
</style>

