        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4 py-2 border-0" id="dealer-tab" data-bs-toggle="tab" data-bs-target="#dealer-pane" type="button" role="tab" style="font-size: 0.88rem; border-radius: 6px;">
                <i class="fa-solid fa-magnifying-glass-chart me-1"></i> Dealer Simulator
            </button>
        </li>
    </ul>

    <!-- Tabs Content Container -->
    <div class="tab-content">
        <!-- ======================================================== -->
        <!-- TAB 1: EXECUTIVE MAIN DASHBOARD VIEW                     -->
        <!-- ======================================================== -->
        @if (CurrentUser.IsInRole("Super Admin") || CurrentUser.IsInRole("HO Finance") || CurrentUser.IsInRole("Auditor"))
        {
            <div class="tab-pane fade show active animate-fade-in" id="ho-pane" role="tabpanel">
                                <!-- 4 HERO KPI MATRIX (Stitch design layout & solid color gradient) -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                    <!-- Card 1: YTD Sales -->
                    <div class="widget-card card-purple p-5 flex flex-col justify-between h-[135px]">
                        <div class="flex justify-between items-start w-full">
                            <span class="text-[11px] font-bold uppercase tracking-wider font-mono text-white/80">YTD Sales</span>
                            <span class="material-symbols-outlined text-[24px] text-white">monetization_on</span>
                        </div>
                        <div>
                            <div class="text-3xl font-extrabold mt-1 text-white">@FormatCr(ytdSales)</div>
                            <div class="flex items-center gap-2 mt-2">
                                <div class="trend-pill-up text-[10px] font-bold px-2 py-0.5 rounded flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px] font-bold">arrow_upward</span> @((ytdGrowth >= 0 ? "+" : "") + ytdGrowth.ToString("F1"))%
                                </div>
                                <span class="text-[10px] font-mono text-white/80">vs LYTD</span>
                            </div>
                        </div>
                    </div>

                    <!-- Card 2: MTD Sales -->
                    <div class="widget-card card-green p-5 flex flex-col justify-between h-[135px]">
                        <div class="flex justify-between items-start w-full">
                            <span class="text-[11px] font-bold uppercase tracking-wider font-mono text-white/80">MTD Sales</span>
                            <span class="material-symbols-outlined text-[24px] text-white">calendar_month</span>
                        </div>
                        <div>
                            <div class="text-3xl font-extrabold mt-1 text-white">@FormatCr(mtdSales)</div>
                            <div class="flex items-center gap-2 mt-2">
                                <div class="trend-pill-up text-[10px] font-bold px-2 py-0.5 rounded flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px] font-bold">arrow_upward</span> @((mtdGrowth >= 0 ? "+" : "") + mtdGrowth.ToString("F1"))%
                                </div>
                                <span class="text-[10px] font-mono text-white/80">vs LMTD</span>
                            </div>
                        </div>
                    </div>

                    <!-- Card 3: Avg Monthly Sale -->
                    <div class="widget-card card-orange p-5 flex flex-col justify-between h-[135px]">
                        <div class="flex justify-between items-start w-full">
                            <span class="text-[11px] font-bold uppercase tracking-wider font-mono text-white/80">Avg Monthly Sale</span>
                            <span class="material-symbols-outlined text-[24px] text-white">shopping_cart</span>
                        </div>
                        <div>
                            <div class="text-3xl font-extrabold mt-1 text-white">@FormatCr(avgSales)</div>
                            <div class="flex items-center gap-2 mt-2">
                                <div class="trend-pill-up text-[10px] font-bold px-2 py-0.5 rounded flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px] font-bold">arrow_upward</span> @((mtdGrowth >= 0 ? "+" : "") + mtdGrowth.ToString("F1"))%
                                </div>
                                <span class="text-[10px] font-mono text-white/80">vs LMTD</span>
                            </div>
                        </div>
                    </div>

                    <!-- Card 4: Efficiency -->
                    <div class="widget-card card-blue p-5 flex flex-col justify-between h-[135px]">
                        <div class="flex justify-between items-start w-full">
                            <span class="text-[11px] font-bold uppercase tracking-wider font-mono text-white/80">Efficiency</span>
                            <span class="material-symbols-outlined text-[24px] text-white">speed</span>
                        </div>
                        <div>
                            <div class="text-3xl font-extrabold mt-1 text-white">@Model.BudgetVsActualPercent.ToString("F1")%</div>
                            <div class="flex items-center gap-2 mt-2">
                                <div class="trend-pill-up text-[10px] font-bold px-2 py-0.5 rounded flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px] font-bold">arrow_upward</span> @((Model.IncentiveGrowthMonthOnMonth >= 0 ? "+" : "") + Model.IncentiveGrowthMonthOnMonth.ToString("F1"))%
                                </div>
                                <span class="text-[10px] font-mono text-white/80">vs Target</span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- MIDDLE GRID: REVENUE TREND + QUICK ACTIONS -->
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">
                    <!-- Revenue Trend (12 Months) -->
                    <div class="widget-card lg:col-span-9 p-6">
                        <div class="flex justify-between items-center mb-6 border-b border-dash-border/30 pb-3">
                            <div>
                                <h3 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-chart-line text-dash-primary mr-2"></i> Revenue Trend (12 Months)</h3>
                                <p class="text-[11px] text-dash-muted mt-0.5">Rolling calendar performance and targets</p>
                            </div>
                            <div class="flex items-center gap-4 text-[10px] font-bold text-dash-muted">
                                <div class="flex items-center gap-1.5"><span class="w-3 h-1.5 bg-dash-primary rounded-sm shadow-[0_0_8px_var(--dash-accent-glow)]"></span> <span>Current Year</span></div>
                                <div class="flex items-center gap-1.5"><span class="w-3 h-1.5 bg-dash-border rounded-sm border"></span> <span>Target</span></div>
                            </div>
                        </div>
                        <div id="widget-trends-chart" style="height: 290px;"></div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="widget-card lg:col-span-3 p-5 flex flex-col justify-between">
                        <div class="border-b border-dash-border/30 pb-3 mb-4">
                            <h3 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-bolt text-warning mr-2"></i> Governance Actions</h3>
                        </div>
                        <div class="flex flex-col gap-3 flex-grow justify-around">
                            @if (CurrentUser.IsInRole("Super Admin"))
                            {
                                <a asp-controller="UploadManagement" asp-action="Index" class="quick-action-btn flex items-center justify-between p-3 bg-dash-primary/5 border border-dash-primary/20 hover:border-dash-primary/55 rounded-lg text-dash-primary font-bold text-xs no-underline transition-all">
                                    <span class="flex items-center gap-2"><i class="fa-solid fa-cloud-arrow-up text-sm"></i> Upload Console</span>
                                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                                </a>
                                <a asp-controller="Imports" asp-action="MonthlySales" class="quick-action-btn flex items-center justify-between p-3 bg-dash-secondary/5 border border-dash-secondary/20 hover:border-dash-secondary/55 rounded-lg text-dash-secondary font-bold text-xs no-underline transition-all" style="color:var(--dash-secondary);">
                                    <span class="flex items-center gap-2"><i class="fa-solid fa-file-excel text-sm"></i> Workbook Import</span>
                                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                                </a>
                            }
                            <a asp-controller="Imports" asp-action="MonthlySales" class="quick-action-btn flex items-center justify-between p-3 bg-dash-primary/5 border border-dash-primary/20 hover:border-dash-primary/55 rounded-lg text-dash-primary font-bold text-xs no-underline transition-all">
                                <span class="flex items-center gap-2"><i class="fa-solid fa-calculator text-sm"></i> Calculate Incentive</span>
                                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                            </a>
                            <a asp-controller="Reports" asp-action="PendingApprovals" class="quick-action-btn flex items-center justify-between p-3 bg-red-500/5 border border-red-500/20 hover:border-red-500/55 rounded-lg text-red-500 font-bold text-xs no-underline transition-all">
                                <span class="flex items-center gap-2"><i class="fa-solid fa-circle-check text-sm"></i> Pending Approvals</span>
                                <i class="fa-solid fa-chevron-right text-[10px]"></i>
                            </a>
                            <a asp-controller="Reports" asp-action="IncentiveRegister" class="quick-action-btn flex items-center justify-between p-3 bg-dash-accent/5 border border-dash-accent/20 hover:border-dash-accent/55 rounded-lg text-dash-accent font-bold text-xs no-underline transition-all">
                                <span class="flex items-center gap-2"><i class="fa-solid fa-chart-line text-sm"></i> View Reports</span>
                                <i class="fa-solid fa-chevron-right text-[10px]"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- CONTRIBUTION ANALYSIS (Stitch side-by-side metric list layout) -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
                    <!-- Location Split -->
                    <div class="widget-card p-6 flex flex-col min-h-[300px]">
                        <h3 class="text-sm font-bold uppercase tracking-wider text-dash-text mb-4 border-b border-dash-border/30 pb-3"><i class="fa-solid fa-map-location-dot text-dash-primary mr-2"></i> Dealer Location Distribution</h3>
                        <div class="flex-grow flex flex-col sm:flex-row items-center justify-around gap-6">
                            <div class="relative w-44 h-44 flex-shrink-0">
                                <div id="location-split-chart" style="height: 100%; width: 100%;"></div>
                            </div>
                            <div class="flex flex-col gap-2 w-full sm:max-w-[220px]">
                                @{
                                    var totalLocationSales = Model.ChartData.LocationSales.Sum();
                                }
                                @for (int i = 0; i < Math.Min(4, Model.ChartData.LocationLabels.Count); i++)
                                {
                                    var locLabel = Model.ChartData.LocationLabels[i];
                                    var locSales = Model.ChartData.LocationSales[i];
                                    var locPct = totalLocationSales > 0 ? (locSales / totalLocationSales) * 100m : 0m;
                                    var borderColors = new[] { "border-vibrant-green", "border-vibrant-blue", "border-vibrant-purple", "border-vibrant-orange" };
                                    var textColors = new[] { "text-vibrant-green", "text-vibrant-blue", "text-vibrant-purple", "text-vibrant-orange" };
                                    var borderCol = borderColors[i % borderColors.Length];
                                    var textCol = textColors[i % textColors.Length];
                                    
                                    <div class="flex flex-col border-l-2 @borderCol pl-3 py-0.5">
                                        <div class="flex items-center justify-between">
                                            <span class="text-[11px] font-bold text-dash-text uppercase tracking-tight">@locLabel</span>
                                            <span class="text-[11px] font-mono font-bold @textCol">@locPct.ToString("F0")%</span>
                                        </div>
                                        <div class="text-[10px] text-dash-muted mt-0.5">@FormatCr(locSales)</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Category Mix -->
                    <div class="widget-card p-6 flex flex-col min-h-[300px]">
                        <h3 class="text-sm font-bold uppercase tracking-wider text-dash-text mb-4 border-b border-dash-border/30 pb-3"><i class="fa-solid fa-layer-group text-dash-secondary mr-2"></i> Product Category Mix</h3>
                        <div class="flex-grow flex flex-col sm:flex-row items-center justify-around gap-6">
                            <div class="relative w-44 h-44 flex-shrink-0">
                                <div id="category-mix-chart" style="height: 100%; width: 100%;"></div>
                            </div>
                            <div class="flex flex-col gap-2 w-full sm:max-w-[220px]">
                                @{
                                    var totalCategorySales = Model.ChartData.CategorySales.Sum();
                                }
                                @for (int i = 0; i < Math.Min(5, Model.ChartData.CategoryLabels.Count); i++)
                                {
                                    var catLabel = Model.ChartData.CategoryLabels[i];
                                    var catSales = Model.ChartData.CategorySales[i];
                                    var catPct = totalCategorySales > 0 ? (catSales / totalCategorySales) * 100m : 0m;
                                    var borderColors = new[] { "border-vibrant-orange", "border-vibrant-pink", "border-vibrant-purple", "border-vibrant-green", "border-vibrant-blue" };
                                    var textColors = new[] { "text-vibrant-orange", "text-vibrant-pink", "text-vibrant-purple", "text-vibrant-green", "text-vibrant-blue" };
                                    var borderCol = borderColors[i % borderColors.Length];
                                    var textCol = textColors[i % textColors.Length];
                                    
                                    <div class="flex flex-col border-l-2 @borderCol pl-3 py-0.5">
                                        <div class="flex items-center justify-between">
                                            <span class="text-[11px] font-bold text-dash-text uppercase tracking-tight">@catLabel</span>
                                            <span class="text-[11px] font-mono font-bold @textCol">@catPct.ToString("F0")%</span>
                                        </div>
                                        <div class="text-[10px] text-dash-muted mt-0.5">@FormatCr(catSales)</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TABLE ANALYSIS: LOCATION WISE PERFORMANCE & COMPARISON -->
                <div class="widget-card overflow-hidden mb-6">
                    <div class="px-5 py-4 border-b border-dash-border bg-black/5 dark:bg-white/5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                        <h3 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-list-ol text-dash-primary mr-2"></i> Location Wise MTD/LMTD and YTD/LYTD Performance Analysis</h3>
                        <a asp-controller="Reports" asp-action="IncentiveRegister" class="text-[11px] font-bold text-dash-primary flex items-center gap-1 no-underline">VIEW FULL REPORT <span class="material-symbols-outlined text-[14px]">arrow_forward</span></a>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[900px]">
                            <thead class="bg-black/10 dark:bg-white/10 border-b border-dash-border">
                                <tr class="text-[11px] font-bold text-dash-muted uppercase tracking-wider font-mono">
                                    <th class="p-4">LOCATION / BRANCH</th>
                                    <th class="p-4">MTD SALES</th>
                                    <th class="p-4">LMTD SALES</th>
                                    <th class="p-4">MTD GROWTH %</th>
                                    <th class="p-4">YTD SALES</th>
                                    <th class="p-4">LYTD SALES</th>
                                    <th class="p-4">YTD GROWTH %</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-dash-border/30">
                                @foreach (var code in allLocationCodes)
                                {
                                    var branchName = branchNamesMap.TryGetValue(code, out var name) ? name : code;
                                    var mtd = mtdBranchSales.GetValueOrDefault(code, 0m);
                                    var lmtd = lmtdBranchSales.GetValueOrDefault(code, 0m);
                                    var locMtdGrowth = CalcGrowth(mtd, lmtd);

                                    var ytd = ytdBranchSales.GetValueOrDefault(code, 0m);
                                    var lytd = lytdBranchSales.GetValueOrDefault(code, 0m);
                                    var locYtdGrowth = CalcGrowth(ytd, lytd);

                                    var isMtdPos = locMtdGrowth >= 0;
                                    var mtdGrowthColor = isMtdPos ? "text-vibrant-green" : "text-red-500";
                                    var mtdIcon = isMtdPos ? "arrow_upward" : "arrow_downward";

                                    var isYtdPos = locYtdGrowth >= 0;
                                    var ytdGrowthColor = isYtdPos ? "text-vibrant-green" : "text-red-500";
                                    var ytdIcon = isYtdPos ? "arrow_upward" : "arrow_downward";

                                    <tr class="hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
                                        <td class="p-4 font-bold text-dash-text text-sm">@branchName (@code)</td>
                                        <td class="p-4 font-mono text-sm">@FormatCr(mtd)</td>
                                        <td class="p-4 font-mono text-sm text-dash-muted">@FormatCr(lmtd)</td>
                                        <td class="p-4">
                                            <div class="flex items-center gap-1 @mtdGrowthColor font-bold font-mono text-[11px]">
                                                <span class="material-symbols-outlined text-[14px]">@mtdIcon</span>
                                                <span>@((isMtdPos ? "+" : "") + locMtdGrowth.ToString("F1"))%</span>
                                            </div>
                                        </td>
                                        <td class="p-4 font-mono text-sm">@FormatCr(ytd)</td>
                                        <td class="p-4 font-mono text-sm text-dash-muted">@FormatCr(lytd)</td>
                                        <td class="p-4">
                                            <div class="flex items-center gap-1 @ytdGrowthColor font-bold font-mono text-[11px]">
                                                <span class="material-symbols-outlined text-[14px]">@ytdIcon</span>
                                                <span>@((isYtdPos ? "+" : "") + locYtdGrowth.ToString("F1"))%</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (allLocationCodes.Count == 0)
                                {
                                    <tr>
                                        <td colspan="7" class="p-4 text-center text-dash-muted text-sm">No Location Sales telemetries found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- MONTH-END CHECKLIST -->
                <div class="widget-card p-6 mb-6">
                    <div class="flex justify-between items-center mb-4 border-b border-dash-border/30 pb-3">
                        <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text">
                            <i class="fa-solid fa-clipboard-check text-dash-primary mr-2"></i> Month-End Configuration Checklist
                        </h4>
                        <span class="badge bg-dash-border/20 text-dash-text border border-dash-border text-[10px] font-mono">Readiness Status</span>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <!-- SMTP -->
                        <div class="flex items-center gap-3 p-3 rounded-lg border @(isSmtpConfigured ? "bg-green-500/10 border-green-500/20" : "bg-red-500/10 border-red-500/20")">
                            <div class="text-2xl @(isSmtpConfigured ? "text-green-500" : "text-red-500")">
                                <i class="fa-solid @(isSmtpConfigured ? "fa-circle-check" : "fa-circle-xmark")"></i>
                            </div>
                            <div>
                                <div class="font-bold text-xs text-dash-text">SMTP Mail Server</div>
                                <div class="text-[10px] text-dash-muted mt-0.5">@(isSmtpConfigured ? "Configured & Active" : "SMTP Settings Lacking")</div>
                            </div>
                        </div>

                        <!-- TDS -->
                        <div class="flex items-center gap-3 p-3 rounded-lg border @(isTdsActive ? "bg-green-500/10 border-green-500/20" : "bg-red-500/10 border-red-500/20")">
                            <div class="text-2xl @(isTdsActive ? "text-green-500" : "text-red-500")">
                                <i class="fa-solid @(isTdsActive ? "fa-circle-check" : "fa-circle-xmark")"></i>
                            </div>
                            <div>
                                <div class="font-bold text-xs text-dash-text">Active TDS Rules</div>
                                <div class="text-[10px] text-dash-muted mt-0.5">@(isTdsActive ? "Active rules present" : "No active rules today")</div>
                            </div>
                        </div>

                        <!-- Tally -->
                        <div class="flex items-center gap-3 p-3 rounded-lg border @(isTallyActive ? "bg-green-500/10 border-green-500/20" : "bg-red-500/10 border-red-500/20")">
                            <div class="text-2xl @(isTallyActive ? "text-green-500" : "text-red-500")">
                                <i class="fa-solid @(isTallyActive ? "fa-circle-check" : "fa-circle-xmark")"></i>
                            </div>
                            <div>
                                <div class="font-bold text-xs text-dash-text">Tally Integration</div>
                                <div class="text-[10px] text-dash-muted mt-0.5">@(isTallyActive ? "Enabled & Ready" : "Sync disabled/inactive")</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SUB-GRID: RECENT ACTIVITY & TOP DISTRIBUTORS -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
                    <!-- Recent Activity -->
                    <div class="widget-card lg:col-span-2 p-5">
                        <div class="flex justify-between items-center mb-4 border-b border-dash-border/30 pb-3">
                            <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-clock-rotate-left text-dash-primary mr-2"></i> Recent Activity</h4>
                            <a asp-controller="Ledger" asp-action="Index" class="text-xs text-dash-primary font-bold no-underline">View All</a>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full align-middle text-left" id="dashboardActivityTable" style="font-size: 0.8rem; min-width: 500px;">
                                <thead class="bg-black/5 dark:bg-white/5 border-b border-dash-border">
                                    <tr class="text-dash-muted font-bold text-[10px] uppercase font-mono">
                                        <th class="p-2.5">#</th>
                                        <th class="p-2.5">Activity</th>
                                        <th class="p-2.5">User</th>
                                        <th class="p-2.5">Date &amp; Time</th>
                                        <th class="p-2.5">Status</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-dash-border/30">
                                    <tr>
                                        <td class="p-2.5">1</td>
                                        <td class="p-2.5"><span class="flex items-center gap-2 fw-semibold text-dash-text"><i class="fa-solid fa-cloud-arrow-up text-dash-primary"></i> E-Way Bills Uploaded</span></td>
                                        <td class="p-2.5 text-dash-muted">John Doe</td>
                                        <td class="p-2.5 text-dash-muted">31 May 2024, 10:30 AM</td>
                                        <td class="p-2.5"><span class="badge bg-green-500/10 text-green-500 border border-green-500/20 text-[10px] font-bold px-2 py-0.5 rounded-full">Success</span></td>
                                    </tr>
                                    <tr>
                                        <td class="p-2.5">2</td>
                                        <td class="p-2.5"><span class="flex items-center gap-2 fw-semibold text-dash-text"><i class="fa-solid fa-calculator text-dash-primary"></i> Incentive Calculated</span></td>
                                        <td class="p-2.5 text-dash-muted">Jane Smith</td>
                                        <td class="p-2.5 text-dash-muted">31 May 2024, 09:15 AM</td>
                                        <td class="p-2.5"><span class="badge bg-green-500/10 text-green-500 border border-green-500/20 text-[10px] font-bold px-2 py-0.5 rounded-full">Success</span></td>
                                    </tr>
                                    <tr>
                                        <td class="p-2.5">3</td>
                                        <td class="p-2.5"><span class="flex items-center gap-2 fw-semibold text-dash-text"><i class="fa-solid fa-file-excel text-dash-primary"></i> Incentive Data Uploaded</span></td>
                                        <td class="p-2.5 text-dash-muted">Rahul Verma</td>
                                        <td class="p-2.5 text-dash-muted">30 May 2024, 06:45 PM</td>
                                        <td class="p-2.5"><span class="badge bg-green-500/10 text-green-500 border border-green-500/20 text-[10px] font-bold px-2 py-0.5 rounded-full">Success</span></td>
                                    </tr>
                                    <tr>
                                        <td class="p-2.5">4</td>
                                        <td class="p-2.5"><span class="flex items-center gap-2 fw-semibold text-dash-text"><i class="fa-solid fa-circle-check text-dash-primary"></i> Incentive Approved</span></td>
                                        <td class="p-2.5 text-dash-muted">Priya Sharma</td>
                                        <td class="p-2.5 text-dash-muted">30 May 2024, 04:20 PM</td>
                                        <td class="p-2.5"><span class="badge bg-dash-primary/10 text-dash-primary border border-dash-primary/20 text-[10px] font-bold px-2 py-0.5 rounded-full">Approved</span></td>
                                    </tr>
                                    <tr>
                                        <td class="p-2.5">5</td>
                                        <td class="p-2.5"><span class="flex items-center gap-2 fw-semibold text-dash-text"><i class="fa-solid fa-credit-card text-dash-primary"></i> Payment Released</span></td>
                                        <td class="p-2.5 text-dash-muted">Admin User</td>
                                        <td class="p-2.5 text-dash-muted">30 May 2024, 02:10 PM</td>
                                        <td class="p-2.5"><span class="badge bg-dash-secondary/10 text-dash-secondary border border-dash-secondary/20 text-[10px] font-bold px-2 py-0.5 rounded-full">Paid</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Top Distributors -->
                    <div class="widget-card p-5 flex flex-col justify-between">
                        <div class="flex justify-between items-center mb-4 border-b border-dash-border/30 pb-3">
                            <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-medal text-warning mr-2"></i> Top Distributors</h4>
                            <a asp-controller="Parties" asp-action="Index" class="text-xs text-dash-primary font-bold no-underline">View All</a>
                        </div>
                        <div class="flex flex-col gap-4 flex-grow justify-around">
                            @{
                                int rank = 1;
                                var topDealersList = Model.TopDealers.Take(5).ToList();
                                decimal maxSales = topDealersList.Count > 0 ? topDealersList.Max(x => x.Sales) : 1m;
                            }
                            @foreach (var d in topDealersList)
                            {
                                var percent = maxSales > 0 ? (d.Sales / maxSales) * 100m : 0m;
                                <div>
                                    <div class="flex justify-between items-center mb-1 text-xs">
                                        <span class="font-bold flex items-center">
                                            <span style="background: rgba(37, 99, 235, 0.1); color: var(--dash-primary); width: 20px; height: 20px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 0.65rem; font-weight: 700; margin-right: 6px;">@rank</span>
                                            @d.PartyName
                                        </span>
                                        <strong class="font-mono text-dash-text">@FormatCr(d.Sales)</strong>
                                    </div>
                                    <div class="progress" style="height: 5px; border-radius: 10px;">
                                        <div class="progress-bar" role="progressbar" style="width: @percent.ToString("F1")%; background: var(--dash-primary); border-radius: 10px;" aria-valuenow="@percent.ToString("F1")" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                                rank++;
                            }
                        </div>
                    </div>
                </div>

            </div>
        }

        <!-- ======================================================== -->
        <!-- TAB 2: BRANCH PERFORMANCE ISOLATION                      -->
        <!-- ======================================================== -->
        <div class="tab-pane fade @(!(CurrentUser.IsInRole("Super Admin") || CurrentUser.IsInRole("HO Finance") || CurrentUser.IsInRole("Auditor")) ? "show active" : "")" id="branch-pane" role="tabpanel">
            <div class="widget-card mb-6 p-5">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-filter text-dash-primary mr-2"></i> Local Branch Analytics Console</h4>
                        <p class="text-[11px] text-dash-muted mt-1">Enforces role-based isolation of dealer records for your specific jurisdiction</p>
                    </div>
                    <div>
                        <select class="form-select corp-select inline-block w-auto" id="branch-selector" @(CurrentUser.BranchId.HasValue && !CurrentUser.IsInRole("Super Admin") && !CurrentUser.IsInRole("HO Finance") && !CurrentUser.IsInRole("Auditor") ? "disabled" : "") style="height: 38px; font-weight:600; border-radius: 8px;">
                            @foreach (var br in branches)
                            {
                                <option value="@br.Id">@br.Name (@br.Code)</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Branch summaries metrics -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                <div class="metric" style="border-left: 4px solid #22C55E;">
                    <span class="text-[10px] text-dash-muted uppercase tracking-wider">Branch Sales Accrued</span>
                    <strong id="br-kpi-sales" class="font-mono text-2xl font-bold">₹0</strong>
                    <small>Accrued this intake period</small>
                </div>
                <div class="metric" style="border-left: 4px solid var(--dash-primary);">
                    <span class="text-[10px] text-dash-muted uppercase tracking-wider">Branch Payout Liability</span>
                    <strong id="br-kpi-payout" class="text-green-500 font-mono text-2xl font-bold">₹0</strong>
                    <small>Calculated net payout</small>
                </div>
                <div class="metric" style="border-left: 4px solid #f59e0b;">
                    <span class="text-[10px] text-dash-muted uppercase tracking-wider">Growth Momentum</span>
                    <strong id="br-kpi-growth" class="font-mono text-2xl font-bold">0%</strong>
                    <small>Accrued liability progress</small>
                </div>
                <div class="metric" style="border-left: 4px solid #ef4444;">
                    <span class="text-[10px] text-dash-muted uppercase tracking-wider">Slab Target Progress</span>
                    <strong id="br-kpi-slab-ach" class="font-mono text-2xl font-bold">0%</strong>
                    <small>Dealers on target thresholds</small>
                </div>
            </div>

            <!-- Branch top growth dealers & chart -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">
                <div class="widget-card lg:col-span-7 p-5">
                    <div class="mb-4 border-b border-dash-border/30 pb-3">
                        <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-list-ol text-dash-primary mr-2"></i> Branch Growth Dealers</h4>
                        <p class="text-[11px] text-dash-muted mt-1">Highest performing dealer accounts associated with this branch</p>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full table-hover align-middle text-left" id="br-top-dealers-table" style="font-size: 0.8rem;">
                            <thead class="bg-black/5 dark:bg-white/5 border-b border-dash-border">
                                <tr class="text-dash-muted font-bold uppercase font-mono">
                                    <th class="p-2.5">Dealer Profile</th>
                                    <th class="p-2.5 text-end">Sales Value</th>
                                    <th class="p-2.5 text-end">Gross Payout</th>
                                    <th class="p-2.5 text-end">Growth MoM</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-dash-border/30">
                                <!-- Populated via AJAX -->
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="widget-card lg:col-span-5 p-5">
                    <div class="mb-4 border-b border-dash-border/30 pb-3">
                        <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-chart-pie text-dash-secondary mr-2"></i> Branch Incentive Slab Spread</h4>
                        <p class="text-[11px] text-dash-muted mt-1">Slab categorization of dealers within this branch</p>
                    </div>
                    <div id="branch-slab-dist-chart" style="height: 300px;"></div>
                </div>
            </div>
        </div>

        <!-- ======================================================== -->
        <!-- TAB 3: DEALER SIMULATOR INTELLIGENCE                     -->
        <!-- ======================================================== -->
        <div class="tab-pane fade" id="dealer-pane" role="tabpanel">
            <div class="widget-card mb-6 p-5">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-magnifying-glass-chart text-dash-primary mr-2"></i> Dealer Performance Intelligence Selector</h4>
                        <p class="text-[11px] text-dash-muted mt-1">Select an active dealer account to simulate performance projections and view transaction lifecycles</p>
                    </div>
                    <div>
                        <select class="form-select corp-select inline-block w-auto" id="dealer-selector" style="height: 38px; font-weight:600; border-radius: 8px;">
                            <option value="">-- Choose Dealer --</option>
                            @foreach (var dl in parties)
                            {
                                <option value="@dl.Id">@dl.PartyCode - @dl.PartyName (@dl.Branch.Code)</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Dealer Shell populated dynamically -->
            <div id="dealer-insights-shell" style="display: none;">
                
                <!-- Dealer Stats Row -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                    <div class="metric" style="border-left: 4px solid #0ea5e9;">
                        <span class="text-[10px] text-dash-muted uppercase tracking-wider">Current Purchase Value</span>
                        <strong id="dl-kpi-sales" class="font-mono text-2xl font-bold">₹0</strong>
                        <small>Accrued this period</small>
                    </div>
                    <div class="metric" style="border-left: 4px solid var(--dash-primary);">
                        <span class="text-[10px] text-dash-muted uppercase tracking-wider">Current Slab Tier</span>
                        <strong id="dl-kpi-slab" class="font-mono text-2xl font-bold">0%</strong>
                        <small>Matched calculation rate</small>
                    </div>
                    <div class="metric" style="border-left: 4px solid #22c55e;">
                        <span class="text-[10px] text-dash-muted uppercase tracking-wider">Gross Accrued Payout</span>
                        <strong id="dl-kpi-incentive" class="text-green-500 font-mono text-2xl font-bold">₹0</strong>
                        <small>Accrued liability</small>
                    </div>
                    <div class="metric" style="border-left: 4px solid #f59e0b;">
                        <span class="text-[10px] text-dash-muted uppercase tracking-wider">Account Growth Trend</span>
                        <strong id="dl-kpi-growth" class="font-mono text-lg font-bold pt-1">0% / 0%</strong>
                        <small>MoM / YoY growth momentum</small>
                    </div>
                </div>

                <!-- Simulation projection & milestones -->
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">
                    
                    <!-- Circular progress toward next milestone -->
                    <div class="widget-card lg:col-span-5 p-6 flex flex-col justify-between items-center text-center">
                        <div class="w-full text-left border-b border-dash-border/30 pb-3 mb-4">
                            <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-bullseye text-dash-primary mr-2"></i> Next Slab Milestone Progress</h4>
                        </div>
                        <div class="flex justify-center my-4 relative">
                            <div class="circular-progress-wrap relative">
                                <svg class="progress-ring" width="180" height="180">
                                    <circle class="progress-ring__circle-bg" stroke="var(--dash-border)" stroke-width="12" fill="transparent" r="75" cx="90" cy="90"/>
                                    <circle class="progress-ring__circle" id="progress-circle" stroke="var(--dash-primary)" stroke-width="14" fill="transparent" r="75" cx="90" cy="90" stroke-linecap="round" style="transform: rotate(-90deg); transform-origin: 50% 50%; transition: stroke-dashoffset 0.35s;"/>
                                </svg>
                                <div class="absolute inset-0 flex flex-col items-center justify-center">
                                    <strong class="text-3xl font-extrabold text-dash-text" id="prog-circle-pct">0%</strong>
                                    <span class="text-[9px] text-dash-muted uppercase font-bold mt-1">Completed</span>
                                </div>
                            </div>
                        </div>
                        <div>
                            <p class="font-bold text-dash-text mb-1" id="next-slab-message" style="font-size: 0.95rem;">Calculating milestone targets...</p>
                            <small class="text-dash-muted" id="next-slab-detail">Purchase progress toward next tier</small>
                        </div>
                    </div>

                    <!-- Projection simulator -->
                    <div class="widget-card lg:col-span-7 p-6 flex flex-col justify-between">
                        <div>
                            <div class="mb-4 border-b border-dash-border/30 pb-3">
                                <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-sliders text-dash-secondary mr-2"></i> Interactive Payout Projection Simulator</h4>
                                <p class="text-[11px] text-dash-muted mt-1">Drag slider to simulate purchase values and immediately calculate higher slab payouts</p>
                            </div>

                            <div class="bg-black/5 dark:bg-white/5 p-4 rounded-lg mb-6">
                                <div class="flex justify-between items-center mb-2">
                                    <span class="font-bold text-dash-text text-xs">SIMULATED PURCHASE INCREASE</span>
                                    <span class="text-xl font-extrabold text-green-500 font-mono" id="simulator-purchase-text">+ ₹0</span>
                                </div>
                                <input type="range" class="form-range w-full" id="simulator-slider" min="0" max="500000" step="10000" value="0">
                                <div class="flex justify-between text-dash-muted text-[10px] mt-1 font-mono">
                                    <span>Current Sale</span>
                                    <span>+ ₹2,50,000</span>
                                    <span>+ ₹5,00,000</span>
                                </div>
                            </div>
                        </div>

                        <!-- Interactive Simulation Output -->
                        <div class="simulator-display-card p-4 rounded-lg text-center">
                            <div class="grid grid-cols-2 divide-x divide-dash-border/30">
                                <div>
                                    <span class="text-dash-muted text-xs block mb-1">PROJECTED PURCHASES</span>
                                    <strong class="text-lg text-dash-text font-mono" id="sim-sale">₹0</strong>
                                </div>
                                <div>
                                    <span class="text-dash-muted text-xs block mb-1">PROJECTED SLAB RATE</span>
                                    <strong class="text-lg text-dash-primary font-mono" id="sim-slab">0%</strong>
                                </div>
                            </div>
                            <hr class="my-3 border-dash-border/30">
                            <span class="text-dash-muted text-xs block mb-1">FORECASTED TOTAL INCENTIVE PAYOUT</span>
                            <strong class="text-3xl text-green-500 block font-mono font-extrabold" id="sim-incentive">₹0</strong>
                            <span class="badge bg-green-500/10 text-green-500 border border-green-500/20 mt-2 font-bold inline-block" id="sim-increase-text" style="font-size: 0.76rem;">Additional payout: ₹0</span>
                        </div>
                    </div>

                </div>

                <!-- 12-Month Performance timeline chart -->
                <div class="widget-card p-6 mb-6">
                    <div class="mb-4 border-b border-dash-border/30 pb-3">
                        <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-timeline text-dash-primary mr-2"></i> 12-Month Purchase &amp; Slab Lifecycle Trend</h4>
                        <p class="text-[11px] text-dash-muted mt-1">Analyze dealer purchase and slab tier trajectory across a rolling calendar year</p>
                    </div>
                    <div id="dealer-timeline-chart" style="height: 300px;"></div>
                </div>

                <!-- Three-Date Incentive Payment Lifecycle Tracker -->
                <div class="widget-card p-6">
                    <div class="mb-4 border-b border-dash-border/30 pb-3">
                        <h4 class="text-sm font-bold uppercase tracking-wider text-dash-text"><i class="fa-solid fa-money-check-dollar text-dash-primary mr-2"></i> Incentive Payment Lifecycle Tracker</h4>
                        <p class="text-[11px] text-dash-muted mt-1">Detailed temporal log showing Month Accrued, Processing Date, and Payment Credit Date</p>
                    </div>

                    <!-- Mobile Card Layout -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6" id="dl-history-cards-container">
                        <!-- Populated dynamically -->
                    </div>

                    <!-- Large Screens Table View -->
                    <div class="overflow-x-auto d-none d-md-block">
                        <table class="w-full text-left border-collapse" id="dl-history-lifecycle-table" style="font-size: 0.8rem;">
                            <thead class="bg-black/5 dark:bg-white/5 border-b border-dash-border">
                                <tr class="text-dash-muted font-bold uppercase font-mono">
                                    <th class="p-2.5">Accrued Month</th>
                                    <th class="p-2.5 text-end">Sales Value</th>
                                    <th class="p-2.5 text-end">Slab Rate</th>
                                    <th class="p-2.5 text-end">Gross Incentive</th>
                                    <th class="p-2.5 text-end">TDS Deducted</th>
                                    <th class="p-2.5 text-end text-green-500 font-extrabold" style="font-size:0.9rem;">Net Credited</th>
                                    <th class="p-2.5">Lifecycle State</th>
                                    <th class="p-2.5">Settled Payment Date</th>
                                    <th class="p-2.5">UTR Reference</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-dash-border/30">
                                <!-- Populated via AJAX -->
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>

            <!-- Empty Selector State -->
            <div class="widget-card text-center p-12" id="dealer-empty-state">
                <div class="text-6xl text-dash-muted/40 mb-4"><i class="fa-solid fa-magnifying-glass-chart"></i></div>
                <h4 class="font-extrabold text-dash-text text-lg">No Dealer Selected</h4>
                <p class="text-dash-muted text-xs mt-1">Select an active dealer account from the top right menu to load simulate metrics and lifecycle logs.</p>
            </div>

        </div>

    </div>

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
$(document).ready(function() {
    
    // Get theme state
    var isDark = $('body').hasClass('dark-theme');

    // Sync theme options (dispatched by modified site.js click handler)
    window.addEventListener('globalThemeChanged', function(e) {
        var dark = e.detail.isDark;
        var mode = dark ? 'dark' : 'light';
        if (trendsChart) trendsChart.updateOptions({ theme: { mode: mode } });
        if (locationSplitChart) locationSplitChart.updateOptions({ theme: { mode: mode } });
        if (categoryMixChart) categoryMixChart.updateOptions({ theme: { mode: mode } });
        if (branchSlabChart) branchSlabChart.updateOptions({ theme: { mode: mode } });
        if (dealerHistoryChart) dealerHistoryChart.updateOptions({ theme: { mode: mode } });
    });

    // ----------------------------------------------------
    // CHARTS ENGINE (TAB 1: DASHBOARD VIEW)
    // ----------------------------------------------------
    var trendsChart = null;
    var locationSplitChart = null;
    var categoryMixChart = null;
    var hoChartsInitialized = false;

    // Load data from model
    var salesTrendData = @Html.Raw(Json.Serialize(Model.ChartData.SalesTrend));
    var targetTrendData = salesTrendData.map(function(val) { return Math.round(val * 1.18); });

    function initHoCharts() {
        if (hoChartsInitialized) return;
        if (!document.querySelector("#widget-trends-chart")) return;
        hoChartsInitialized = true;

        // 12-Month Performance Trend line/area chart
        var trendsOptions = {
            chart: { 
                height: 290, 
                type: 'area', 
                toolbar: { show: false }, 
                fontFamily: 'Inter, sans-serif'
            },
            colors: ['#4f46e5', '#38bdf8'],
            stroke: { width: [3, 2], curve: 'smooth', dashArray: [0, 4] },
            fill: {
                type: ['gradient', 'solid'],
                gradient: {
                    shadeIntensity: 1,
                    opacityFrom: 0.35,
                    opacityTo: 0.05,
                    stops: [0, 95]
                }
            },
            series: [
                { name: 'Achieved Sales (₹)', data: salesTrendData },
                { name: 'Target (₹)', data: targetTrendData }
            ],
            xaxis: { 
                categories: @Html.Raw(Json.Serialize(Model.ChartData.Months)),
                labels: { style: { colors: 'var(--dash-text-muted)', fontWeight: 500 } }
            },
            yaxis: { 
                labels: { 
                    formatter: function(val) { 
                        if (val >= 10000000) return '₹' + (val / 10000000).toFixed(1) + ' Cr';
                        if (val >= 100000) return '₹' + (val / 100000).toFixed(1) + ' L';
                        return '₹' + val.toLocaleString('en-IN'); 
                    },
                    style: { colors: 'var(--dash-text-muted)', fontWeight: 500 }
                } 
            },
            legend: { position: 'bottom', labels: { colors: 'var(--dash-text)' }, fontWeight: 600 },
            grid: { borderColor: 'rgba(156, 163, 175, 0.15)' },
            theme: { mode: $('body').hasClass('dark-theme') ? 'dark' : 'light' }
        };
        trendsChart = new ApexCharts(document.querySelector("#widget-trends-chart"), trendsOptions);
        trendsChart.render();

        // Location Split Donut (minimalist design matching Stitch)
        var locationLabels = @Html.Raw(Json.Serialize(Model.ChartData.LocationLabels));
        var locationSales  = @Html.Raw(Json.Serialize(Model.ChartData.LocationSales));
        var totalLocationSales = locationSales.reduce(function(a,b){ return a+b; }, 0);

        var locationSplitOptions = {
            chart: { type: 'donut', height: 180, fontFamily: 'Inter, sans-serif' },
            colors: ['#059669', '#0284c7', '#7c3aed', '#ea580c', '#ec4899'],
            series: locationSales,
            labels: locationLabels,
            legend: { show: false },
            dataLabels: { enabled: false },
            stroke: { colors: ['var(--dash-card)'], width: 2 },
            plotOptions: {
                pie: {
                    donut: {
                        size: '72%',
                        labels: {
                            show: true,
                            name: { show: true, fontSize: '10px', color: 'var(--dash-text-muted)', formatter: function() { return 'Total Sales'; } },
                            value: {
                                show: true,
                                fontSize: '13px',
                                color: 'var(--dash-text)',
                                fontWeight: '700',
                                formatter: function() {
                                    if (totalLocationSales >= 10000000) return '₹' + (totalLocationSales / 10000000).toFixed(2) + ' Cr';
                                    return '₹' + totalLocationSales.toLocaleString('en-IN');
                                }
                            }
                        }
                    }
                }
            },
            theme: { mode: $('body').hasClass('dark-theme') ? 'dark' : 'light' }
        };
        locationSplitChart = new ApexCharts(document.querySelector("#location-split-chart"), locationSplitOptions);
        locationSplitChart.render();

        // Category Mix Donut (minimalist design matching Stitch)
        var categoryLabels = @Html.Raw(Json.Serialize(Model.ChartData.CategoryLabels));
        var categorySales  = @Html.Raw(Json.Serialize(Model.ChartData.CategorySales));
        var totalCategorySales = categorySales.reduce(function(a,b){ return a+b; }, 0);

        var categoryMixOptions = {
            chart: { type: 'donut', height: 180, fontFamily: 'Inter, sans-serif' },
            colors: ['#ea580c', '#db2777', '#7c3aed', '#059669', '#0284c7'],
            series: categorySales,
            labels: categoryLabels,
            legend: { show: false },
            dataLabels: { enabled: false },
            stroke: { colors: ['var(--dash-card)'], width: 2 },
            plotOptions: {
                pie: {
                    donut: {
                        size: '72%',
                        labels: {
                            show: true,
                            name: { show: true, fontSize: '10px', color: 'var(--dash-text-muted)', formatter: function() { return 'Total Mix'; } },
                            value: {
                                show: true,
                                fontSize: '13px',
                                color: 'var(--dash-text)',
                                fontWeight: '700',
                                formatter: function() {
                                    if (totalCategorySales >= 10000000) return '₹' + (totalCategorySales / 10000000).toFixed(2) + ' Cr';
                                    return '₹' + totalCategorySales.toLocaleString('en-IN');
                                }
                            }
                        }
                    }
                }
            },
            theme: { mode: $('body').hasClass('dark-theme') ? 'dark' : 'light' }
        };
        categoryMixChart = new ApexCharts(document.querySelector("#category-mix-chart"), categoryMixOptions);
        categoryMixChart.render();
    }

    // ----------------------------------------------------
    // BRANCH TAB ENGINE (ISOLATING DETAILS)
    // ----------------------------------------------------
    let branchSlabChart = null;

    function renderBranchSlabChart(ranges, counts) {
        const options = {
            chart: { height: 300, type: 'donut', fontFamily: 'Inter, sans-serif' },
            colors: ['#0284c7', '#ef4444', '#0ea5e9', '#06b6d4', '#10B981'],
            series: counts,
            labels: ranges,
            stroke: { colors: ['var(--dash-card)'], width: 2 },
            responsive: [{ breakpoint: 480, options: { chart: { width: 180 } } }],
            legend: { position: 'bottom', labels: { colors: 'var(--dash-text)' }, fontWeight: 600 },
            theme: { mode: $('body').hasClass('dark-theme') ? 'dark' : 'light' }
        };
        if (branchSlabChart) {
            branchSlabChart.destroy();
        }
        branchSlabChart = new ApexCharts(document.querySelector("#branch-slab-dist-chart"), options);
        branchSlabChart.render();
    }

    function loadBranchAnalytics(branchId) {
        $.ajax({ url: `/api/branch/${branchId}/analytics`, method: 'GET' })
            .done(r => {
                $('#br-kpi-sales').text('₹' + Math.round(r.totalSales).toLocaleString('en-IN'));
                $('#br-kpi-payout').text('₹' + Math.round(r.totalIncentive).toLocaleString('en-IN'));
                $('#br-kpi-growth').text((r.growthPercent >= 0 ? '+' : '') + r.growthPercent.toFixed(2) + '%');
                $('#br-kpi-slab-ach').text(r.slabAchievementPercent.toFixed(1) + '%');

                // Render top/weak dealers
                const table = $('#br-top-dealers-table tbody').empty();
                r.topDealers.forEach(d => {
                    table.append(`
                        <tr class="hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
                            <td class="p-2.5">
                                <span class="fw-bold text-dash-text">${d.partyName}</span>
                                <span class="d-block small text-dash-muted font-mono" style="font-size:0.72rem;">Code: ${d.partyCode}</span>
                            </td>
                            <td class="p-2.5 text-end font-mono fw-bold text-dash-text">₹${Math.round(d.sales).toLocaleString('en-IN')}</td>
                            <td class="p-2.5 text-end text-green-500 font-mono fw-bold">₹${Math.round(d.incentive).toLocaleString('en-IN')}</td>
                            <td class="p-2.5 text-end fw-bold ${d.growthMoM >= 0 ? 'text-green-500' : 'text-red-500'}">
                                ${d.growthMoM >= 0 ? '▲' : '▼'} ${Math.abs(d.growthMoM).toFixed(1)}%
                            </td>
                        </tr>
                    `);
                });

                // Update slab charts
                const slabRanges = [];
                const slabCounts = [];
                const distribution = {};
                r.topDealers.forEach(d => {
                    const label = `${d.slabPercent.toFixed(0)}% Slab`;
                    distribution[label] = (distribution[label] || 0) + 1;
                });
                for (const key in distribution) {
                    slabRanges.push(key);
                    slabCounts.push(distribution[key]);
                }
                renderBranchSlabChart(slabRanges.length ? slabRanges : ['0% Slab'], slabCounts.length ? slabCounts : [1]);
            })
            .fail(xhr => {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to load branch analytics.' });
            });
    }

    let hoChartsPending = $('#ho-tab').length > 0 && !$('#ho-tab').hasClass('active');
    let branchAnalyticsPending = $('#branch-tab').length > 0 && !$('#branch-tab').hasClass('active');

    // Trigger Branch analytics reload
    $('#branch-selector').on('change', function() {
        loadBranchAnalytics($(this).val());
        branchAnalyticsPending = false;
    });

    // Initialize HO charts on page load if active
    if ($('#ho-tab').hasClass('active')) {
        initHoCharts();
    }
    // Initialize Branch analytics on page load if active
    if ($('#branch-tab').hasClass('active')) {
        if ($('#branch-selector').val()) {
            loadBranchAnalytics($('#branch-selector').val());
        }
    }

    // Tab shown listener to load deferred content
    $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
        const targetId = $(e.target).attr('id');
        if (targetId === 'ho-tab' && hoChartsPending) {
            initHoCharts();
            hoChartsPending = false;
        } else if (targetId === 'branch-tab' && branchAnalyticsPending) {
            if ($('#branch-selector').val()) {
                loadBranchAnalytics($('#branch-selector').val());
            }
            branchAnalyticsPending = false;
        }
    });

    // ----------------------------------------------------
    // DEALER TAB & SIMULATION SIMULATOR ENGINE
    // ----------------------------------------------------
    let activeDealerSlabs = [];
    let currentDealerSales = 0;
    let currentDealerAchievement = 0;
    let currentDealerIncentive = 0;
    let nextSlabTarget = 0;
    let nextSlabPercent = 0;
    let dealerHistoryChart = null;

    function renderDealerHistoryChart(months, sales, incentives) {
        const options = {
            chart: { height: 300, type: 'area', toolbar: { show: false }, fontFamily: 'Inter, sans-serif' },
            colors: ['#0284c7', '#059669'],
            stroke: { width: [3, 3], curve: 'smooth' },
            series: [
                { name: 'Net Purchase Value', data: sales },
                { name: 'Accrued Incentive Payout', data: incentives }
            ],
            fill: { type: ['gradient', 'solid'], gradient: { opacityFrom: 0.35, opacityTo: 0.05 } },
            xaxis: { categories: months, labels: { style: { colors: 'var(--dash-text-muted)', fontWeight: 500 } } },
            yaxis: { 
                labels: { 
                    formatter: val => '₹' + val.toLocaleString('en-IN'),
                    style: { colors: 'var(--dash-text-muted)', fontWeight: 500 }
                } 
            },
            grid: { borderColor: 'rgba(156, 163, 175, 0.15)' },
            legend: { labels: { colors: 'var(--dash-text)' } },
            theme: { mode: $('body').hasClass('dark-theme') ? 'dark' : 'light' }
        };
        if (dealerHistoryChart) {
            dealerHistoryChart.destroy();
        }
        dealerHistoryChart = new ApexCharts(document.querySelector("#dealer-timeline-chart"), options);
        dealerHistoryChart.render();
    }

    function loadDealerIntelligence(partyId) {
        if (!partyId) {
            $('#dealer-insights-shell').hide();
            $('#dealer-empty-state').show();
            return;
        }

        // Fetch Summary
        $.ajax({ url: `/api/party/${partyId}/summary`, method: 'GET' })
            .done(r => {
                currentDealerSales = r.currentSale;
                currentDealerIncentive = r.currentIncentive;
                currentDealerAchievement = r.currentSale > 0 ? (r.currentSale / (r.currentSale + r.additionalPurchaseRequired)) * 100 : 0;
                activeDealerSlabs = r.activeSlabs;
                nextSlabTarget = r.nextSlabTarget;
                nextSlabPercent = r.nextSlabPercent;

                $('#dl-kpi-sales').text('₹' + Math.round(r.currentSale).toLocaleString('en-IN'));
                $('#dl-kpi-slab').text(r.currentSlabPercent.toFixed(1) + '%');
                $('#dl-kpi-incentive').text('₹' + Math.round(r.currentIncentive).toLocaleString('en-IN'));
                $('#dl-kpi-growth').text(`${r.growthMoM >= 0 ? '+' : ''}${r.growthMoM.toFixed(0)}% MoM / ${r.growthYoY >= 0 ? '+' : ''}${r.growthYoY.toFixed(0)}% YoY`);

                // Update circular ring progress
                const pct = Math.min(100, Math.round(r.progressPercent));
                $('#prog-circle-pct').text(pct + '%');
                const strokeDashOffset = 471 - (471 * pct) / 100;
                $('#progress-circle').css('stroke-dashoffset', strokeDashOffset);

                if (r.additionalPurchaseRequired > 0) {
                    $('#next-slab-message').html(`Only <span class="text-dash-primary fw-bold">₹${Math.round(r.additionalPurchaseRequired).toLocaleString('en-IN')}</span> more to unlock ${r.nextSlabPercent.toFixed(0)}% Slab!`);
                    $('#next-slab-detail').text(`Current purchase: ₹${Math.round(r.currentSale).toLocaleString('en-IN')} | Milestone target: ₹${Math.round(r.currentSale + r.additionalPurchaseRequired).toLocaleString('en-IN')}`);
                } else {
                    $('#next-slab-message').text('🎉 Highest Incentive Slab Target Fully Achieved!');
                    $('#next-slab-detail').text('Maximum available slab rates successfully unlocked');
                }

                // Reset simulator slider
                $('#simulator-slider').val(0).trigger('input');

                $('#dealer-empty-state').hide();
                $('#dealer-insights-shell').show();
            })
            .fail(xhr => Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to load dealer summary details.' }));

        // Fetch History Lifecycle
        $.ajax({ url: `/api/party/${partyId}/history`, method: 'GET' })
            .done(h => {
                const months = h.map(x => x.monthName);
                const sales = h.map(x => x.sales);
                const incentives = h.map(x => x.incentive);
                renderDealerHistoryChart(months, sales, incentives);

                const tbody = $('#dl-history-lifecycle-table tbody').empty();
                const cardContainer = $('#dl-history-cards-container').empty();

                if (h.length === 0) {
                    tbody.append('<tr><td colspan="9" class="text-center text-dash-muted py-5"><i class="fa-solid fa-inbox fa-xl d-block mb-2"></i> No transaction records found</td></tr>');
                    cardContainer.append('<div class="col-12 text-center text-dash-muted py-4">No transaction records found</div>');
                    return;
                }

                const reverseHist = [...h].reverse();

                reverseHist.forEach(item => {
                    const isSettled = item.status === "Success" || item.status === "Completed" || item.status === "Reconciled" || item.status === "Paid";
                    const statusClass = isSettled ? "success" : (item.status === "Pending" ? "warning" : "neutral");

                    tbody.append(`
                        <tr class="hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
                            <td class="p-2.5 font-bold">${item.monthName}</td>
                            <td class="p-2.5 text-end font-mono">₹${Math.round(item.sales).toLocaleString('en-IN')}</td>
                            <td class="p-2.5 text-end"><span class="badge bg-black/5 dark:bg-white/5 text-dash-text border border-dash-border">${item.slabPercent.toFixed(1)}%</span></td>
                            <td class="p-2.5 text-end font-mono fw-bold">₹${Math.round(item.incentive).toLocaleString('en-IN')}</td>
                            <td class="p-2.5 text-end text-red-500 font-mono">₹${Math.round(item.tdsAmount).toLocaleString('en-IN')}</td>
                            <td class="p-2.5 text-end text-green-500 font-mono fw-extrabold text-[0.95rem]">₹${Math.round(item.netCreditedAmount).toLocaleString('en-IN')}</td>
                            <td class="p-2.5"><span class="badge bg-dash-primary/10 text-dash-primary border border-dash-primary/20">${item.status === 'Paid' ? 'Reconciled' : item.status}</span></td>
                            <td class="p-2.5 text-dash-muted"><i class="fa-regular fa-calendar-check mr-1"></i> ${item.creditedOn}</td>
                            <td class="p-2.5 font-mono text-[10px] text-dash-muted">${item.utr}</td>
                        </tr>
                    `);

                    cardContainer.append(`
                        <div class="col-md-6 col-xl-4 animate-fade-in-up">
                            <div class="widget-card p-4 hover:shadow-md transition-all">
                                <div class="flex justify-between items-center mb-3 border-b border-dash-border/30 pb-2">
                                    <h5 class="font-bold mb-0 text-dash-text text-xs"><i class="fa-regular fa-calendar mr-1 text-dash-primary"></i> ${item.monthName}</h5>
                                    <span class="badge bg-dash-primary/10 text-dash-primary border border-dash-primary/20 text-[10px]">${item.status === 'Paid' ? 'Reconciled' : item.status}</span>
                                </div>
                                <div class="grid grid-cols-2 gap-2 text-[11px]">
                                    <div class="text-dash-muted">Purchase Sales:</div>
                                    <div class="text-end font-bold text-dash-text font-mono">₹${Math.round(item.sales).toLocaleString('en-IN')}</div>
                                    
                                    <div class="text-dash-muted">Accrued Gross:</div>
                                    <div class="text-end font-bold text-dash-text font-mono">₹${Math.round(item.incentive).toLocaleString('en-IN')}</div>
                                    
                                    <div class="text-dash-muted">TDS Deducted:</div>
                                    <div class="text-end font-bold text-red-500 font-mono">₹${Math.round(item.tdsAmount).toLocaleString('en-IN')}</div>
                                    
                                    <div class="text-dash-muted">Net Credited:</div>
                                    <div class="text-end font-extrabold text-green-500 font-mono" style="font-size: 0.85rem;">₹${Math.round(item.netCreditedAmount).toLocaleString('en-IN')}</div>
                                    
                                    <hr class="my-2 col-span-2 border-dash-border/30">
                                    
                                    <div class="text-dash-muted">Credit Date:</div>
                                    <div class="text-end text-dash-text">${item.creditedOn}</div>
                                    
                                    <div class="text-dash-muted">UTR Code:</div>
                                    <div class="text-end text-dash-text font-mono"><code>${item.utr}</code></div>
                                </div>
                            </div>
                        </div>
                    `);
                });
            });
    }

    // simulator slider triggers
    $('#simulator-slider').on('input', function() {
        const val = Number($(this).val());
        $('#simulator-purchase-text').text('+ ₹' + val.toLocaleString('en-IN'));

        const simulatedSale = currentDealerSales + val;
        $('#sim-sale').text('₹' + Math.round(simulatedSale).toLocaleString('en-IN'));

        const baseTarget = currentDealerSales > 0 ? (currentDealerSales * 100) / currentDealerAchievement : currentDealerSales;
        const simAchievement = baseTarget > 0 ? (simulatedSale / baseTarget) * 100 : 100;

        let matchedSlab = activeDealerSlabs[0];
        activeDealerSlabs.forEach(s => {
            if (simAchievement >= s.minAchievement && simAchievement <= s.maxAchievement) {
                matchedSlab = s;
            }
        });

        const slabPercent = matchedSlab ? matchedSlab.percentage : 0;
        const fixedAmt = matchedSlab ? matchedSlab.fixedAmount : 0;
        const projectedIncentive = Math.round(fixedAmt + (simulatedSale * (slabPercent / 100)));
        const increase = Math.max(0, projectedIncentive - currentDealerIncentive);

        $('#sim-slab').text(slabPercent.toFixed(0) + '% Slab');
        $('#sim-incentive').text('₹' + projectedIncentive.toLocaleString('en-IN'));
        $('#sim-increase-text').text(`Simulated payout increase of: ₹${increase.toLocaleString('en-IN')}`);

        if (nextSlabTarget > 0) {
            const simProgress = Math.min(100, Math.round((simulatedSale / nextSlabTarget) * 100));
            $('#prog-circle-pct').text(simProgress + '%');
            const strokeDashOffset = 471 - (471 * simProgress) / 100;
            $('#progress-circle').css('stroke-dashoffset', strokeDashOffset);

            if (simulatedSale >= nextSlabTarget) {
                $('#next-slab-message').html('🎉 Simulated target achieved! <strong>' + nextSlabPercent.toFixed(0) + '% Slab rate unlocked!</strong>');
                $('#next-slab-detail').text('Maximum simulated slab rate successfully achieved');
            } else {
                const remaining = Math.max(0, nextSlabTarget - simulatedSale);
                $('#next-slab-message').html(`Simulated: Only <span class="text-dash-primary fw-bold">₹${Math.round(remaining).toLocaleString('en-IN')}</span> more to unlock ${nextSlabPercent.toFixed(0)}% Slab!`);
                $('#next-slab-detail').text(`Simulated purchase: ₹${Math.round(simulatedSale).toLocaleString('en-IN')} | Target threshold: ₹${Math.round(nextSlabTarget).toLocaleString('en-IN')}`);
            }
        }
    });

    $('#dealer-selector').on('change', function() {
        loadDealerIntelligence($(this).val());
    });
});
</script>
}
