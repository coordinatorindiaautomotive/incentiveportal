@{
    ViewBag.Title = "Upload Bank Payments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ── Bank Payment Upload ─────────────────────────────────────── */
    .upload-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 14px;
        padding-bottom: 20px;
        margin-bottom: 24px;
        border-bottom: 1px solid var(--line, #e2e8f0);
    }
    .upload-page-title {
        font-size: 1.28rem;
        font-weight: 700;
        color: var(--text, #0f172a);
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .upload-page-title .title-icon {
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg, #2563eb 0%, #06b6d4 100%);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        flex-shrink: 0;
    }

    /* Drop zone */
    .dropzone-area {
        border: 2px dashed var(--line, #e2e8f0);
        border-radius: 16px;
        padding: 48px 24px;
        text-align: center;
        background: #f8fafc;
        cursor: pointer;
        transition: all 0.25s ease;
        position: relative;
    }
    .dropzone-area:hover,
    .dropzone-area.drag-over {
        border-color: #2563eb;
        background: rgba(37, 99, 235, 0.04);
    }
    .dropzone-area .dz-icon {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, #2563eb 0%, #06b6d4 100%);
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        margin-bottom: 16px;
    }
    .dropzone-area h5 {
        font-weight: 700;
        color: var(--text, #0f172a);
        margin-bottom: 6px;
    }
    .dropzone-area p { font-size: 0.88rem; color: var(--muted, #64748b); margin-bottom: 0; }
    .dropzone-area input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }
    .file-selected-badge {
        display: none;
        align-items: center;
        gap: 10px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        padding: 12px 16px;
        margin-top: 14px;
        font-size: 0.875rem;
        font-weight: 600;
        color: #15803d;
    }

    /* Info card */
    .ssot-info-card {
        background: linear-gradient(135deg, rgba(37,99,235,0.04), rgba(6,182,212,0.04));
        border: 1px solid rgba(37,99,235,0.15);
        border-radius: 12px;
        padding: 18px 20px;
    }
    .ssot-info-card h6 {
        font-size: 0.85rem;
        font-weight: 700;
        color: #1e40af;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 7px;
    }
    .ssot-info-card ul {
        margin: 0;
        padding-left: 18px;
        font-size: 0.83rem;
        color: var(--muted, #64748b);
        line-height: 1.9;
    }

    /* Preview table */
    .preview-panel {
        display: none;
        background: var(--panel, #fff);
        border: 1px solid var(--line, #e2e8f0);
        border-radius: 14px;
        overflow: hidden;
        margin-top: 24px;
    }
    .preview-panel-header {
        background: #f8fafc;
        padding: 14px 18px;
        border-bottom: 1px solid var(--line, #e2e8f0);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }
    .preview-panel-header h6 { margin: 0; font-weight: 700; font-size: 0.9rem; }
    .preview-scroll { overflow-x: auto; }
    .preview-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
    .preview-table th {
        background: #f1f5f9;
        padding: 8px 12px;
        font-weight: 700;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--muted, #64748b);
        white-space: nowrap;
        border-bottom: 1px solid var(--line, #e2e8f0);
        position: sticky;
        top: 0;
    }
    .preview-table td {
        padding: 7px 12px;
        border-bottom: 1px solid #f1f5f9;
        white-space: nowrap;
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        color: var(--text, #0f172a);
    }
    .preview-table tbody tr:hover { background: #f8fafc; }

    /* Alerts */
    .dup-warning {
        display: none;
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 10px;
        padding: 14px 18px;
        font-size: 0.875rem;
        color: #92400e;
        align-items: flex-start;
        gap: 10px;
        margin-top: 14px;
    }
    .dup-warning i { flex-shrink: 0; color: #f59e0b; margin-top: 1px; }

    /* Action buttons */
    .commit-btn {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        color: #fff;
        border-radius: 10px;
        padding: 11px 28px;
        font-size: 0.9rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: opacity 0.2s;
    }
    .commit-btn:hover { opacity: 0.9; }
    .commit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* Result card */
    .result-card {
        display: none;
        border-radius: 14px;
        padding: 24px;
        margin-top: 20px;
    }
    .result-card.success { background: #f0fdf4; border: 1px solid #bbf7d0; }
    .result-card.partial  { background: #eff6ff; border: 1px solid #bfdbfe; }
    .result-card.failure  { background: #fef2f2; border: 1px solid #fecaca; }
    .result-card h5 { font-weight: 800; font-size: 1.05rem; margin-bottom: 14px; }
    .result-stat { display: inline-flex; flex-direction: column; align-items: center; min-width: 80px; }
    .result-stat-val { font-size: 1.4rem; font-weight: 800; }
    .result-stat-label { font-size: 0.73rem; color: var(--muted,#64748b); }

    /* Progress spinner overlay */
    #uploadSpinner {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,0.5);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 14px;
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
    }
    #uploadSpinner .spinner-ring {
        width: 52px;
        height: 52px;
        border: 4px solid rgba(255,255,255,0.2);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@* Spinner overlay *@
<div id="uploadSpinner">
    <div class="spinner-ring"></div>
    <div id="spinnerMsg">Processing…</div>
</div>

<div class="container-fluid px-0">

    @* Page Header *@
    <div class="upload-page-header">
        <div class="upload-page-title">
            <div class="title-icon">
                <i data-lucide="upload-cloud" style="width:16px;height:16px;"></i>
            </div>
            <div>
                Upload Bank Payment File
                <div style="font-size:0.78rem;font-weight:500;color:var(--muted,#64748b);margin-top:2px;">
                    All rows will be stored as the protected SSOT — no modifications after upload
                </div>
            </div>
        </div>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm rounded-pill" style="font-size:0.82rem;">
            <i data-lucide="arrow-left" style="width:13px;height:13px;margin-right:4px;"></i>Back to History
        </a>
    </div>

    <div class="row g-4">
        @* Left: Upload form *@
        <div class="col-lg-8">

            @* SSOT guarantee notice *@
            <div class="ssot-info-card mb-4">
                <h6>
                    <i data-lucide="shield-check" style="width:14px;height:14px;"></i>
                    Protected Raw Bank Payment Table — SSOT Rules
                </h6>
                <ul>
                    <li>Every row is stored exactly as received from the bank. No field is modified.</li>
                    <li>Rows are <strong>never updated or deleted</strong> after insert.</li>
                    <li>Duplicate rows (same File_Sequence_Num + UTR No) are automatically skipped.</li>
                    <li>Re-uploading the same file name triggers a row-level duplicate check — not a file-level block.</li>
                </ul>
            </div>

            @* Reconciliation Period Selection *@
            <div class="card mb-4 border-0 shadow-sm" style="border-radius:12px; background:var(--panel,#fff); border: 1px solid var(--line,#e2e8f0)!important;">
                <div class="card-body p-3">
                    <h6 class="mb-3 d-flex align-items-center gap-2" style="font-size:0.85rem; font-weight:700; color:var(--text,#0f172a);">
                        <i data-lucide="calendar" style="width:15px; height:15px; color:#2563eb;"></i>
                        Reconciliation Target Period
                    </h6>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label text-muted mb-1" style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.03em;">Month</label>
                            <select id="reconMonth" class="form-select form-select-sm rounded-3">
                                @{
                                    var currentMonth = 4; // Default to April
                                    var months = new[] { "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December" };
                                }
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m" selected="@(m == currentMonth ? "selected" : null)">@months[m - 1]</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted mb-1" style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.03em;">Year</label>
                            <select id="reconYear" class="form-select form-select-sm rounded-3">
                                @{
                                    var currentYear = 2026; // Default to 2026
                                }
                                @for (int y = currentYear - 2; y <= currentYear + 2; y++)
                                {
                                    <option value="@y" selected="@(y == currentYear ? "selected" : null)">@y</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            @* Drop zone *@
            <div class="dropzone-area" id="dropzone">
                <input type="file" id="fileInput" accept=".xlsx,.xls" />
                <div class="dz-icon"><i data-lucide="file-spreadsheet" style="width:26px;height:26px;"></i></div>
                <h5>Drop your bank payment Excel file here</h5>
                <p>Or click to browse — .xlsx / .xls accepted, max 50 MB</p>
            </div>
            <div class="file-selected-badge" id="fileSelectedBadge">
                <i data-lucide="check-circle" style="width:18px;height:18px;"></i>
                <div id="selectedFileName">No file selected</div>
                <button type="button" class="btn btn-outline-secondary btn-sm ms-auto rounded-pill" onclick="clearFile()" style="font-size:0.78rem;">Change</button>
            </div>

            @* Duplicate file warning *@
            <div class="dup-warning" id="dupWarning">
                <i data-lucide="alert-triangle" style="width:18px;height:18px;"></i>
                <div id="dupWarningText"></div>
            </div>

            @* Preview controls *@
            <div id="previewControls" style="display:none;margin-top:20px;">
                <div class="d-flex gap-3 align-items-center flex-wrap">
                    <button type="button" class="btn btn-outline-primary rounded-pill px-4" id="previewBtn" onclick="doPreview()" style="font-size:0.88rem;">
                        <i data-lucide="eye" style="width:14px;height:14px;margin-right:5px;"></i>Preview (first 50 rows)
                    </button>
                    <button type="button" class="commit-btn" id="commitBtn" onclick="doCommit()" disabled>
                        <i data-lucide="cloud-upload" style="width:16px;height:16px;"></i>Commit to Protected Table
                    </button>
                    <a href="@Url.Action("DownloadTemplate")" class="btn btn-outline-secondary btn-sm rounded-pill" style="font-size:0.82rem;">
                        <i data-lucide="download" style="width:13px;height:13px;margin-right:4px;"></i>Template
                    </a>
                </div>
            </div>

            @* Preview panel *@
            <div class="preview-panel" id="previewPanel">
                <div class="preview-panel-header">
                    <h6><i data-lucide="table" style="width:14px;height:14px;margin-right:5px;color:#2563eb;"></i>File Preview <span id="previewRowCount" style="font-weight:500;color:var(--muted,#64748b);font-size:0.82rem;"></span></h6>
                    <span style="font-size:0.78rem;color:var(--muted,#64748b);">Showing up to 50 rows. Click Commit to import all rows.</span>
                </div>
                <div class="preview-scroll" style="max-height:380px;overflow:auto;">
                    <table class="preview-table">
                        <thead id="previewThead"></thead>
                        <tbody id="previewTbody"></tbody>
                    </table>
                </div>
            </div>

            @* Result card *@
            <div class="result-card" id="resultCard">
                <h5 id="resultTitle"></h5>
                <div class="d-flex gap-4 flex-wrap mb-3" id="resultStats"></div>
                <div id="resultBatchRef" style="font-size:0.82rem;color:var(--muted,#64748b);margin-bottom:12px;"></div>
                <div id="resultMsg" style="font-size:0.875rem;margin-bottom:16px;"></div>
                <div class="d-flex gap-2">
                    <a id="viewBatchLink" href="#" class="btn btn-primary btn-sm rounded-pill" style="font-size:0.82rem;background:linear-gradient(135deg,#2563eb,#06b6d4);border:none;">
                        <i data-lucide="eye" style="width:12px;height:12px;margin-right:4px;"></i>View Batch Detail
                    </a>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm rounded-pill" style="font-size:0.82rem;">Back to History</a>
                    <button type="button" class="btn btn-outline-primary btn-sm rounded-pill" style="font-size:0.82rem;" onclick="resetForm()">Upload Another</button>
                </div>
            </div>

        </div>

        @* Right: Help panel *@
        <div class="col-lg-4">
            <div class="bpi-help-panel" style="background:var(--panel,#fff);border:1px solid var(--line,#e2e8f0);border-radius:14px;padding:20px;">
                <h6 style="font-size:0.88rem;font-weight:700;margin-bottom:14px;color:var(--text,#0f172a);display:flex;align-items:center;gap:7px;">
                    <i data-lucide="info" style="width:14px;height:14px;color:#2563eb;"></i>Expected Columns
                </h6>
                <div style="font-size:0.78rem;color:var(--muted,#64748b);line-height:2;">
                    @foreach (var col in new[]{"File_Sequence_Num","Pymt_Prod_Type_Code","Pymt_Mode","Debit_Acct_no","Beneficiary Name","Beneficiary Account No","Bene_IFSC_Code","Amount","Debit Narration","Credit Narration","Mobile Number","Email ID","Remark","Pymt_Date","Reference_no","Addl_Info1","Addl_Info2","Addl_Info3","Addl_Info4","Addl_Info5","Beneficiary LEI","STATUS","Current Step","File Name","Rejected By","Rejection Reason","Acct_Debit_Date","Customer Ref No","UTR NO"})
                    {
                        <div style="padding:2px 0;border-bottom:1px solid #f1f5f9;display:flex;align-items:center;gap:6px;">
                            <i data-lucide="minus" style="width:9px;height:9px;color:#2563eb;flex-shrink:0;"></i>@col
                        </div>
                    }
                </div>
                <div style="margin-top:14px;font-size:0.77rem;color:var(--muted,#64748b);background:#f8fafc;border-radius:8px;padding:10px;">
                    <i data-lucide="lightbulb" style="width:12px;height:12px;color:#f59e0b;margin-right:4px;"></i>
                    Column matching is <strong>header-name based</strong> and case-insensitive. Column order in your file does not matter.
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
(function () {
    'use strict';

    const dropzone     = document.getElementById('dropzone');
    const fileInput    = document.getElementById('fileInput');
    const filesBadge   = document.getElementById('fileSelectedBadge');
    const fileNameEl   = document.getElementById('selectedFileName');
    const previewCtrl  = document.getElementById('previewControls');
    const previewPanel = document.getElementById('previewPanel');
    const commitBtn    = document.getElementById('commitBtn');
    const dupWarning   = document.getElementById('dupWarning');
    const dupWarnText  = document.getElementById('dupWarningText');
    const resultCard   = document.getElementById('resultCard');
    const spinner      = document.getElementById('uploadSpinner');
    const spinnerMsg   = document.getElementById('spinnerMsg');

    let currentFile = null;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                ?? document.cookie.match(/CSRF-TOKEN=([^;]+)/)?.[1] ?? '';

    // ── Drag & Drop ───────────────────────────────────────────────
    dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('drag-over'); });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag-over'));
    dropzone.addEventListener('drop', e => {
        e.preventDefault();
        dropzone.classList.remove('drag-over');
        if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
    });
    fileInput.addEventListener('change', () => { if (fileInput.files.length) handleFile(fileInput.files[0]); });

    function handleFile(f) {
        if (!f.name.match(/\.(xlsx|xls)$/i)) { alert('Please select an Excel file (.xlsx or .xls)'); return; }
        currentFile = f;
        fileNameEl.textContent = f.name + ' (' + (f.size / 1024).toFixed(1) + ' KB)';
        filesBadge.style.display = 'flex';
        dropzone.style.display = 'none';
        previewCtrl.style.display = 'block';
        hideResult();
        resetPreview();
        dupWarning.style.display = 'none';
        commitBtn.disabled = true;
    }

    window.clearFile = function () {
        currentFile = null;
        fileInput.value = '';
        filesBadge.style.display = 'none';
        dropzone.style.display = 'block';
        previewCtrl.style.display = 'none';
        resetPreview();
        hideResult();
        dupWarning.style.display = 'none';
    };

    // ── Preview ───────────────────────────────────────────────────
    window.doPreview = async function () {
        if (!currentFile) return;
        showSpinner('Parsing file…');
        const fd = new FormData();
        fd.append('file', currentFile);
        fd.append('__RequestVerificationToken', token);
        try {
            const res  = await fetch('@Url.Action("Preview")', { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                throw new Error(text.substring(0, 300) || 'Server returned an error status.');
            }
            const data = await res.json();
            hideSpinner();

            if (!data.success && data.errors?.length) {
                alert('Preview failed:\n' + data.errors.join('\n'));
                return;
            }

            // Duplicate file warning
            if (data.isDuplicateFile) {
                dupWarnText.innerHTML = `⚠ This file was previously uploaded as batch <strong>${data.duplicateBatchRef}</strong>. Individual row duplicates will still be detected and skipped.`;
                dupWarning.style.display = 'flex';
            }

            // Render preview table
            if (data.previewRows?.length) {
                renderPreview(data.previewRows, data.totalRows);
                previewPanel.style.display = 'block';
                commitBtn.disabled = false;
            } else {
                alert('No rows found in the file.');
            }
        } catch (err) {
            hideSpinner();
            alert('Preview error: ' + err.message);
        }
    };

    function renderPreview(rows, totalRows) {
        if (!rows.length) return;
        const cols = Object.keys(rows[0]);
        const thead = document.getElementById('previewThead');
        const tbody = document.getElementById('previewTbody');
        const countEl = document.getElementById('previewRowCount');

        thead.innerHTML = '<tr>' + ['#', ...cols].map(c => `<th>${c}</th>`).join('') + '</tr>';
        tbody.innerHTML = rows.map((r, i) =>
            '<tr><td style="color:var(--muted,#64748b);">' + (i + 1) + '</td>' +
            cols.map(c => `<td title="${(r[c] ?? '').substring(0,200)}">${(r[c] ?? '')}</td>`).join('') +
            '</tr>'
        ).join('');

        countEl.textContent = `— showing ${rows.length} of ${totalRows} rows`;
    }

    function resetPreview() {
        previewPanel.style.display = 'none';
        document.getElementById('previewThead').innerHTML = '';
        document.getElementById('previewTbody').innerHTML = '';
        document.getElementById('previewRowCount').textContent = '';
    }

    // ── Commit ────────────────────────────────────────────────────
    window.doCommit = async function () {
        if (!currentFile) return;
        if (!confirm('Commit this file to the Protected Raw Bank Payment Table? This action cannot be undone.')) return;

        showSpinner('Importing records to SSOT…');
        const fd = new FormData();
        fd.append('file', currentFile);
        fd.append('__RequestVerificationToken', token);
        
        const mVal = document.getElementById('reconMonth')?.value;
        const yVal = document.getElementById('reconYear')?.value;
        if (mVal) fd.append('reconMonth', mVal);
        if (yVal) fd.append('reconYear', yVal);

        try {
            const res  = await fetch('@Url.Action("Commit")', { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                throw new Error(text.substring(0, 300) || 'Server returned an error status.');
            }
            const data = await res.json();
            hideSpinner();
            showResult(data);
        } catch (err) {
            hideSpinner();
            alert('Commit failed: ' + err.message);
        }
    };

    function showResult(data) {
        resultCard.style.display = 'block';
        resultCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        let cls = data.success ? (data.failedRecords > 0 || data.duplicateRecords > 0 ? 'partial' : 'success') : 'failure';
        resultCard.className = 'result-card ' + cls;

        document.getElementById('resultTitle').textContent = data.success ? '✅ Import Complete' : '❌ Import Failed';
        document.getElementById('resultMsg').textContent   = data.message;
        document.getElementById('resultBatchRef').innerHTML= data.batchRef
            ? `Batch Reference: <strong style="font-family:monospace;color:#2563eb;">${data.batchRef}</strong>`
            : '';

        document.getElementById('resultStats').innerHTML = [
            { val: data.totalRecords,     label: 'Total',      col: '#64748b' },
            { val: data.importedRecords,  label: 'Imported',   col: '#10b981' },
            { val: data.duplicateRecords, label: 'Duplicates', col: '#f59e0b' },
            { val: data.failedRecords,    label: 'Failed',     col: '#ef4444' },
        ].map(s => `
            <div class="result-stat">
                <span class="result-stat-val" style="color:${s.col};">${s.val}</span>
                <span class="result-stat-label">${s.label}</span>
            </div>`).join('');

        const viewLink = document.getElementById('viewBatchLink');
        viewLink.href  = data.batchId ? `/BankPaymentImports/BatchDetail/${data.batchId}` : '#';

        // Disable commit to prevent double-submit
        commitBtn.disabled = true;
    }

    function hideResult() { resultCard.style.display = 'none'; }

    window.resetForm = function () { clearFile(); };

    // ── Spinner helpers ───────────────────────────────────────────
    function showSpinner(msg) { spinnerMsg.textContent = msg; spinner.style.display = 'flex'; }
    function hideSpinner()    { spinner.style.display = 'none'; }

})();
</script>
}
