@{
    ViewData["Title"] = "Asset Register Management";
    Layout = "_Layout";
}

<div class="main">
    <!-- Header Block -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-1 fw-bold text-gradient">Central IT Asset Register</h4>
            <p class="text-muted small mb-0">Manage hardware inventory lifecycle, physical allocations, transfers, and depreciations.</p>
        </div>
        <div>
            <button onclick="openFormModal(0)" class="btn btn-primary btn-sm d-flex align-items-center gap-2">
                <i data-lucide="plus" style="width:14px; height:14px;"></i> Register New Asset
            </button>
            <a id="exportBtn" href="/AssetRegister/Export" class="btn btn-outline-primary btn-sm">Export CSV</a>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="cc p-2 mb-4">
        <ul class="nav nav-pills" id="assetTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="directory-tab" data-bs-toggle="tab" data-bs-target="#directory-pane" type="button" role="tab">
                    Asset Directory
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="transfer-tab" data-bs-toggle="tab" data-bs-target="#transfer-pane" type="button" role="tab">
                    Allocate & Transfer Logs
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="qrcode-tab" data-bs-toggle="tab" data-bs-target="#qrcode-pane" type="button" role="tab">
                    Print QR Labels
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="depr-tab" data-bs-toggle="tab" data-bs-target="#depr-pane" type="button" role="tab">
                    Depreciation Tracker
                </button>
            </li>
        </ul>
    </div>

    <!-- Tab Contents -->
    <div class="tab-content" id="assetTabContent">
        <!-- DIRECTORY TAB -->
        <div class="tab-pane fade show active" id="directory-pane" role="tabpanel" tabindex="0">
            <!-- Search & Filters -->
            <div class="cc p-3 mb-4">
                <div class="row g-3">
                    <div class="col-md-3">
                        <input type="text" id="assetSearch" oninput="loadAssets()" class="form-control" placeholder="Search by name, code, serial..." />
                    </div>
                    <div class="col-md-2">
                        <select id="filterCategory" onchange="loadAssets()" class="form-select">
                            <option value="">All Categories</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterStatus" onchange="loadAssets()" class="form-select">
                            <option value="">All Statuses</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select id="filterBranch" onchange="loadAssets()" class="form-select">
                            <option value="">All Branches</option>
                        </select>
                    </div>
                    <div class="col-md-3 text-md-end d-flex align-items-center justify-content-md-end">
                        <span class="badge bg-light text-dark p-2" id="assetCount">0 Assets</span>
                    </div>
                </div>
            </div>

            <!-- Assets Grid Table -->
            <div class="cc p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th>Asset Code</th>
                                <th>Asset Name</th>
                                <th>Category</th>
                                <th>Brand / Model</th>
                                <th>Branch / Spot</th>
                                <th>Assigned To</th>
                                <th class="text-center">Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="assetsTableBody">
                            <tr>
                                <td colspan="8" class="text-center p-4 text-muted">Loading assets registry...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <!-- Pagination -->
                <div class="p-3 border-top d-flex justify-content-between align-items-center">
                    <button class="btn btn-outline-secondary btn-sm" id="prevPageBtn" onclick="changePage(-1)">Previous</button>
                    <span class="small text-muted" id="pageLabel">Page 1 of 1</span>
                    <button class="btn btn-outline-secondary btn-sm" id="nextPageBtn" onclick="changePage(1)">Next</button>
                </div>
            </div>
        </div>

        <!-- TRANSFERS & LIFECYCLE TAB -->
        <div class="tab-pane fade" id="transfer-pane" role="tabpanel" tabindex="0">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="cc p-3">
                        <h6 class="fw-bold mb-3 small text-muted uppercase">Initiate Movement / Transfer</h6>
                        <form id="transferForm">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Select Asset</label>
                                <select id="xferAsset" class="form-select" required></select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Movement Action</label>
                                <select id="xferAction" class="form-select">
                                    <option value="Allocate">Allocate to Employee</option>
                                    <option value="Transfer">Transfer to Branch</option>
                                    <option value="Repair">Send for Repair</option>
                                    <option value="Return">Return to Stock</option>
                                </select>
                            </div>
                            <div class="mb-3" id="xferBranchGroup">
                                <label class="form-label small fw-bold">Destination Branch</label>
                                <select id="xferBranch" class="form-select"></select>
                            </div>
                            <div class="mb-3" id="xferUserGroup">
                                <label class="form-label small fw-bold">Assignee Employee</label>
                                <select id="xferUser" class="form-select"></select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Reason / Remarks</label>
                                <textarea id="xferReason" class="form-control" rows="2" required></textarea>
                            </div>
                            <button type="button" onclick="executeTransfer()" class="btn btn-primary btn-sm w-100">Submit Request</button>
                        </form>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="cc p-0 overflow-hidden">
                        <div class="p-3 bg-light border-bottom fw-bold small text-muted uppercase">Recent Movement History</div>
                        <div class="table-responsive" style="max-height: 500px;">
                            <table class="table mb-0 align-middle">
                                <thead>
                                    <tr>
                                        <th>Asset</th>
                                        <th>Action</th>
                                        <th>Details</th>
                                        <th>Approved By</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody id="transferLogsBody">
                                    <tr>
                                        <td colspan="5" class="text-center p-4 text-muted">Select an asset to view historical transfers.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PRINT QR CODES TAB -->
        <div class="tab-pane fade" id="qrcode-pane" role="tabpanel" tabindex="0">
            <div class="cc p-3 mb-4">
                <button onclick="printLabels()" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2">
                    <i data-lucide="printer" style="width:14px; height:14px;"></i> Print Label Sheets
                </button>
            </div>
            <div class="row row-cols-2 row-cols-md-4 row-cols-lg-6 g-3" id="qrLabelGrid">
                <!-- QR Cards go here -->
            </div>
        </div>

        <!-- DEPRECIATION TAB -->
        <div class="tab-pane fade" id="depr-pane" role="tabpanel" tabindex="0">
            <div class="cc p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th>Asset Code</th>
                                <th>Asset Name</th>
                                <th>Purchase Cost</th>
                                <th>Depreciation Rate</th>
                                <th>Calculated Depreciation</th>
                                <th>Current Book Value</th>
                            </tr>
                        </thead>
                        <tbody id="deprTableBody">
                            <!-- Calculated depreciation lines -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Form (Create/Edit) -->
<div class="modal fade" id="assetFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Register New Asset</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="assetForm">
                    <input type="hidden" id="itemId" value="0" />

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Asset Name</label>
                            <input type="text" id="assetName" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Asset Category</label>
                            <select id="assetCategory" class="form-select" required></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Asset Type</label>
                            <select id="assetType" class="form-select" required></select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Brand</label>
                            <select id="assetBrand" class="form-select" required></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Model</label>
                            <select id="assetModel" class="form-select" required></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Serial Number</label>
                            <input type="text" id="serialNo" class="form-control" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label class="form-label small fw-bold">Purchase Date</label>
                            <input type="date" id="purchaseDate" class="form-control" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label small fw-bold">Purchase Cost</label>
                            <input type="number" id="purchaseCost" class="form-control" step="0.01" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label small fw-bold">Vendor</label>
                            <select id="assetVendor" class="form-select" required></select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label small fw-bold">Invoice Number</label>
                            <input type="text" id="invoiceNo" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label class="form-label small fw-bold">Warranty Start</label>
                            <input type="date" id="warrantyStart" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label small fw-bold">Warranty End</label>
                            <input type="date" id="warrantyEnd" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label small fw-bold">AMC Start</label>
                            <input type="date" id="amcStart" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label small fw-bold">AMC End</label>
                            <input type="date" id="amcEnd" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Branch</label>
                            <select id="assetBranch" class="form-select" required></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Physical Location Spot</label>
                            <select id="assetLocation" class="form-select" required></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Department</label>
                            <select id="assetDept" class="form-select" required></select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Assigned Employee</label>
                            <select id="assetEmployee" class="form-select">
                                <option value="">Unassigned (In Stock)</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Asset Status</label>
                            <select id="assetStatus" class="form-select" required></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Condition</label>
                            <select id="assetCondition" class="form-select">
                                <option value="New">New</option>
                                <option value="Good">Good</option>
                                <option value="Fair">Fair</option>
                                <option value="Poor">Poor</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Purchase Order (PO)</label>
                            <input type="text" id="purchaseOrder" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Depreciation Rate (% Annually)</label>
                            <input type="number" id="deprRate" class="form-control" step="0.01" value="10" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold">Cost Center</label>
                            <select id="assetCostCenter" class="form-select" required></select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Remarks / Internal notes</label>
                        <textarea id="assetRemarks" class="form-control" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" onclick="saveAsset()" class="btn btn-primary btn-sm">Save Asset</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let formModal = null;
        let currentPage = 1;
        let loadedAssets = [];

        document.addEventListener("DOMContentLoaded", () => {
            formModal = new bootstrap.Modal(document.getElementById("assetFormModal"));
            loadDropdowns();
            loadAssets();

            // Toggle movement forms based on selected movement action
            document.getElementById("xferAction").addEventListener("change", (e) => {
                const act = e.target.value;
                document.getElementById("xferBranchGroup").style.display = act === 'Transfer' ? 'block' : 'none';
                document.getElementById("xferUserGroup").style.display = act === 'Allocate' ? 'block' : 'none';
            });

            // Initial trigger
            document.getElementById("xferAction").dispatchEvent(new Event("change"));
        });

        async function loadDropdowns() {
            try {
                const [branchesRes, mastersRes] = await Promise.all([
                    fetch("/AssetRegister/GetBranches"),
                    fetch("/AssetRegister/GetMasterOptions")
                ]);

                const branches = await branchesRes.json();
                const m = await mastersRes.json();

                // Populate layouts
                const filterBranch = document.getElementById("filterBranch");
                filterBranch.innerHTML = `<option value="">All Branches</option>` + branches.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                
                const filterCat = document.getElementById("filterCategory");
                filterCat.innerHTML = `<option value="">All Categories</option>` + m.categories.map(x => `<option value="${x.id}">${x.name}</option>`).join("");

                const filterStatus = document.getElementById("filterStatus");
                filterStatus.innerHTML = `<option value="">All Statuses</option>` + m.statuses.map(x => `<option value="${x.id}">${x.name}</option>`).join("");

                // Populate Form Dropdowns
                document.getElementById("assetBranch").innerHTML = branches.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("assetCategory").innerHTML = m.categories.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("assetType").innerHTML = m.types.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("assetBrand").innerHTML = m.brands.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("assetModel").innerHTML = m.models.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("assetVendor").innerHTML = m.vendors.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("assetLocation").innerHTML = m.locations.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("assetDept").innerHTML = m.departments.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("assetStatus").innerHTML = m.statuses.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("assetCostCenter").innerHTML = m.costCenters.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                
                document.getElementById("assetEmployee").innerHTML = `<option value="">Unassigned (In Stock)</option>` + 
                    m.employees.map(x => `<option value="${x.id}">${x.name}</option>`).join("");

                // Populate Transfer Dropdowns
                document.getElementById("xferBranch").innerHTML = branches.map(x => `<option value="${x.id}">${x.name}</option>`).join("");
                document.getElementById("xferUser").innerHTML = m.employees.map(x => `<option value="${x.id}">${x.name}</option>`).join("");

            } catch (err) {
                console.error("Master Options failed to load", err);
            }
        }

        async function loadAssets() {
            const search = document.getElementById("assetSearch").value;
            const catId = document.getElementById("filterCategory").value;
            const statusId = document.getElementById("filterStatus").value;
            const branchId = document.getElementById("filterBranch").value;

            const tbody = document.getElementById("assetsTableBody");
            tbody.innerHTML = `<tr><td colspan="8" class="text-center p-4"><div class="spinner-border spinner-border-sm text-primary"></div> Loading...</td></tr>`;

            // Configure export button link
            document.getElementById("exportBtn").href = `/AssetRegister/Export?branchId=${branchId}&categoryId=${catId}&statusId=${statusId}`;

            try {
                const res = await fetch(`/AssetRegister/GetAssets?branchId=${branchId}&categoryId=${catId}&statusId=${statusId}&search=${encodeURIComponent(search)}&page=${currentPage}`);
                const data = await res.json();
                loadedAssets = data.items;

                document.getElementById("assetCount").textContent = `${data.total} Assets`;

                // Update pagination controls
                const totalPages = Math.ceil(data.total / data.pageSize) || 1;
                document.getElementById("pageLabel").textContent = `Page ${data.page} of ${totalPages}`;
                document.getElementById("prevPageBtn").disabled = data.page <= 1;
                document.getElementById("nextPageBtn").disabled = data.page >= totalPages;

                if (loadedAssets.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="8" class="text-center p-4 text-muted">No assets found in registries.</td></tr>`;
                    return;
                }

                tbody.innerHTML = loadedAssets.map(x => `
                    <tr>
                        <td><strong>${escapeHtml(x.assetCode)}</strong></td>
                        <td>${escapeHtml(x.name)}</td>
                        <td><span class="badge bg-light text-dark">${escapeHtml(x.category)}</span></td>
                        <td class="small">${escapeHtml(x.brand)} &bull; ${escapeHtml(x.model)}</td>
                        <td class="small">${escapeHtml(x.branchName)}<div class="text-muted" style="font-size:10px;">${escapeHtml(x.location)}</div></td>
                        <td><span class="badge bg-primary-light text-primary">${escapeHtml(x.employee)}</span></td>
                        <td class="text-center">
                            <span class="badge bg-success">${escapeHtml(x.status)}</span>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-outline-primary btn-sm py-1 px-2" onclick="openFormModal(${x.id})">Edit</button>
                            <button class="btn btn-outline-danger btn-sm py-1 px-2" onclick="deleteAsset(${x.id})">Delete</button>
                        </td>
                    </tr>
                `).join("");

                // Populate movement selection dropdown
                document.getElementById("xferAsset").innerHTML = loadedAssets.map(x => `<option value="${x.id}">${x.assetCode} - ${x.name}</option>`).join("");
                
                // Draw print labels
                renderQrLabels(loadedAssets);
                // Draw depreciation table
                renderDepreciation(loadedAssets);

                // Fetch movement history for first item by default
                if (loadedAssets.length > 0) {
                    loadAssetHistory(loadedAssets[0].id);
                    document.getElementById("xferAsset").value = loadedAssets[0].id;
                }

            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="8" class="text-center p-4 text-danger">Error loading asset register rows.</td></tr>`;
            }
        }

        async function loadAssetHistory(id) {
            const tbody = document.getElementById("transferLogsBody");
            try {
                const res = await fetch(`/AssetRegister/GetAssetHistory?id=${id}`);
                const logs = await res.json();

                if (logs.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center p-3 text-muted">No historical transactions logged for this asset.</td></tr>`;
                    return;
                }

                tbody.innerHTML = logs.map(x => `
                    <tr>
                        <td><strong>${x.actionType}</strong></td>
                        <td class="small text-muted">${escapeHtml(x.details)}</td>
                        <td>${escapeHtml(x.reason)}</td>
                        <td class="small fw-bold">${escapeHtml(x.approvedBy)}</td>
                        <td class="small text-muted">${x.transactionDate}</td>
                    </tr>
                `).join("");
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="5" class="text-center p-3 text-danger">Failed to fetch asset history.</td></tr>`;
            }
        }

        // Catch asset selection change in movement tab
        document.getElementById("xferAsset").addEventListener("change", (e) => {
            loadAssetHistory(e.target.value);
        });

        function changePage(dir) {
            currentPage += dir;
            loadAssets();
        }

        function renderQrLabels(assets) {
            const container = document.getElementById("qrLabelGrid");
            container.innerHTML = assets.map(a => `
                <div class="col">
                    <div class="cc p-2 text-center h-100 d-flex flex-column justify-content-between">
                        <div class="small fw-bold mb-1" style="font-size: 11px;">${escapeHtml(a.name.substring(0, 15))}</div>
                        <div class="my-2">
                            <img src="/AssetRegister/GetQrCode?id=${a.id}" style="width:90px; height:90px;" />
                        </div>
                        <div class="small text-muted" style="font-size: 10px;">${a.assetCode}</div>
                    </div>
                </div>
            `).join("");
        }

        function renderDepreciation(assets) {
            const tbody = document.getElementById("deprTableBody");
            tbody.innerHTML = assets.map(a => {
                const deprCost = a.purchaseCost * (a.depreciationRatePercent / 100);
                const currentVal = a.purchaseCost - deprCost;

                return `
                    <tr>
                        <td><strong>${a.assetCode}</strong></td>
                        <td>${escapeHtml(a.name)}</td>
                        <td>₹${a.purchaseCost.toLocaleString('en-IN', { minimumFractionDigits: 2 })}</td>
                        <td><span class="badge bg-light text-dark">${a.depreciationRatePercent}%</span></td>
                        <td class="text-danger">- ₹${deprCost.toLocaleString('en-IN', { minimumFractionDigits: 2 })}</td>
                        <td class="text-success fw-bold">₹${currentVal.toLocaleString('en-IN', { minimumFractionDigits: 2 })}</td>
                    </tr>
                `;
            }).join("");
        }

        function openFormModal(id) {
            document.getElementById("assetForm").reset();
            document.getElementById("itemId").value = id;

            if (id === 0) {
                document.getElementById("modalTitle").textContent = "Register New Asset";
                document.getElementById("purchaseDate").valueAsDate = new Date();
                document.getElementById("warrantyStart").valueAsDate = new Date();
            } else {
                const item = loadedAssets.find(x => x.id === id);
                if (!item) return;

                document.getElementById("modalTitle").textContent = "Edit Asset Register: " + item.assetCode;
                document.getElementById("assetName").value = item.name;
                document.getElementById("assetCategory").value = item.categoryId;
                document.getElementById("assetType").value = item.typeId;
                document.getElementById("assetBrand").value = item.brandId;
                document.getElementById("assetModel").value = item.modelId;
                document.getElementById("serialNo").value = item.serialNumber;
                document.getElementById("purchaseDate").value = item.purchaseDate;
                document.getElementById("purchaseCost").value = item.purchaseCost;
                document.getElementById("assetVendor").value = item.vendorId;
                document.getElementById("invoiceNo").value = item.invoiceNumber || "";
                document.getElementById("assetBranch").value = item.branchId;
                document.getElementById("assetLocation").value = item.locationId;
                document.getElementById("assetDept").value = item.departmentId;
                document.getElementById("assetEmployee").value = item.assignedEmployeeId || "";
                document.getElementById("assetStatus").value = item.assetStatusId;
                document.getElementById("assetCondition").value = item.condition;
                document.getElementById("purchaseOrder").value = item.purchaseOrder || "";
                document.getElementById("deprRate").value = item.depreciationRatePercent;
                document.getElementById("assetRemarks").value = item.remarks || "";
            }

            formModal.show();
        }

        async function saveAsset() {
            const id = parseInt(document.getElementById("itemId").value);
            const name = document.getElementById("assetName").value.trim();
            const categoryId = parseInt(document.getElementById("assetCategory").value);
            const typeId = parseInt(document.getElementById("assetType").value);
            const brandId = parseInt(document.getElementById("assetBrand").value);
            const modelId = parseInt(document.getElementById("assetModel").value);
            const serialNumber = document.getElementById("serialNo").value.trim();
            const purchaseDate = document.getElementById("purchaseDate").value;
            const purchaseCost = parseFloat(document.getElementById("purchaseCost").value) || 0;
            const vendorId = parseInt(document.getElementById("assetVendor").value);
            const invoiceNumber = document.getElementById("invoiceNo").value.trim();
            const branchId = parseInt(document.getElementById("assetBranch").value);
            const locationId = parseInt(document.getElementById("assetLocation").value);
            const departmentId = parseInt(document.getElementById("assetDept").value);
            const empIdStr = document.getElementById("assetEmployee").value;
            const assignedEmployeeId = empIdStr ? parseInt(empIdStr) : null;
            const assetStatusId = parseInt(document.getElementById("assetStatus").value);
            const condition = document.getElementById("assetCondition").value;
            const purchaseOrder = document.getElementById("purchaseOrder").value.trim();
            const deprRate = parseFloat(document.getElementById("deprRate").value) || 0;
            const remarks = document.getElementById("assetRemarks").value.trim();

            if (!name || !serialNumber || !purchaseDate || purchaseCost <= 0) {
                Swal.fire("Validation Error", "Name, Serial No, Purchase Date and Cost are required.", "warning");
                return;
            }

            const model = {
                id, name, categoryId, typeId, brandId, modelId, serialNumber,
                purchaseDate, purchaseCost, vendorId, invoiceNumber,
                branchId, locationId, departmentId, assignedEmployeeId,
                assetStatusId, condition, purchaseOrder, depreciationRatePercent: deprRate,
                remarks
            };

            try {
                const res = await fetch("/AssetRegister/Save", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(model)
                });

                const data = await res.json();
                if (data.ok) {
                    formModal.hide();
                    Swal.fire("Success", data.message, "success");
                    loadAssets();
                } else {
                    Swal.fire("Error", data.message, "error");
                }
            } catch (err) {
                Swal.fire("Error", "Server submission failed.", "error");
            }
        }

        async function executeTransfer() {
            const assetId = parseInt(document.getElementById("xferAsset").value);
            const actionType = document.getElementById("xferAction").value;
            const toBranchId = parseInt(document.getElementById("xferBranch").value);
            const toUserId = parseInt(document.getElementById("xferUser").value);
            const reason = document.getElementById("xferReason").value.trim();

            if (!assetId || !reason) {
                Swal.fire("Validation Error", "Asset and Reason are required.", "warning");
                return;
            }

            const model = {
                assetId, actionType, reason,
                toBranchId: actionType === 'Transfer' ? toBranchId : null,
                toUserId: actionType === 'Allocate' ? toUserId : null
            };

            try {
                const res = await fetch("/AssetRegister/AllocateOrTransfer", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(model)
                });

                const data = await res.json();
                if (data.ok) {
                    Swal.fire("Success", data.message, "success");
                    document.getElementById("transferForm").reset();
                    loadAssets();
                }
            } catch (err) {
                Swal.fire("Error", "Reallocation failed.", "error");
            }
        }

        async function deleteAsset(id) {
            const result = await Swal.fire({
                title: "Are you sure?",
                text: "Flag this asset register item as disposed/deleted?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                confirmButtonText: "Yes, Dispose"
            });

            if (!result.isConfirmed) return;

            try {
                const res = await fetch(`/AssetRegister/Delete?id=${id}`, { method: "POST" });
                const data = await res.json();
                if (data.ok) {
                    Swal.fire("Success", data.message, "success");
                    loadAssets();
                }
            } catch (err) {
                Swal.fire("Error", "Deletion failed.", "error");
            }
        }

        function printLabels() {
            const printContent = document.getElementById("qrLabelGrid").innerHTML;
            const windowUrl = 'about:blank';
            const uniqueName = new Date();
            const windowName = 'Print' + uniqueName.getTime();
            const printWindow = window.open(windowUrl, windowName, 'left=50000,top=50000,width=0,height=0');
            
            printWindow.document.write(`
                <html>
                    <head>
                        <title>Print Asset Labels</title>
                        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
                        <style>
                            body { padding: 20px; }
                            .col { page-break-inside: avoid; margin-bottom: 20px; }
                        </style>
                    </head>
                    <body>
                        <div class="row row-cols-4 g-3">${printContent}</div>
                        <script>
                            window.onload = function() { window.print(); window.close(); }
                        <\/script>
                    </body>
                </html>
            `);
            printWindow.document.close();
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
        }
    </script>
}
