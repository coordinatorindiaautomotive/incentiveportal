@model IncentivePortal.Models.TestRunReport
@{
    ViewData["Title"] = "Automated Unit Test Suite";
    var passRate = Model?.PassRate ?? 0.0;
    var dashoffset = 314.16 - (passRate / 100.0 * 314.16);
}

<!-- Premium Test Suite Styling -->
<style>
    /* Card Styles */
    .test-card {
        background: var(--panel, #ffffff);
        border: 1px solid var(--line, #e2e8f0);
        border-radius: var(--radius, 16px);
        box-shadow: var(--shadow);
        transition: all 0.25s ease;
        overflow: hidden;
    }
    .test-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.08);
    }
    
    /* Stats Grids */
    .stat-badge-card {
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 16px;
        border-radius: 12px;
        background: var(--canvas, #f8fafc);
        border: 1px solid var(--line, #e2e8f0);
        transition: all 0.2s ease;
    }
    .stat-badge-card:hover {
        transform: scale(1.02);
    }
    
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    /* Status Badges */
    .status-pill {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }
    .status-passed {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success, #10b981);
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .status-failed {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger, #ef4444);
        border: 1px solid rgba(239, 68, 68, 0.2);
    }
    .status-skipped {
        background: rgba(245, 158, 11, 0.1);
        color: var(--warning, #f59e0b);
        border: 1px solid rgba(245, 158, 11, 0.2);
    }

    /* Circular Progress */
    .progress-ring-container {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 120px;
        height: 120px;
    }
    .progress-ring__circle {
        transform: rotate(-90deg);
        transform-origin: 50% 50%;
        transition: stroke-dashoffset 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Test List Styling */
    .test-item-row {
        cursor: pointer;
        padding: 16px 20px;
        border-bottom: 1px solid var(--line, #e2e8f0);
        display: flex;
        flex-direction: column;
        gap: 8px;
        transition: background-color 0.15s ease;
    }
    .test-item-row:hover {
        background-color: rgba(37, 99, 235, 0.02);
    }
    .test-item-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }
    .test-item-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.8rem;
        color: var(--muted, #64748b);
    }
    .test-item-details {
        display: none;
        padding: 16px;
        background: #0f172a;
        color: #f8fafc;
        border-radius: 8px;
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.82rem;
        overflow-x: auto;
        margin-top: 8px;
        border: 1px solid #1e293b;
    }

    /* Terminal Console Panel */
    .terminal-panel {
        background: #090d16;
        color: #f1f5f9;
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: 0.84rem;
        border-radius: 12px;
        border: 1px solid #1e293b;
        box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }
    .terminal-header {
        background: #1e293b;
        padding: 8px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #0f172a;
    }
    .terminal-body {
        padding: 16px;
        max-height: 350px;
        overflow-y: auto;
        white-space: pre-wrap;
        line-height: 1.5;
    }

    /* Filter Active Button */
    .btn-filter {
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 6px 16px;
        transition: all 0.2s ease;
    }
    .btn-filter.active {
        background: var(--brand, #2563eb) !important;
        color: #ffffff !important;
        border-color: var(--brand, #2563eb) !important;
    }

    /* Loader Overlay */
    .loader-overlay {
        position: absolute;
        inset: 0;
        background: rgba(var(--canvas-rgb, 248), var(--canvas-rgb, 250), var(--canvas-rgb, 252), 0.85);
        backdrop-filter: blur(4px);
        z-index: 50;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .loader-overlay.active {
        opacity: 1;
        pointer-events: all;
    }

    /* Responsive adjustments */
    @@media (max-width: 991.98px) {
        .test-dashboard-grid {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
    }
</style>

<div class="container-fluid py-2">
    <!-- Action Bar & AntiForgery -->
    @Html.AntiForgeryToken()
    
    <!-- Outer Container (Responsive Grid) -->
    <div class="test-dashboard-grid">
        
        <!-- Left Panel: Summary & Controls -->
        <div class="d-flex flex-column gap-4">
            
            <!-- Core execution controls card -->
            <div class="test-card p-4 text-center position-relative">
                <!-- Loader Overlay -->
                <div class="loader-overlay" id="runnerLoader">
                    <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                    <h5 class="fw-bold text-ink">Executing test suite...</h5>
                    <p class="text-muted small px-3">Compiling projects and running unit tests using server dotnet CLI</p>
                </div>

                <div class="d-flex flex-column align-items-center gap-3">
                    <div class="progress-ring-container">
                        <svg width="120" height="120" viewBox="0 0 120 120">
                            <circle cx="60" cy="60" r="50" stroke="var(--line, #e2e8f0)" stroke-width="8" fill="transparent" />
                            <circle class="progress-ring__circle" id="progressRing" cx="60" cy="60" r="50" 
                                    stroke="var(--success, #10b981)" stroke-width="8" fill="transparent" 
                                    stroke-dasharray="314.16" stroke-dashoffset="@dashoffset" />
                        </svg>
                        <div class="position-absolute d-flex flex-column align-items-center">
                            <span class="fs-3 fw-extrabold text-ink" id="passPercentLabel">@((int)passRate)%</span>
                            <span class="text-muted" style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Pass Rate</span>
                        </div>
                    </div>

                    <div class="w-100">
                        <h4 class="fw-bold mb-1 text-ink">Test Suite Status</h4>
                        <p class="text-muted small" id="lastRunTimeLabel">
                            @if (Model != null)
                            {
                                @($"Last run: {Model.FinishTime.ToLocalTime():g}")
                            }
                            else
                            {
                                @("Never executed")
                            }
                        </p>
                    </div>

                    <button class="btn btn-primary btn-lg w-100 py-3 rounded-pill fw-bold shadow-sm" id="btnRunTests" onclick="runTestSuite()">
                        <i class="fa-solid fa-play me-2"></i> Run Test Suite
                    </button>
                </div>
            </div>

            <!-- Stats breakdown card -->
            <div class="test-card p-4">
                <h5 class="fw-bold mb-3 text-ink">Metrics Overview</h5>
                
                <div class="d-flex flex-column gap-3">
                    <div class="stat-badge-card">
                        <div class="stat-icon" style="background: rgba(37, 99, 235, 0.1); color: var(--brand);">
                            <i class="fa-solid fa-list-check"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Total Tests</div>
                            <h4 class="fw-bold mb-0 text-ink" id="totalCountLabel">@(Model?.TotalTests ?? 0)</h4>
                        </div>
                    </div>
                    
                    <div class="stat-badge-card">
                        <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--success);">
                            <i class="fa-solid fa-circle-check"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Passed</div>
                            <h4 class="fw-bold mb-0 text-ink" id="passedCountLabel">@(Model?.Passed ?? 0)</h4>
                        </div>
                    </div>
                    
                    <div class="stat-badge-card">
                        <div class="stat-icon" style="background: rgba(239, 68, 68, 0.1); color: var(--danger);">
                            <i class="fa-solid fa-circle-xmark"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Failed</div>
                            <h4 class="fw-bold mb-0 text-ink" id="failedCountLabel">@(Model?.Failed ?? 0)</h4>
                        </div>
                    </div>
                    
                    <div class="stat-badge-card">
                        <div class="stat-icon" style="background: rgba(245, 158, 11, 0.1); color: var(--warning);">
                            <i class="fa-solid fa-circle-minus"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Skipped</div>
                            <h4 class="fw-bold mb-0 text-ink" id="skippedCountLabel">@(Model?.Skipped ?? 0)</h4>
                        </div>
                    </div>
                    
                    <div class="stat-badge-card">
                        <div class="stat-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366f1;">
                            <i class="fa-solid fa-stopwatch"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold">Duration</div>
                            <h4 class="fw-bold mb-0 text-ink" id="durationLabel">
                                @if (Model != null)
                                {
                                    @((Model.TotalDurationMs / 1000.0).ToString("F2") + "s")
                                }
                                else
                                {
                                    @("0.00s")
                                }
                            </h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Right Panel: Test Listing & Output Log -->
        <div class="d-flex flex-column gap-4">
            
            <!-- Test Cases List Card -->
            <div class="test-card">
                <!-- Card Header with Search and Filter tabs -->
                <div class="p-4 border-bottom border-line d-flex flex-column gap-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <h4 class="fw-bold mb-0 text-ink">Test Suite Cases</h4>
                        <span class="badge bg-secondary rounded-pill" id="badgeTotalTests">@(Model?.TestResults.Count ?? 0) Loaded</span>
                    </div>
                    
                    <div class="row g-2">
                        <!-- Search Bar -->
                        <div class="col-md-6">
                            <div class="position-relative">
                                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="left: 14px; top: 12px; font-size: 0.85rem;"></i>
                                <input type="text" id="testSearchInput" placeholder="Search tests by name..." class="form-control ps-5 rounded-pill" style="height: 38px; font-size: 0.85rem;" onkeyup="filterTests()" />
                            </div>
                        </div>
                        
                        <!-- Status Filter Buttons -->
                        <div class="col-md-6 d-flex align-items-center justify-content-md-end gap-1 flex-wrap">
                            <button class="btn btn-light btn-filter active" id="btnFilterAll" onclick="filterStatus('all')">All</button>
                            <button class="btn btn-light btn-filter" id="btnFilterPassed" onclick="filterStatus('Passed')">
                                <i class="fa-solid fa-circle text-success me-1" style="font-size: 0.5rem;"></i> Passed
                            </button>
                            <button class="btn btn-light btn-filter" id="btnFilterFailed" onclick="filterStatus('Failed')">
                                <i class="fa-solid fa-circle text-danger me-1" style="font-size: 0.5rem;"></i> Failed
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- Test Cases Table/List -->
                <div class="test-list-container" id="testListContainer" style="max-height: 480px; overflow-y: auto;">
                    @if (Model == null || !Model.TestResults.Any())
                    {
                        <div class="p-5 text-center text-muted" id="placeholderMessage">
                            <div class="fs-1 mb-3 text-secondary"><i class="fa-solid fa-square-poll-horizontal"></i></div>
                            <h5 class="fw-bold text-ink">No Test Results Available</h5>
                            <p class="small mb-0">The test suite hasn't been executed yet, or no results were saved.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var test in Model.TestResults)
                        {
                            var outcomeClass = test.Outcome.Equals("Passed", StringComparison.OrdinalIgnoreCase) ? "status-passed" : 
                                               (test.Outcome.Equals("Failed", StringComparison.OrdinalIgnoreCase) ? "status-failed" : "status-skipped");
                            
                            var iconClass = test.Outcome.Equals("Passed", StringComparison.OrdinalIgnoreCase) ? "fa-circle-check text-success" : 
                                            (test.Outcome.Equals("Failed", StringComparison.OrdinalIgnoreCase) ? "fa-circle-xmark text-danger" : "fa-circle-minus text-warning");

                            <div class="test-item-row" data-status="@test.Outcome" data-name="@test.TestName.ToLower()">
                                <div class="test-item-header" onclick="toggleTestDetails(this)">
                                    <div class="d-flex align-items-start gap-3">
                                        <i class="fa-solid @iconClass mt-1 fs-5"></i>
                                        <div style="line-height: 1.3;">
                                            <div class="fw-bold text-ink" style="font-size: 0.95rem;">@test.MethodName</div>
                                            <div class="text-muted small">@test.ClassName</div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="text-muted small fw-semibold">@($"{test.DurationMs}ms")</span>
                                        <span class="status-pill @outcomeClass">@test.Outcome</span>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(test.ErrorMessage) || !string.IsNullOrEmpty(test.StackTrace))
                                {
                                    <div class="test-item-details">
                                        @if (!string.IsNullOrEmpty(test.ErrorMessage))
                                        {
                                            <div class="text-danger fw-bold mb-2">Error: @test.ErrorMessage</div>
                                        }
                                        @if (!string.IsNullOrEmpty(test.StackTrace))
                                        {
                                            <div class="text-white-50 small" style="white-space: pre-wrap;">@test.StackTrace</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Terminal Console logs Card -->
            <div class="test-card">
                <div class="p-4 border-bottom border-line d-flex align-items-center justify-content-between">
                    <h5 class="fw-bold mb-0 text-ink"><i class="fa-solid fa-terminal me-2 text-muted"></i>Raw test console logs</h5>
                    <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="copyConsoleOutput()">
                        <i class="fa-solid fa-copy me-1"></i> Copy Logs
                    </button>
                </div>
                <div class="p-4">
                    <div class="terminal-panel">
                        <div class="terminal-header">
                            <span class="text-muted small fw-bold">bash - dotnet test</span>
                            <div class="d-flex gap-1.5">
                                <span style="width: 8px; height: 8px; border-radius: 50%; background: #ef4444; display: inline-block;"></span>
                                <span style="width: 8px; height: 8px; border-radius: 50%; background: #f59e0b; display: inline-block;"></span>
                                <span style="width: 8px; height: 8px; border-radius: 50%; background: #10b981; display: inline-block;"></span>
                            </div>
                        </div>
                        <div class="terminal-body" id="rawConsoleOutput">@(Model?.ConsoleOutput ?? "Ready. Console output will populate here after a run.")</div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toggle view details for single test cases
        function toggleTestDetails(headerEl) {
            const row = headerEl.closest('.test-item-row');
            const details = row.querySelector('.test-item-details');
            if (details) {
                $(details).slideToggle(200);
            }
        }

        // Real-time keyword filter
        function filterTests() {
            const term = $('#testSearchInput').val().toLowerCase();
            const activeStatus = $('.btn-filter.active').text().trim();
            
            $('.test-item-row').each(function() {
                const name = $(this).attr('data-name');
                const status = $(this).attr('data-status');
                
                const matchesKeyword = name.includes(term);
                const matchesStatus = (activeStatus === 'All' || status.toLowerCase() === activeStatus.toLowerCase());
                
                if (matchesKeyword && matchesStatus) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });
        }

        // Active Status filter toggle
        function filterStatus(statusVal) {
            $('.btn-filter').removeClass('active');
            
            if (statusVal === 'all') {
                $('#btnFilterAll').addClass('active');
            } else if (statusVal === 'Passed') {
                $('#btnFilterPassed').addClass('active');
            } else if (statusVal === 'Failed') {
                $('#btnFilterFailed').addClass('active');
            }
            
            filterTests();
        }

        // Run the backend Test suite process
        function runTestSuite() {
            // Disable button, show loader overlay
            $('#btnRunTests').prop('disabled', true);
            $('#runnerLoader').addClass('active');

            // Collect forgery token
            const token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '/TestRunner/RunTests',
                method: 'POST',
                headers: {
                    'RequestVerificationToken': token
                },
                success: function(response) {
                    if (response.success) {
                        const report = response.report;
                        
                        // 1. Update stats & counts
                        animateCount('totalCountLabel', report.totalTests);
                        animateCount('passedCountLabel', report.passed);
                        animateCount('failedCountLabel', report.failed);
                        animateCount('skippedCountLabel', report.skipped);
                        
                        const durationSec = (report.totalDurationMs / 1000.0).toFixed(2);
                        $('#durationLabel').text(durationSec + 's');
                        
                        // 2. Update Progress ring & pass percent
                        const passPercent = Math.round(report.passRate);
                        $('#passPercentLabel').text(passPercent + '%');
                        
                        const strokeOffset = 314.16 - (report.passRate / 100.0 * 314.16);
                        $('#progressRing').css('stroke-dashoffset', strokeOffset);
                        
                        // Color of the circle based on success rate
                        if (passPercent === 100) {
                            $('#progressRing').css('stroke', 'var(--success, #10b981)');
                        } else if (passPercent >= 80) {
                            $('#progressRing').css('stroke', 'var(--warning, #f59e0b)');
                        } else {
                            $('#progressRing').css('stroke', 'var(--danger, #ef4444)');
                        }

                        // 3. Update Last Run Time
                        const now = new Date();
                        $('#lastRunTimeLabel').text('Last run: ' + now.toLocaleString());

                        // 4. Update Header Count
                        $('#badgeTotalTests').text(report.testResults.length + ' Loaded');

                        // 5. Update Console Logs
                        $('#rawConsoleOutput').text(report.consoleOutput || '');

                        // 6. Build the Test Items list html dynamically
                        let html = '';
                        if (report.testResults.length === 0) {
                            html = `<div class="p-5 text-center text-muted">
                                        <div class="fs-1 mb-3 text-secondary"><i class="fa-solid fa-square-poll-horizontal"></i></div>
                                        <h5 class="fw-bold text-ink">No Test Results Available</h5>
                                        <p class="small mb-0">No tests were loaded by the runner.</p>
                                    </div>`;
                        } else {
                            report.testResults.forEach(function(test) {
                                const outcomeClass = test.outcome === 'Passed' ? 'status-passed' : 
                                                     (test.outcome === 'Failed' ? 'status-failed' : 'status-skipped');
                                
                                const iconClass = test.outcome === 'Passed' ? 'fa-circle-check text-success' : 
                                                 (test.outcome === 'Failed' ? 'fa-circle-xmark text-danger' : 'fa-circle-minus text-warning');

                                html += `<div class="test-item-row" data-status="${test.outcome}" data-name="${test.testName.toLowerCase()}">
                                            <div class="test-item-header" onclick="toggleTestDetails(this)">
                                                <div class="d-flex align-items-start gap-3">
                                                    <i class="fa-solid ${iconClass} mt-1 fs-5"></i>
                                                    <div style="line-height: 1.3;">
                                                        <div class="fw-bold text-ink" style="font-size: 0.95rem;">${test.methodName}</div>
                                                        <div class="text-muted small">${test.className}</div>
                                                    </div>
                                                </div>
                                                <div class="d-flex align-items-center gap-3">
                                                    <span class="text-muted small fw-semibold">${test.durationMs}ms</span>
                                                    <span class="status-pill ${outcomeClass}">${test.outcome}</span>
                                                </div>
                                            </div>`;
                                
                                if (test.errorMessage || test.stackTrace) {
                                    html += `<div class="test-item-details">`;
                                    if (test.errorMessage) {
                                        html += `<div class="text-danger fw-bold mb-2">Error: ${test.errorMessage}</div>`;
                                    }
                                    if (test.stackTrace) {
                                        html += `<div class="text-white-50 small" style="white-space: pre-wrap;">${test.stackTrace}</div>`;
                                    }
                                    html += `</div>`;
                                }
                                html += `</div>`;
                            });
                        }
                        
                        $('#testListContainer').html(html);

                        // Trigger visual alert
                        if (report.failed === 0) {
                            Swal.fire({
                                icon: 'success',
                                title: 'All Tests Passed!',
                                text: `${report.passed} of ${report.totalTests} unit tests ran successfully.`,
                                timer: 3000,
                                showConfirmButton: false,
                                background: 'var(--panel)',
                                color: 'var(--ink)'
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Test Failures Detected',
                                text: `${report.failed} unit tests failed out of ${report.totalTests} total executed.`,
                                background: 'var(--panel)',
                                color: 'var(--ink)'
                            });
                        }
                    } else {
                        // Display error message
                        Swal.fire({
                            icon: 'error',
                            title: 'Execution Error',
                            text: response.message || 'Unknown error occurred.',
                            background: 'var(--panel)',
                            color: 'var(--ink)'
                        });
                        
                        if (response.console) {
                            $('#rawConsoleOutput').text(response.console);
                        }
                    }
                },
                error: function(xhr, status, error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Server Error',
                        text: 'Failed to connect to the test runner API endpoint.',
                        background: 'var(--panel)',
                        color: 'var(--ink)'
                    });
                },
                complete: function() {
                    // Reset buttons
                    $('#btnRunTests').prop('disabled', false);
                    $('#runnerLoader').removeClass('active');
                    filterStatus('all'); // Refresh view filters
                    $('#testSearchInput').val('');
                }
            });
        }

        // Animate counting numbers
        function animateCount(elementId, targetVal) {
            const el = document.getElementById(elementId);
            if (!el) return;
            
            const startVal = parseInt(el.textContent) || 0;
            if (startVal === targetVal) return;

            const duration = 800; // ms
            const startTime = performance.now();

            function update(now) {
                const elapsed = now - startTime;
                const progress = Math.min(elapsed / duration, 1);
                
                // Ease out quad
                const easeProgress = progress * (2 - progress);
                const currentVal = Math.round(startVal + (targetVal - startVal) * easeProgress);
                
                el.textContent = currentVal;

                if (progress < 1) {
                    requestAnimationFrame(update);
                }
            }
            requestAnimationFrame(update);
        }

        // Copy raw log to clipboard
        function copyConsoleOutput() {
            const logsText = $('#rawConsoleOutput').text();
            navigator.clipboard.writeText(logsText).then(function() {
                Swal.fire({
                    icon: 'success',
                    title: 'Logs Copied',
                    text: 'Console log output copied to clipboard successfully.',
                    timer: 1500,
                    showConfirmButton: false,
                    background: 'var(--panel)',
                    color: 'var(--ink)'
                });
            }, function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Copy Failed',
                    text: 'Could not copy logs to clipboard.',
                    background: 'var(--panel)',
                    color: 'var(--ink)'
                });
            });
        }
    </script>
}
