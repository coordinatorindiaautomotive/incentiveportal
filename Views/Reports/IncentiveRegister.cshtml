@section Scripts {
<script>
$(document).ready(function() {
    // ----------------------------------------------------
    // CUSTOM SEARCHABLE CHECKBOX DROPDOWN LOGIC
    // ----------------------------------------------------
    
    // Prevent dropdown menu from closing when clicking inside
    $('.custom-multiselect .dropdown-menu').on('click', function(e) {
        e.stopPropagation();
    });

    function updateMultiselectLabel(wrapperId, defaultText) {
        var wrapper = $('#' + wrapperId);
        var checked = wrapper.find('.option-cb:checked');
        var total = wrapper.find('.option-cb').length;
        var labelSpan = wrapper.find('.selected-label');
        
        if (checked.length === 0) {
            labelSpan.text('None Selected');
            wrapper.find('.select-all-cb').prop('checked', false).prop('indeterminate', false);
        } else if (checked.length === total) {
            labelSpan.text(defaultText);
            wrapper.find('.select-all-cb').prop('checked', true).prop('indeterminate', false);
        } else {
            if (checked.length === 1) {
                labelSpan.text(checked.first().parent().find('label').text());
            } else {
                labelSpan.text(checked.length + ' Selected');
            }
            wrapper.find('.select-all-cb').prop('checked', false).prop('indeterminate', true);
        }
    }

    // Initialize labels
    updateMultiselectLabel('partyCodeMultiselect', 'All Parties');
    updateMultiselectLabel('periodsMultiselect', 'All Periods');

    // Handle "Select All / Clear" checkbox changes
    $('.select-all-cb').on('change', function() {
        var isChecked = $(this).is(':checked');
        var wrapper = $(this).closest('.custom-multiselect');
        
        wrapper.find('.option-cb').prop('checked', isChecked);
        
        var id = wrapper.attr('id');
        var defaultText = id === 'partyCodeMultiselect' ? 'All Parties' : (id === 'periodsMultiselect' ? 'All Periods' : 'All Payment Months');
        updateMultiselectLabel(id, defaultText);
    });

    // Handle individual checkbox changes
    $('.option-cb').on('change', function() {
        var wrapper = $(this).closest('.custom-multiselect');
        var id = wrapper.attr('id');
        var defaultText = id === 'partyCodeMultiselect' ? 'All Parties' : (id === 'periodsMultiselect' ? 'All Periods' : 'All Payment Months');
        updateMultiselectLabel(id, defaultText);
    });

    // Handle inline search filtering
    $('.search-input').on('input', function() {
        var query = $(this).val().toLowerCase();
        var wrapper = $(this).closest('.custom-multiselect');
        
        wrapper.find('.option-item').each(function() {
            var labelText = $(this).find('label').text().toLowerCase();
            if (labelText.indexOf(query) > -1) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    });

    // Intercept form submission to prevent HTTP 414 (URI Too Long) when all options are checked.
    // If all checkboxes in a custom multiselect are checked, we temporarily disable them so they
    // do not get sent in the query string. The server interprets a missing parameter list as "All".
    $('form.corp-filter-band').on('submit', function() {
        var disabledInputs = [];
        $('.custom-multiselect').each(function() {
            var wrapper = $(this);
            var total = wrapper.find('.option-cb').length;
            var checked = wrapper.find('.option-cb:checked').length;
            
            if (total > 0 && checked === total) {
                var inputs = wrapper.find('.option-cb');
                inputs.each(function() {
                    var input = $(this);
                    input.prop('disabled', true);
                    disabledInputs.push(input);
                });
            }
        });
        
        // Re-enable checkboxes shortly after submit to ensure the page remains interactive
        // (especially for spreadsheet downloads which do not reload the page).
        setTimeout(function() {
            $.each(disabledInputs, function(i, input) {
                input.prop('disabled', false);
            });
        }, 300);
    });

    @if (User.IsInRole("Super Admin") || User.IsInRole("HO Finance") || User.IsInRole("Branch Manager"))
    {
        <text>
        // ----------------------------------------------------
        // SEARCHABLE DROPDOWN LOGIC - UPDATE BANK MODAL
        // ----------------------------------------------------
        var allModalParties = $('#modalPartySelect option').clone();
        $('#modalPartySearch').on('input', function() {
            var val = $(this).val().toLowerCase();
            var select = $('#modalPartySelect');
            select.empty();
            allModalParties.each(function() {
                var option = $(this);
                if (option.text().toLowerCase().indexOf(val) > -1 || option.val() === "") {
                    select.append(option.clone());
                }
            });
        });
        </text>
    }

    // -------------------------------------------------------
    // CLICK-TO-SORT ENGINE
    // -------------------------------------------------------
    var sortState = { col: null, dir: 0 }; // dir: 0=none, 1=asc, -1=desc

    $('.sortable-th').css('cursor', 'pointer');

    $('.sortable-th').on('click', function () {
        var col  = $(this).data('sort');
        var type = $(this).data('type'); // text | num | date

        // cycle: none → asc → desc → none
        if (sortState.col === col) {
            sortState.dir = sortState.dir === 1 ? -1 : (sortState.dir === -1 ? 0 : 1);
        } else {
            sortState.col = col;
            sortState.dir = 1;
        }

        // Update all header icons
        $('.sortable-th .sort-icon').text('⇅');
        $('.sortable-th').removeClass('sort-asc sort-desc');

        if (sortState.dir !== 0) {
            var icon = sortState.dir === 1 ? '▲' : '▼';
            $(this).find('.sort-icon').text(icon);
            $(this).addClass(sortState.dir === 1 ? 'sort-asc' : 'sort-desc');
        }

        var tbody = $('table.corp-table tbody');
        var rows  = tbody.find('tr').toArray();

        if (sortState.dir === 0) {
            // Reset to original order using data-original-index
            rows.sort(function (a, b) {
                return $(a).data('orig-index') - $(b).data('orig-index');
            });
        } else {
            // Store original index the first time
            rows.forEach(function (r, idx) {
                if ($(r).data('orig-index') === undefined) {
                    $(r).data('orig-index', idx);
                }
            });

            rows.sort(function (a, b) {
                var av = $(a).data(col);
                var bv = $(b).data(col);

                var cmp;
                if (type === 'num') {
                    cmp = (parseFloat(av) || 0) - (parseFloat(bv) || 0);
                } else if (type === 'date') {
                    var ad = av ? new Date(av) : new Date(0);
                    var bd = bv ? new Date(bv) : new Date(0);
                    cmp = ad - bd;
                } else {
                    cmp = (av || '').toString().localeCompare((bv || '').toString(), undefined, { sensitivity: 'base' });
                }
                return cmp * sortState.dir;
            });
        }

        // Re-append sorted rows and fix serial numbers
        $.each(rows, function (i, row) {
            tbody.append(row);
            $(row).find('.row-serial').text(i + 1);
        });
    });
});
</script>
}


